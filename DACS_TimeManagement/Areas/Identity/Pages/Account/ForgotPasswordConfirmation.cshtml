@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Kiểm tra email của bạn";
}

<style>
    .confirm-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .confirm-card {
        background: var(--card-bg, #ffffff);
        border-radius: 24px;
        border: 1px solid var(--border-color, #e2e8f0);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
        padding: 56px 44px;
        width: 100%;
        max-width: 460px;
        text-align: center;
        animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes popIn {
        from { opacity: 0; transform: scale(0.9); }
        to   { opacity: 1; transform: scale(1); }
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        margin: 0 auto 28px;
        box-shadow: 0 8px 24px rgba(34, 197, 94, 0.35);
        animation: bounce 0.6s 0.3s ease both;
    }

    @@keyframes bounce {
        0%   { transform: scale(0); }
        60%  { transform: scale(1.15); }
        100% { transform: scale(1); }
    }

    .confirm-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-dark, #0d1224);
        margin-bottom: 12px;
    }

    .confirm-desc {
        color: var(--text-muted, #64748b);
        font-size: 0.95rem;
        line-height: 1.7;
        margin-bottom: 32px;
    }

    .tips-box {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 14px;
        padding: 18px 20px;
        text-align: left;
        margin-bottom: 28px;
    }

    .tips-box p {
        color: #166534;
        font-size: 0.85rem;
        margin: 0 0 8px;
        line-height: 1.5;
    }

    .tips-box p:last-child { margin-bottom: 0; }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 13px 32px;
        border-radius: 50px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        transition: all 0.2s;
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3);
    }

    .btn-back:hover {
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 10px 28px rgba(99, 102, 241, 0.4);
    }

    body.theme-dark .confirm-card {
        background: var(--card-bg, #161b30);
        border-color: rgba(255,255,255,0.06);
    }

    body.theme-dark .tips-box {
        background: rgba(34,197,94,0.08);
        border-color: rgba(34,197,94,0.2);
    }
</style>

<div class="confirm-wrapper">
    <div class="confirm-card">
        <div class="success-icon">✉️</div>

        <h1 class="confirm-title">Kiểm tra hộp thư!</h1>
        <p class="confirm-desc">
            Nếu địa chỉ email bạn nhập đã được đăng ký,<br>
            chúng tôi đã gửi một <strong>đường dẫn đặt lại mật khẩu</strong> vào hộp thư của bạn.
        </p>

        <div class="tips-box">
            <p>📬 <strong>Không thấy email?</strong></p>
            <p>• Kiểm tra thư mục <strong>Spam / Junk</strong></p>
            <p>• Email có thể mất vài phút để đến</p>
            <p>• Đường dẫn có hiệu lực trong <strong>24 giờ</strong></p>
        </div>

        <a href="/Identity/Account/Login" class="btn-back">
            <i class="fas fa-arrow-left"></i> Quay lại đăng nhập
        </a>
    </div>
</div>
