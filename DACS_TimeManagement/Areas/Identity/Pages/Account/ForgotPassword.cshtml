@page
@model ForgotPasswordModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<ForgotPasswordModel> Localizer
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<style>
    .forgot-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .forgot-card {
        background: var(--card-bg, #ffffff);
        border-radius: 24px;
        border: 1px solid var(--border-color, #e2e8f0);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
        padding: 48px 44px;
        width: 100%;
        max-width: 460px;
        animation: slideUp 0.4s ease;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .icon-header {
        width: 68px;
        height: 68px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin: 0 auto 24px;
        box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3);
    }

    .forgot-title {
        font-size: 1.5rem;
        font-weight: 800;
        text-align: center;
        color: var(--text-dark, #0d1224);
        margin-bottom: 8px;
    }

    .forgot-subtitle {
        text-align: center;
        color: var(--text-muted, #64748b);
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 32px;
    }

    .form-label-modern {
        font-size: 0.82rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--text-muted, #64748b);
        margin-bottom: 8px;
        display: block;
    }

    .input-wrap {
        position: relative;
        margin-bottom: 24px;
    }

    .input-wrap i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 0.95rem;
    }

    .input-modern {
        width: 100%;
        padding: 13px 16px 13px 40px;
        border: 1.5px solid var(--border-color, #e2e8f0);
        border-radius: 12px;
        background: var(--body-bg, #f8fafc);
        color: var(--text-dark, #0d1224);
        font-size: 0.95rem;
        transition: all 0.2s;
        outline: none;
    }

    .input-modern:focus {
        border-color: #6366f1;
        background: var(--card-bg, #fff);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
    }

    .btn-submit {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3);
        letter-spacing: 0.3px;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 28px rgba(99, 102, 241, 0.4);
    }

    .btn-submit:active { transform: translateY(0); }

    .back-login {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin-top: 20px;
        color: #6366f1;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        transition: gap 0.2s;
    }

    .back-login:hover { gap: 10px; color: #4f46e5; }

    .validation-error {
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.25);
        border-radius: 10px;
        padding: 10px 14px;
        color: #dc2626;
        font-size: 0.85rem;
        margin-bottom: 16px;
    }

    /* Dark mode */
    body.theme-dark .forgot-card {
        background: var(--card-bg, #161b30);
        border-color: rgba(255,255,255,0.06);
    }
    body.theme-dark .input-modern {
        background: rgba(255,255,255,0.04);
        color: #f1f5f9;
        border-color: rgba(255,255,255,0.1);
    }
    body.theme-dark .input-modern:focus {
        background: rgba(255,255,255,0.07);
    }
</style>

<div class="forgot-wrapper">
    <div class="forgot-card">
        <!-- Icon -->
        <div class="icon-header">🔑</div>

        <h1 class="forgot-title">Quên mật khẩu?</h1>
        <p class="forgot-subtitle">
            Nhập địa chỉ email đã đăng ký. Chúng tôi sẽ gửi đường dẫn đặt lại mật khẩu vào hộp thư của bạn.
        </p>

        <!-- Validation errors -->
        <div asp-validation-summary="ModelOnly" class="validation-error" style="display:none"></div>

        <form method="post">
            <label class="form-label-modern" asp-for="Input.Email">Địa chỉ Email</label>
            <div class="input-wrap">
                <i class="fas fa-envelope"></i>
                <input asp-for="Input.Email"
                       class="input-modern"
                       placeholder="example@email.com"
                       autocomplete="email"
                       autofocus />
            </div>
            <span asp-validation-for="Input.Email" class="text-danger small d-block mb-3" style="margin-top:-16px;"></span>

            <button type="submit" class="btn-submit">
                <i class="fas fa-paper-plane me-2"></i>Gửi link đặt lại mật khẩu
            </button>
        </form>

        <a href="/Identity/Account/Login" class="back-login">
            <i class="fas fa-arrow-left"></i> Quay lại đăng nhập
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Show validation summary if has errors
        const summary = document.querySelector('[data-valmsg-summary]') ||
                        document.querySelector('.validation-error');
        if (summary && summary.querySelector('li')) {
            summary.style.display = 'block';
        }
    </script>
}
