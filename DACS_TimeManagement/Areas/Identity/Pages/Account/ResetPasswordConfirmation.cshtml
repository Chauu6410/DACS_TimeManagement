@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = Localizer["Reset Password Confirmation"];
}

<div class="login-container" data-aos="fade-up">
    <div class="row justify-content-center w-100 m-0">
        <div class="col-12 col-sm-10 col-md-8 col-lg-7 col-xl-6">
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
                <!-- Header Gradient -->
                <div class="card-header bg-gradient-pastel-primary text-white border-0 py-4 text-center">
                    <div class="icon-circle bg-white bg-opacity-20 mx-auto mb-3">
                        <i class="fas fa-check-double fa-2x animate-bounce"></i>
                    </div>
                    <h3 class="fw-bold mb-0">@Localizer["Reset Password Confirmation"]</h3>
                </div>

                <!-- Content Body -->
                <div class="card-body p-4 p-lg-5 text-center">
                    <p class="fs-5 text-dark mb-4">
                        @Localizer["Your password has been reset successfully."]
                    </p>
                    <a asp-page="./Login" class="btn btn-pastel-primary rounded-pill px-4 py-2 fw-semibold shadow-sm">
                        <i class="fas fa-sign-in-alt me-2"></i>@Localizer["Log In"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #e0e7ff 0%, #f3e8ff 100%);
        padding: 1rem;
    }

    body.theme-dark .login-container {
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
    }

    .bg-gradient-pastel-primary {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
    }

    .icon-circle {
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 60px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(4px);
    }

    .btn-pastel-primary {
        background: #4f46e5;
        color: white;
        border: none;
        transition: all 0.2s;
        font-weight: 500;
        text-decoration: none;
    }
    .btn-pastel-primary:hover {
        background: #4338ca;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3);
        color: white;
    }

    body.theme-dark .text-dark {
        color: #f1f5f9 !important;
    }

    @@media (max-width: 768px) {
        .card-body {
            padding: 1.5rem !important;
        }
        .icon-circle {
            width: 50px;
            height: 50px;
        }
    }
</style>
