@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="logout-container" data-aos="fade-up">
    <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-lg-5 col-md-7 col-11">
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
                <!-- Header Gradient (Pastel đậm) -->
                <div class="card-header bg-gradient-pastel-primary text-white border-0 py-4 text-center">
                    <div class="icon-circle bg-white bg-opacity-20 mx-auto mb-3">
                        <i class="fas fa-sign-out-alt fa-2x"></i>
                    </div>
                    <h3 class="fw-bold mb-0">@ViewData["Title"]</h3>
                    <p class="opacity-75 small mb-0">See you next time!</p>
                </div>

                <!-- Body -->
                <div class="card-body p-4 p-lg-5 text-center">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="mb-4">
                            <i class="fas fa-question-circle fa-3x text-pastel-primary mb-3"></i>
                            <h5 class="fw-semibold">Are you sure you want to log out?</h5>
                            <p class="text-pastel-muted small">You will need to log in again to access your account.</p>
                        </div>
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                            <button type="submit" class="btn btn-pastel-primary rounded-pill px-5 py-2 shadow-sm w-100">
                                <i class="fas fa-sign-out-alt me-2"></i>Yes, Logout
                            </button>
                        </form>
                        <div class="mt-3">
                            <a href="/" class="text-pastel-primary small">Cancel and go back</a>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <i class="fas fa-check-circle fa-3x text-pastel-success mb-3"></i>
                            <h5 class="fw-semibold">You have been logged out</h5>
                            <p class="text-pastel-muted small">Thank you for using TimeMaster. We hope to see you again soon!</p>
                        </div>
                        <a href="/" class="btn btn-pastel-primary rounded-pill px-5 py-2 shadow-sm">
                            <i class="fas fa-home me-2"></i>Return to Home
                        </a>
                        <div class="mt-3">
                            <a href="/Identity/Account/Login" class="text-pastel-primary small">Log in again</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Logout page pastel (đậm hơn) - đồng bộ với Login */
    .logout-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--logout-bg, linear-gradient(135deg, #e0e7ff 0%, #f3e8ff 100%));
        padding: 1rem;
    }

    body.theme-dark .logout-container {
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
    }

    .bg-gradient-pastel-primary {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
    }

    .icon-circle {
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 60px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(4px);
    }

    /* Buttons */
    .btn-pastel-primary {
        background: #4f46e5;
        color: white;
        border: none;
        transition: all 0.2s;
        font-weight: 500;
    }
    .btn-pastel-primary:hover {
        background: #4338ca;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3);
    }

    .text-pastel-primary {
        color: #4f46e5;
        text-decoration: none;
    }
    .text-pastel-primary:hover {
        color: #4338ca;
        text-decoration: underline;
    }
    .text-pastel-muted {
        color: #64748b;
    }
    .text-pastel-success {
        color: #10b981;
    }

    /* Dark mode overrides */
    body.theme-dark .text-pastel-muted {
        color: #94a3b8;
    }
    body.theme-dark .text-pastel-primary {
        color: #a5b4fc;
    }
    body.theme-dark .text-pastel-primary:hover {
        color: #c7d2fe;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .card-body {
            padding: 1.5rem !important;
        }
        .icon-circle {
            width: 50px;
            height: 50px;
        }
        .btn {
            font-size: 0.9rem;
        }
    }
</style>

<script>
    if (typeof AOS !== 'undefined') AOS.refresh();
</script>