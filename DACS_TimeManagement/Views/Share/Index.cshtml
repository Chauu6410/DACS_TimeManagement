@model IEnumerable<DACS_TimeManagement.Models.SharedTask>
@{
    ViewData["Title"] = "Team Shared Workspace";
    var sharedEvents = ViewBag.SharedEvents as IEnumerable<DACS_TimeManagement.Models.SharedEvent> ?? new List<DACS_TimeManagement.Models.SharedEvent>();
}

<div class="shared-workspace-container" data-aos="fade-up">
    <!-- Actions -->
    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-semibold" onclick="openShareModal()">
            <i class="fas fa-plus-circle me-2"></i>New Share
        </button>
    </div>

    <!-- Share Modal -->
    <div class="modal fade" id="shareModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-xl rounded-4">
                <div class="modal-header bg-primary text-white" style="background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;">
                    <h5 class="modal-title fw-bold"><i class="fas fa-share-alt me-2"></i>Share Workspace Item</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <form id="shareForm">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Item Type</label>
                            <select id="itemTypeSelect" class="form-select rounded-3" onchange="onItemTypeChange()">
                                <option value="Task">Task</option>
                                <option value="Event">Calendar Event</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Select Item</label>
                            <select id="itemIdSelect" class="form-select rounded-3" required>
                                <option value="">-- Loading... --</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Share With (User Email)</label>
                            <input type="email" id="shareEmailInput" class="form-control rounded-3" placeholder="colleague@example.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Permission Level</label>
                            <select id="permissionSelect" class="form-select rounded-3">
                                <option value="View">View Only</option>
                                <option value="Edit">Can Edit</option>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0 pb-4 pe-4 bg-light">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm" onclick="submitShare()">Share Item</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Shared Tasks Column -->
        <div class="col-lg-6">
            <div class="card h-100 border-0 shadow-lg rounded-4 overflow-hidden hover-lift transition-all">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <div class="d-flex align-items-center gap-2">
                        <div class="icon-circle bg-primary-soft text-primary">
                            <i class="fas fa-tasks fs-5"></i>
                        </div>
                        <h5 class="fw-bold mb-0">Tasks Shared with Me</h5>
                        <span class="badge bg-primary rounded-pill ms-auto">@Model.Count()</span>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (!Model.Any())
                    {
                        <div class="empty-state text-center py-5">
                            <div class="empty-icon mb-3">
                                <i class="fas fa-inbox fa-4x text-muted opacity-50"></i>
                            </div>
                            <h6 class="fw-semibold">No shared tasks yet</h6>
                            <p class="small text-muted mb-0">Tasks shared with you by teammates will appear here.</p>
                        </div>
                    }
                    else
                    {
                        <div class="task-list">
                            @foreach (var st in Model)
                            {
                                <div class="task-item mb-3 p-3 rounded-3 border bg-white theme-bg-card transition-all">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <i class="fas fa-check-circle text-success small"></i>
                                                <h6 class="fw-bold mb-0">@st.WorkTask?.Title</h6>
                                            </div>
                                            <p class="small text-muted mb-0">
                                                <i class="far fa-calendar-alt me-1"></i>Shared on @st.SharedDate.ToString("MMM dd, yyyy")
                                            </p>
                                        </div>
                                        <div>
                                            @{
                                                string badgeClass = st.PermissionLevel?.ToLower() switch
                                                {
                                                    "edit" => "bg-warning text-dark",
                                                    "view" => "bg-secondary",
                                                    _ => "bg-info"
                                                };
                                            }
                                            <span class="badge @badgeClass rounded-pill px-3 py-1 fw-normal">
                                                <i class="fas @(st.PermissionLevel == "edit" ? "fa-pen" : "fa-eye") me-1"></i>@st.PermissionLevel
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                @if (Model.Any())
                {
                    <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-4">
                        <a href="#" class="text-decoration-none small fw-semibold text-primary">View all tasks →</a>
                    </div>
                }
            </div>
        </div>

        <!-- Shared Events Column -->
        <div class="col-lg-6">
            <div class="card h-100 border-0 shadow-lg rounded-4 overflow-hidden hover-lift transition-all">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <div class="d-flex align-items-center gap-2">
                        <div class="icon-circle bg-warning-soft text-warning">
                            <i class="far fa-calendar-alt fs-5"></i>
                        </div>
                        <h5 class="fw-bold mb-0">Events Shared with Me</h5>
                        <span class="badge bg-warning rounded-pill ms-auto">@sharedEvents.Count()</span>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (!sharedEvents.Any())
                    {
                        <div class="empty-state text-center py-5">
                            <div class="empty-icon mb-3">
                                <i class="far fa-calendar-times fa-4x text-muted opacity-50"></i>
                            </div>
                            <h6 class="fw-semibold">No shared events yet</h6>
                            <p class="small text-muted mb-0">Calendar events shared with you will be listed here.</p>
                        </div>
                    }
                    else
                    {
                        <div class="event-list">
                            @foreach (var se in sharedEvents)
                            {
                                <div class="event-item mb-3 p-3 rounded-3 border bg-white theme-bg-card transition-all">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <i class="fas fa-video text-primary small"></i>
                                                <h6 class="fw-bold mb-0">@se.Event?.Subject</h6>
                                            </div>
                                            <p class="small text-muted mb-0">
                                                <i class="far fa-clock me-1"></i>@se.Event?.StartTime.ToString("MMM dd, yyyy · HH:mm")
                                            </p>
                                        </div>
                                        <div>
                                            @{
                                                string eventBadgeClass = se.PermissionLevel?.ToLower() switch
                                                {
                                                    "edit" => "bg-warning text-dark",
                                                    "view" => "bg-secondary",
                                                    _ => "bg-info"
                                                };
                                            }
                                            <span class="badge @eventBadgeClass rounded-pill px-3 py-1 fw-normal">
                                                <i class="fas @(se.PermissionLevel == "edit" ? "fa-pen" : "fa-eye") me-1"></i>@se.PermissionLevel
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                @if (sharedEvents.Any())
                {
                    <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-4">
                        <a href="#" class="text-decoration-none small fw-semibold text-primary">View all events →</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* Additional styles for Shared Workspace */
    .shared-workspace-container {
        max-width: 1400px;
        margin: -1rem auto 0;
        padding: 0;
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--primary, #6366f1), #8b5cf6);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .icon-circle {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }

    .bg-primary-soft {
        background: rgba(99, 102, 241, 0.12);
    }
    .bg-warning-soft {
        background: rgba(245, 158, 11, 0.12);
    }

    .hover-lift {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.15) !important;
    }

    .task-item, .event-item {
        transition: all 0.2s ease;
        background-color: var(--card-bg, white);
        border-color: var(--border-color, #e5e7eb);
    }
    .task-item:hover, .event-item:hover {
        background-color: rgba(99, 102, 241, 0.03);
        transform: translateX(4px);
        border-left: 3px solid var(--primary, #6366f1);
    }

    /* Dark mode overrides */
    body.theme-dark .task-item,
    body.theme-dark .event-item {
        background-color: var(--card-bg, #1e293b);
        border-color: var(--border-color, #334155);
    }
    body.theme-dark .task-item:hover,
    body.theme-dark .event-item:hover {
        background-color: rgba(99, 102, 241, 0.1);
    }
    body.theme-dark .bg-primary-soft {
        background: rgba(99, 102, 241, 0.2);
    }
    body.theme-dark .bg-warning-soft {
        background: rgba(245, 158, 11, 0.2);
    }
    body.theme-dark .empty-icon i {
        color: #475569;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .icon-circle {
            width: 36px;
            height: 36px;
        }
        .task-item, .event-item {
            padding: 1rem !important;
        }
        .card-header .badge {
            font-size: 0.7rem;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let myTasks = [];
    let myEvents = [];

    async function openShareModal() {
        try {
            const res = await fetch('/Share/GetMyItems');
            const data = await res.json();
            if (data.success) {
                myTasks = data.tasks;
                myEvents = data.events;
                onItemTypeChange();
                new bootstrap.Modal(document.getElementById('shareModal')).show();
            } else {
                Swal.fire('Error', 'Failed to load items', 'error');
            }
        } catch(e) {
            Swal.fire('Error', 'Server error', 'error');
        }
    }

    function onItemTypeChange() {
        const type = document.getElementById('itemTypeSelect').value;
        const select = document.getElementById('itemIdSelect');
        select.innerHTML = '<option value="">-- Choose an item --</option>';
        const items = type === 'Task' ? myTasks : myEvents;
        
        items.forEach(item => {
            const opt = document.createElement('option');
            opt.value = item.id;
            opt.textContent = item.title || 'Unnamed Item';
            select.appendChild(opt);
        });
        
        if(items.length === 0) {
            select.innerHTML = `<option value="" disabled>-- No ${type}s available --</option>`;
        }
    }

    async function submitShare() {
        const itemType = document.getElementById('itemTypeSelect').value;
        const itemId = document.getElementById('itemIdSelect').value;
        const email = document.getElementById('shareEmailInput').value;
        const permission = document.getElementById('permissionSelect').value;

        if(!itemId || !email) {
            return Swal.fire('Warning', 'Please fill all required fields', 'warning');
        }

        Swal.fire({title: 'Sharing...', allowOutsideClick: false, didOpen: () => Swal.showLoading()});

        try {
            const res = await fetch('/Share/CreateShare', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemType: itemType, itemId: parseInt(itemId), email: email, permissionLevel: permission })
            });
            const data = await res.json();
            Swal.close();
            if (data.success) {
                Swal.fire('Success', data.message, 'success').then(() => {
                    location.reload();
                });
            } else {
                Swal.fire('Error', data.message, 'error');
            }
        } catch(e) {
            Swal.close();
            Swal.fire('Error', 'Server error', 'error');
        }
    }

    // Optional: Kích hoạt AOS nếu có trong layout (đã có sẵn)
    if (typeof AOS !== 'undefined') {
        AOS.refresh();
    }
</script>