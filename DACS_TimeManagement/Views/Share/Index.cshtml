@model IEnumerable<DACS_TimeManagement.Models.SharedTask>
@{
    ViewData["Title"] = "Team Shared Workspace";
    var sharedEvents = ViewBag.SharedEvents as IEnumerable<DACS_TimeManagement.Models.SharedEvent> ?? new List<DACS_TimeManagement.Models.SharedEvent>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 fw-bold text-dark"><i class="fas fa-users text-primary me-2"></i>Shared Workspace</h2>
    <button class="btn btn-primary shadow-sm px-4 fw-bold disabled" aria-disabled="true">
        <i class="fas fa-share-alt me-2"></i>Share New Item
    </button>
</div>

<div class="row g-4">
    <!-- Tasks Shared With Me -->
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom p-4">
                <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-tasks text-primary me-2"></i>Tasks Shared with Me</h5>
            </div>
            <div class="card-body p-0">
                @if (!Model.Any())
                {
                    <div class="p-5 text-center text-muted">
                        <i class="fas fa-clipboard-list fa-3x mb-3 text-light"></i>
                        <h6>No shared tasks yet</h6>
                        <p class="small">Tasks your teammates share with you will appear here.</p>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush m-0">
                        @foreach(var st in Model)
                        {
                            <li class="list-group-item p-4">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0 fw-bold">@st.WorkTask?.Title</h6>
                                    <span class="badge bg-info">@st.PermissionLevel</span>
                                </div>
                                <p class="text-muted small mb-0">Shared on @st.SharedDate.ToString("MMM dd, yyyy")</p>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <!-- Events Shared With Me -->
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom p-4">
                <h5 class="mb-0 fw-bold text-dark"><i class="far fa-calendar-alt text-warning me-2"></i>Events Shared with Me</h5>
            </div>
            <div class="card-body p-0">
                @if (!sharedEvents.Any())
                {
                    <div class="p-5 text-center text-muted">
                        <i class="far fa-calendar-check fa-3x mb-3 text-light"></i>
                        <h6>No shared events yet</h6>
                        <p class="small">Meetings and calendar events assigned to you will appear here.</p>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush m-0">
                        @foreach(var se in sharedEvents)
                        {
                            <li class="list-group-item p-4">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0 fw-bold">@se.Event?.Subject</h6>
                                    <span class="badge bg-warning text-dark">@se.PermissionLevel</span>
                                </div>
                                <p class="text-muted small mb-0">Scheduled for @se.Event?.StartTime.ToString("MMM dd HH:mm")</p>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
