@model DACS_TimeManagement.Models.UserProfile
@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="profile-avatar mb-3">
                        <i class="fas fa-user-circle fa-5x text-primary"></i>
                    </div>
                    <h4>@Model.FullName</h4>
                    <p class="text-muted">@Model.Email</p>
                    <p class="text-muted">
                        <i class="fas fa-calendar-alt"></i> Member since @Model.JoinDate.ToString("MMMM yyyy")
                    </p>
                    <button class="btn btn-outline-primary" onclick="changeAvatar()">
                        <i class="fas fa-camera"></i> Change Avatar
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <ul class="nav nav-tabs card-header-tabs">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#profile">
                                Profile Information
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#preferences">
                                Preferences
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#security">
                                Security
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    <div class="tab-content">
                        <!-- Profile Tab -->
                        <div class="tab-pane fade show active" id="profile">
                            <form asp-action="UpdateProfile" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Full Name</label>
                                    <input asp-for="FullName" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Email</label>
                                    <input asp-for="Email" class="form-control" readonly />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Phone Number</label>
                                    <input asp-for="PhoneNumber" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Department</label>
                                    <input asp-for="Department" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Position</label>
                                    <input asp-for="Position" class="form-control" />
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Save Changes
                                </button>
                            </form>
                        </div>

                        <!-- Preferences Tab -->
                        <div class="tab-pane fade" id="preferences">
                            <form asp-action="UpdatePreferences" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Theme</label>
                                    <select asp-for="Theme" class="form-select">
                                        <option value="light">Light</option>
                                        <option value="dark">Dark</option>
                                        <option value="auto">Auto</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Default View</label>
                                    <select asp-for="DefaultView" class="form-select">
                                        <option value="dashboard">Dashboard</option>
                                        <option value="tasks">Tasks</option>
                                        <option value="calendar">Calendar</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Notification Settings</label>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" asp-for="EmailNotifications" />
                                        <label class="form-check-label">Email Notifications</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" asp-for="PushNotifications" />
                                        <label class="form-check-label">Push Notifications</label>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Working Hours</label>
                                    <div class="row">
                                        <div class="col">
                                            <input type="time" asp-for="WorkStartTime" class="form-control" />
                                        </div>
                                        <div class="col">
                                            <input type="time" asp-for="WorkEndTime" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary">Save Preferences</button>
                            </form>
                        </div>

                        <!-- Security Tab -->
                        <div class="tab-pane fade" id="security">
                            <form asp-action="ChangePassword" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Current Password</label>
                                    <input type="password" name="currentPassword" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">New Password</label>
                                    <input type="password" name="newPassword" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Confirm New Password</label>
                                    <input type="password" name="confirmPassword" class="form-control" required />
                                </div>
                                <button type="submit" class="btn btn-primary">Change Password</button>
                            </form>

                            <hr />

                            <h5>Two-Factor Authentication</h5>
                            <p class="text-muted">Add an extra layer of security to your account</p>
                            <button class="btn btn-outline-primary" onclick="enable2FA()">
                                <i class="fas fa-shield-alt"></i> Enable 2FA
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeAvatar() {
            // Implement avatar upload logic
            alert('Avatar upload feature coming soon!');
        }

        function enable2FA() {
            // Implement 2FA setup
            alert('2FA setup feature coming soon!');
        }
    </script>
}