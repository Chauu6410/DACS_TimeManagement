@model DACS_TimeManagement.Models.UserProfile
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["My Profile"];
    var currentCulture = System.Threading.Thread.CurrentThread.CurrentUICulture.Name;
    var langCode = currentCulture.StartsWith("vi") ? "vi" : "en";
}

<div class="settings-container" data-aos="fade-up">
    <div class="row g-4">
        <!-- Sidebar Navigation & Quick Profile -->
        <div class="col-lg-4">
            <!-- Profile Summary Card -->
            <div class="glass-card p-4 text-center mb-4 position-relative overflow-hidden">
                <div class="profile-card-glow"></div>
                <div class="position-relative z-1">
                    <div class="avatar-wrapper mx-auto mb-3" onclick="document.getElementById('avatarUploadInput').click()">
                        <div class="avatar-circle shadow-md">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img src="@Model.AvatarUrl" alt="Avatar" class="w-100 h-100 object-fit-cover" />
                            }
                            else
                            {
                                <i class="fas fa-user-circle text-muted" style="font-size: 5rem;"></i>
                            }
                        </div>
                        <div class="avatar-overlay">
                            <i class="fas fa-camera text-white"></i>
                        </div>
                    </div>
                    
                    <h4 class="fw-bold mb-1" style="color: var(--dark);">@Model.FullName</h4>
                    <p class="text-muted small mb-3">@Model.Email</p>
                    
                    <div class="d-flex justify-content-center gap-2 mb-3">
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-semibold">
                            <i class="fas fa-star me-1 text-warning"></i> Level @Model.Level
                        </span>
                        <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill fw-semibold">
                            <i class="fas fa-fire me-1 text-danger"></i> @Model.CurrentStreak @Localizer["Days Streak"]
                        </span>
                    </div>

                    <p class="text-muted small m-0">
                        <i class="far fa-calendar-alt me-1"></i>
                        @Localizer["Member Since"] @Model.JoinDate.ToString("MMMM yyyy", new System.Globalization.CultureInfo(langCode == "vi" ? "vi-VN" : "en-US"))
                    </p>

                    <!-- Hidden form for avatar upload -->
                    <form id="avatarUploadForm" asp-action="UploadAvatar" method="post" enctype="multipart/form-data" class="d-none">
                        <input type="file" id="avatarUploadInput" name="avatarFile" accept="image/*" onchange="document.getElementById('avatarUploadForm').submit()" />
                    </form>
                </div>
            </div>

            <!-- Settings Sidebar Menu (SaaS style) -->
            <div class="glass-card p-3">
                <div class="nav flex-column nav-pills settings-nav" id="profileTab" role="tablist">
                    <button class="nav-link active text-start d-flex align-items-center gap-3 py-3 px-4 mb-1" data-bs-toggle="pill" data-bs-target="#profile" type="button" role="tab">
                        <i class="fas fa-user-cog"></i>
                        <span>@Localizer["Profile"]</span>
                    </button>
                    <button class="nav-link text-start d-flex align-items-center gap-3 py-3 px-4 mb-1" data-bs-toggle="pill" data-bs-target="#preferences" type="button" role="tab">
                        <i class="fas fa-palette"></i>
                        <span>@Localizer["Preferences"]</span>
                    </button>
                    <button class="nav-link text-start d-flex align-items-center gap-3 py-3 px-4" data-bs-toggle="pill" data-bs-target="#security" type="button" role="tab">
                        <i class="fas fa-shield-alt"></i>
                        <span>@Localizer["Security"]</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="col-lg-8">
            <div class="glass-card p-4 p-md-5">
                <div class="tab-content">
                    <!-- Profile Tab -->
                    <div class="tab-pane fade show active" id="profile" role="tabpanel">
                        <h4 class="fw-bold mb-4" style="color: var(--dark);">@Localizer["Profile Information"]</h4>
                        <form asp-action="UpdateProfile" method="post">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label asp-for="FullName" class="form-label text-muted fw-semibold">@Localizer["Full Name"]</label>
                                    <div class="input-group-modern">
                                        <i class="fas fa-user input-icon"></i>
                                        <input asp-for="FullName" class="form-control-modern" />
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <label asp-for="Email" class="form-label text-muted fw-semibold">@Localizer["Email"]</label>
                                    <div class="input-group-modern disabled">
                                        <i class="fas fa-envelope input-icon"></i>
                                        <input asp-for="Email" class="form-control-modern" readonly />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="PhoneNumber" class="form-label text-muted fw-semibold">@Localizer["Phone Number"]</label>
                                    <div class="input-group-modern">
                                        <i class="fas fa-phone input-icon"></i>
                                        <input asp-for="PhoneNumber" class="form-control-modern" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Department" class="form-label text-muted fw-semibold">@Localizer["Department"]</label>
                                    <div class="input-group-modern">
                                        <i class="fas fa-building input-icon"></i>
                                        <input asp-for="Department" class="form-control-modern" />
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label asp-for="Position" class="form-label text-muted fw-semibold">@Localizer["Position"]</label>
                                    <div class="input-group-modern">
                                        <i class="fas fa-briefcase input-icon"></i>
                                        <input asp-for="Position" class="form-control-modern" />
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary-modern px-4 py-2.5 rounded-pill shadow-sm">
                                    <i class="fas fa-save me-2"></i>@Localizer["Save Changes"]
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Preferences Tab -->
                    <div class="tab-pane fade" id="preferences" role="tabpanel">
                        <h4 class="fw-bold mb-4" style="color: var(--dark);">@Localizer["Preferences"]</h4>
                        <form asp-action="UpdatePreferences" method="post">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label asp-for="Theme" class="form-label text-muted fw-semibold">@Localizer["Theme"]</label>
                                    <select asp-for="Theme" class="form-select-modern">
                                        <option value="light">☀️ @Localizer["Light Theme"]</option>
                                        <option value="dark">🌙 @Localizer["Dark Theme"]</option>
                                        <option value="auto">🔄 @Localizer["Auto Theme"]</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="DefaultView" class="form-label text-muted fw-semibold">@Localizer["Default View"]</label>
                                    <select asp-for="DefaultView" class="form-select-modern">
                                        <option value="dashboard">@Localizer["Dashboard"]</option>
                                        <option value="tasks">@Localizer["Tasks List"]</option>
                                        <option value="calendar">@Localizer["Calendar"]</option>
                                    </select>
                                </div>
                                
                                <div class="col-12">
                                    <label class="form-label text-muted fw-semibold mb-3">@Localizer["Notification Settings"]</label>
                                    <div class="d-flex flex-column gap-3">
                                        <div class="switch-card d-flex align-items-center justify-content-between p-3 border rounded-3">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="switch-icon bg-primary bg-opacity-10 text-primary">
                                                    <i class="fas fa-envelope"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-semibold small" style="color: var(--dark);">@Localizer["Email Notifications"]</div>
                                                    <div class="text-muted small" style="font-size: 0.75rem;">@Localizer["Email Notifications Description"]</div>
                                                </div>
                                            </div>
                                            <div class="form-check form-switch p-0 m-0">
                                                <input class="form-check-input-modern shadow-none" type="checkbox" asp-for="EmailNotifications" id="emailNotif">
                                            </div>
                                        </div>
                                        <div class="switch-card d-flex align-items-center justify-content-between p-3 border rounded-3">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="switch-icon bg-primary bg-opacity-10 text-primary">
                                                    <i class="fas fa-bell"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-semibold small" style="color: var(--dark);">@Localizer["Push Notifications"]</div>
                                                    <div class="text-muted small" style="font-size: 0.75rem;">@Localizer["Push Notifications Description"]</div>
                                                </div>
                                            </div>
                                            <div class="form-check form-switch p-0 m-0">
                                                <input class="form-check-input-modern shadow-none" type="checkbox" asp-for="PushNotifications" id="pushNotif">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="WorkStartTime" class="form-label text-muted fw-semibold">@Localizer["Work Start Time"]</label>
                                    <input type="time" asp-for="WorkStartTime" class="form-control-modern" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="WorkEndTime" class="form-label text-muted fw-semibold">@Localizer["Work End Time"]</label>
                                    <input type="time" asp-for="WorkEndTime" class="form-control-modern" />
                                </div>
                                <div class="col-md-12">
                                    <label asp-for="Language" class="form-label text-muted fw-semibold">@Localizer["Language"]</label>
                                    <select asp-for="Language" class="form-select-modern">
                                        <option value="en">🇬🇧 English</option>
                                        <option value="vi">🇻🇳 Tiếng Việt</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mt-4 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary-modern px-4 py-2.5 rounded-pill shadow-sm">
                                    <i class="fas fa-save me-2"></i>@Localizer["Save Preferences"]
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Security Tab -->
                    <div class="tab-pane fade" id="security" role="tabpanel">
                        <h4 class="fw-bold mb-4" style="color: var(--dark);">@Localizer["Security"]</h4>
                        <form asp-action="ChangePassword" method="post">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label text-muted fw-semibold">@Localizer["Current Password"]</label>
                                    <div class="input-group-modern">
                                        <i class="fas fa-lock input-icon"></i>
                                        <input type="password" name="currentPassword" class="form-control-modern" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fw-semibold">@Localizer["New Password"]</label>
                                    <div class="input-group-modern">
                                        <i class="fas fa-key input-icon"></i>
                                        <input type="password" name="newPassword" class="form-control-modern" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted fw-semibold">@Localizer["Confirm New Password"]</label>
                                    <div class="input-group-modern">
                                        <i class="fas fa-key input-icon"></i>
                                        <input type="password" name="confirmPassword" class="form-control-modern" required />
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary-modern px-4 py-2.5 rounded-pill shadow-sm">
                                    <i class="fas fa-key me-2"></i>@Localizer["Change Password"]
                                </button>
                            </div>
                        </form>
                        
                        <hr class="my-5 opacity-25">
                        
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 p-4 rounded-3 border" style="background: rgba(99,102,241,0.02);">
                            <div>
                                <h5 class="fw-bold mb-1" style="color: var(--dark);">@Localizer["Two-Factor Authentication"]</h5>
                                <p class="text-muted small mb-0">@Localizer["Two-Factor Description"]</p>
                            </div>
                            <button class="btn btn-outline-modern px-4 py-2 rounded-pill" onclick="enable2FA()">
                                <i class="fas fa-shield-alt me-2"></i>@Localizer["Enable 2FA"]
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function enable2FA() {
            alert('2FA setup feature coming soon!');
        }
    </script>
}

<style>
    /* ========== SETTINGS STYLES ========== */
    :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --primary-light: #a5b4fc;
        --primary-soft: #e0e7ff;
        --secondary: #8b5cf6;
        --dark: #0f172a;
        --gray: #64748b;
        --border: #e2e8f0;
        --card-bg: #ffffff;
        --body-bg: #f8fafc;
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
        --shadow-md: 0 8px 24px rgba(0,0,0,0.05);
        --shadow-lg: 0 16px 32px -12px rgba(0,0,0,0.1);
        --radius-xl: 28px;
        --radius-lg: 20px;
        --radius-md: 16px;
        --transition: all 0.25s ease;
    }

    body.theme-dark {
        --primary: #818cf8;
        --primary-dark: #6366f1;
        --primary-soft: #1e293b;
        --dark: #f1f5f9;
        --gray: #94a3b8;
        --border: #334155;
        --card-bg: #1e293b;
        --body-bg: #0f172a;
    }

    .settings-container {
        max-width: 1440px;
        margin: 0 auto;
        padding: 1.5rem 1.5rem 2rem;
    }

    /* Icon Header */
    .settings-header-icon {
        width: 50px;
        height: 50px;
        border-radius: var(--radius-md);
        background: var(--card-bg);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }

    /* Glass Card */
    .glass-card {
        background: var(--card-bg);
        border-radius: var(--radius-xl);
        transition: var(--transition);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
        position: relative;
    }
    .glass-card:hover {
        box-shadow: var(--shadow-md);
    }

    /* Avatar Wrapper & Circle */
    .avatar-wrapper {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        position: relative;
        cursor: pointer;
        overflow: hidden;
    }
    .avatar-circle {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        border: 3px solid var(--card-bg);
        box-shadow: var(--shadow-sm);
        background: var(--body-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .avatar-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: var(--transition);
        border-radius: 50%;
    }
    .avatar-wrapper:hover .avatar-overlay {
        opacity: 1;
    }

    /* profile card ambient glow */
    .profile-card-glow {
        position: absolute;
        top: -50px;
        left: -50px;
        width: 150px;
        height: 150px;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, rgba(99, 102, 241, 0) 70%);
        pointer-events: none;
    }

    /* Settings vertical nav */
    .settings-nav .nav-link {
        color: var(--gray);
        font-weight: 600;
        border-radius: var(--radius-md);
        transition: var(--transition);
        border: 1px solid transparent;
        background: transparent;
        font-size: 0.95rem;
    }
    .settings-nav .nav-link i {
        font-size: 1.1rem;
        transition: var(--transition);
    }
    .settings-nav .nav-link:hover {
        background: var(--body-bg);
        color: var(--primary);
    }
    .settings-nav .nav-link.active {
        background: var(--primary-soft) !important;
        color: var(--primary) !important;
        border-color: var(--primary-light) !important;
    }

    /* Input modern groups */
    .input-group-modern {
        position: relative;
        display: flex;
        align-items: center;
    }
    .input-group-modern .input-icon {
        position: absolute;
        left: 1rem;
        color: var(--gray);
        font-size: 0.95rem;
        pointer-events: none;
    }
    .form-control-modern {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.75rem;
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
        background: var(--body-bg);
        color: var(--dark);
        font-size: 0.95rem;
        transition: var(--transition);
    }
    .form-control-modern:focus {
        background: var(--card-bg);
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
        outline: none;
    }
    .input-group-modern.disabled {
        opacity: 0.65;
    }
    .input-group-modern.disabled .form-control-modern {
        background: rgba(100, 116, 139, 0.05);
        cursor: not-allowed;
    }

    /* Select modern */
    .form-select-modern {
        width: 100%;
        padding: 0.75rem 2.25rem 0.75rem 1rem;
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
        background: var(--body-bg);
        color: var(--dark);
        font-size: 0.95rem;
        transition: var(--transition);
        appearance: none;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%2364748b' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 1rem center;
        background-size: 10px;
    }
    .form-select-modern:focus {
        background-color: var(--card-bg);
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
        outline: none;
    }

    /* Switches & Cards */
    .switch-card {
        background: var(--body-bg);
        border-color: var(--border) !important;
        transition: var(--transition);
    }
    .switch-card:hover {
        border-color: var(--primary-light) !important;
        background: var(--card-bg);
    }
    .switch-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }
    .form-check-input-modern {
        width: 2.5rem;
        height: 1.25rem;
        border-radius: 30px;
        background-color: var(--gray);
        border: none;
        appearance: none;
        cursor: pointer;
        position: relative;
        transition: background-color 0.25s ease;
    }
    .form-check-input-modern:checked {
        background-color: var(--primary);
    }
    .form-check-input-modern::before {
        content: '';
        position: absolute;
        width: 1rem;
        height: 1rem;
        border-radius: 50%;
        top: 0.125rem;
        left: 0.125rem;
        background: white;
        transition: transform 0.25s ease;
    }
    .form-check-input-modern:checked::before {
        transform: translateX(1.25rem);
    }

    /* Buttons */
    .btn-primary-modern {
        background: var(--primary);
        color: white;
        border-radius: 30px;
        padding: 0.6rem 1.75rem;
        font-weight: 600;
        transition: var(--transition);
        border: none;
    }
    .btn-primary-modern:hover {
        background: var(--primary-dark);
        transform: translateY(-1px);
        box-shadow: 0 6px 16px -6px rgba(99, 102, 241, 0.4);
    }
    .btn-outline-modern {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--dark);
        border-radius: 30px;
        padding: 0.6rem 1.75rem;
        font-weight: 600;
        transition: var(--transition);
    }
    .btn-outline-modern:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: rgba(99, 102, 241, 0.05);
    }
</style>