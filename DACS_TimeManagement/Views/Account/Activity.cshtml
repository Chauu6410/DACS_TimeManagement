@{
    ViewData["Title"] = "Activity Log";
}

<div class="container py-4">
    <h2><i class="fas fa-history text-primary"></i> Activity Log</h2>
    <div class="list-group mt-3">
        @foreach (var a in ViewBag.Activities ?? new List<string>())
        {
            <div class="list-group-item">
                <p class="mb-0">@a</p>
            </div>
        }
    </div>
</div>
