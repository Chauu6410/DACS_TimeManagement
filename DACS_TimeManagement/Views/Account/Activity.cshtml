@{
    ViewData["Title"] = "Activity Log";
}

<div class="activity-container" data-aos="fade-up">
    <!-- Header Pastel -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="icon-circle bg-pastel-primary-soft">
                <i class="fas fa-history text-pastel-primary fs-4"></i>
            </div>
            <div>
                <h1 class="display-6 fw-bold text-gradient-pastel mb-0">Activity Log</h1>
                <p class="text-pastel-muted small mb-0">Track your recent actions and events</p>
            </div>
        </div>
    </div>

    <!-- Activity List Card -->
    <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
        <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
            <div class="d-flex align-items-center gap-2">
                <div class="icon-circle bg-pastel-primary-soft" style="width: 36px; height: 36px;">
                    <i class="fas fa-list-ul text-pastel-primary fs-6"></i>
                </div>
                <h5 class="fw-bold mb-0 text-pastel-dark">Recent Activities</h5>
            </div>
        </div>
        <div class="card-body p-0">
            @{
                var activities = ViewBag.Activities as List<string> ?? new List<string>();
            }
            @if (activities.Any())
            {
                <div class="activity-timeline">
                    @foreach (var activity in activities)
                    {
                        <div class="activity-item p-4 border-bottom">
                            <div class="d-flex gap-3">
                                <div class="activity-icon flex-shrink-0">
                                    <i class="fas fa-circle text-pastel-primary" style="font-size: 10px;"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-0 text-pastel-dark">@activity</p>
                                    <small class="text-pastel-muted">
                                        <i class="far fa-clock me-1"></i>Just now
                                    </small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state text-center py-5">
                    <i class="fas fa-history fa-4x text-pastel-muted opacity-50 mb-3"></i>
                    <h6 class="fw-semibold text-pastel-dark">No activities recorded yet</h6>
                    <p class="small text-pastel-muted">Your actions will appear here as you use the system.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Activity Log Pastel Styles - đồng bộ với toàn bộ hệ thống */
    .activity-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .text-gradient-pastel {
        background: linear-gradient(135deg, var(--pastel-primary-dark, #818cf8), #c4b5fd);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }
    .bg-pastel-primary-soft {
        background: rgba(99, 102, 241, 0.12);
    }
    .text-pastel-primary {
        color: var(--pastel-primary-dark, #818cf8);
    }
    .text-pastel-dark {
        color: var(--pastel-dark, #1e293b);
    }
    .text-pastel-muted {
        color: var(--pastel-muted, #64748b);
    }

    /* Activity Timeline */
    .activity-timeline {
        position: relative;
    }
    .activity-item {
        transition: background 0.2s ease;
    }
    .activity-item:hover {
        background: rgba(99, 102, 241, 0.04);
    }
    .activity-item:last-child {
        border-bottom: none !important;
    }
    .border-bottom {
        border-bottom: 1px solid var(--pastel-border, #e2e8f0);
    }

    /* Empty State */
    .empty-state {
        background: var(--pastel-card-bg, #ffffff);
    }

    /* Dark Mode Variables */
    body.theme-dark {
        --pastel-primary-dark: #6366f1;
        --pastel-border: #334155;
        --pastel-card-bg: #1e293b;
        --pastel-dark: #f1f5f9;
        --pastel-muted: #94a3b8;
        --pastel-soft: #0f172a;
    }
    body.theme-dark .bg-pastel-primary-soft {
        background: rgba(99, 102, 241, 0.2);
    }
    body.theme-dark .border-bottom {
        border-bottom-color: #334155;
    }
    body.theme-dark .activity-item:hover {
        background: rgba(99, 102, 241, 0.1);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .activity-container {
            padding: 0 0.5rem;
        }
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .activity-item {
            padding: 1rem !important;
        }
    }
</style>

@* Kích hoạt AOS nếu có *@
<script>
    if (typeof AOS !== 'undefined') {
        AOS.refresh();
    }
</script>