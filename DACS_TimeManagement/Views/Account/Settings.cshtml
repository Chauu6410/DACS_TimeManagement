@{
    ViewData["Title"] = "Settings";
}

<div class="settings-container" data-aos="fade-up">
    <!-- Header Pastel -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="icon-circle bg-pastel-primary-soft">
                <i class="fas fa-sliders-h text-pastel-primary fs-4"></i>
            </div>
            <div>
                <h1 class="display-6 fw-bold text-gradient-pastel mb-0">Account Settings</h1>
                <p class="text-pastel-muted small mb-0">Manage your preferences and account settings</p>
            </div>
        </div>
    </div>

    <!-- Settings Card -->
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden hover-lift">
                <div class="card-header bg-gradient-pastel-primary text-white border-0 py-3 px-4">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-user-cog fs-5"></i>
                        <h5 class="fw-bold mb-0">General Settings</h5>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-action="Settings">
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-user text-pastel-primary me-1"></i> Display Name
                            </label>
                            <input type="text" class="form-control form-control-lg rounded-3" name="displayName" value="@User.Identity?.Name" placeholder="Your display name" />
                            <div class="form-text text-pastel-muted">This name will be shown on your profile and dashboard.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="fas fa-globe text-pastel-primary me-1"></i> Language
                            </label>
                            <select class="form-select form-select-lg rounded-3" name="language">
                                <option value="en">🇬🇧 English</option>
                                <option value="vi">🇻🇳 Tiếng Việt</option>
                            </select>
                            <div class="form-text text-pastel-muted">Choose your preferred language for the interface.</div>
                        </div>

                        <hr class="my-4 opacity-25" />

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-pastel-primary rounded-pill px-5 py-2 shadow-sm">
                                <i class="fas fa-save me-2"></i>Save Settings
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Additional Info Card -->
            <div class="card border-0 shadow-lg rounded-4 mt-4 bg-pastel-soft">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start gap-3">
                        <div class="icon-circle bg-pastel-primary-soft" style="width: 40px; height: 40px;">
                            <i class="fas fa-info-circle text-pastel-primary"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Need more options?</h6>
                            <p class="small text-pastel-muted mb-2">For advanced security settings like password change and 2FA, please visit your <a href="/Profile" class="text-pastel-primary">Profile page</a>.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Settings Pastel Styles - đồng bộ với toàn bộ hệ thống */
    .settings-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .text-gradient-pastel {
        background: linear-gradient(135deg, var(--pastel-primary-dark, #818cf8), #c4b5fd);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }
    .bg-pastel-primary-soft {
        background: rgba(99, 102, 241, 0.12);
    }
    .text-pastel-primary {
        color: var(--pastel-primary-dark, #818cf8);
    }
    .text-pastel-dark {
        color: var(--pastel-dark, #1e293b);
    }
    .text-pastel-muted {
        color: var(--pastel-muted, #64748b);
    }
    .bg-pastel-soft {
        background: var(--pastel-soft, #f8fafc);
    }

    .bg-gradient-pastel-primary {
        background: linear-gradient(135deg, var(--pastel-primary, #a5b4fc), var(--pastel-primary-dark, #818cf8));
    }

    .hover-lift {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .hover-lift:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.2) !important;
    }

    /* Form controls */
    .form-control, .form-select {
        border: 1px solid var(--pastel-border, #e2e8f0);
        background-color: var(--pastel-card-bg, #ffffff);
        color: var(--pastel-dark, #0f172a);
        transition: all 0.2s ease;
        font-size: 0.95rem;
        padding: 0.7rem 1rem;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--pastel-primary-dark, #818cf8);
        box-shadow: 0 0 0 4px rgba(129, 140, 248, 0.2);
        outline: none;
    }
    .form-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--pastel-muted, #64748b);
    }
    .form-text {
        font-size: 0.75rem;
        margin-top: 0.25rem;
    }

    /* Buttons Pastel */
    .btn-pastel-primary {
        background: var(--pastel-primary, #a5b4fc);
        color: #1e293b;
        border: none;
        transition: all 0.2s;
        font-weight: 500;
    }
    .btn-pastel-primary:hover {
        background: var(--pastel-primary-dark, #818cf8);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(129, 140, 248, 0.3);
    }

    /* Dark Mode Variables */
    body.theme-dark {
        --pastel-primary: #818cf8;
        --pastel-primary-dark: #6366f1;
        --pastel-border: #334155;
        --pastel-card-bg: #1e293b;
        --pastel-dark: #f1f5f9;
        --pastel-muted: #94a3b8;
        --pastel-soft: #0f172a;
    }
    body.theme-dark .form-control,
    body.theme-dark .form-select {
        background-color: #1e293b;
        border-color: #334155;
        color: #f1f5f9;
    }
    body.theme-dark .bg-pastel-primary-soft {
        background: rgba(99, 102, 241, 0.2);
    }
    body.theme-dark .bg-pastel-soft {
        background: #0f172a;
    }
    body.theme-dark .btn-pastel-primary {
        background: #4f46e5;
        color: #e0e7ff;
    }
    body.theme-dark .btn-pastel-primary:hover {
        background: #6366f1;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .settings-container {
            padding: 0 0.5rem;
        }
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .card-body {
            padding: 1.5rem !important;
        }
    }
</style>

<script>
    if (typeof AOS !== 'undefined') AOS.refresh();
</script>