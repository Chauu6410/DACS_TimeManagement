@{
    ViewData["Title"] = "Settings";
}

<div class="container py-4">
    <h2><i class="fas fa-sliders-h text-primary"></i> Account Settings</h2>
    <p class="text-muted">Manage your preferences and account settings.</p>

    <div class="card">
        <div class="card-body">
            <form method="post" asp-action="Settings">
                <div class="mb-3">
                    <label class="form-label">Display Name</label>
                    <input class="form-control" name="displayName" value="@User.Identity?.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Language</label>
                    <select class="form-select" name="language">
                        <option value="en">English</option>
                        <option value="vi">Tiếng Việt</option>
                    </select>
                </div>
                <button class="btn btn-primary" type="submit"><i class="fas fa-save"></i> Save</button>
            </form>
        </div>
    </div>
</div>
