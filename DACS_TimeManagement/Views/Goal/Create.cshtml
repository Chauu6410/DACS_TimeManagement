@model DACS_TimeManagement.DTOs.CreateGoalDto
@{
    ViewData["Title"] = "Tạo Goal";
    var projects = (IEnumerable<dynamic>)ViewBag.Projects;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card glass p-4 rounded-4 shadow-lg">
                <h3 class="fw-bold mb-3"><i class="fas fa-plus-circle me-2 text-primary"></i>Tạo Goal Mới</h3>
                <form asp-action="Create" method="post" id="goalForm">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chọn Dự Án Liên Kết</label>
                        <select name="ProjectId" id="ProjectId" class="form-select" required>
                            <option value="">-- Chọn một dự án --</option>
                            @foreach(var p in projects)
                            {
                                <option value="@p.Id" data-deadline="@(p.EndDate?.ToString("yyyy-MM-dd"))">@p.Name</option>
                            }
                        </select>
                        <div id="projectDeadlineInfo" class="mt-2 small text-muted d-none">
                             Dự án này có hạn chót là <span id="deadlineDisplay" class="fw-bold"></span>
                        </div>
                        <span asp-validation-for="ProjectId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô tả mục tiêu</label>
                        <textarea name="Description" class="form-control" rows="3" placeholder="Bạn muốn đạt được điều gì cho dự án này?"></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Ngày hoàn thành mong muốn</label>
                        <input type="date" name="TargetDate" id="TargetDate" class="form-control" value="@Model.TargetDate.ToString("yyyy-MM-dd")" required />
                        <div id="dateWarning" class="mt-2 small text-danger d-none">
                            ⚠️ Ngày hoàn thành không thể muộn hơn hạn chót của dự án!
                        </div>
                        <span asp-validation-for="TargetDate" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
                        <button type="submit" id="submitBtn" class="btn btn-primary rounded-pill px-4 bg-gradient">
                            <i class="fas fa-check me-1"></i> Tạo Goal
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const projectSelect = document.getElementById('ProjectId');
            const targetDateInput = document.getElementById('TargetDate');
            const deadlineInfo = document.getElementById('projectDeadlineInfo');
            const deadlineDisplay = document.getElementById('deadlineDisplay');
            const dateWarning = document.getElementById('dateWarning');
            const submitBtn = document.getElementById('submitBtn');

            function validateDates() {
                const selectedOption = projectSelect.options[projectSelect.selectedIndex];
                const projectDeadline = selectedOption.getAttribute('data-deadline');
                const targetDate = targetDateInput.value;

                if (projectDeadline) {
                    deadlineDisplay.textContent = new Date(projectDeadline).toLocaleDateString('vi-VN');
                    deadlineInfo.classList.remove('d-none');

                    if (targetDate && new Date(targetDate) > new Date(projectDeadline)) {
                        dateWarning.classList.remove('d-none');
                        submitBtn.disabled = true;
                        submitBtn.style.opacity = '0.5';
                        targetDateInput.classList.add('is-invalid');
                    } else {
                        dateWarning.classList.add('d-none');
                        submitBtn.disabled = false;
                        submitBtn.style.opacity = '1';
                        targetDateInput.classList.remove('is-invalid');
                    }
                } else {
                    deadlineInfo.classList.add('d-none');
                    dateWarning.classList.add('d-none');
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                    targetDateInput.classList.remove('is-invalid');
                }
            }

            projectSelect.addEventListener('change', validateDates);
            targetDateInput.addEventListener('change', validateDates);
        });
    </script>
}

<style>
    .glass { background: rgba(255,255,255,0.95); backdrop-filter: blur(12px); border-radius: 24px; border: 1px solid rgba(255,255,255,0.3); }
    .btn-primary.bg-gradient { background: linear-gradient(135deg, #6366f1, #a855f7); border: none; }
    .btn-primary.bg-gradient:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(99,102,241,0.4); }
    .form-select, .form-control { border-radius: 12px; border: 1px solid #e2e8f0; padding: 0.75rem 1rem; }
    .form-select:focus, .form-control:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
</style>