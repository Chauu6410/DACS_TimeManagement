@model DACS_TimeManagement.DTOs.CreateGoalDto
@using DACS_TimeManagement.Models
@{
    ViewData["Title"] = "Set Up New Goal";
    var projects = (IEnumerable<dynamic>)ViewBag.Projects;
}

<div class="create-goal-container" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden transition-all hover-lift">
                <!-- Header Gradient -->
                <div class="card-header bg-gradient-primary text-white border-0 py-4 px-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-white bg-opacity-25 text-white">
                            <i class="fas fa-bullseye fs-4"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">Thiết lập mục tiêu mới</h4>
                            <p class="opacity-75 small mb-0">Xác định mục tiêu và đo lường tiến độ công việc</p>
                        </div>
                    </div>
                </div>

                <!-- Form Body -->
                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Create" method="post" id="goalForm">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 border-0" role="alert"></div>

                        <div class="row g-4">
                            <!-- Goal Type Selection -->
                            <div class="col-12 mb-2">
                                <label class="form-label fw-semibold mb-3">
                                    <i class="fas fa-layer-group text-primary me-1"></i> Loại Mục Tiêu
                                </label>
                                <div class="d-flex gap-3 flex-wrap">
                                    <div class="form-check custom-radio-card flex-grow-1 p-0 m-0">
                                        <input class="form-check-input" type="radio" name="Type" id="typeTask" value="TaskBased" @(Model.Type == GoalType.TaskBased ? "checked" : "")>
                                        <label class="form-check-label w-100 p-3 border rounded-3 text-center cursor-pointer h-100" for="typeTask">
                                            <i class="fas fa-project-diagram fs-4 text-primary d-block mb-2 mt-2"></i>
                                            <span class="fw-bold d-block">Mục Tiêu Dự Án</span>
                                            <small class="text-muted">Hoàn thành theo Task của một Project</small>
                                        </label>
                                    </div>
                                    <div class="form-check custom-radio-card flex-grow-1 p-0 m-0">
                                        <input class="form-check-input" type="radio" name="Type" id="typeTime" value="TimeBased" @(Model.Type == GoalType.TimeBased ? "checked" : "")>
                                        <label class="form-check-label w-100 p-3 border rounded-3 text-center cursor-pointer h-100" for="typeTime">
                                            <i class="fas fa-stopwatch fs-4 text-warning d-block mb-2 mt-2"></i>
                                            <span class="fw-bold d-block">Mục Tiêu Cá Nhân</span>
                                            <small class="text-muted">Hoàn thành X giờ cho 1 việc (Dùng Pomodoro)</small>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Title (For TimeBased) -->
                            <div class="col-12 d-none" id="titleGroup">
                                <label class="form-label fw-semibold mb-2">
                                    <i class="fas fa-heading text-primary me-1"></i> Tên Mục Tiêu <span class="text-danger">*</span>
                                </label>
                                <input type="text" name="Title" id="Title" class="form-control form-control-lg rounded-3" placeholder="e.g., Học tiếng Anh, Tập thể dục..." value="@Model.Title" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <!-- Linked Project (For TaskBased) -->
                            <div class="col-12" id="projectGroup">
                                <label class="form-label fw-semibold mb-2">
                                    <i class="fas fa-project-diagram text-primary me-1"></i> Project Liên Kết <span class="text-danger">*</span>
                                </label>
                                <select name="ProjectId" id="ProjectId" class="form-select form-select-lg rounded-3">
                                    <option value="">-- Chọn một project --</option>
                                    @foreach(var p in projects)
                                    {
                                        <option value="@p.Id" data-deadline="@(p.EndDate?.ToString("yyyy-MM-dd"))">@p.Name</option>
                                    }
                                </select>
                                <div id="projectDeadlineInfo" class="mt-2 small text-muted d-none">
                                     <i class="far fa-calendar-alt me-1"></i> Hạn chót project: <span id="deadlineDisplay" class="fw-bold"></span>
                                </div>
                                <span asp-validation-for="ProjectId" class="text-danger small"></span>
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label class="form-label fw-semibold mb-2">
                                    <i class="fas fa-align-left text-primary me-1"></i> Mô tả chi tiết
                                </label>
                                <textarea name="Description" class="form-control rounded-3" rows="4" placeholder="Bạn muốn đạt được điều gì?">@Model.Description</textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <!-- Target Date -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold mb-2">
                                    <i class="fas fa-calendar-check text-primary me-1"></i> Ngày hoàn thành mục tiêu <span class="text-danger">*</span>
                                </label>
                                <input type="datetime-local" name="TargetDate" id="TargetDate" class="form-control form-control-lg rounded-3" value="@Model.TargetDate.ToString("yyyy-MM-ddTHH:mm")" required />
                                <div id="dateWarning" class="mt-2 small text-danger d-none">
                                    <i class="fas fa-exclamation-triangle me-1"></i> Ngày hoàn thành không được vượt quá hạn chót của Project!
                                </div>
                                <span asp-validation-for="TargetDate" class="text-danger small"></span>
                            </div>

                            <!-- Target Hours -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold mb-2">
                                    <i class="fas fa-clock text-primary me-1"></i> Tổng số giờ mục tiêu <span id="effortRequiredMark" class="text-danger d-none">*</span>
                                </label>
                                <div class="input-group input-group-lg">
                                    <input type="number" step="0.5" name="TargetHours" id="TargetHours" class="form-control rounded-start-3" placeholder="Ví dụ: 30" value="@Model.TargetHours" />
                                    <span class="input-group-text rounded-end-3 bg-light border-start-0 text-muted">giờ</span>
                                </div>
                                <div id="effortHelp" class="mt-1 small text-muted d-none">Bắt buộc đối với Mục tiêu cá nhân.</div>
                                <span asp-validation-for="TargetHours" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25" />

                        <!-- Form Actions -->
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                                <i class="fas fa-arrow-left me-2"></i>Hủy
                            </a>
                            <button type="submit" id="submitBtn" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">
                                <i class="fas fa-check-circle me-2"></i>Tạo Mục Tiêu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const projectSelect = document.getElementById('ProjectId');
            const targetDateInput = document.getElementById('TargetDate');
            const deadlineInfo = document.getElementById('projectDeadlineInfo');
            const deadlineDisplay = document.getElementById('deadlineDisplay');
            const dateWarning = document.getElementById('dateWarning');
            const submitBtn = document.getElementById('submitBtn');

            const typeTask = document.getElementById('typeTask');
            const typeTime = document.getElementById('typeTime');
            const titleGroup = document.getElementById('titleGroup');
            const projectGroup = document.getElementById('projectGroup');
            const effortRequiredMark = document.getElementById('effortRequiredMark');
            const effortHelp = document.getElementById('effortHelp');
            const titleInput = document.getElementById('Title');
            const targetHoursInput = document.getElementById('TargetHours');

            function toggleType() {
                if (typeTask.checked) {
                    titleGroup.classList.add('d-none');
                    titleInput.required = false;
                    
                    projectGroup.classList.remove('d-none');
                    projectSelect.required = true;
                    
                    effortRequiredMark.classList.add('d-none');
                    effortHelp.classList.add('d-none');
                    targetHoursInput.required = false;
                } else {
                    titleGroup.classList.remove('d-none');
                    titleInput.required = true;
                    
                    projectGroup.classList.add('d-none');
                    projectSelect.required = false;
                    
                    effortRequiredMark.classList.remove('d-none');
                    effortHelp.classList.remove('d-none');
                    targetHoursInput.required = true;
                }
                validateDates();
            }

            function validateDates() {
                // Only validate project deadline if TaskBased
                if (typeTask.checked && projectSelect.selectedIndex >= 0) {
                    const selectedOption = projectSelect.options[projectSelect.selectedIndex];
                    const projectDeadline = selectedOption ? selectedOption.getAttribute('data-deadline') : null;
                    const targetDate = targetDateInput.value;

                    if (projectDeadline && projectDeadline !== "") {
                        deadlineDisplay.textContent = new Date(projectDeadline).toLocaleDateString('vi-VN');
                        deadlineInfo.classList.remove('d-none');

                        if (targetDate && new Date(targetDate) > new Date(projectDeadline)) {
                            dateWarning.classList.remove('d-none');
                            submitBtn.disabled = true;
                            submitBtn.style.opacity = '0.5';
                            targetDateInput.classList.add('is-invalid');
                        } else {
                            dateWarning.classList.add('d-none');
                            submitBtn.disabled = false;
                            submitBtn.style.opacity = '1';
                            targetDateInput.classList.remove('is-invalid');
                        }
                    } else {
                        deadlineInfo.classList.add('d-none');
                        dateWarning.classList.add('d-none');
                        submitBtn.disabled = false;
                        submitBtn.style.opacity = '1';
                        targetDateInput.classList.remove('is-invalid');
                    }
                } else {
                    deadlineInfo.classList.add('d-none');
                    dateWarning.classList.add('d-none');
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                    targetDateInput.classList.remove('is-invalid');
                }
            }

            typeTask.addEventListener('change', toggleType);
            typeTime.addEventListener('change', toggleType);
            projectSelect.addEventListener('change', validateDates);
            targetDateInput.addEventListener('change', validateDates);
            
            toggleType(); // initial load setup
        });
    </script>
}

<style>
    .create-goal-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #6366f1, #a855f7);
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 60px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(4px);
    }

    .hover-lift {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .hover-lift:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.2) !important;
    }

    /* Custom Radio Buttons */
    .custom-radio-card input[type="radio"] { display: none; }
    .custom-radio-card label { transition: 0.3s; background: white; }
    .custom-radio-card input[type="radio"]:checked + label {
        border-color: var(--primary, #6366f1) !important;
        background: #f5f3ff !important;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.1);
    }
    .cursor-pointer { cursor: pointer; }

    /* Form controls */
    .form-control, .form-select {
        border: 1px solid var(--border-color, #e2e8f0);
        background-color: var(--card-bg, #ffffff);
        color: var(--text-dark, #0f172a);
        transition: all 0.2s ease;
        font-size: 0.95rem;
        padding: 0.7rem 1rem;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--primary, #6366f1);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
        outline: none;
    }
    .form-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-muted, #64748b);
    }

    .input-group-text {
        border: 1px solid var(--border-color, #e2e8f0);
        background-color: #f8fafc;
        font-size: 0.9rem;
    }

    /* Dark mode overrides */
    body.theme-dark .form-control, 
    body.theme-dark .form-select {
        background-color: var(--card-bg, #1e293b);
        border-color: var(--border-color, #334155);
        color: #f1f5f9;
    }
    body.theme-dark .input-group-text {
        background-color: #1e293b;
        border-color: #334155;
        color: #94a3b8;
    }
    body.theme-dark .btn-outline-secondary {
        color: #cbd5e1;
        border-color: #475569;
    }
    body.theme-dark .btn-outline-secondary:hover {
        background-color: #334155;
        color: white;
    }
    body.theme-dark .custom-radio-card label { background: var(--card-bg, #1e293b); }
    body.theme-dark .custom-radio-card input[type="radio"]:checked + label {
        background: rgba(99, 102, 241, 0.1) !important;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .create-goal-container {
            padding: 0 0.5rem;
        }
        .card-body {
            padding: 1.5rem !important;
        }
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .btn {
            width: 100%;
            text-align: center;
            justify-content: center;
        }
        .d-flex.flex-wrap {
            flex-direction: column-reverse;
        }
    }
</style>