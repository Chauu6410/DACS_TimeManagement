            // Timer Circle Circumference calculation
            const radius = timerProgressCircle.r.baseVal.value;
            const circumference = 2 * Math.PI * radius;
            timerProgressCircle.style.strokeDasharray = `${circumference} ${circumference}`;
            
            function setProgress(percent) {
                const offset = circumference - (percent / 100) * circumference;
                timerProgressCircle.style.strokeDashoffset = offset;
            }
            setProgress(100);

            // --- LOCAL STORAGE OCEAN COLLECTION LOGIC ---
            function getCollection() {
                const data = localStorage.getItem(collectionKey);
                return data ? JSON.parse(data) : { coral: 0, clownfish: 0, octopus: 0, turtle: 0, whale: 0, ship: 0 };
            }

            function saveCollection(col) {
                localStorage.setItem(collectionKey, JSON.stringify(col));
            }

            function addCreature(type) {
                const col = getCollection();
                col[type] = (col[type] || 0) + 1;
                saveCollection(col);
                renderAquarium();
            }

            function renderAquarium() {
                const col = getCollection();
                aquariumCreaturesContainer.innerHTML = '';

                // Update Counts HUD
                let total = 0;
                for (const [key, count] of Object.entries(col)) {
                    const badge = document.getElementById(`count-${key}`);
                    if (badge) badge.textContent = count;
                    total += count;
                }
                document.getElementById('totalCreaturesCounter').textContent = total;

                // Spawn SVG creatures in aquarium
                for (const [type, count] of Object.entries(col)) {
                    for (let i = 0; i < count; i++) {
                        const el = document.createElement('div');
                        el.className = `aquarium-creature creature-${type}`;
                        el.innerHTML = CREATURE_SVGS[type];

                        if (type === 'coral' || type === 'ship') {
                            const left = 5 + Math.random() * 85;
                            el.style.left = `${left}%`;
