@inject IViewLocalizer Localizer
@model DACS_TimeManagement.Models.PersonalGoal
@using System.Security.Claims
@{
    ViewData["Title"] = Localizer["FocusMode"] + " - " + Model.Title;
    var isVi = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("vi");
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div id="focusApp" class="focus-app nox-ocean-theme">
    <!-- Ambient Ocean Background Effects -->
    <div class="ocean-background">
        <div class="light-beams"></div>
        <div class="bubble-emitter" id="bgBubbles"></div>
        <div class="seaweed-bed">
            <svg viewBox="0 0 1200 120" class="seaweed-svg" preserveAspectRatio="none">
                <path d="M50 120 C60 80, 40 40, 60 10 C65 40, 55 80, 70 120 Z" fill="#2d6a4f" opacity="0.4" class="seaweed-1"/>
                <path d="M150 120 C140 70, 160 40, 150 15 C165 40, 155 70, 170 120 Z" fill="#1b4332" opacity="0.6" class="seaweed-2"/>
                <path d="M220 120 C240 85, 210 50, 230 20 C240 50, 230 85, 250 120 Z" fill="#40916c" opacity="0.3" class="seaweed-3"/>
                <path d="M380 120 C360 80, 390 40, 370 15 C385 40, 375 80, 390 120 Z" fill="#2d6a4f" opacity="0.5" class="seaweed-2"/>
                <path d="M550 120 C570 75, 540 40, 560 5 C575 40, 560 75, 580 120 Z" fill="#2d6a4f" opacity="0.5" class="seaweed-1"/>
                <path d="M620 120 C610 80, 630 45, 620 20 C635 45, 625 80, 640 120 Z" fill="#1b4332" opacity="0.7" class="seaweed-2"/>
                <path d="M780 120 C800 85, 770 50, 790 20 C800 50, 790 85, 810 120 Z" fill="#40916c" opacity="0.4" class="seaweed-3"/>
                <path d="M950 120 C940 80, 960 50, 950 25 C965 50, 955 80, 970 120 Z" fill="#40916c" opacity="0.5" class="seaweed-1"/>
                <path d="M1050 120 C1070 70, 1040 30, 1060 10 C1075 30, 1060 70, 1080 120 Z" fill="#2d6a4f" opacity="0.4" class="seaweed-2"/>
            </svg>
        </div>
    </div>

    <!-- Top Navigation Bar -->
    <div class="top-nav-bar d-flex justify-content-between align-items-center px-4 py-3">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link text-white text-decoration-none d-flex align-items-center gap-2">
            <i class="fas fa-chevron-left"></i> @Localizer["BackToDetails"]
        </a>
        <button id="btnOpenAquarium" class="btn btn-outline-info rounded-pill px-4">
            🐠 @(isVi ? "Bể cá đại dương" : "My Ocean Aquarium")
        </button>
    </div>

    <!-- Step 1: Selection and Config Screen -->
    <div id="selectionScreen" class="container py-4 selection-screen">
        <div class="row justify-content-center">
            <div class="col-xl-8 col-lg-10">
                <div class="glass-premium p-4 p-md-5 rounded-5 shadow-lg text-center animate-fade-in">
                    <div class="mb-4">
                        <div class="logo-container mb-3">
                            <i class="fas fa-water fa-3x text-info pulse-icon"></i>
                        </div>
                        <h2 class="fw-bold text-white mb-2">@(isVi ? "Nox Ocean Focus" : "Nox Ocean Focus Mode")</h2>
                        <p class="text-white-50">@(isVi ? "Hãy lựa chọn sinh vật biển bạn muốn nuôi dưỡng bằng cách tập trung." : "Choose the sea creature you want to grow by staying focused.")</p>
                    </div>

                    <!-- Mode Toggle -->
                    <div class="d-flex justify-content-center mb-4">
                        <div class="mode-tabs-container p-1 rounded-pill bg-dark bg-opacity-50">
                            <button id="modeCountdown" class="btn mode-tab active rounded-pill px-4 py-2">
                                <i class="fas fa-hourglass-half me-1"></i> @(isVi ? "Đếm ngược" : "Countdown")
                            </button>
                            <button id="modeStopwatch" class="btn mode-tab rounded-pill px-4 py-2">
                                <i class="fas fa-stopwatch me-1"></i> @(isVi ? "Đếm xuôi (Zen)" : "Stopwatch (Zen)")
                            </button>
                        </div>
                    </div>

                    <!-- Step 1.1: Choose Sea Creature Grid -->
                    <div class="mb-4 text-start">
                        <h5 class="text-white mb-3 fw-bold"><i class="fas fa-fish me-2 text-info"></i>@(isVi ? "1. Chọn sinh vật biển để nuôi dưỡng" : "1. Choose Sea Creature to Grow")</h5>
                        <div class="row g-3 creature-grid">
                            <div class="col-6 col-md-4">
                                <div class="creature-card selected animate-hover-scale" data-type="coral" data-min-time="10">
                                    <div class="creature-preview" id="preview-coral"></div>
                                    <div class="creature-info">
                                        <span class="creature-name">@(isVi ? "San hô hồng" : "Pink Coral")</span>
                                        <span class="creature-time">≥ 10 @(isVi ? "phút" : "mins")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-md-4">
                                <div class="creature-card animate-hover-scale" data-type="clownfish" data-min-time="25">
                                    <div class="creature-preview" id="preview-clownfish"></div>
                                    <div class="creature-info">
                                        <span class="creature-name">@(isVi ? "Cá Nemo" : "Clownfish")</span>
                                        <span class="creature-time">≥ 25 @(isVi ? "phút" : "mins")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-md-4">
                                <div class="creature-card animate-hover-scale" data-type="octopus" data-min-time="45">
                                    <div class="creature-preview" id="preview-octopus"></div>
                                    <div class="creature-info">
                                        <span class="creature-name">@(isVi ? "Bạch tuộc tím" : "Purple Octopus")</span>
                                        <span class="creature-time">≥ 45 @(isVi ? "phút" : "mins")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-md-4">
                                <div class="creature-card animate-hover-scale" data-type="turtle" data-min-time="60">
                                    <div class="creature-preview" id="preview-turtle"></div>
                                    <div class="creature-info">
                                        <span class="creature-name">@(isVi ? "Rùa biển" : "Sea Turtle")</span>
                                        <span class="creature-time">≥ 60 @(isVi ? "phút" : "mins")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-md-4">
                                <div class="creature-card animate-hover-scale" data-type="whale" data-min-time="90">
                                    <div class="creature-preview" id="preview-whale"></div>
                                    <div class="creature-info">
                                        <span class="creature-name">@(isVi ? "Cá voi xanh" : "Blue Whale")</span>
                                        <span class="creature-time">≥ 90 @(isVi ? "phút" : "mins")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 col-md-4">
                                <div class="creature-card animate-hover-scale" data-type="ship" data-min-time="120">
                                    <div class="creature-preview" id="preview-ship"></div>
                                    <div class="creature-info">
                                        <span class="creature-name">@(isVi ? "Tàu cổ chìm" : "Ancient Galleon")</span>
                                        <span class="creature-time">≥ 120 @(isVi ? "phút" : "mins")</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Step 1.2: Duration control (Countdown Mode only) -->
                    <div id="durationControllerSection" class="mb-4 text-start">
                        <h5 class="text-white mb-3 fw-bold"><i class="fas fa-clock me-2 text-info"></i>@(isVi ? "2. Thiết lập thời gian tập trung" : "2. Set Focus Duration")</h5>
                        <div class="duration-controls-box p-3 rounded-4 bg-dark bg-opacity-25 border border-white border-opacity-10 d-flex justify-content-center align-items-center gap-4">
                            <button id="btnTimeMinus" class="btn btn-outline-light rounded-circle time-adjust-btn"><i class="fas fa-minus"></i></button>
                            <div class="text-center">
                                <div id="selectedTimeDisplay" class="fw-bold text-info fs-1 font-monospace">10:00</div>
                                <div class="small text-white-50">@(isVi ? "Phút : Giây" : "Minutes : Seconds")</div>
                            </div>
                            <button id="btnTimePlus" class="btn btn-outline-light rounded-circle time-adjust-btn"><i class="fas fa-plus"></i></button>
                        </div>
                        <div id="durationMatchWarning" class="text-info mt-2 text-center small fw-semibold">
                            <!-- Populated by JS -->
                        </div>
                    </div>

                    <!-- Step 1.3: Task Selection (Only for TaskBased goals) -->
                    <div class="mb-5 text-start @(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? "d-none" : "")">
                        <h5 class="text-white mb-3 fw-bold"><i class="fas fa-tasks me-2 text-info"></i>@(isVi ? "3. Chọn nhiệm vụ cần hoàn thành" : "3. Choose Linked Task")</h5>
                        <div class="task-list-selection" style="max-height: 250px; overflow-y: auto; padding-right: 5px;">
                            @if (Model.GoalTasks != null && Model.GoalTasks.Any())
                            {
                                @foreach (var gt in Model.GoalTasks.Where(x => x.WorkTask != null))
                                {
                                    <div class="task-option p-3 mb-2 rounded-4 border border-white border-opacity-10 d-flex align-items-center gap-3 bg-dark bg-opacity-25 text-white" 
                                         data-task-id="@gt.WorkTaskId" data-title="@gt.WorkTask.Title">
                                        <div class="task-icon-circle bg-info bg-opacity-25 text-info">
                                            <i class="fas fa-tasks"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-bold">@gt.WorkTask.Title</div>
                                            <div class="small text-white-50">
                                                @Localizer["Status"]: <span class="badge bg-light text-dark fw-normal border">@gt.WorkTask.Status</span>
                                                • @Localizer["Progress"]: @gt.WorkTask.Progress%
                                            </div>
                                        </div>
                                        <div class="selection-indicator text-info">
                                            <i class="far fa-circle select-empty"></i>
                                            <i class="fas fa-check-circle select-checked"></i>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4 bg-dark bg-opacity-25 rounded-4 border border-dashed border-white border-opacity-25">
                                    <i class="fas fa-clipboard-list fa-2x text-white-50 mb-2"></i>
                                    <p class="text-white-50 mb-0">@Localizer["NoLinkedTasksFound"]</p>
                                    <p class="small text-white-50">@Localizer["PleaseAddTasks"]</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Start diving Button -->
                    <button id="btnStartDive" class="btn btn-info btn-lg rounded-pill px-5 py-3 shadow w-100 fw-bold fs-5 text-white btn-glow">
                        <i class="fas fa-water me-2"></i> @(isVi ? "Bắt đầu lặn" : "Start Diving")
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 2: Zen Focus Screen (The Deep Dive) -->
    <div id="zenOverlay" class="zen-overlay d-none">
        <div class="zen-container text-center text-white">
            <div class="mb-4">
                <h1 class="zen-goal-title mb-1 text-info fw-bold">@Model.Title</h1>
                <p id="focusTaskName" class="text-white-50 fs-5 mb-0">
                    <!-- Updated dynamically -->
                </p>
            </div>

            <!-- Timer Circle Display -->
            <div class="timer-circle-container mb-4">
                <!-- Paused Overlay Badge -->
                <div class="paused-watermark d-none" id="pausedWatermark">
                    @(isVi ? "ĐANG TẠM DỪNG" : "PAUSED")
                </div>
                <svg class="timer-ring-svg" width="280" height="280" viewBox="0 0 280 280">
                    <circle class="timer-ring-bg" cx="140" cy="140" r="125" stroke="rgba(255, 255, 255, 0.08)" stroke-width="8" fill="transparent" />
                    <circle class="timer-ring-progress" id="timerProgressCircle" cx="140" cy="140" r="125" stroke="#0dcaf0" stroke-width="8" stroke-linecap="round" fill="transparent" />
                </svg>
                <div class="timer-inner-content">
                    <div class="creature-zen-display" id="creatureZenDisplay">
                        <!-- Loaded dynamically -->
                    </div>
                    <div class="timer-display font-monospace mt-2" id="focusTimerDisplay">00:00:00</div>
                </div>
            </div>

            <!-- Ambient Sound Controller -->
            <div class="ambient-sound-widget mb-4 mx-auto p-2 rounded-pill bg-dark bg-opacity-50 border border-white border-opacity-10" style="max-width: 320px;">
                <div class="d-flex justify-content-between align-items-center px-2">
                    <span class="small text-white-50"><i class="fas fa-volume-up me-1"></i> @(isVi ? "Âm thanh" : "Ambient")</span>
                    <div class="btn-group sound-btn-group" role="group">
                        <button type="button" class="btn btn-sm btn-outline-info active" data-sound="mute">🤫</button>
                        <button type="button" class="btn btn-sm btn-outline-info" data-sound="waves" title="@(isVi ? "Sóng ngầm đại dương" : "Ocean Waves")">🌊</button>
                        <button type="button" class="btn btn-sm btn-outline-info" data-sound="bubbles" title="@(isVi ? "Bong bóng nước" : "Water Bubbles")">🫧</button>
                        <button type="button" class="btn btn-sm btn-outline-info" data-sound="both" title="@(isVi ? "Tất cả" : "Combined")">🔊</button>
                    </div>
                </div>
            </div>

            <!-- Motivational Quotes -->
            <div class="quote-display-container mb-4">
                <p id="motivationalQuote" class="text-white-50 italic fs-6 px-4">
                    @(isVi ? "Hãy tập trung như đại dương sâu thẳm." : "Stay focused like the deep blue ocean.")
                </p>
            </div>

            <!-- Controls Panel -->
            <div class="timer-controls d-flex justify-content-center align-items-center gap-3 mb-4">
                <!-- Play/Pause toggle -->
                <button id="playPauseBtn" class="btn btn-info btn-lg rounded-pill px-4 shadow btn-control text-white">
                    <i class="fas fa-pause me-2"></i> @(isVi ? "Tạm dừng" : "Pause")
                </button>
                <!-- Give up / Stop button -->
                <button id="stopTimerBtn" class="btn btn-danger btn-lg rounded-pill px-4 shadow btn-control">
                    <i class="fas fa-chevron-circle-up me-2"></i> @(isVi ? "Trồi lên (Huỷ)" : "Give Up")
                </button>
            </div>

            <!-- Switches Card -->
            <div class="d-flex justify-content-center gap-3">
                <div class="distraction-blocker-card px-3 py-2 rounded-pill d-flex align-items-center gap-3 shadow bg-dark bg-opacity-50 border border-white border-opacity-10">
                    <div class="form-check form-switch m-0 d-flex align-items-center gap-2">
                        <input class="form-check-input custom-switch" type="checkbox" role="switch" id="strictModeToggle">
                        <label class="form-check-label text-white small fw-semibold" for="strictModeToggle">
                            <i class="fas fa-shield-alt text-info me-1"></i> @Localizer["DistractionBlocker"]
                        </label>
                    </div>
                    <div class="vr bg-white bg-opacity-25"></div>
                    <button id="fullScreenBtn" class="btn btn-sm btn-link text-white text-decoration-none p-0">
                        <i class="fas fa-expand me-1"></i> <span class="small">@(isVi ? "Toàn màn hình" : "Fullscreen")</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 3: My Ocean Aquarium View overlay -->
    <div id="aquariumOverlay" class="aquarium-overlay">
        <!-- Aquarium HUD -->
        <div class="aquarium-hud d-flex justify-content-between align-items-center px-4 py-3">
            <button id="btnCloseAquarium" class="btn btn-outline-light rounded-pill px-4">
                <i class="fas fa-chevron-left me-2"></i> @(isVi ? "Quay lại tập trung" : "Back to Focus")
            </button>
            <h4 class="text-white fw-bold mb-0 text-center"><i class="fas fa-fish me-2 text-info"></i>@(isVi ? "Đại Dương Của Tôi" : "My Personal Ocean")</h4>
            <button id="btnResetAquarium" class="btn btn-outline-danger rounded-pill px-3">
                <i class="fas fa-trash-alt me-1"></i> @(isVi ? "Đặt lại" : "Reset")
            </button>
        </div>

        <!-- Main Aquarium Viewport -->
        <div class="aquarium-viewport" id="aquariumViewport">
            <!-- Aquarium Background Elements -->
            <div class="aquarium-water-glow"></div>
            <div class="aquarium-light-rays"></div>
            <div class="aquarium-bubble-emitter" id="aquariumBubbles"></div>
            <div class="aquarium-seabed">
                <div class="seabed-sand"></div>
                <div class="seabed-seaweed">
                    <svg viewBox="0 0 1200 150" class="aquarium-seaweed-svg" preserveAspectRatio="none">
                        <path d="M80 150 C95 100, 70 50, 95 10 C102 50, 88 100, 110 150 Z" fill="#2d6a4f" opacity="0.6" class="seaweed-1"/>
                        <path d="M180 150 C165 90, 195 50, 180 15 C200 50, 185 90, 205 150 Z" fill="#1b4332" opacity="0.8" class="seaweed-2"/>
                        <path d="M300 150 C325 110, 290 60, 315 20 C328 60, 312 110, 335 150 Z" fill="#40916c" opacity="0.5" class="seaweed-3"/>
                        <path d="M500 150 C480 100, 520 50, 500 15 C520 50, 505 100, 525 150 Z" fill="#2d6a4f" opacity="0.7" class="seaweed-2"/>
                        <path d="M720 150 C745 105, 710 60, 735 15 C748 60, 732 105, 755 150 Z" fill="#40916c" opacity="0.5" class="seaweed-3"/>
                        <path d="M900 150 C880 90, 915 50, 900 20 C920 50, 905 90, 925 150 Z" fill="#1b4332" opacity="0.8" class="seaweed-1"/>
                        <path d="M1080 150 C1105 100, 1070 50, 1095 10 C1108 50, 1092 100, 1115 150 Z" fill="#2d6a4f" opacity="0.6" class="seaweed-2"/>
                    </svg>
                </div>
            </div>

            <!-- Dynamic Creatures Container -->
            <div class="aquarium-creatures-container" id="aquariumCreaturesContainer">
                <!-- Injected via JS -->
            </div>
        </div>

        <!-- Sidebar / Statistics Counter -->
        <div class="aquarium-sidebar p-4 bg-dark bg-opacity-75 border-start border-white border-opacity-10">
            <h5 class="text-white fw-bold border-bottom border-white border-opacity-25 pb-2 mb-3">
                <i class="fas fa-layer-group text-info me-2"></i>@(isVi ? "Bộ Sưu Tập" : "Collection")
            </h5>
            <div class="creature-count-list text-white">
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-white border-opacity-10">
                    <span class="d-flex align-items-center gap-2">🪸 @(isVi ? "San hô hồng" : "Pink Coral")</span>
                    <span class="badge bg-info" id="count-coral">0</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-white border-opacity-10">
                    <span class="d-flex align-items-center gap-2">🐠 @(isVi ? "Cá Nemo" : "Clownfish")</span>
                    <span class="badge bg-info" id="count-clownfish">0</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-white border-opacity-10">
                    <span class="d-flex align-items-center gap-2">🐙 @(isVi ? "Bạch tuộc tím" : "Purple Octopus")</span>
                    <span class="badge bg-info" id="count-octopus">0</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-white border-opacity-10">
                    <span class="d-flex align-items-center gap-2">🐢 @(isVi ? "Rùa biển" : "Sea Turtle")</span>
                    <span class="badge bg-info" id="count-turtle">0</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-white border-opacity-10">
                    <span class="d-flex align-items-center gap-2">🐳 @(isVi ? "Cá voi xanh" : "Blue Whale")</span>
                    <span class="badge bg-info" id="count-whale">0</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2">
                    <span class="d-flex align-items-center gap-2">🚢 @(isVi ? "Tàu cổ chìm" : "Ancient Galleon")</span>
                    <span class="badge bg-info" id="count-ship">0</span>
                </div>
            </div>
            <div class="mt-4 text-center">
                <div class="small text-white-50 mb-2">@(isVi ? "Đại dương của bạn chứa các sinh vật biển đã được nuôi dưỡng thành công sau các phiên tập trung." : "Your ocean displays sea creatures grown successfully after completing focus sessions.")</div>
                <div class="fs-4 text-info fw-bold font-monospace" id="totalCreaturesCounter">0</div>
                <div class="small text-white-50">@(isVi ? "Sinh vật biển" : "Total Creatures")</div>
            </div>
        </div>
    </div>

    <!-- Diving Splash Transition Overlay Screen -->
    <div id="diveTransition" class="dive-transition d-none">
        <div class="dive-transition-content text-center">
            <div class="water-splash">
                <i class="fas fa-water fa-4x text-info"></i>
                <div class="splash-ring"></div>
                <div class="splash-ring delay-1"></div>
                <div class="splash-ring delay-2"></div>
            </div>
            <h3 class="text-white mt-4 fw-bold" id="diveText">@(isVi ? "Đang lặn sâu xuống biển..." : "Diving deep into the ocean...")</h3>
            <p class="text-white-50 small">@(isVi ? "Chuẩn bị dưỡng khí và tập trung..." : "Prepare your oxygen and focus...")</p>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // === FULLSCREEN IMMERSIVE MODE ===
            // Hide layout chrome (sidebar, topbar, pomodoro) for fullscreen immersive focus
            (function initFullscreenMode() {
                const sidebar = document.getElementById('sidebar');
                const topbar = document.querySelector('.topbar');
                const mainContent = document.querySelector('.main-content');
                const mainWrapper = document.querySelector('.main-wrapper');
                const pomodoroBtn = document.getElementById('togglePomodoro');
                const pomodoroWidget = document.getElementById('pomodoroWidget');
                const layoutFooter = document.querySelector('.main-content footer');
                const containerFluid = document.querySelector('.main-content > .container-fluid');

                if (sidebar) sidebar.style.display = 'none';
                if (topbar) topbar.style.display = 'none';
                if (pomodoroBtn) pomodoroBtn.style.display = 'none';
                if (pomodoroWidget) pomodoroWidget.style.display = 'none';
                if (layoutFooter) layoutFooter.style.display = 'none';
                if (mainContent) {
                    mainContent.style.padding = '0';
                    mainContent.style.margin = '0';
                    mainContent.style.overflow = 'hidden';
                    mainContent.style.height = '100vh';
                    mainContent.style.maxHeight = '100vh';
                }
                if (mainWrapper) {
                    mainWrapper.style.height = '100vh';
                    mainWrapper.style.overflow = 'hidden';
                }
                if (containerFluid) {
                    containerFluid.style.padding = '0';
                    containerFluid.style.margin = '0';
                    containerFluid.style.maxWidth = '100%';
                    containerFluid.style.height = '100%';
                }
                document.body.style.overflow = 'hidden';
