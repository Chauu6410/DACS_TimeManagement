                            timer: 2000,
                            showConfirmButton: false,
                            customClass: { popup: 'rounded-5 glass-premium shadow' }
                        });
                    }
                    updateDurationDisplay();
                }
            });

            btnTimePlus.addEventListener('click', () => {
                SoundManager.playPlopSound();
                if (targetDurationMinutes < 180) {
                    targetDurationMinutes += 5;
                    updateDurationDisplay();
                }
            });

            function updateDurationDisplay() {
                selectedTimeDisplay.textContent = `${targetDurationMinutes.toString().padStart(2, '0')}:00`;
                updateCreatureDurationConstraints();
            }

            function updateCreatureDurationConstraints() {
                if (activeMode === 'stopwatch') {
                    durationMatchWarning.innerHTML = isVi 
                        ? `<i class="fas fa-magic me-1"></i> Sinh vật lớn lên dựa trên thời gian thực tập trung của bạn.`
                        : `<i class="fas fa-magic me-1"></i> Companion will grow based on your real focus duration.`;
                    return;
                }

                let highestAffordable = 'coral';
                if (targetDurationMinutes >= 120) highestAffordable = 'ship';
                else if (targetDurationMinutes >= 90) highestAffordable = 'whale';
                else if (targetDurationMinutes >= 60) highestAffordable = 'turtle';
                else if (targetDurationMinutes >= 45) highestAffordable = 'octopus';
                else if (targetDurationMinutes >= 25) highestAffordable = 'clownfish';

                const targetName = CREATURE_NAMES[selectedCreature];
                const activeCard = document.querySelector('.creature-card.selected');
                const reqTime = activeCard ? parseInt(activeCard.dataset.minTime) : 10;

                if (targetDurationMinutes >= reqTime) {
                    durationMatchWarning.innerHTML = isVi 
                        ? `<i class="fas fa-check-circle text-success me-1"></i> Đủ điều kiện nuôi dưỡng: <strong>${targetName}</strong>`
                        : `<i class="fas fa-check-circle text-success me-1"></i> Eligible to grow: <strong>${targetName}</strong>`;
                } else {
                    creatureCards.forEach(c => {
                        c.classList.remove('selected');
                        if (c.dataset.type === highestAffordable) {
                            c.classList.add('selected');
                            selectedCreature = highestAffordable;
                        }
                    });
                    const adjustedName = CREATURE_NAMES[selectedCreature];
                    durationMatchWarning.innerHTML = isVi 
                        ? `<i class="fas fa-exclamation-circle text-warning me-1"></i> Đã chỉnh sinh vật thành: <strong>${adjustedName}</strong> (do thiếu thời gian)`
                        : `<i class="fas fa-exclamation-circle text-warning me-1"></i> Adjusted to: <strong>${adjustedName}</strong> due to duration constraints`;
                }
            }

            // Task list selection logic
            if (isTaskBased) {
                taskOptions.forEach(opt => {
                    opt.addEventListener('click', function() {
                        SoundManager.playPlopSound();
                        taskOptions.forEach(o => {
                            o.classList.remove('active', 'border-info');
                            o.querySelector('.selection-indicator i').className = 'far fa-circle select-empty';
                        });
                        this.classList.add('active', 'border-info');
                        this.querySelector('.selection-indicator i').className = 'fas fa-check-circle select-checked';
                        selectedTaskId = this.dataset.taskId;
                        selectedTaskTitle = this.dataset.title;
                    });
                });
            }

            // --- DIVE / START TRANSITION ---
            btnStartDive.addEventListener('click', () => {
                if (isTaskBased && !selectedTaskId) {
                    Swal.fire({
                        icon: 'warning',
                        title: '@Localizer["TaskRequiredTitle"]',
                        text: '@Localizer["TaskRequiredDescription"]',
                        customClass: { popup: 'rounded-5 glass-premium shadow' }
                    });
                    return;
                }

                SoundManager.playPlopSound();

                // Setup state
                isRunning = false;
                isPaused = false;
                elapsedSeconds = 0;
                if (activeMode === 'countdown') {
                    totalTargetSeconds = targetDurationMinutes * 60;
                } else {
                    totalTargetSeconds = 0;
                }

                // UI setup
                focusTaskName.innerHTML = isTaskBased 
                    ? `🎯 <span class="fw-bold">${selectedTaskTitle}</span> • <span>${isVi ? "Nuôi dưỡng" : "Growing"}: ${CREATURE_NAMES[selectedCreature]}</span>`
                    : `🧘 @Localizer["TrackingFocusTime"] • <span>${isVi ? "Nuôi dưỡng" : "Growing"}: ${CREATURE_NAMES[selectedCreature]}</span>`;

                creatureZenDisplay.innerHTML = CREATURE_SVGS[selectedCreature];
                updateTimerDisplay();

                // Show Splash diving transition
                diveTransition.classList.remove('d-none');
                setTimeout(() => diveTransition.classList.add('show'), 50);

                // Play rapid splash bubble sound
                for (let i = 0; i < 6; i++) {
                    setTimeout(() => SoundManager.playSingleBubble(), i * 150);
                }

                setTimeout(() => {
                    diveTransition.classList.remove('show');
                    setTimeout(() => {
                        diveTransition.classList.add('d-none');
                        
                        // Hide selection screen and show focus overlay
                        selectionScreen.classList.add('d-none');
                        zenOverlay.classList.remove('d-none');
                        zenOverlay.classList.add('d-flex', 'fade-in');
                        
                        // Auto start timer
                        startTimer();
                    }, 500);
                }, 1600);
            });

            // --- TIMER RUNTIME LOGIC ---
            function updateTimerDisplay() {
                let secondsToDisplay = 0;
                if (activeMode === 'countdown') {
                    secondsToDisplay = totalTargetSeconds - elapsedSeconds;
                    if (secondsToDisplay < 0) secondsToDisplay = 0;
                    
                    const progressPercent = (secondsToDisplay / totalTargetSeconds) * 100;
                    setProgress(progressPercent);
                } else {
                    secondsToDisplay = elapsedSeconds;
                    // Stopwatch fills from 0 to 60 seconds to show active seconds ticking
                    const progressPercent = ((elapsedSeconds % 60) / 60) * 100;
                    setProgress(progressPercent);
                }

                const hrs = Math.floor(secondsToDisplay / 3600);
                const mins = Math.floor((secondsToDisplay % 3600) / 60);
                const secs = secondsToDisplay % 60;
                
                focusTimerDisplay.textContent = hrs > 0 
                    ? `${hrs.toString().padStart(2, '0')}:${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`
                    : `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
            }

            function startTimer() {
                if (timerInterval) clearInterval(timerInterval);
                isRunning = true;
                isPaused = false;
                
                // Reset controls
                playPauseBtn.innerHTML = `<i class="fas fa-pause me-2"></i> ${isVi ? "Tạm dừng" : "Pause"}`;
                playPauseBtn.className = "btn btn-info btn-lg rounded-pill px-4 shadow btn-control text-white";
                focusTimerDisplay.classList.remove('timer-paused');
                pausedWatermark.classList.add('d-none');

                // Strict mode visibility check for pause button
                if (strictModeActive) {
                    playPauseBtn.classList.add('d-none');
                } else {
                    playPauseBtn.classList.remove('d-none');
                }

                // Sync audio
                SoundManager.updateSoundState();

                timerInterval = setInterval(() => {
                    if (isRunning) {
                        elapsedSeconds++;
                        updateTimerDisplay();

                        if (activeMode === 'countdown' && elapsedSeconds >= totalTargetSeconds) {
                            completeFocusSession();
                        }
                    }
                }, 1000);

                if (quoteInterval) clearInterval(quoteInterval);
                quoteInterval = setInterval(() => {
                    const rIndex = Math.floor(Math.random() * MOTIVATIONAL_QUOTES.length);
                    motivationalQuote.style.opacity = 0;
                    setTimeout(() => {
                        motivationalQuote.textContent = MOTIVATIONAL_QUOTES[rIndex];
                        motivationalQuote.style.opacity = 1;
                    }, 400);
                }, 15000);
            }

            function pauseTimerInternal() {
                isRunning = false;
                if (timerInterval) {
                    clearInterval(timerInterval);
                    timerInterval = null;
                }
                if (quoteInterval) {
                    clearInterval(quoteInterval);
                    quoteInterval = null;
                }
                SoundManager.stopAll();
            }

            // --- PLAY / PAUSE BUTTON ---
            playPauseBtn.addEventListener('click', () => {
                SoundManager.playPlopSound();
                if (strictModeActive) {
                    Swal.fire({
                        icon: 'warning',
                        title: isVi ? 'Chế độ Nghiêm ngặt' : 'Strict Mode Active',
                        text: isVi ? 'Không thể tạm dừng khi đang ở chế độ Chặn xao nhãng!' : 'You cannot pause while Distraction Blocker is active!',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    return;
                }

                if (isRunning) {
                    // Pause
                    pauseTimerInternal();
                    isPaused = true;
                    playPauseBtn.innerHTML = `<i class="fas fa-play me-2"></i> ${isVi ? "Tiếp tục" : "Resume"}`;
                    playPauseBtn.className = "btn btn-success btn-lg rounded-pill px-4 shadow btn-control text-white";
                    focusTimerDisplay.classList.add('timer-paused');
                    pausedWatermark.classList.remove('d-none');
                } else {
                    // Resume
                    startTimer();
                }
            });

            // --- STOP / GIVE UP SEQUENCE ---
            stopTimerBtn.addEventListener('click', () => {
                SoundManager.playPlopSound();
                const wasRunningBeforePrompt = isRunning;
                pauseTimerInternal();

                // Dynamic sad grey creature SVG
                const greyCreatureSVG = CREATURE_SVGS[selectedCreature]
                    .replace(/fill="#[^"]+"/g, 'fill="#9ca3af"')
                    .replace(/stroke="#[^"]+"/g, 'stroke="#4b5563"')
                    .replace(/filter="[^"]+"/g, 'style="filter: grayscale(1) opacity(0.4);"');

                if (activeMode === 'countdown') {
                    Swal.fire({
                        title: isVi ? 'Từ bỏ lặn sâu?' : 'Give up diving?',
                        html: `<div class="text-center mb-3">
                                 <div style="width:110px; height:110px; margin:0 auto; opacity:0.7;">
                                    ${greyCreatureSVG}
                                 </div>
                                 <p class="mt-3 mb-0">${isVi 
                                     ? `Nếu từ bỏ lúc này, sinh vật biển <strong>${CREATURE_NAMES[selectedCreature]}</strong> của bạn sẽ tan biến! Bạn vẫn muốn trồi lên chứ?`
                                     : `If you give up now, your <strong>${CREATURE_NAMES[selectedCreature]}</strong> will vanish! Do you still want to surface?`}</p>
                               </div>`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: isVi ? 'Từ bỏ' : 'Give up',
                        cancelButtonText: isVi ? 'Tập trung tiếp' : 'Stay Focused',
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        customClass: { popup: 'rounded-5 glass-premium shadow-lg' }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            const actualMins = Math.floor(elapsedSeconds / 60);
                            if (actualMins >= 1) {
                                Swal.fire({
                                    title: isVi ? 'Lưu thời gian tập trung?' : 'Save Focus Time?',
                                    text: isVi 
                                        ? `Bạn đã tập trung được ${actualMins} phút. Bạn có muốn lưu nhật ký công việc này mà không nhận được sinh vật biển?`
                                        : `You focused for ${actualMins} minutes. Would you like to log this time without receiving a creature?`,
                                    icon: 'question',
                                    showCancelButton: true,
                                    confirmButtonText: isVi ? 'Lưu' : 'Save',
                                    cancelButtonText: isVi ? 'Không lưu' : 'Discard',
                                    customClass: { popup: 'rounded-5 glass-premium shadow' }
                                }).then((saveRes) => {
                                    if (saveRes.isConfirmed) {
                                        promptSaveNoteAndRedirect(elapsedSeconds, false);
                                    } else {
                                        exitToSelection();
                                    }
                                });
                            } else {
                                exitToSelection();
                            }
                        } else {
                            // Resume if they canceled the give up prompt
                            if (wasRunningBeforePrompt && !isPaused) {
                                startTimer();
                            } else {
                                // Keep paused state
                                isPaused = true;
                                playPauseBtn.innerHTML = `<i class="fas fa-play me-2"></i> ${isVi ? "Tiếp tục" : "Resume"}`;
                                playPauseBtn.className = "btn btn-success btn-lg rounded-pill px-4 shadow btn-control text-white";
                                focusTimerDisplay.classList.add('timer-paused');
                                pausedWatermark.classList.remove('d-none');
                            }
                        }
                    });
                } else {
                    const actualMins = Math.floor(elapsedSeconds / 60);
                    if (actualMins < 10) {
                        Swal.fire({
                            title: isVi ? 'Dừng tập trung?' : 'Stop Focus?',
                            text: isVi 
                                ? `Thời gian tập trung dưới 10 phút sẽ không đủ để sinh trưởng sinh vật biển. Bạn có muốn lưu lại thời gian này?`
                                : `Focusing under 10 mins is not enough to grow a creature. Do you want to save this log anyway?`,
                            icon: 'question',
                            showCancelButton: true,
                            confirmButtonText: isVi ? 'Lưu thời gian' : 'Save Time',
                            cancelButtonText: isVi ? 'Huỷ & Tập trung tiếp' : 'Cancel & Resume',
                            customClass: { popup: 'rounded-5 glass-premium shadow' }
                        }).then((result) => {
                            if (result.isConfirmed) {
                                promptSaveNoteAndRedirect(elapsedSeconds, false);
                            } else {
                                if (wasRunningBeforePrompt && !isPaused) {
                                    startTimer();
                                } else {
                                    isPaused = true;
                                    playPauseBtn.innerHTML = `<i class="fas fa-play me-2"></i> ${isVi ? "Tiếp tục" : "Resume"}`;
                                    playPauseBtn.className = "btn btn-success btn-lg rounded-pill px-4 shadow btn-control text-white";
                                    focusTimerDisplay.classList.add('timer-paused');
                                    pausedWatermark.classList.remove('d-none');
                                }
                            }
                        });
                    } else {
                        let earnedType = 'coral';
                        if (actualMins >= 120) earnedType = 'ship';
                        else if (actualMins >= 90) earnedType = 'whale';
                        else if (actualMins >= 60) earnedType = 'turtle';
                        else if (actualMins >= 45) earnedType = 'octopus';
                        else if (actualMins >= 25) earnedType = 'clownfish';

                        completeStopwatchSession(elapsedSeconds, earnedType);
                    }
                }
            });

            function exitToSelection() {
                pauseTimerInternal();
                strictModeToggle.checked = false;
                strictModeActive = false;
                isPaused = false;
                
                zenOverlay.classList.add('d-none');
                zenOverlay.classList.remove('d-flex');
                selectionScreen.classList.remove('d-none');
                selectionScreen.classList.add('fade-in');
            }

            // --- COMPLETION HANDLERS ---
            function completeFocusSession() {
                pauseTimerInternal();
                addCreature(selectedCreature);

                Swal.fire({
                    title: isVi ? 'Nuôi dưỡng thành công!' : 'Grow Successful!',
                    html: isVi 
                        ? `<div class="text-center">
                             <div class="glow-animation-container p-3 mb-3 mx-auto" style="width:140px; height:140px;">
                                ${CREATURE_SVGS[selectedCreature]}
                             </div>
                             <p class="fs-5">Tuyệt vời! Bạn đã nuôi dưỡng thành công sinh vật: <strong>${CREATURE_NAMES[selectedCreature]}</strong>!</p>
                           </div>`
                        : `<div class="text-center">
                             <div class="glow-animation-container p-3 mb-3 mx-auto" style="width:140px; height:140px;">
                                ${CREATURE_SVGS[selectedCreature]}
                             </div>
                             <p class="fs-5">Awesome! You successfully grew: <strong>${CREATURE_NAMES[selectedCreature]}</strong>!</p>
                           </div>`,
                    icon: 'success',
                    allowOutsideClick: false,
                    confirmButtonText: isVi ? 'Ghi lại nhật ký' : 'Record Session Log',
                    customClass: { popup: 'rounded-5 glass-premium shadow-lg border border-info' }
                }).then(() => {
                    promptSaveNoteAndRedirect(elapsedSeconds, true);
                });
            }

            function completeStopwatchSession(durationSecs, earnedType) {
                pauseTimerInternal();
                addCreature(earnedType);

                Swal.fire({
                    title: isVi ? 'Tập trung xuất sắc!' : 'Excellent Focus!',
                    html: isVi 
                        ? `<div class="text-center">
                             <div class="glow-animation-container p-3 mb-3 mx-auto" style="width:140px; height:140px;">
                                ${CREATURE_SVGS[earnedType]}
                             </div>
                             <p class="fs-5">Bạn đã tập trung ${Math.floor(durationSecs / 60)} phút và nuôi dưỡng thành công: <strong>${CREATURE_NAMES[earnedType]}</strong>!</p>
                           </div>`
                        : `<div class="text-center">
                             <div class="glow-animation-container p-3 mb-3 mx-auto" style="width:140px; height:140px;">
                                ${CREATURE_SVGS[earnedType]}
                             </div>
                             <p class="fs-5">You focused for ${Math.floor(durationSecs / 60)} minutes and successfully grew: <strong>${CREATURE_NAMES[earnedType]}</strong>!</p>
                           </div>`,
                    icon: 'success',
                    allowOutsideClick: false,
                    confirmButtonText: isVi ? 'Ghi lại nhật ký' : 'Record Session Log',
                    customClass: { popup: 'rounded-5 glass-premium shadow-lg border border-info' }
                }).then(() => {
                    promptSaveNoteAndRedirect(durationSecs, true);
                });
            }

            function promptSaveNoteAndRedirect(durationSecs, hasCreature) {
                const durationStr = formatTime(durationSecs);
                const titleStr = hasCreature 
                    ? (isVi ? `Đã nuôi dưỡng ${CREATURE_NAMES[selectedCreature]}` : `Grew ${CREATURE_NAMES[selectedCreature]}`)
                    : (isVi ? "Tập trung không sinh vật" : "Focus session (No creature)");

                Swal.fire({
                    title: isVi ? 'Ghi chú phiên làm việc' : 'Session Notes',
                    input: 'textarea',
                    inputLabel: isVi ? 'Bạn đã hoàn thành những công việc gì?' : 'What did you accomplish during this session?',
                    inputPlaceholder: isVi ? 'Nhập nội dung công việc thực tế...' : 'Type details of your work...',
                    inputAttributes: {
                        'aria-label': isVi ? 'Nội dung công việc' : 'Work detail input'
                    },
                    confirmButtonText: isVi ? 'Lưu phiên' : 'Save Session',
                    allowOutsideClick: false,
                    preConfirm: (value) => {
                        if (!value.trim()) {
                            Swal.showValidationMessage(isVi ? 'Vui lòng nhập nội dung công việc để ghi nhận.' : 'Please enter a description of your work.');
                        }
                        return value;
                    },
                    customClass: { popup: 'rounded-5 glass-premium shadow-lg border border-info' }
                }).then((res) => {
                    const note = res.value;
                    saveSessionAjax(durationSecs, `[Focus ${durationStr} - ${titleStr}] ${note}`);
                });
            }

            async function saveSessionAjax(durationSecs, finalNote) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const body = new URLSearchParams();
                body.append('goalId', goalId);
                body.append('taskId', selectedTaskId || "");
                body.append('durationSeconds', durationSecs);
                body.append('note', finalNote);
                body.append('__RequestVerificationToken', token);

                Swal.fire({
                    title: '@Localizer["Saving"]',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });

                try {
                    const response = await fetch('/Goal/RecordFocusSession', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: body
                    });
                    const data = await response.json();
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: '@Localizer["SessionSaved"]',
                            text: '@Localizer["SessionSavedDescription"]',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.href = `/Goal/Details/${goalId}`;
                        });
                    } else {
                        throw new Error(data.message || '@Localizer["UnknownError"]');
                    }
                } catch (err) {
                    console.error("AJAX Error:", err);
                    Swal.fire('@Localizer["Error"]', '@Localizer["ErrorSavingSession"]', 'error');
                }
            }

            // --- STRICT MODE & VISIBILITY CHANGE ---
            strictModeToggle.addEventListener('change', function() {
                SoundManager.playPlopSound();
                strictModeActive = this.checked;
                if (strictModeActive) {
                    Swal.fire({
                        title: '@Localizer["StrictModeEnabled"]',
                        text: '@Localizer["DistractionMessage"]',
                        icon: 'info',
                        timer: 2000,
                        showConfirmButton: false,
                        customClass: { popup: 'rounded-5 glass-premium shadow' }
                    });
                }
            });

            document.addEventListener('visibilitychange', () => {
                if (document.hidden && strictModeActive && isRunning) {
                    pauseTimerInternal();
                    Swal.fire({
                        icon: 'error',
                        title: isVi ? 'Thất bại!' : 'Failed!',
                        text: isVi 
                            ? 'Bạn đã rời khỏi trang tập trung trong chế độ Chặn xao nhãng! Sinh vật biển của bạn đã tan biến.'
                            : 'You left the focus page in Strict Mode! Your sea creature has withered.',
                        confirmButtonText: 'OK',
                        customClass: { popup: 'rounded-5 glass-premium shadow-lg border border-danger' }
                    }).then(() => {
                        exitToSelection();
                    });
                }
            });

            window.addEventListener('beforeunload', function(e) {
                if (isRunning) {
                    e.preventDefault();
                    e.returnValue = '';
                }
                SoundManager.stopAll();
            });

            // --- SOUND CONTROLLER EVENTS ---
            const soundButtons = document.querySelectorAll('.sound-btn-group button');
            soundButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    SoundManager.playPlopSound();
                    soundButtons.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    const sound = this.dataset.sound;
                    SoundManager.setMode(sound);
                });
            });

            // --- BACKGROUND BUBBLE SPANNER ---
            function initBubbles(containerId, isBig) {
                const emitter = document.getElementById(containerId);
                if (!emitter) return;

                setInterval(() => {
                    if (document.hidden) return;

                    const bubble = document.createElement('div');
                    bubble.className = isBig ? 'bg-bubble big' : 'bg-bubble';
                    
                    const size = (isBig ? 10 : 5) + Math.random() * 15;
                    bubble.style.width = `${size}px`;
                    bubble.style.height = `${size}px`;
                    bubble.style.left = `${Math.random() * 100}%`;
                    
                    const duration = 6 + Math.random() * 8;
                    bubble.style.animationDuration = `${duration}s`;
                    bubble.style.opacity = 0.2 + Math.random() * 0.4;

                    emitter.appendChild(bubble);

                    setTimeout(() => { bubble.remove(); }, duration * 1000);
                }, 350);
            }
            initBubbles('bgBubbles', false);
            initBubbles('aquariumBubbles', true);

            // --- AQUARIUM OVERLAY CONTROLS ---
            btnOpenAquarium.addEventListener('click', () => {
                SoundManager.playPlopSound();
                aquariumOverlay.classList.add('show');
                renderAquarium();
            });

            btnCloseAquarium.addEventListener('click', () => {
                SoundManager.playPlopSound();
                aquariumOverlay.classList.remove('show');
            });

            btnResetAquarium.addEventListener('click', () => {
                SoundManager.playPlopSound();
                Swal.fire({
                    title: isVi ? 'Đặt lại Đại dương?' : 'Reset Ocean?',
                    text: isVi 
                        ? 'Tất cả sinh vật biển bạn thu hoạch được sẽ bị xóa sạch! Bạn chắc chắn chứ?'
                        : 'All harvested sea creatures will be cleared forever! Are you sure?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: isVi ? 'Xóa sạch' : 'Clear All',
                    cancelButtonText: isVi ? 'Huỷ' : 'Cancel',
                    confirmButtonColor: '#d33',
                    customClass: { popup: 'rounded-5 glass-premium shadow-lg' }
                }).then((res) => {
                    if (res.isConfirmed) {
                        localStorage.removeItem(collectionKey);
                        renderAquarium();
                        Swal.fire({
                            icon: 'success',
                            title: isVi ? 'Đã dọn dẹp!' : 'Cleared!',
                            text: isVi ? 'Đại dương đã được đưa về trạng thái nguyên sơ.' : 'Your ocean has been returned to its pristine state.',
                            timer: 1500,
                            showConfirmButton: false,
                            customClass: { popup: 'rounded-5 glass-premium shadow' }
                        });
                    }
                });
            });

            // --- FULLSCREEN CONTROLS ---
            fullScreenBtn.addEventListener('click', function() {
                SoundManager.playPlopSound();
                if (!document.fullscreenElement) {
                    document.documentElement.requestFullscreen().catch(err => {
                        console.error(`Error attempting to enable full-screen mode: ${err.message}`);
                    });
                } else {
                    document.exitFullscreen();
                }
            });

            document.addEventListener('fullscreenchange', () => {
                if (document.fullscreenElement) {
                    fullScreenBtn.innerHTML = '<i class="fas fa-compress me-1"></i> <span class="small">' + (isVi ? 'Thoát toàn màn hình' : 'Exit Fullscreen') + '</span>';
                } else {
                    fullScreenBtn.innerHTML = '<i class="fas fa-expand me-1"></i> <span class="small">' + (isVi ? 'Toàn màn hình' : 'Fullscreen') + '</span>';
                }
            });
        });
    </script>
}

<style>
    /* CSS Grid/Layout variables for Nox Ocean theme */
    :root {
        --ocean-deep: radial-gradient(circle at center, #0d2b45 0%, #030814 100%);
        --ocean-bright: radial-gradient(circle at center, #1e3d59 0%, #081121 100%);
        --neon-cyan: #0dcaf0;
        --neon-blue: #3b82f6;
        --neon-cyan-glow: 0 0 15px rgba(13, 202, 240, 0.6);
        --neon-blue-glow: 0 0 15px rgba(59, 130, 246, 0.6);
        --glass-bg: rgba(10, 20, 38, 0.55);
        --glass-border: rgba(255, 255, 255, 0.08);
        --focus-primary: #6366f1;
        --focus-primary-light: #818cf8;
        --focus-accent: #0dcaf0;
    }

    /* Core Layout Styles - FULLSCREEN IMMERSIVE */
    .focus-app {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        overflow-y: auto;
        overflow-x: hidden;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: #081121;
        z-index: 50;
    }

    /* Ocean Background Visual Effects */
    .ocean-background {
        position: absolute;
        inset: 0;
        background: var(--ocean-deep);
        z-index: -2;
        overflow: hidden;
    }

    .light-beams {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
