@model DACS_TimeManagement.Models.PersonalGoal
@{
    ViewData["Title"] = "Focus Mode - " + Model.Title;
}

<div id="focusApp" class="focus-app">
    <!-- Step 1: Task Selection -->
    <div id="selectionScreen" class="selection-screen container py-5 @(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? "d-none" : "")">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <div class="glass-premium p-5 rounded-5 shadow-lg">
                    <div class="mb-4">
                        <i class="fas fa-brain fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold">Bắt đầu phiên tập trung</h2>
                        <p class="text-muted">Chọn một nhiệm vụ từ mục tiêu <strong>@Model.Title</strong> để bắt đầu Pomodoro.</p>
                    </div>

                    <div class="task-list-selection text-start mb-5" style="max-height: 400px; overflow-y: auto; padding-right: 10px;">
                        @if (Model.GoalTasks != null && Model.GoalTasks.Any())
                        {
                            @foreach (var gt in Model.GoalTasks.Where(x => x.WorkTask != null))
                            {
                                <div class="task-option p-3 mb-3 rounded-4 border d-flex align-items-center gap-3 bg-white shadow-sm" 
                                     data-task-id="@gt.WorkTaskId" data-title="@gt.WorkTask.Title">
                                    <div class="task-icon-circle">
                                        <i class="fas fa-tasks"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-bold text-dark">@gt.WorkTask.Title</div>
                                        <div class="small text-muted">
                                            Trạng thái: <span class="badge bg-light text-dark fw-normal border">@gt.WorkTask.Status</span>
                                            • Tiến độ: @gt.WorkTask.Progress%
                                        </div>
                                    </div>
                                    <div class="selection-indicator">
                                        <i class="fas fa-check-circle"></i>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4 bg-light rounded-4 border border-dashed">
                                <i class="fas fa-clipboard-list fa-2x text-muted mb-2"></i>
                                <p class="text-muted mb-0">Không tìm thấy công việc nào liên kết.</p>
                                <p class="small text-muted">Vui lòng thêm task vào Project trước khi sử dụng Focus.</p>
                            </div>
                        }
                    </div>

                    <button id="btnEnterZen" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow">
                        <i class="fas fa-bolt me-2"></i> Vào chế độ Zen
                    </button>
                    <div class="mt-3">
                        <a asp-action="Index" class="text-muted text-decoration-none small">Quay lại danh sách</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 2: Zen Mode Overlay -->
    <div id="zenOverlay" class="zen-overlay @(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? "" : "d-none")">
        <div class="zen-content text-center">
            <h1 class="zen-task-title mb-2 text-white"></h1>
            <p class="text-white-50">Đang thực hiện phiên Pomodoro...</p>
        </div>

        <!-- Floating Tomato Widget -->
        <div id="tomatoWidget" class="tomato-widget">
            <div class="tomato-container" id="tomatoTrigger">
                <img src="https://cdn-icons-png.flaticon.com/512/2907/2907214.png" alt="Tomato" class="tomato-img pulse-tomato">
                <div class="timer-bubble" id="timerDisplay">25:00</div>
                <div class="click-hint small text-white-50">Click me</div>
            </div>
            
            <div class="tomato-controls shadow-lg p-3 rounded-4 d-none" id="tomatoMenu">
                <div class="text-center mb-3">
                    <span class="fw-bold d-block mb-1">Phiên làm việc</span>
                    <div class="progress rounded-pill" style="height: 6px;">
                        <div id="timerProgress" class="progress-bar bg-danger" style="width: 100%"></div>
                    </div>
                </div>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex gap-2">
                        <button id="startBtn" class="btn btn-danger btn-sm rounded-pill flex-grow-1"><i class="fas fa-play"></i> Bắt đầu</button>
                        <button id="pauseBtn" class="btn btn-outline-secondary btn-sm rounded-pill d-none flex-grow-1"><i class="fas fa-pause"></i> Tạm dừng</button>
                    </div>
                    <button id="saveBtn" class="btn btn-success btn-sm rounded-pill w-100 shadow-sm" disabled style="opacity: 0.5;"><i class="fas fa-save"></i> Lưu thời gian này</button>
                    <button id="exitZen" class="btn btn-light btn-sm rounded-pill w-100"><i class="fas fa-times"></i> Thoát</button>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const selectionScreen = document.getElementById('selectionScreen');
            const zenOverlay = document.getElementById('zenOverlay');
            const tomatoMenu = document.getElementById('tomatoMenu');
            const tomatoTrigger = document.getElementById('tomatoTrigger');
            const taskOptions = document.querySelectorAll('.task-option');
            const zenTaskTitle = document.querySelector('.zen-task-title');
            
            let selectedTaskId = null;
            let selectedTaskTitle = "@(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? Model.Title : "")";
            let timerInterval = null;
            let timeLeft = 25 * 60; // 25 minutes
            let isRunning = false;
            let sessionStartTime = null;
            let totalElapsedSeconds = 0;
            let sessionSaved = false;
            const initialTime = 25 * 60;

            // Task Selection
            taskOptions.forEach(opt => {
                opt.addEventListener('click', function() {
                    taskOptions.forEach(o => o.classList.remove('active', 'border-primary'));
                    this.classList.add('active', 'border-primary');
                    selectedTaskId = this.dataset.taskId;
                    selectedTaskTitle = this.dataset.title;
                });
            });

            // Enter Zen Mode
            document.getElementById('btnEnterZen').addEventListener('click', function() {
                if ("@Model.Type" === "TaskBased" && !selectedTaskId) {
                     Swal.fire({ icon: 'warning', title: 'Vui lòng chọn một Task', text: 'Mục tiêu dự án yêu cầu bạn chọn task trước khi bắt đầu.' });
                     return;
                }
                
                selectionScreen.classList.add('fade-out');
                setTimeout(() => {
                    selectionScreen.classList.add('d-none');
                    zenOverlay.classList.remove('d-none');
                    zenOverlay.classList.add('fade-in');
                    zenTaskTitle.textContent = selectedTaskTitle || "Tập trung hoàn thành mục tiêu";
                    // Show tomato menu by default in Zen mode
                    tomatoMenu.classList.remove('d-none');
                }, 500);
            });

            // Auto-set title and show menu for personal goals
            if ("@Model.Type" === "TimeBased") {
                zenTaskTitle.textContent = "@Model.Title";
                tomatoMenu.classList.remove('d-none');
            }

            // Tomato Widget Toggle
            tomatoTrigger.addEventListener('click', () => {
                tomatoMenu.classList.toggle('d-none');
            });

            // Timer Logic
            const startBtn = document.getElementById('startBtn');
            const pauseBtn = document.getElementById('pauseBtn');
            const saveBtn = document.getElementById('saveBtn');
            const timerDisplay = document.getElementById('timerDisplay');
            const timerProgressBar = document.getElementById('timerProgress');

            function updateDisplay() {
                const mins = Math.floor(timeLeft / 60);
                const secs = timeLeft % 60;
                timerDisplay.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
                const percent = (timeLeft / (25 * 60)) * 100;
                timerProgressBar.style.width = `${percent}%`;
            }

            function startTimer() {
                if (isRunning || sessionSaved) return;
                isRunning = true;
                
                if (!sessionStartTime) {
                    sessionStartTime = new Date();
                }

                startBtn.classList.add('d-none');
                pauseBtn.classList.remove('d-none');
                saveBtn.disabled = false;
                saveBtn.style.opacity = "1";

                timerInterval = setInterval(() => {
                    timeLeft--;
                    totalElapsedSeconds++;
                    updateDisplay();

                    if (timeLeft <= 0) {
                        clearInterval(timerInterval);
                        completeSession();
                    }
                }, 1000);
            }

            function pauseTimer() {
                isRunning = false;
                clearInterval(timerInterval);
                pauseBtn.classList.add('d-none');
                
                // Show "Tiếp tục" ONLY if we haven't saved yet
                if (!sessionSaved) {
                    startBtn.classList.remove('d-none');
                    startBtn.innerHTML = '<i class="fas fa-play"></i> Tiếp tục';
                }
            }

            async function saveSession() {
                if (sessionSaved) return;

                const elapsedSeconds = initialTime - timeLeft;
                const elapsedHours = elapsedSeconds / 3600;
                const elapsedMins = Math.floor(elapsedSeconds / 60);
                const elapsedSecs = elapsedSeconds % 60;
                
                if (elapsedSeconds < 5) {
                    Swal.fire('Thông báo', 'Bạn cần tập trung ít nhất 5 giây trước khi lưu.', 'info');
                    return;
                }

                // Pause and prepare for save
                isRunning = false;
                clearInterval(timerInterval);
                pauseBtn.classList.add('d-none');
                startBtn.classList.add('d-none');

                const { value: note } = await Swal.fire({
                    title: 'Ghi chú công việc',
                    input: 'textarea',
                    inputLabel: 'Bạn đã hoàn thành những gì?',
                    inputPlaceholder: 'Nhập ghi chú tại đây...',
                    showCancelButton: true,
                    confirmButtonText: 'Lưu kết quả',
                    cancelButtonText: 'Quay lại',
                    inputValidator: (value) => {
                        if (!value) return 'Vui lòng nhập ghi chú công việc!';
                    }
                });

                if (note) {
                    // Block all UI interaction during save
                    sessionSaved = true;
                    saveBtn.disabled = true;
                    saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';
                    document.getElementById('exitZen').disabled = true;
                    document.getElementById('exitZen').style.opacity = "0.5";

                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const body = new URLSearchParams();
                    body.append('goalId', '@Model.Id');
                    body.append('taskId', selectedTaskId || "");
                    body.append('durationHours', elapsedHours.toFixed(4));
                    
                    const finalNote = "@Model.Type" === "TimeBased" 
                        ? `[Focus ${elapsedMins}m ${elapsedSecs}s] ${note}`
                        : note;
                    
                    body.append('note', finalNote);
                    body.append('__RequestVerificationToken', token);

                    try {
                        const response = await fetch('/Goal/RecordFocusSession', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: body
                        });
                        const data = await response.json();
                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Đã lưu!',
                                text: 'Dữ liệu đã được cập nhật thành công.',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => location.href = '/Goal/Index');
                        } else {
                            throw new Error(data.message || 'Lỗi không xác định');
                        }
                    } catch (error) {
                        console.error('Save error:', error);
                        sessionSaved = false;
                        saveBtn.disabled = false;
                        saveBtn.innerHTML = '<i class="fas fa-save"></i> Thử lại';
                        document.getElementById('exitZen').disabled = false;
                        document.getElementById('exitZen').style.opacity = "1";
                        Swal.fire('Lỗi', 'Không thể lưu dữ liệu. Vui lòng thử lại.', 'error');
                    }
                } else {
                    // If cancelled, restore the "Tiếp tục" button
                    if (!sessionSaved) {
                        startBtn.classList.remove('d-none');
                        startBtn.innerHTML = '<i class="fas fa-play"></i> Tiếp tục';
                    }
                }
            }

            async function completeSession() {
                isRunning = false;
                clearInterval(timerInterval);
                sessionSaved = true;
                saveBtn.disabled = true;
                pauseBtn.classList.add('d-none');
                startBtn.classList.add('d-none');
                document.getElementById('exitZen').disabled = true;

                const { value: note } = await Swal.fire({
                    title: 'Hoàn thành Pomodoro!',
                    input: 'textarea',
                    inputLabel: 'Chúc mừng! Bạn đã đạt được gì trong 25 phút qua?',
                    inputPlaceholder: 'Nhập ghi chú tại đây...',
                    confirmButtonText: 'Lưu và Kết thúc',
                    allowOutsideClick: false,
                    inputValidator: (value) => {
                        if (!value) return 'Vui lòng nhập ghi chú để ghi nhận!';
                    }
                });

                if (note) {
                    saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const body = new URLSearchParams();
                    body.append('goalId', '@Model.Id');
                    body.append('taskId', selectedTaskId || "");
                    body.append('durationHours', '0.4167'); // 25 mins
                    
                    const finalNote = "@Model.Type" === "TimeBased" 
                        ? `[Hoàn thành 25m] ${note}`
                        : note;

                    body.append('note', finalNote);
                    body.append('__RequestVerificationToken', token);

                    try {
                        const response = await fetch('/Goal/RecordFocusSession', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: body
                        });
                        const data = await response.json();
                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Tuyệt vời!',
                                text: 'Phiên làm việc đã được lưu thành công.',
                                confirmButtonText: 'Xong'
                            }).then(() => location.href = '/Goal/Index');
                        }
                    } catch (error) {
                        saveBtn.innerHTML = '<i class="fas fa-save"></i> Lỗi';
                        Swal.fire('Lỗi', 'Không thể lưu kết quả.', 'error');
                    }
                }
            }

            startBtn.addEventListener('click', startTimer);
            pauseBtn.addEventListener('click', pauseTimer);
            saveBtn.addEventListener('click', saveSession);
            document.getElementById('exitZen').addEventListener('click', function() {
                if (this.disabled) return;
                
                if (isRunning && !sessionSaved) {
                    Swal.fire({
                        title: 'Dừng phiên tập trung?',
                        text: "Tiến độ hiện tại sẽ bị hủy bỏ.",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Đồng ý thoát',
                        cancelButtonText: 'Tiếp tục'
                    }).then((result) => {
                        if (result.isConfirmed) location.href = '/Goal/Index';
                    });
                } else {
                    location.href = '/Goal/Index';
                }
            });
        });
    </script>
}

<style>
    .focus-app { min-height: 100vh; background: #f8fafc; font-family: 'Inter', sans-serif; overflow-x: hidden; }
    
    .glass-premium { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.5); }
    
    .task-option { cursor: pointer; transition: all 0.2s; border: 1px solid #e2e8f0; position: relative; }
    .task-option:hover { transform: translateX(5px); border-color: #6366f1; }
    .task-option.active { border-color: #6366f1; background: #f5f3ff !important; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.1); }
    .task-icon-circle { width: 45px; height: 45px; border-radius: 14px; background: #f1f5f9; color: #64748b; display: flex; align-items: center; justify-content: center; transition: 0.3s; }
    .task-option.active .task-icon-circle { background: #6366f1; color: white; }
    
    .selection-indicator { font-size: 1.25rem; color: #6366f1; opacity: 0; transition: 0.3s; }
    .task-option.active .selection-indicator { opacity: 1; }

    /* Custom scrollbar for task list */
    .task-list-selection::-webkit-scrollbar { width: 6px; }
    .task-list-selection::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 10px; }
    .task-list-selection::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .task-list-selection::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

    .fade-out { opacity: 0; transform: translateY(-20px); transition: 0.5s; }
    .fade-in { animation: fadeIn 0.8s forwards; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    /* Zen Overlay */
    .zen-overlay { position: fixed; inset: 0; background: #000; z-index: 2000; display: flex; align-items: center; justify-content: center; }
    .zen-content { transition: 0.5s; }
    .zen-task-title { font-size: 3.5rem; font-weight: 800; letter-spacing: -1px; }

    /* Tomato Widget */
    .tomato-widget { position: fixed; bottom: 40px; right: 40px; z-index: 2100; }
    .tomato-container { position: relative; cursor: pointer; transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .tomato-container:hover { transform: scale(1.1); }
    .tomato-img { width: 80px; height: 80px; filter: drop-shadow(0 10px 15px rgba(239, 68, 68, 0.4)); transition: transform 0.3s; }
    
    .pulse-tomato { animation: pulse 2s infinite; }
    @@keyframes pulse { 
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }

    .click-hint { position: absolute; bottom: -20px; left: 50%; transform: translateX(-50%); white-space: nowrap; font-size: 0.7rem; pointer-events: none; }

    .timer-bubble { position: absolute; top: -10px; right: -10px; background: white; color: #ef4444; font-weight: 800; padding: 4px 10px; border-radius: 50px; border: 2px solid #ef4444; font-size: 0.85rem; }
    
    .tomato-controls { position: absolute; bottom: 100px; right: 0; width: 220px; background: white; border: 1px solid #e2e8f0; animation: slideUp 0.3s; z-index: 10; }
    @@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    @@media (max-width: 768px) {
        .zen-task-title { font-size: 2rem; padding: 0 20px; }
        .tomato-widget { bottom: 20px; right: 20px; }
    }
</style>