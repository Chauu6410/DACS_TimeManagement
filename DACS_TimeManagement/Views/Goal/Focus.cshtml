            btnTimeMinus.addEventListener('click', () => {
                SoundManager.playPlopSound();
                if (targetDurationMinutes > 5) {
                    targetDurationMinutes -= 5;
                    const activeCard = document.querySelector('.creature-card.selected');
                    const minTime = activeCard ? parseInt(activeCard.dataset.minTime) : 10;
                    if (targetDurationMinutes < minTime) {
                        targetDurationMinutes = minTime;
                        Swal.fire({
                            icon: 'info',
                            title: isVi ? 'Thời gian tối thiểu' : 'Minimum Duration',
                            text: isVi 
                                ? `Sinh vật đã chọn yêu cầu thời gian tập trung tối thiểu là ${minTime} phút.`
