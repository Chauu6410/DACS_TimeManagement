            // --- AUDIO SYNTHESIS SYSTEM (Web Audio API) ---
            const SoundManager = {
                audioCtx: null,
                oceanNode: null,
                oceanFilter: null,
                oceanLfo: null,
                wavesVolume: null,
                bubbleInterval: null,
                activeMode: 'mute',

                init() {
                    if (this.audioCtx) return;
                    this.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                },

                playPlopSound() {
                    this.init();
                    if (!this.audioCtx) return;
                    try {
                        const osc = this.audioCtx.createOscillator();
                        const gain = this.audioCtx.createGain();
                        osc.type = 'sine';
                        osc.frequency.setValueAtTime(180, this.audioCtx.currentTime);
                        osc.frequency.exponentialRampToValueAtTime(550, this.audioCtx.currentTime + 0.08);
                        
                        gain.gain.setValueAtTime(0.001, this.audioCtx.currentTime);
                        gain.gain.exponentialRampToValueAtTime(0.02, this.audioCtx.currentTime + 0.015);
                        gain.gain.exponentialRampToValueAtTime(0.001, this.audioCtx.currentTime + 0.08);

                        osc.connect(gain);
                        gain.connect(this.audioCtx.destination);
                        osc.start();
                        osc.stop(this.audioCtx.currentTime + 0.08);
                    } catch(e){}
                },

                setMode(mode) {
                    this.activeMode = mode;
                    this.updateSoundState();
                },

                updateSoundState() {
                    if (!isRunning) {
                        this.stopAll();
                        return;
                    }

                    this.init();

                    const shouldPlayWaves = (this.activeMode === 'waves' || this.activeMode === 'both');
                    const shouldPlayBubbles = (this.activeMode === 'bubbles' || this.activeMode === 'both');

                    if (shouldPlayWaves) {
                        this.startWaves();
                    } else {
                        this.stopWaves();
                    }

                    if (shouldPlayBubbles) {
                        this.startBubbles();
                    } else {
                        this.stopBubbles();
                    }
                },

                startWaves() {
                    if (this.oceanNode) return;
                    if (!this.audioCtx) return;

                    try {
                        const bufferSize = 2 * this.audioCtx.sampleRate;
                        const noiseBuffer = this.audioCtx.createBuffer(1, bufferSize, this.audioCtx.sampleRate);
                        const output = noiseBuffer.getChannelData(0);
                        for (let i = 0; i < bufferSize; i++) {
                            output[i] = Math.random() * 2 - 1;
                        }

                        this.oceanNode = this.audioCtx.createBufferSource();
                        this.oceanNode.buffer = noiseBuffer;
                        this.oceanNode.loop = true;

                        this.oceanFilter = this.audioCtx.createBiquadFilter();
                        this.oceanFilter.type = 'lowpass';
                        this.oceanFilter.frequency.setValueAtTime(180, this.audioCtx.currentTime);
                        this.oceanFilter.Q.setValueAtTime(1.5, this.audioCtx.currentTime);

                        this.oceanLfo = this.audioCtx.createOscillator();
                        this.oceanLfo.type = 'sine';
                        this.oceanLfo.frequency.setValueAtTime(0.08, this.audioCtx.currentTime); // 12.5 seconds wave cycle

                        const lfoGain = this.audioCtx.createGain();
                        lfoGain.gain.setValueAtTime(50, this.audioCtx.currentTime);

                        this.oceanLfo.connect(lfoGain);
                        lfoGain.connect(this.oceanFilter.frequency);

                        this.wavesVolume = this.audioCtx.createGain();
                        this.wavesVolume.gain.setValueAtTime(0, this.audioCtx.currentTime);
                        this.wavesVolume.gain.linearRampToValueAtTime(0.15, this.audioCtx.currentTime + 1.0); // 1s Fade-in

                        this.oceanNode.connect(this.oceanFilter);
                        this.oceanFilter.connect(this.wavesVolume);
                        this.wavesVolume.connect(this.audioCtx.destination);

                        this.oceanNode.start(0);
                        this.oceanLfo.start(0);
                    } catch (e) {
                        console.error("Wave synthesis error:", e);
                    }
                },

                stopWaves() {
                    if (this.wavesVolume) {
                        const volumeNode = this.wavesVolume;
                        const node = this.oceanNode;
                        const lfo = this.oceanLfo;
                        try {
                            volumeNode.gain.setValueAtTime(volumeNode.gain.value, this.audioCtx.currentTime);
                            volumeNode.gain.linearRampToValueAtTime(0, this.audioCtx.currentTime + 0.5); // Fade out
                            setTimeout(() => {
                                try { node.stop(); } catch(e){}
                                try { lfo.stop(); } catch(e){}
                            }, 550);
                        } catch(e){}
                        this.oceanNode = null;
                        this.oceanLfo = null;
                        this.wavesVolume = null;
                    }
                    this.oceanFilter = null;
                },

                startBubbles() {
                    if (this.bubbleInterval) return;
                    this.bubbleInterval = setInterval(() => {
                        if (!isRunning || document.hidden) return;
                        if (Math.random() < 0.4) {
                            this.playSingleBubble();
                        }
                    }, 850);
                },

                playSingleBubble() {
                    if (!this.audioCtx) return;
                    try {
                        const osc = this.audioCtx.createOscillator();
                        const gain = this.audioCtx.createGain();
                        osc.type = 'sine';

                        const startFreq = 150 + Math.random() * 80;
                        const endFreq = 600 + Math.random() * 250;
                        const duration = 0.12 + Math.random() * 0.12;

                        osc.frequency.setValueAtTime(startFreq, this.audioCtx.currentTime);
                        osc.frequency.exponentialRampToValueAtTime(endFreq, this.audioCtx.currentTime + duration);

                        gain.gain.setValueAtTime(0.001, this.audioCtx.currentTime);
                        gain.gain.exponentialRampToValueAtTime(0.02, this.audioCtx.currentTime + 0.015);
                        gain.gain.exponentialRampToValueAtTime(0.001, this.audioCtx.currentTime + duration);

                        osc.connect(gain);
                        gain.connect(this.audioCtx.destination);

                        osc.start();
                        osc.stop(this.audioCtx.currentTime + duration);
                    } catch (e) {
                        console.error("Bubble play error:", e);
                    }
                },

                stopBubbles() {
                    if (this.bubbleInterval) {
                        clearInterval(this.bubbleInterval);
                        this.bubbleInterval = null;
                    }
                },

                stopAll() {
                    this.stopWaves();
                    this.stopBubbles();
                }
            };

            // --- DOM ELEMENTS ---
            const selectionScreen = document.getElementById('selectionScreen');
