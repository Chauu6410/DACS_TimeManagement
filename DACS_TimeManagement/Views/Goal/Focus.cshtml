@inject IViewLocalizer Localizer
@model DACS_TimeManagement.Models.PersonalGoal
@{
    ViewData["Title"] = Localizer["FocusMode"] + " - " + Model.Title;
}

<div id="focusApp" class="focus-app">
    <!-- Step 1: Task Selection (only for TaskBased goals) -->
    <div id="selectionScreen" class="selection-screen container py-5 @(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? "d-none" : "")">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <div class="glass-premium p-5 rounded-5 shadow-lg">
                    <div class="mb-4">
                        <i class="fas fa-brain fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold">@Localizer["StartFocusSession"]</h2>
                        <p class="text-muted">@Html.Raw(string.Format(Localizer["SelectTaskFrom"].Value, Model.Title))</p>
                    </div>

                    <div class="task-list-selection text-start mb-5" style="max-height: 400px; overflow-y: auto; padding-right: 10px;">
                        @if (Model.GoalTasks != null && Model.GoalTasks.Any())
                        {
                            @foreach (var gt in Model.GoalTasks.Where(x => x.WorkTask != null))
                            {
                                <div class="task-option p-3 mb-3 rounded-4 border d-flex align-items-center gap-3 bg-white shadow-sm" 
                                     data-task-id="@gt.WorkTaskId" data-title="@gt.WorkTask.Title">
                                    <div class="task-icon-circle">
                                        <i class="fas fa-tasks"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-bold text-dark">@gt.WorkTask.Title</div>
                                        <div class="small text-muted">
                                            @Localizer["Status"]: <span class="badge bg-light text-dark fw-normal border">@gt.WorkTask.Status</span>
                                            • @Localizer["Progress"]: @gt.WorkTask.Progress%
                                        </div>
                                    </div>
                                    <div class="selection-indicator">
                                        <i class="fas fa-check-circle"></i>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4 bg-light rounded-4 border border-dashed">
                                <i class="fas fa-clipboard-list fa-2x text-muted mb-2"></i>
                                <p class="text-muted mb-0">@Localizer["NoLinkedTasksFound"]</p>
                                <p class="small text-muted">@Localizer["PleaseAddTasks"]</p>
                            </div>
                        }
                    </div>

                    <button id="btnEnterZen" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow">
                        <i class="fas fa-bolt me-2"></i> @Localizer["EnterZenMode"]
                    </button>
                    <div class="mt-3">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="text-muted text-decoration-none small">@Localizer["BackToDetails"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 2: Zen Mode Overlay with Theme Support + Stopwatch Timer -->
    <div id="zenOverlay" class="zen-overlay @(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? "d-flex" : "d-none")" 
         style="background-image: url('https://images.unsplash.com/photo-1518837695005-2083093ee35b?w=1600&q=80');">
        
        <!-- Theme Selector Bar -->
        <div class="theme-bar">
            <button class="theme-btn active" data-theme="ocean" data-img="https://images.unsplash.com/photo-1518837695005-2083093ee35b?w=1600&q=80">
                <i class="fas fa-water"></i> @Localizer["SeaFoam"]
            </button>
            <button class="theme-btn" data-theme="ocean-deep" data-img="https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=1600&q=80">
                <i class="fas fa-fish"></i> @Localizer["Ocean"]
            </button>
            <button class="theme-btn" data-theme="forest" data-img="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=1600&q=80">
                <i class="fas fa-tree"></i> @Localizer["Forest"]
            </button>
            <button class="theme-btn" data-theme="clouds" data-img="https://images.unsplash.com/photo-1534088568595-a066f410bcda?w=1600&q=80">
                <i class="fas fa-cloud-sun"></i> @Localizer["Clouds"]
            </button>
            <button class="theme-btn" data-theme="flowers" data-img="https://images.unsplash.com/photo-1490750967868-88aa4486c946?w=1600&q=80">
                <i class="fas fa-seedling"></i> @Localizer["Flowers"]
            </button>
            <button class="theme-btn" data-theme="mountains" data-img="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1600&q=80">
                <i class="fas fa-mountain"></i> @Localizer["Mountains"]
            </button>
        </div>

        <!-- Main Focus Content -->
        <div class="zen-container">
            <div class="text-center mb-4">
                <h1 class="zen-goal-title text-white mb-1">@Model.Title</h1>
                <p id="focusTaskName" class="text-white-50 fs-5">
                    @if (Model.Type == DACS_TimeManagement.Models.GoalType.TaskBased)
                    {<span>@Localizer["SelectATaskToStart"]</span>}
                    else
                    {<span>@Localizer["TrackingFocusTime"]</span>}
                </p>
            </div>

            <div class="timer-panel">
                <div class="timer-display" id="focusTimerDisplay">00:00:00</div>
                
                <div class="timer-controls mb-4">
                    <button id="startTimerBtn" class="btn btn-success btn-lg rounded-pill px-5 shadow">
                        <i class="fas fa-play me-2"></i> @Localizer["Start"]
                    </button>
                    <button id="stopTimerBtn" class="btn btn-warning btn-lg rounded-pill px-5 shadow" disabled>
                        <i class="fas fa-stop me-2"></i> @Localizer["Stop"]
                    </button>
                    <button id="resetTimerBtn" class="btn btn-secondary btn-lg rounded-pill px-4 shadow">
                        <i class="fas fa-undo-alt me-2"></i> @Localizer["Reset"]
                    </button>
                </div>

                <!-- Distraction Blocker Toggle -->
                <div class="d-flex justify-content-center mb-4">
                    <div class="distraction-blocker-card px-4 py-3 rounded-pill d-flex align-items-center gap-3 shadow-sm border border-white border-opacity-25">
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input custom-switch" type="checkbox" role="switch" id="strictModeToggle">
                            <label class="form-check-label text-white fw-semibold" for="strictModeToggle">
                                <i class="fas fa-shield-alt me-1"></i> @Localizer["DistractionBlocker"]
                            </label>
                        </div>
                        <button id="fullScreenBtn" class="btn btn-sm btn-outline-light rounded-pill px-3 border-opacity-50">
                            <i class="fas fa-expand me-1"></i> @Localizer["EnableFullScreen"]
                        </button>
                    </div>
                </div>

                <!-- Note & Save Section (appears after Stop) -->
                <div id="noteSection" class="note-section mt-4" style="display: none;">
                    <div class="glass-card p-4 rounded-4">
                        <label class="form-label text-white fw-bold mb-2">
                            <i class="fas fa-pen-alt me-2"></i> @Localizer["SessionNote"]
                        </label>
                        <textarea id="sessionNote" class="form-control bg-white bg-opacity-25 text-white border-0 rounded-3" rows="3" 
                                  placeholder="@Localizer["WhatDidYouAchieve"]"></textarea>
                        <button id="saveSessionBtn" class="btn btn-primary rounded-pill mt-3 px-5 py-2 w-100 fw-bold" disabled>
                            <i class="fas fa-save me-2"></i> @Localizer["SaveSession"]
                        </button>
                    </div>
                </div>
            </div>

            <button id="exitZenBtn" class="btn btn-outline-light rounded-pill mt-5 px-4 py-2">
                <i class="fas fa-sign-out-alt me-2"></i> @Localizer["ExitFocus"]
            </button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // DOM Elements
            const selectionScreen = document.getElementById('selectionScreen');
            const zenOverlay = document.getElementById('zenOverlay');
            const taskOptions = document.querySelectorAll('.task-option');
            const btnEnterZen = document.getElementById('btnEnterZen');
            const startTimerBtn = document.getElementById('startTimerBtn');
            const stopTimerBtn = document.getElementById('stopTimerBtn');
            const resetTimerBtn = document.getElementById('resetTimerBtn');
            const saveSessionBtn = document.getElementById('saveSessionBtn');
            const exitZenBtn = document.getElementById('exitZenBtn');
            const focusTimerDisplay = document.getElementById('focusTimerDisplay');
            const noteSection = document.getElementById('noteSection');
            const sessionNote = document.getElementById('sessionNote');
            const focusTaskNameSpan = document.getElementById('focusTaskName');
            
            // Theme buttons
            const themeBtns = document.querySelectorAll('.theme-btn');
            
            // Distraction Blocker elements
            const strictModeToggle = document.getElementById('strictModeToggle');
            const fullScreenBtn = document.getElementById('fullScreenBtn');
            
            // State variables
            let selectedTaskId = null;
            let selectedTaskTitle = "";
            let elapsedSeconds = 0;          // Total seconds elapsed
            let timerInterval = null;
            let isRunning = false;
            let sessionSaved = false;
            let isTaskBased = "@Model.Type" === "TaskBased";
            
            // Helper: format HH:MM:SS
            function formatTime(seconds) {
                const hrs = Math.floor(seconds / 3600);
                const mins = Math.floor((seconds % 3600) / 60);
                const secs = seconds % 60;
                return `${hrs.toString().padStart(2, '0')}:${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
            }
            
            function updateTimerDisplay() {
                focusTimerDisplay.textContent = formatTime(elapsedSeconds);
            }
            
            // Stop timer and clear interval
            function stopTimerInternal() {
                if (timerInterval) {
                    clearInterval(timerInterval);
                    timerInterval = null;
                }
                isRunning = false;
            }
            
            // Start counting
            function startTimer() {
                if (sessionSaved) return;
                if (timerInterval) stopTimerInternal();
                isRunning = true;
                timerInterval = setInterval(() => {
                    if (isRunning) {
                        elapsedSeconds++;
                        updateTimerDisplay();
                    }
                }, 1000);
            }
            
            // Reset timer (stop, set to 0, reset UI)
            function resetTimer() {
                if (sessionSaved) {
                    Swal.fire('Thông báo', 'Phiên đã được lưu, không thể đặt lại. Thoát và bắt đầu lại.', 'info');
                    return;
                }
                // Stop if running
                if (isRunning) {
                    stopTimerInternal();
                }
                elapsedSeconds = 0;
                updateTimerDisplay();
                // Reset buttons state
                startTimerBtn.disabled = false;
                stopTimerBtn.disabled = true;
                // Hide note & save section, clear note
                noteSection.style.display = 'none';
                sessionNote.value = '';
                saveSessionBtn.disabled = true;
                // Reset saved flag
                sessionSaved = false;
            }
            
            // Stop action: pause timer, show note section and enable save
            function stopTimer() {
                if (sessionSaved) return;
                if (!isRunning) {
                    Swal.fire('Chú ý', 'Đồng hồ chưa chạy!', 'info');
                    return;
                }
                // Stop timer
                stopTimerInternal();
                // Update buttons
                startTimerBtn.disabled = false;
                stopTimerBtn.disabled = true;
                // Show note section
                noteSection.style.display = 'block';
                // Enable save if at least 1 second
                if (elapsedSeconds >= 1) {
                    saveSessionBtn.disabled = false;
                } else {
                    saveSessionBtn.disabled = true;
                    Swal.fire('Thông báo', 'Vui lòng tập trung ít nhất 1 giây để lưu phiên.', 'warning');
                }
            }
            
            // Save session with note
            async function saveSession() {
                if (sessionSaved) {
                    Swal.fire('Đã lưu', 'Phiên tập trung này đã được lưu trước đó.', 'info');
                    return;
                }
                const note = sessionNote.value.trim();
                if (!note) {
                    Swal.fire('Thiếu ghi chú', 'Vui lòng nhập ghi chú về những gì bạn đã đạt được.', 'warning');
                    return;
                }
                if (elapsedSeconds < 1) {
                    Swal.fire('Lỗi', 'Không thể lưu phiên trống.', 'error');
                    return;
                }
                
                // Prepare data
                const durationHours = elapsedSeconds / 3600;
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const body = new URLSearchParams();
                body.append('goalId', '@Model.Id');
                body.append('taskId', selectedTaskId || "");
                body.append('durationSeconds', elapsedSeconds);
                // Append note with optional duration summary
                const durationStr = formatTime(elapsedSeconds);
                const finalNote = `[Focus ${durationStr}] ${note}`;
                body.append('note', finalNote);
                body.append('__RequestVerificationToken', token);
                
                // Show loading
                saveSessionBtn.disabled = true;
                saveSessionBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';
                
                try {
                    const response = await fetch('/Goal/RecordFocusSession', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: body
                    });
                    const data = await response.json();
                    if (data.success) {
                        sessionSaved = true;
                        // Disable all timer controls after save
                        startTimerBtn.disabled = true;
                        stopTimerBtn.disabled = true;
                        resetTimerBtn.disabled = true;
                        saveSessionBtn.disabled = true;
                        exitZenBtn.disabled = false;
                        Swal.fire({
                            icon: 'success',
                            title: '@Localizer["SessionSaved"]',
                            text: '@Localizer["SessionSavedDescription"]',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.href = '/Goal/Details/@Model.Id';
                        });
                    } else {
                        throw new Error(data.message || '@Localizer["UnknownError"]');
                    }
                } catch (error) {
                    console.error('Save error:', error);
                    saveSessionBtn.disabled = false;
                    saveSessionBtn.innerHTML = '<i class="fas fa-save me-2"></i> @Localizer["SaveSession"]';
                    Swal.fire('@Localizer["Error"]', '@Localizer["ErrorSavingSession"]', 'error');
                }
            }
            
            // Exit with confirmation
            function exitFocus() {
                if (sessionSaved) {
                    window.location.href = '/Goal/Details/@Model.Id';
                    return;
                }
                let warningMsg = '@Localizer["ExitWarning"]';
                if (elapsedSeconds > 0 && !sessionSaved) {
                    Swal.fire({
                        title: '@Localizer["ExitSessionTitle"]',
                        text: warningMsg,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: '@Localizer["Exit"]',
                        cancelButtonText: '@Localizer["Stay"]'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = '/Goal/Details/@Model.Id';
                        }
                    });
                } else {
                    window.location.href = '/Goal/Details/@Model.Id';
                }
            }
            
            // --- Task selection logic (for TaskBased) ---
            if (isTaskBased) {
                taskOptions.forEach(opt => {
                    opt.addEventListener('click', function() {
                        taskOptions.forEach(o => o.classList.remove('active', 'border-primary'));
                        this.classList.add('active', 'border-primary');
                        selectedTaskId = this.dataset.taskId;
                        selectedTaskTitle = this.dataset.title;
                    });
                });
                
                btnEnterZen.addEventListener('click', function() {
                    if (!selectedTaskId) {
                        Swal.fire({
                            icon: 'warning',
                            title: '@Localizer["TaskRequiredTitle"]',
                            text: '@Localizer["TaskRequiredDescription"]'
                        });
                        return;
                    }
                    // Update task name in zen mode
                    focusTaskNameSpan.innerHTML = `<span class="fw-bold">🎯 ${selectedTaskTitle}</span>`;
                    // Hide selection screen with animation
                    selectionScreen.classList.add('fade-out');
                    setTimeout(() => {
                        selectionScreen.classList.add('d-none');
                        zenOverlay.classList.remove('d-none');
                        zenOverlay.classList.add('d-flex', 'fade-in');
                        // Reset timer state before session start
                        resetTimer();
                    }, 500);
                });
            } else {
                // TimeBased: directly show zen overlay, no need task selection
                // But still we might allow optional task selection? Not required.
                selectedTaskId = null;
                selectedTaskTitle = "@Model.Title";
                focusTaskNameSpan.innerHTML = `<span>🧘 @Localizer["TrackingFocusTime"]</span>`;
                resetTimer();
            }
            
            // Auto initial reset for TimeBased
            if (!isTaskBased) {
                resetTimer();
            }
            
            // --- Theme switching ---
            themeBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    const imgUrl = this.dataset.img;
                    if (imgUrl) {
                        zenOverlay.style.backgroundImage = `url('${imgUrl}')`;
                    }
                    // Update active state
                    themeBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                });
            });
            
            // --- Distraction Blocker Logic ---
            let strictModeActive = false;
            
            strictModeToggle.addEventListener('change', function() {
                strictModeActive = this.checked;
                if (strictModeActive) {
                    Swal.fire({
                        title: '@Localizer["StrictModeEnabled"]',
                        text: '@Localizer["DistractionMessage"]',
                        icon: 'info',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            });

            // Detect tab visibility change
            document.addEventListener('visibilitychange', function() {
                if (document.hidden && strictModeActive && isRunning) {
                    // When user leaves the tab
                    console.warn("Distraction detected!");
                } else if (!document.hidden && strictModeActive && isRunning) {
                    // When user comes back
                    Swal.fire({
                        title: '@Localizer["DistractionWarning"]',
                        text: '@Localizer["DistractionMessage"]',
                        icon: 'warning',
                        confirmButtonText: 'OK',
                        customClass: { popup: 'rounded-4 shadow-lg' }
                    });
                }
            });

            // Full Screen Logic
            fullScreenBtn.addEventListener('click', function() {
                if (!document.fullscreenElement) {
                    document.documentElement.requestFullscreen().catch(err => {
                        console.error(`Error attempting to enable full-screen mode: ${err.message}`);
                    });
                } else {
                    document.exitFullscreen();
                }
            });

            document.addEventListener('fullscreenchange', () => {
                if (document.fullscreenElement) {
                    fullScreenBtn.innerHTML = '<i class="fas fa-compress me-1"></i> Exit Full Screen';
                } else {
                    fullScreenBtn.innerHTML = '<i class="fas fa-expand me-1"></i> @Localizer["EnableFullScreen"]';
                }
            });

            // --- Timer event handlers ---
            startTimerBtn.addEventListener('click', () => {
                if (sessionSaved) {
                    Swal.fire('@Localizer["Saved"]', '@Localizer["SessionAlreadySaved"]', 'info');
                    return;
                }
                if (!isRunning) {
                    startTimer();
                    startTimerBtn.disabled = true;
                    stopTimerBtn.disabled = false;
                    
                    // Auto-enable strict mode if not already (optional recommendation)
                    // strictModeToggle.checked = true;
                    // strictModeActive = true;

                    // Hide note section if visible during restart
                    if (noteSection.style.display === 'block') {
                        noteSection.style.display = 'none';
                        sessionNote.value = '';
                        saveSessionBtn.disabled = true;
                    }
                }
            });
            
            stopTimerBtn.addEventListener('click', stopTimer);
            resetTimerBtn.addEventListener('click', resetTimer);
            saveSessionBtn.addEventListener('click', saveSession);
            exitZenBtn.addEventListener('click', exitFocus);
            
            // Prevent leaving tab if timer is running
            window.addEventListener('beforeunload', function(e) {
                if (isRunning || (strictModeActive && elapsedSeconds > 0)) {
                    e.preventDefault();
                    e.returnValue = ''; // Shows standard browser confirmation
                }
                if (timerInterval) clearInterval(timerInterval);
            });
        });
    </script>
}

<style>
    /* Base Styles */
    .focus-app {
        min-height: 100vh;
        background: #0f172a;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }
    
    .glass-premium {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.5);
    }
    
    /* Task Selection Styles */
    .task-option {
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid #e2e8f0;
        position: relative;
    }
    .task-option:hover {
        transform: translateX(5px);
        border-color: #6366f1;
    }
    .task-option.active {
        border-color: #6366f1;
        background: #f5f3ff !important;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.1);
    }
    .task-icon-circle {
        width: 45px;
        height: 45px;
        border-radius: 14px;
        background: #f1f5f9;
        color: #64748b;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
    }
    .task-option.active .task-icon-circle {
        background: #6366f1;
        color: white;
    }
    .selection-indicator {
        font-size: 1.25rem;
        color: #6366f1;
        opacity: 0;
        transition: 0.3s;
    }
    .task-option.active .selection-indicator {
        opacity: 1;
    }
    
    .fade-out {
        opacity: 0;
        transform: translateY(-20px);
        transition: 0.5s ease;
    }
    .fade-in {
        animation: fadeIn 0.8s forwards;
    }
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    
    /* Zen Overlay Main Background */
    .zen-overlay {
        position: fixed;
        inset: 0;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 2000;
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: background-image 0.4s ease;
    }
    .zen-overlay::before {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        backdrop-filter: blur(3px);
        z-index: 1;
    }
    .zen-overlay > * {
        z-index: 2;
    }
    
    /* Theme Bar */
    .theme-bar {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 12px;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(12px);
        padding: 10px 20px;
        border-radius: 60px;
        z-index: 2100;
        border: 1px solid rgba(255,255,255,0.2);
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }
    .theme-btn {
        background: transparent;
        border: none;
        color: white;
        font-weight: 500;
        font-size: 0.9rem;
        padding: 6px 16px;
        border-radius: 40px;
        transition: all 0.2s;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .theme-btn i {
        font-size: 1rem;
    }
    .theme-btn:hover {
        background: rgba(255,255,255,0.2);
        transform: translateY(-2px);
    }
    .theme-btn.active {
        background: white;
        color: #0f172a;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
    
    /* Zen Container */
    .zen-container {
        text-align: center;
        max-width: 700px;
        width: 90%;
        padding: 2rem;
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(16px);
        border-radius: 56px;
        border: 1px solid rgba(255,255,255,0.2);
        box-shadow: 0 25px 40px rgba(0,0,0,0.3);
        animation: scaleUp 0.5s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }
    @@keyframes scaleUp {
        from { transform: scale(0.95); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
    
    .zen-goal-title {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        text-shadow: 0 2px 10px rgba(0,0,0,0.3);
    }
    
    /* Timer Panel */
    .timer-panel {
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(8px);
        border-radius: 48px;
        padding: 2rem 1.5rem;
        margin-top: 1rem;
    }

    .distraction-blocker-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
