@model DACS_TimeManagement.Models.PersonalGoal
@{
    ViewData["Title"] = "Chỉnh sửa mục tiêu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-premium p-5 rounded-5 shadow-lg border-0">
                <div class="text-center mb-5">
                    <div class="icon-circle-lg bg-primary-gradient text-white mb-3 shadow-glow">
                        <i class="fas fa-edit"></i>
                    </div>
                    <h2 class="fw-bold text-dark">Chỉnh sửa mục tiêu</h2>
                    <p class="text-muted">Cập nhật thông tin và điều chỉnh kế hoạch của bạn.</p>
                </div>

                <form asp-action="Edit" id="editGoalForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 border-0 shadow-sm mb-4" role="alert"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Type" />
                    <input type="hidden" asp-for="ProjectId" />
                    <input type="hidden" asp-for="TargetValue" />
                    <input type="hidden" asp-for="CurrentValue" />
                    <input type="hidden" asp-for="Status" />

                    <div class="row g-4">
                        <!-- Goal Title -->
                        <div class="col-12">
                            <label asp-for="Title" class="form-label-custom">Tên mục tiêu <span class="text-danger">*</span></label>
                            <div class="input-group-custom">
                                <i class="fas fa-bullseye input-icon"></i>
                                <input asp-for="Title" class="form-control-custom" placeholder="Ví dụ: Hoàn thành khóa học MVC" required />
                            </div>
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            <label asp-for="Description" class="form-label-custom">Mô tả (Không bắt buộc)</label>
                            <div class="input-group-custom align-items-start">
                                <i class="fas fa-align-left input-icon mt-3"></i>
                                <textarea asp-for="Description" class="form-control-custom" rows="3" placeholder="Chi tiết mục tiêu..."></textarea>
                            </div>
                        </div>

                        <!-- Target Date -->
                        <div class="col-12">
                            <label asp-for="TargetDate" class="form-label-custom">Ngày hoàn thành mong muốn <span class="text-danger">*</span></label>
                            <div class="input-group-custom">
                                <i class="fas fa-calendar-day input-icon"></i>
                                <input asp-for="TargetDate" type="date" class="form-control-custom" required />
                            </div>
                            <span asp-validation-for="TargetDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-5">
                        <a asp-action="Index" class="btn btn-light-custom flex-grow-1 py-3 rounded-4 fw-bold">
                            <i class="fas fa-arrow-left me-2"></i>Hủy
                        </a>
                        <button type="submit" class="btn btn-primary-gradient flex-grow-1 py-3 rounded-4 fw-bold shadow-glow">
                            <i class="fas fa-save me-2"></i>Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.8);
        --glass-border: rgba(255, 255, 255, 0.4);
        --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
    }

    body {
        background: #f1f5f9;
        background-image: radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.05) 0px, transparent 50%), 
                          radial-gradient(at 100% 100%, rgba(168, 85, 247, 0.05) 0px, transparent 50%);
    }

    .glass-premium {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
    }

    .icon-circle-lg {
        width: 72px; height: 72px; border-radius: 24px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; margin: 0 auto;
    }

    .bg-primary-gradient { background: var(--primary-gradient); }
    .shadow-glow { box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.4); }

    .form-label-custom { font-weight: 700; font-size: 0.85rem; color: #475569; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.75rem; display: block; }

    .input-group-custom { position: relative; margin-bottom: 0.5rem; display: flex; align-items: center; }
    .input-icon { position: absolute; left: 1.25rem; color: #94a3b8; font-size: 1.1rem; z-index: 10; }
    .form-control-custom {
        width: 100%; padding: 0.85rem 1.25rem 0.85rem 3.25rem;
        background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px;
        color: #1e293b; font-weight: 500; transition: all 0.3s;
    }
    .form-control-custom:focus {
        background: white; border-color: #6366f1; outline: none;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }
    
    textarea.form-control-custom { padding-left: 3.25rem; }

    .btn-primary-gradient { background: var(--primary-gradient); border: none; color: white; transition: all 0.3s; }
    .btn-primary-gradient:hover { transform: translateY(-2px); opacity: 0.95; color: white; }

    .btn-light-custom { background: #f1f5f9; border: 1px solid #e2e8f0; color: #475569; transition: all 0.3s; }
    .btn-light-custom:hover { background: #e2e8f0; color: #1e293b; }

    @@media (max-width: 768px) { .p-5 { padding: 2rem !important; } }
</style>