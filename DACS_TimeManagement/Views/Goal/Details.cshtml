@using DACS_TimeManagement.DTOs
@model DACS_TimeManagement.Models.PersonalGoal
@{
    ViewData["Title"] = "Goal Details";
}

<div class="container py-4">
    <div class="row g-4">
        <!-- Main Column -->
        <div class="col-lg-8">
            <div class="card glass p-4 rounded-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h1 class="fw-bold">@Model.Title</h1>
                        <div class="d-flex gap-2 mt-2">
                            <span class="status-badge @Model.Status.ToString().ToLower()">@Model.Status</span>
                            <span class="text-muted"><i class="far fa-calendar"></i> Due @Model.TargetDate.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                    @if (Model.Type != DACS_TimeManagement.Models.GoalType.TaskBased)
                    {
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-outline-custom"><i class="fas fa-edit"></i> Edit</a>
                            <a asp-action="Focus" asp-route-id="@Model.Id" class="btn-primary-custom"><i class="fas fa-stopwatch"></i> Focus</a>
                        </div>
                    }
                </div>

                <!-- Progress Section -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">Overall Progress</span>
                        <span class="fw-bold" id="pctLarge">0%</span>
                    </div>
                    <div class="progress-bar-large mt-1">
                        <div id="mainProgress" class="progress-fill" style="width:0%"></div>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="stat-mini glass text-center p-3">
                            <div class="stat-mini-icon text-primary"><i class="fas fa-chart-simple"></i></div>
                            <h4 class="mb-0">@((Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased) ? (Model.CompletedHours < (1.0/60.0) ? (Math.Round(Model.CompletedHours * 3600)) + "s" : (Model.CompletedHours < 1 ? (Math.Round(Model.CompletedHours * 60)) + "m" : Model.CompletedHours.ToString("0.##") + "h")) : Model.CompletedTasks.ToString())</h4>
                            <small class="text-muted">Completed</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-mini glass text-center p-3">
                            <div class="stat-mini-icon text-info"><i class="fas fa-bullseye"></i></div>
                            <h4 class="mb-0">@((Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased) ? (Model.TargetHours?.ToString("0.##") + "h") : (Model.TargetTasks?.ToString() ?? "-"))</h4>
                            <small class="text-muted">Target</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-mini glass text-center p-3">
                            <div class="stat-mini-icon text-warning"><i class="fas fa-fire"></i></div>
                            <h4 class="mb-0">@Model.CurrentStreak</h4>
                            <small class="text-muted">Streak</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-mini glass text-center p-3">
                            @{
                                var daysLeft = (Model.TargetDate.Date - DateTime.Now.Date).Days;
                            }
                            <div class="stat-mini-icon text-danger"><i class="fas fa-clock"></i></div>
                            <h4 class="mb-0 @(daysLeft < 0 ? "text-danger" : "")">@(daysLeft < 0 ? "Overdue" : daysLeft + "d")</h4>
                            <small class="text-muted">Left</small>
                        </div>
                    </div>
                </div>

                <!-- AI Strategy Section -->
                <div class="mb-5">
                    <div class="glass p-4 rounded-4 border-start border-4 border-primary">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0"><i class="fas fa-robot text-primary me-2"></i>AI Action Plan</h5>
                            <button class="btn btn-sm btn-light rounded-pill regenerate-ai-btn" data-goal-id="@Model.Id">
                                <i class="fas fa-sync-alt me-1"></i> Update
                            </button>
                        </div>
                        <div class="ai-strategy-content small text-dark" id="aiContent-@Model.Id">
                            @if (!string.IsNullOrEmpty(Model.AIActionPlan))
                            {
                                @Html.Raw(Model.AIActionPlan.Replace("\n", "<br/>"))
                            }
                            else
                            {
                                <span class="text-muted italic">No strategy generated yet. Click update to analyze your goal.</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Chart -->
                <div class="mb-5">
                    <h5 class="fw-semibold"><i class="fas fa-chart-line me-2"></i>Progress History</h5>
                    <div class="chart-container">
                        <canvas id="progressChart" height="200"></canvas>
                    </div>
                </div>

                <!-- Time History -->
                <div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box-history">
                                <i class="fas fa-history"></i>
                            </div>
                            <div class="lh-1">
                                <h4 class="fw-bold mb-0" style="color: #1e293b;">Time</h4>
                                <h4 class="fw-bold mb-0" style="color: #1e293b;">History</h4>
                            </div>
                        </div>
                        @{
                            var totalLogged = (double)(ViewBag.TotalLogged ?? 0.0);
                        }
                        @if (totalLogged > 0)
                        {
                            <div class="badge-total-history">
                                @totalLogged.ToString("0.##") hrs total
                            </div>
                        }
                    </div>

                    <div class="time-history-list">
                        @{
                            var now = DateTime.UtcNow;
                            var allHistory = ViewBag.AllHistory as IEnumerable<GoalHistoryItemDto> ?? Enumerable.Empty<GoalHistoryItemDto>();
                        }
                        @foreach(var item in allHistory)
                        {
                            var isJustNow = (now - item.Date).TotalMinutes < 1;
                            <div class="timeline-item p-3 position-relative">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="fw-bold text-dark" style="font-size: 1.1rem;">
                                            @if (item.Duration != null && item.Duration.Value > 0)
                                            {
                                                var totalSecs = (int)Math.Round(item.Duration.Value * 3600);
                                                var h = totalSecs / 3600;
                                                var m = (totalSecs % 3600) / 60;
                                                var s = totalSecs % 60;
                                                
                                                if (h > 0) {
                                                    @:@h.ToString()h @m.ToString()m
                                                } else if (m > 0) {
                                                    @:@m.ToString()m @s.ToString()s
                                                } else {
                                                    @:@s.ToString()s
                                                }
                                            }
                                            else
                                            {
                                                @:(Session)
                                            }
                                        </span>
                                        @if (item.Type != "Goal Focus")
                                        {
                                            <span class="text-primary-dark fw-bold ms-2" style="font-size: 0.9rem;">— @item.Title</span>
                                        }
                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="text-muted opacity-75 small">
                                            @(isJustNow ? "Just now" : item.Date.ToString("MMM dd, HH:mm"))
                                        </div>
                                        <div class="timeline-actions transition-all">
                                            <button class="delete-history-btn" data-id="@item.Id" data-type="@item.Type" title="Delete record">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(item.Note))
                                {
                                    var displayNote = item.Note;
                                    if (displayNote.Contains("]") && displayNote.IndexOf("]") < 30) 
                                    {
                                        displayNote = displayNote.Substring(displayNote.IndexOf("]") + 1).Trim();
                                    }
                                    if (!string.IsNullOrEmpty(displayNote))
                                    {
                                        <div class="text-muted fst-italic ms-4 ps-1 opacity-75" style="font-size: 0.95rem;">"@displayNote"</div>
                                    }
                                }

                            </div>
                        }
                        @if (!allHistory.Any())
                        {
                            <div class="text-muted text-center p-4">No focus sessions recorded yet.</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card glass p-4 rounded-4 sticky-top" style="top: 1rem;">
                <h5 class="fw-semibold"><i class="fas fa-bolt me-2"></i>Quick Actions</h5>
                <div class="d-grid gap-2 mt-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-outline-custom">Edit Goal</a>
                    <a asp-action="Focus" asp-route-id="@Model.Id" class="btn-primary-custom">Enter Focus Mode</a>
                    <button class="btn-danger-custom delete-goal-btn" data-id="@Model.Id" data-name="@Model.Title">Delete Goal</button>
                </div>
                <hr class="my-3">
                <h5 class="fw-semibold"><i class="fas fa-chart-simple me-2"></i>Insights</h5>
                <ul class="list-unstyled small">
                    <li class="d-flex justify-content-between mb-2"><span>Created</span><strong>@Model.CreatedAt.ToString("dd MMM yyyy")</strong></li>
                    <li class="d-flex justify-content-between mb-2"><span>Last updated</span><strong>@(Model.UpdatedAt?.ToString("dd MMM yyyy") ?? "-")</strong></li>
                    <li class="d-flex justify-content-between mb-2"><span>Target date</span><strong>@Model.TargetDate.ToString("dd MMM yyyy")</strong></li>
                    <li class="d-flex justify-content-between"><span>Goal type</span><strong>@Model.Type</strong></li>
                </ul>
                <div class="alert alert-info mt-3 small">
                    <i class="fas fa-lightbulb"></i> Complete tasks daily to maintain your streak.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            loadProgressChart();
            updateProgressDisplays();

            // AI Regeneration
            document.querySelectorAll('.regenerate-ai-btn').forEach(btn => {
                btn.addEventListener('click', async function() {
                    const goalId = this.dataset.goalId;
                    const contentDiv = document.getElementById(`aiContent-${goalId}`);
                    
                    this.classList.add('fa-spin');
                    contentDiv.innerHTML = '<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary"></div> Analyzing...</div>';

                    try {
                        const response = await fetch(`/Goal/RegenerateAIStrategy?goalId=${goalId}`, { method: 'POST' });
                        const data = await response.json();
                        if (data.success) {
                            contentDiv.innerHTML = data.newStrategy.replace(/\n/g, '<br/>');
                        } else {
                            Swal.fire('Error', 'Failed to regenerate AI strategy.', 'error');
                        }
                    } catch (e) {
                        contentDiv.innerHTML = '<span class="text-danger">Error connecting to AI service.</span>';
                    } finally {
                        this.classList.remove('fa-spin');
                    }
                });
            });

            // Delete Goal
            document.querySelector('.delete-goal-btn')?.addEventListener('click', function() {
                const id = this.dataset.id;
                const name = this.dataset.name;
                Swal.fire({
                    title: 'Delete Goal?',
                    text: `Are you sure you want to delete "${name}"?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    confirmButtonText: 'Yes, delete'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const form = document.createElement('form');
                        form.method = 'POST';
                        form.action = '/Goal/Delete/' + id;
                        const token = document.querySelector('input[name="__RequestVerificationToken"]');
                        if (token) form.appendChild(token.cloneNode(true));
                        document.body.appendChild(form);
                        form.submit();
                    }
                });
            });

            // Delete History Log
            document.querySelectorAll('.delete-history-btn').forEach(btn => {
                btn.addEventListener('click', async function(e) {
                    e.preventDefault();
                    const id = this.dataset.id;
                    const type = this.dataset.type;
                    
                    const result = await Swal.fire({
                        title: 'Delete History Entry?',
                        text: "This action cannot be undone.",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        confirmButtonText: 'Yes, delete'
                    });

                    if (result.isConfirmed) {
                        const url = type === 'Goal Focus' ? `/Goal/DeleteHistory/${id}` : `/TimeLog/DeleteLog/${id}`;
                        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                        
                        try {
                            const response = await fetch(url, {
                                method: 'POST',
                                headers: {
                                    'X-Requested-With': 'XMLHttpRequest',
                                    'RequestVerificationToken': token
                                }
                            });
                            const data = await response.json();
                            if (data.success) {
                                this.closest('.timeline-item').classList.add('fade-out-item');
                                setTimeout(() => location.reload(), 400);
                            }
                        } catch (err) {
                            Swal.fire('Error', 'Failed to delete history entry.', 'error');
                        }
                    }
                });
            });
        });

        function updateProgressDisplays() {
            const completed = @(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? Model.CompletedHours : Model.CompletedTasks);
            const target = @(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? (Model.TargetHours ?? 0) : (Model.TargetTasks ?? 0));
            const pct = target > 0 ? Math.round((completed / target) * 100) : 0;
            
            const fill = document.getElementById('mainProgress');
            const label = document.getElementById('pctLarge');
            if (fill) fill.style.width = pct + '%';
            if (label) label.innerText = pct + '%';
        }

        async function loadProgressChart() {
            const res = await fetch(`/Goal/GetGoalHistory/@Model.Id`);
            const data = await res.json();
            
            const ctx = document.getElementById('progressChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.map(d => d.date),
                    datasets: [{
                        label: 'Progress %',
                        data: data.map(d => d.progress),
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99, 102, 241, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { min: 0, max: 100, ticks: { callback: value => value + '%' } }
                    }
                }
            });
        }
    </script>
}

<style>
    .glass { background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); border-radius: 24px; border: 1px solid rgba(255,255,255,0.8); box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .progress-bar-large { background: #f1f5f9; border-radius: 50px; height: 14px; overflow: hidden; }
    .progress-fill { background: linear-gradient(90deg, #6366f1, #a855f7); height: 100%; transition: width 0.8s cubic-bezier(0.34, 1.56, 0.64, 1); }
    
    .stat-mini { border-radius: 20px; transition: all 0.3s ease; border: 1px solid rgba(0,0,0,0.05); background: white; }
    .stat-mini:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
    .stat-mini-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
    
    .ai-strategy-content { line-height: 1.6; color: #334155; }
    .task-item { transition: all 0.2s; border: 1px solid transparent; }
    .task-item:hover { background: #f8fafc; border-color: #6366f1; transform: scale(1.01); }

    .btn-primary-custom { background: linear-gradient(135deg, #6366f1, #4f46e5); color: white; border: none; padding: 10px 24px; border-radius: 50px; font-weight: 600; transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; justify-content: center; }
    .btn-primary-custom:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3); color: white; }
    
    .btn-outline-custom { background: white; color: #475569; border: 1px solid #e2e8f0; padding: 10px 24px; border-radius: 50px; font-weight: 600; transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; justify-content: center; }
    .btn-outline-custom:hover { background: #f8fafc; border-color: #cbd5e1; color: #1e293b; }
    
    .btn-danger-custom { background: #fee2e2; color: #dc2626; border: none; padding: 10px 24px; border-radius: 50px; font-weight: 600; transition: all 0.3s; width: 100%; display: inline-flex; align-items: center; gap: 8px; justify-content: center; }
    .btn-danger-custom:hover { background: #fecaca; }

    .chart-container { position: relative; margin: auto; height: 250px; width: 100%; }
    .x-small { font-size: 0.75rem; }
    .italic { font-style: italic; }
    
    .timeline-item { transition: all 0.3s ease; border-bottom: 1px solid rgba(0,0,0,0.03); }
    .timeline-item:hover { background: rgba(99, 102, 241, 0.05); transform: translateX(4px); }
    .timeline-actions { opacity: 0.2; }
    .timeline-item:hover .timeline-actions { opacity: 1; }
    .transition-all { transition: all 0.3s ease; }
    .fade-out-item { opacity: 0; transform: translateX(20px); }

    .delete-history-btn { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #fee2e2; color: #dc2626; border: none; transition: all 0.2s; font-size: 0.85rem; }
    .delete-history-btn:hover { background: #fecaca; transform: scale(1.1); color: #b91c1c; }

    .icon-box-history { width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; color: #4338ca; font-size: 1.5rem; }
    .badge-total-history { background: #eef2ff; color: #4338ca; padding: 10px 20px; border-radius: 30px; font-weight: 700; font-size: 1.1rem; }
    .text-primary-dark { color: #4338ca !important; }
    
    .status-badge { padding: 4px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; }
    .status-badge.active { background: #e0f2fe; color: #0284c7; }
    .status-badge.completed { background: #dcfce7; color: #166534; }
    .status-badge.overdue { background: #fee2e2; color: #991b1b; }
    .status-badge.behind { background: #fef3c7; color: #92400e; }
    .status-badge.ontrack { background: #f0fdf4; color: #15803d; }
    
    @@media (max-width: 768px) { .sticky-top { position: relative; } }
</style>