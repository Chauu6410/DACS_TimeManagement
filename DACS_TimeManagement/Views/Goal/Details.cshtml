@model DACS_TimeManagement.Models.PersonalGoal
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <div class="row g-4">
        <!-- Main Column -->
        <div class="col-lg-8">
            <div class="card glass p-4 rounded-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h1 class="fw-bold">@Model.Title</h1>
                        <div class="d-flex gap-2 mt-2">
                            <span class="status-badge @Model.Status.ToString().ToLower()">@Model.Status</span>
                            <span class="text-muted"><i class="far fa-calendar"></i> Due @Model.TargetDate.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-outline-custom"><i class="fas fa-edit"></i> Edit</a>
                        <a asp-action="Focus" asp-route-id="@Model.Id" class="btn-primary-custom"><i class="fas fa-stopwatch"></i> Focus</a>
                    </div>
                </div>

                <!-- Progress Section -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">Overall Progress</span>
                        <span class="fw-bold" id="pctLarge">0%</span>
                    </div>
                    <div class="progress-bar-large mt-1">
                        <div id="mainProgress" class="progress-fill" style="width:0%"></div>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="row g-3 mb-4">
                    <div class="col-4">
                        <div class="stat-mini glass text-center p-3">
                            <div class="stat-mini-icon"><i class="fas fa-chart-simple"></i></div>
                            <h4 class="mb-0">@((Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased) ? Model.CompletedHours.ToString("0.##") + "h" : Model.CompletedTasks.ToString())</h4>
                            <small>Completed</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-mini glass text-center p-3">
                            <div class="stat-mini-icon"><i class="fas fa-bullseye"></i></div>
                            <h4 class="mb-0">@((Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased) ? (Model.TargetHours?.ToString("0.##") + "h") : (Model.TargetTasks?.ToString() ?? "-"))</h4>
                            <small>Target</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-mini glass text-center p-3">
                            <div class="stat-mini-icon"><i class="fas fa-fire"></i></div>
                            <h4 class="mb-0">@Model.CurrentStreak</h4>
                            <small>Day streak</small>
                        </div>
                    </div>
                </div>

                <!-- Chart -->
                <div class="mb-5">
                    <h5 class="fw-semibold"><i class="fas fa-chart-line me-2"></i>Progress History</h5>
                    <div class="chart-container">
                        <canvas id="progressChart" height="200"></canvas>
                    </div>
                </div>

                <!-- Linked Tasks -->
                <div>
                    <h5 class="fw-semibold"><i class="fas fa-tasks me-2"></i>Linked Tasks</h5>
                    <div class="task-list">
                        @foreach(var gt in Model.GoalTasks)
                        {
                            <div class="task-item glass d-flex justify-content-between align-items-center p-3 mb-2 rounded-3">
                                <div>
                                    <strong>@gt.WorkTask.Title</strong>
                                    <div class="small text-muted">@gt.WorkTask.Progress% - @gt.WorkTask.Status</div>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input task-complete-toggle" type="checkbox" data-task-id="@gt.WorkTaskId" @(gt.WorkTask.Status == DACS_TimeManagement.Models.TaskStatus.Completed ? "checked" : "")>
                                </div>
                            </div>
                        }
                        @if (!Model.GoalTasks.Any())
                        {
                            <div class="text-muted text-center p-4">No tasks linked. Add tasks to track progress.</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card glass p-4 rounded-4 sticky-top" style="top: 1rem;">
                <h5 class="fw-semibold"><i class="fas fa-bolt me-2"></i>Quick Actions</h5>
                <div class="d-grid gap-2 mt-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-outline-custom">Edit Goal</a>
                    <a asp-action="Focus" asp-route-id="@Model.Id" class="btn-primary-custom">Enter Focus Mode</a>
                    <button class="btn-danger-custom delete-goal-btn" data-id="@Model.Id" data-name="@Model.Title">Delete Goal</button>
                </div>
                <hr class="my-3">
                <h5 class="fw-semibold"><i class="fas fa-chart-simple me-2"></i>Insights</h5>
                <ul class="list-unstyled small">
                    <li class="d-flex justify-content-between mb-2"><span>Created</span><strong>@Model.CreatedAt.ToString("dd MMM yyyy")</strong></li>
                    <li class="d-flex justify-content-between mb-2"><span>Last updated</span><strong>@(Model.UpdatedAt?.ToString("dd MMM yyyy") ?? "-")</strong></li>
                    <li class="d-flex justify-content-between mb-2"><span>Target date</span><strong>@Model.TargetDate.ToString("dd MMM yyyy")</strong></li>
                    <li class="d-flex justify-content-between"><span>Goal type</span><strong>@Model.Type</strong></li>
                </ul>
                <div class="alert alert-info mt-3 small">
                    <i class="fas fa-lightbulb"></i> Complete tasks daily to maintain your streak.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Giữ nguyên toàn bộ JS hiện có (loadHistory, toggle task, delete goal)
        // Chỉ cần đảm bảo các id và class selectors đúng.
    </script>
}

<style>
    .glass { background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); border-radius: 28px; border: 1px solid rgba(255,255,255,0.8); box-shadow: 0 8px 20px rgba(0,0,0,0.05); }
    .progress-bar-large { background: #e2e8f0; border-radius: 20px; height: 12px; overflow: hidden; }
    .progress-fill { background: linear-gradient(90deg, #6366f1, #a855f7); height: 100%; transition: width 0.3s; }
    .stat-mini { transition: 0.2s; }
    .stat-mini:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.08); }
    .stat-mini-icon { font-size: 1.8rem; opacity: 0.5; margin-bottom: 0.5rem; }
    .task-item { transition: 0.2s; }
    .task-item:hover { background: #f1f5f9; }
    .btn-outline-custom, .btn-primary-custom, .btn-danger-custom {
        padding: 0.5rem 1rem; border-radius: 40px; font-weight: 600; text-align: center; text-decoration: none; display: block; transition: 0.2s;
    }
    .btn-outline-custom { background: transparent; border: 1px solid #cbd5e1; color: #1e293b; }
    .btn-outline-custom:hover { background: #f1f5f9; transform: translateY(-2px); }
    .btn-primary-custom { background: linear-gradient(135deg, #6366f1, #a855f7); color: white; border: none; }
    .btn-primary-custom:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(99,102,241,0.3); }
    .btn-danger-custom { background: #fee2e2; color: #dc2626; border: none; }
    .btn-danger-custom:hover { background: #ef4444; color: white; transform: translateY(-2px); }
    .status-badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 40px; font-size: 0.75rem; font-weight: 600; }
    .status-badge.active { background: #dbeafe; color: #2563eb; }
    .status-badge.completed { background: #d1fae5; color: #059669; }
    .status-badge.behind { background: #fed7aa; color: #ea580c; }
    .status-badge.overdue { background: #ffe4e2; color: #dc2626; }
    @@media (max-width: 768px) { .sticky-top { position: relative; } }
</style>