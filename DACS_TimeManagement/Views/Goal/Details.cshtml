@using DACS_TimeManagement.Services
@using DACS_TimeManagement.DTOs
@model DACS_TimeManagement.Models.PersonalGoal
@{
    ViewData["Title"] = Localizer["GoalDetails"];
    var currentCulture = System.Threading.Thread.CurrentThread.CurrentUICulture.Name;
    var langCode = currentCulture.StartsWith("vi") ? "vi" : "en";
}

<div class="container py-4">
    <div class="row g-4">
        <!-- Main Column -->
        <div class="col-lg-8">
            <div class="card glass p-4 rounded-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h1 class="fw-bold">@Model.Title</h1>
                        <div class="d-flex gap-2 mt-2">
                            <span class="status-badge @Model.Status.ToString().ToLower()">@Model.Status</span>
                            @{
                                var culture = new System.Globalization.CultureInfo(langCode == "vi" ? "vi-VN" : "en-US");
                            }
                            <span class="text-muted"><i class="far fa-calendar"></i> @Localizer["Due"] @Model.TargetDate.ToString("d", culture)</span>
                        </div>
                    </div>
                    @if (Model.Type != DACS_TimeManagement.Models.GoalType.TaskBased)
                    {
                        <div class="d-flex gap-2">
                            <button type="button" class="btn-outline-custom edit-goal-btn" data-goal-id="@Model.Id"><i class="fas fa-edit"></i> @Localizer["Edit"]</button>
                            <a asp-action="Focus" asp-route-id="@Model.Id" class="btn-primary-custom"><i class="fas fa-stopwatch"></i> @Localizer["Focus"]</a>
                        </div>
                    }
                </div>

                <!-- Progress Section -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">@Localizer["OverallProgress"]</span>
                        <span class="fw-bold" id="pctLarge">0%</span>
                    </div>
                    <div class="progress-bar-large mt-1">
                        <div id="mainProgress" class="progress-fill" style="width:0%"></div>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="stat-mini glass text-center p-3">
                            <div class="stat-mini-icon text-primary"><i class="fas fa-chart-simple"></i></div>
                            <h4 class="mb-0">@((Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased) ? (Model.CompletedHours < (1.0/60.0) ? (Math.Round(Model.CompletedHours * 3600)) + "s" : (Model.CompletedHours < 1 ? (Math.Round(Model.CompletedHours * 60)) + "m" : Model.CompletedHours.ToString("0.##") + "h")) : Model.CompletedTasks.ToString())</h4>
                            <small class="text-muted">@Localizer["Completed"]</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-mini glass text-center p-3">
                            <div class="stat-mini-icon text-info"><i class="fas fa-bullseye"></i></div>
                            <h4 class="mb-0">@((Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased) ? (Model.TargetHours?.ToString("0.##") + "h") : (Model.TargetTasks?.ToString() ?? "-"))</h4>
                            <small class="text-muted">@Localizer["Target"]</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-mini glass text-center p-3">
                            <div class="stat-mini-icon text-warning"><i class="fas fa-fire"></i></div>
                            @{
                                var todayDate = DateTime.UtcNow.Date;
                                var isStreakActive = Model.LastUpdated.HasValue && Model.LastUpdated.Value.Date >= todayDate.AddDays(-1);
                                var displayStreak = isStreakActive ? Model.CurrentStreak : 0;
                            }
                            <h4 class="mb-0">@displayStreak</h4>

                            <small class="text-muted">@Localizer["Streak"]</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-mini glass text-center p-3">
                            @{
                                var daysLeft = (Model.TargetDate.Date - DateTime.Now.Date).Days;
                            }
                            <div class="stat-mini-icon text-danger"><i class="fas fa-clock"></i></div>
                            <h4 class="mb-0 @(daysLeft < 0 ? "text-danger" : "")">@(daysLeft < 0 ? Localizer["Overdue"].Value : daysLeft + "d")</h4>
                            <small class="text-muted">@Localizer["Left"]</small>
                        </div>
                    </div>
                </div>

                <!-- AI Strategy Section -->
                <div class="mb-5">
                    <div class="glass p-4 rounded-4 border-start border-4 border-primary">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0"><i class="fas fa-robot text-primary me-2"></i>@Localizer["AIActionPlan"]</h5>
                            <button class="btn btn-sm btn-light rounded-pill regenerate-ai-btn" data-goal-id="@Model.Id">
                                <i class="fas fa-sync-alt me-1"></i> @Localizer["Update"]
                            </button>
                        </div>
                        <div class="ai-strategy-content small text-dark" id="aiContent-@Model.Id">
                            @if (!string.IsNullOrEmpty(Model.AIActionPlan))
                            {
                                @Html.Raw(Model.AIActionPlan.Replace("\n", "<br/>"))
                            }
                            else
                            {
                                <span class="text-muted italic">@Localizer["NoStrategyGenerated"]</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Chart -->
                <div class="mb-5">
                    <h5 class="fw-semibold"><i class="fas fa-chart-line me-2"></i>@Localizer["ProgressHistory"]</h5>
                    <div class="chart-container">
                        <canvas id="progressChart" height="200"></canvas>
                    </div>
                </div>

                <!-- Time History -->
                <div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="icon-box-history">
                                <i class="fas fa-history"></i>
                            </div>
                            <div class="lh-1">
                                <h4 class="fw-bold mb-0" style="color: #1e293b;">@Localizer["Time"]</h4>
                                <h4 class="fw-bold mb-0" style="color: #1e293b;">@Localizer["History"]</h4>
                            </div>
                        </div>
                        @{
                            var totalLogged = (double)(ViewBag.TotalLogged ?? 0.0);
                        }
                        @if (totalLogged > 0)
                        {
                            <div class="badge-total-history">
                                @totalLogged.ToString("0.##") @Localizer["HrsTotal"]
                            </div>
                        }
                    </div>

                    <div class="time-history-list">
                        @{
                            var now = DateTime.UtcNow;
                            var allHistory = ViewBag.AllHistory as IEnumerable<GoalHistoryItemDto> ?? Enumerable.Empty<GoalHistoryItemDto>();
                        }
                        @foreach(var item in allHistory)
                        {
                            var isJustNow = (now - item.Date).TotalMinutes < 1;
                            <div class="timeline-item p-3 position-relative">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="fw-bold text-dark" style="font-size: 1.1rem;">
                                            @if (item.Duration != null && item.Duration.Value > 0)
                                            {
                                                var totalSecs = (int)Math.Round(item.Duration.Value * 3600);
                                                var h = totalSecs / 3600;
                                                var m = (totalSecs % 3600) / 60;
                                                var s = totalSecs % 60;
                                                
                                                if (h > 0) {
                                                    @:@h.ToString()h @m.ToString()m
                                                } else if (m > 0) {
                                                    @:@m.ToString()m @s.ToString()s
                                                } else {
                                                    @:@s.ToString()s
                                                }
                                            }
                                            else
                                            {
                                                @:(Session)
                                            }
                                        </span>
                                        @if (item.Type != "Goal Focus")
                                        {
                                            <span class="text-primary-dark fw-bold ms-2" style="font-size: 0.9rem;">— @item.Title</span>
                                        }
                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="text-muted opacity-75 small">
                                            @(isJustNow ? Localizer["JustNow"].Value : DateTimeHelper.FormatByLanguage(item.Date, langCode))
                                        </div>
                                        <div class="timeline-actions transition-all">
                                            <button class="delete-history-btn" data-id="@item.Id" data-type="@item.Type" title="@Localizer["DeleteRecord"]">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(item.Note))
                                {
                                    var displayNote = item.Note;
                                    if (displayNote.Contains("]") && displayNote.IndexOf("]") < 30) 
                                    {
                                        displayNote = displayNote.Substring(displayNote.IndexOf("]") + 1).Trim();
                                    }
                                    if (!string.IsNullOrEmpty(displayNote))
                                    {
                                        <div class="text-muted fst-italic ms-4 ps-1 opacity-75" style="font-size: 0.95rem;">"@displayNote"</div>
                                    }
                                }

                            </div>
                        }
                        @if (!allHistory.Any())
                        {
                            <div class="text-muted text-center p-4">@Localizer["NoSessionsRecorded"]</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card glass p-4 rounded-4 sticky-top" style="top: 1rem;">
                <h5 class="fw-semibold"><i class="fas fa-bolt me-2"></i>@Localizer["QuickActions"]</h5>
                <div class="d-grid gap-2 mt-2">
                    <button type="button" class="btn-outline-custom edit-goal-btn" data-goal-id="@Model.Id">@Localizer["EditGoal"]</button>
                    <a asp-action="Focus" asp-route-id="@Model.Id" class="btn-primary-custom">@Localizer["EnterFocusMode"]</a>
                    <button class="btn-danger-custom delete-goal-btn" data-id="@Model.Id" data-name="@Model.Title">@Localizer["DeleteGoal"]</button>
                </div>
                <hr class="my-3">
                <h5 class="fw-semibold"><i class="fas fa-chart-simple me-2"></i>@Localizer["Insights"]</h5>
                <ul class="list-unstyled small">
                    <li class="d-flex justify-content-between mb-2"><span>@Localizer["Created"]</span><strong>@DateTimeHelper.FormatByLanguage(Model.CreatedAt, langCode)</strong></li>
                    <li class="d-flex justify-content-between mb-2"><span>@Localizer["LastUpdated"]</span><strong>@(Model.UpdatedAt.HasValue ? DateTimeHelper.FormatByLanguage(Model.UpdatedAt.Value, langCode) : "-")</strong></li>
                    <li class="d-flex justify-content-between mb-2"><span>@Localizer["TargetDate"]</span><strong>@DateTimeHelper.FormatByLanguage(Model.TargetDate, langCode)</strong></li>
                    <li class="d-flex justify-content-between"><span>@Localizer["GoalType"]</span><strong>@Model.Type</strong></li>
                </ul>
                <div class="alert alert-info mt-3 small">
                    <i class="fas fa-lightbulb"></i> @Localizer["MaintainStreakTip"]
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Goal Modal -->
<div class="modal fade" id="editGoalModal" tabindex="-1" aria-labelledby="editGoalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-gradient-primary text-white border-0 py-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle bg-white bg-opacity-25 text-white" style="width: 48px; height: 48px; border-radius: 60px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                        <i class="fas fa-pencil-alt fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">Edit Goal</h4>
                        <p class="opacity-75 small mb-0">Update your objective details</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editGoalForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editGoalId" />
                <div class="modal-body p-4 p-lg-5" style="background-color: var(--card-bg);">
                    <div class="row g-4">
                        <!-- Type (Hidden in Edit) -->
                        <input type="hidden" name="Type" id="editGoalType" />

                        <!-- Title (TimeBased) -->
                        <div class="col-12" id="editTitleGroup">
                            <label for="editTitle" class="form-label fw-semibold mb-2">Goal Title <span class="text-danger">*</span></label>
                            <input type="text" name="Title" id="editTitle" class="form-control rounded-3" placeholder="e.g., Learn English" />
                        </div>

                        <!-- Project (TaskBased) -->
                        <div class="col-12" id="editProjectGroup">
                            <label for="editProjectId" class="form-label fw-semibold mb-2">Linked Project <span class="text-danger">*</span></label>
                            <select name="ProjectId" id="editProjectId" class="form-select rounded-3">
                                <option value="">-- Select a project --</option>
                                <!-- Potentially populate this via ViewBag if available or fetch -->
                            </select>
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            <label for="editDescription" class="form-label fw-semibold mb-2">Description</label>
                            <textarea name="Description" id="editDescription" class="form-control rounded-3" rows="3"></textarea>
                        </div>

                        <!-- Target Date & Hours -->
                        <div class="col-md-6">
                            <label for="editTargetDate" class="form-label fw-semibold mb-2">Target Date <span class="text-danger">*</span></label>
                            <input type="datetime-local" name="TargetDate" id="editTargetDate" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label for="editTargetHours" class="form-label fw-semibold mb-2">Target Hours</label>
                            <div class="input-group">
                                <input type="number" step="0.5" name="TargetHours" id="editTargetHours" class="form-control rounded-start-3" />
                                <span class="input-group-text rounded-end-3">hours</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top p-4 d-flex justify-content-between" style="background-color: var(--bg-light);">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="editGoalSubmitBtn" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>

    .icon-circle { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
    .custom-radio-card input { display: none; }
    .custom-radio-card input:checked + label { border-color: #6366f1 !important; background-color: rgba(99, 102, 241, 0.05); }
    .cursor-pointer { cursor: pointer; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            loadProgressChart();
            updateProgressDisplays();

            // Gemini AI Integration
            document.querySelectorAll('.regenerate-ai-btn').forEach(btn => {
                btn.addEventListener('click', async function() {
                    const goalId = this.dataset.goalId;
                    const contentDiv = document.getElementById(`aiContent-${goalId}`);
                    
                    // Show loading state
                    this.disabled = true;
                    this.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Analyzing...';
                    contentDiv.innerHTML = `
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                            <h5 class="text-primary fw-bold">Gemini is thinking...</h5>
                            <p class="text-muted">Crafting your personalized strategy plan</p>
                        </div>`;

                    try {
                        // Prepare data
                        const requestData = {
                            goal: {
                                title: @Html.Raw(Json.Serialize(Model.Title)),
                                description: @Html.Raw(Json.Serialize(Model.Description ?? "")),
                                status: "@Model.Status",
                                type: "@Model.Type",
                                completedTasks: @Model.CompletedTasks,
                                targetTasks: @(Model.TargetTasks ?? 0),
                                completedHours: @Model.CompletedHours,
                                targetHours: @(Model.TargetHours ?? 0.0),
                                targetDate: "@Model.TargetDate.ToString("yyyy-MM-ddTHH:mm:ss")"
                            },
                            project: {
                                name: @Html.Raw(Json.Serialize(Model.Project?.Name ?? "General")),
                                detail: @Html.Raw(Json.Serialize(Model.Project?.Description ?? "No specific project details."))
                            }
                        };


                        const response = await fetch('/api/ai/generate', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(requestData)
                        });

                        const data = await response.json();

                        if (response.ok && data.result) {
                            // Use marked.js for premium formatting
                            contentDiv.style.opacity = 0;
                            contentDiv.innerHTML = `<div class="ai-response-content">${marked.parse(data.result)}</div>`;
                            
                            // Smooth fade in
                            setTimeout(() => {
                                contentDiv.style.transition = 'opacity 0.5s ease';
                                contentDiv.style.opacity = 1;
                            }, 100);
                        } else {
                            throw new Error(data.error || 'Failed to generate content');
                        }
                    } catch (e) {
                        console.error(e);
                        const checkConnMsg = @Html.Raw(Json.Serialize(langCode == "vi" ? "Vui lòng kiểm tra API Key và kết nối." : "Please check your API Key and connection."));
                        const errMsg = e?.message || checkConnMsg;
                        contentDiv.innerHTML = `
                            <div class="alert alert-danger rounded-4">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <strong>${@Html.Raw(Json.Serialize(langCode == "vi" ? "Lỗi" : "Error"))}:</strong> ${errMsg}
                            </div>`;
                        Swal.fire({
                            icon: 'error',
                            title: ${@Html.Raw(Json.Serialize(langCode == "vi" ? "AI tạo thất bại" : "AI Generation Failed"))},
                            text: errMsg
                        });
                    } finally {
                        this.disabled = false;
                        this.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Update';
                    }
                });
            });

            // Delete Goal
            document.querySelector('.delete-goal-btn')?.addEventListener('click', function() {
                const id = this.dataset.id;
                const name = this.dataset.name;
                // localize template on server, perform replacement on client to avoid Razor parsing issues
                const deleteConfirmTemplate = @Html.Raw(Json.Serialize(Localizer["DeleteGoalConfirm"].Value));
                Swal.fire({
                    title: @Html.Raw(Json.Serialize(Localizer["DeleteGoalTitle"].Value)),
                    text: deleteConfirmTemplate.replace("{name}", name),

                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    confirmButtonText: @Html.Raw(Json.Serialize(Localizer["YesDelete"].Value)),
                    cancelButtonText: @Html.Raw(Json.Serialize(Localizer["Cancel"].Value))

                }).then((result) => {
                    if (result.isConfirmed) {
                        const form = document.createElement('form');
                        form.method = 'POST';
                        form.action = '/Goal/Delete/' + id;
                        const token = document.querySelector('input[name="__RequestVerificationToken"]');
                        if (token) form.appendChild(token.cloneNode(true));
                        document.body.appendChild(form);
                        form.submit();
                    }
                });
            });

            // Delete History Log
            document.querySelectorAll('.delete-history-btn').forEach(btn => {
                btn.addEventListener('click', async function(e) {
                    e.preventDefault();
                    const id = this.dataset.id;
                    const type = this.dataset.type;
                    
                    const result = await Swal.fire({
                        title: @Html.Raw(Json.Serialize(Localizer["DeleteHistoryTitle"].Value)),
                        text: @Html.Raw(Json.Serialize(Localizer["CannotUndo"].Value)),

                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        confirmButtonText: @Html.Raw(Json.Serialize(Localizer["YesDelete"].Value)),
                        cancelButtonText: @Html.Raw(Json.Serialize(Localizer["Cancel"].Value))

                    });

                    if (result.isConfirmed) {
                        const url = type === 'Goal Focus' ? `/Goal/DeleteHistory/${id}` : `/TimeLog/DeleteLog/${id}`;
                        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                        
                        try {
                            const response = await fetch(url, {
                                method: 'POST',
                                headers: {
                                    'X-Requested-With': 'XMLHttpRequest',
                                    'RequestVerificationToken': token
                                }
                            });
                            const data = await response.json();
                            if (data.success) {
                                this.closest('.timeline-item').classList.add('fade-out-item');
                                setTimeout(() => location.reload(), 400);
                            }
                        } catch (err) {
                            Swal.fire('Error', 'Failed to delete history entry.', 'error');
                        }
                    }
                });
            });


        function updateProgressDisplays() {
            const completed = @Html.Raw(Json.Serialize(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? Model.CompletedHours : (double)Model.CompletedTasks));
            const target = @Html.Raw(Json.Serialize(Model.Type == DACS_TimeManagement.Models.GoalType.TimeBased ? (Model.TargetHours ?? 0.0) : (double)(Model.TargetTasks ?? 0)));


            const pct = target > 0 ? Math.round((completed / target) * 100) : 0;
            
            const fill = document.getElementById('mainProgress');
            const label = document.getElementById('pctLarge');
            if (fill) fill.style.width = pct + '%';
            if (label) label.innerText = pct + '%';
        }

        async function loadProgressChart() {
            const chartEl = document.getElementById('progressChart');
            if (!chartEl) return;
            const ctx = chartEl.getContext('2d');
            
            try {
                const res = await fetch(`/Goal/GetGoalHistory/@Model.Id`);
                if (!res.ok) throw new Error("Fetch failed");
                const data = await res.json();
                
                if (!data || !Array.isArray(data) || data.length === 0) {
                    ctx.font = '14px sans-serif';
                    ctx.textAlign = 'center';
                    ctx.fillStyle = '#64748b';
                    ctx.fillText('No progress data yet', chartEl.width / 2, chartEl.height / 2);
                    return;
                }

                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: data.map(d => d.date),
                        datasets: [{
                            label: 'Progress %',
                            data: data.map(d => d.progress),
                            borderColor: '#6366f1',
                            backgroundColor: 'rgba(99, 102, 241, 0.1)',
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { min: 0, max: 100, ticks: { callback: value => value + '%' } }
                        }
                    }
                });
            } catch (e) {
                console.error("Chart error:", e);
                ctx.font = '12px sans-serif';
                ctx.textAlign = 'center';
                ctx.fillText('Error loading chart', chartEl.width / 2, chartEl.height / 2);
            }
        }


            // Edit Goal Modal Logic
            const editGoalModalEl = document.getElementById('editGoalModal');
            if (editGoalModalEl) {
                const editGoalModal = new bootstrap.Modal(editGoalModalEl);
                const editTitleGroup = document.getElementById('editTitleGroup');
                const editProjectGroup = document.getElementById('editProjectGroup');

                window.toggleEditType = function(type) {
                    if (type === 'TaskBased') {
                        editTitleGroup.classList.add('d-none');
                        editProjectGroup.classList.remove('d-none');
                    } else {
                        editTitleGroup.classList.remove('d-none');
                        editProjectGroup.classList.add('d-none');
                    }
                };


                document.querySelectorAll('.edit-goal-btn').forEach(btn => {
                    btn.addEventListener('click', function() {
                        const id = this.dataset.goalId;
                        fetch(`/Goal/Details/${id}`, {
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        })
                        .then(res => res.json())
                        .then(data => {
                            document.getElementById('editGoalId').value = data.id;
                            document.getElementById('editTitle').value = data.title || '';
                            document.getElementById('editDescription').value = data.description || '';
                            document.getElementById('editTargetDate').value = data.targetDate;
                            document.getElementById('editTargetHours').value = data.targetHours;
                            
                            const projectSelect = document.getElementById('editProjectId');
                            document.getElementById('editGoalType').value = data.type;
                            toggleEditType(data.type);

                            editGoalModal.show();
                            
                            fetch('/Project/GetUserProjects', { headers: { 'X-Requested-With': 'XMLHttpRequest' }})
                            .then(res => res.json())
                            .then(projects => {
                                if (projectSelect) {
                                    projectSelect.innerHTML = '<option value="">-- Select a project --</option>';
                                    projects.forEach(p => {
                                        const opt = document.createElement('option');
                                        opt.value = p.id;
                                        opt.textContent = p.name;
                                        if (p.id === data.projectId) opt.selected = true;
                                        projectSelect.appendChild(opt);
                                    });
                                }
                            });
                        })
                        .catch(err => console.error(err));
                    });
                });

                document.getElementById('editGoalForm').addEventListener('submit', function(e) {
                    e.preventDefault();
                    const form = this;
                    const id = document.getElementById('editGoalId').value;
                    const submitBtn = document.getElementById('editGoalSubmitBtn');
                    const originalText = submitBtn.innerHTML;
                    
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
                    
                    fetch(`/Goal/Edit/${id}`, {
                        method: 'POST',
                        body: new FormData(form),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        } else {
                            Swal.fire('Error', data.message || 'Validation failed', 'error');
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = originalText;
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalText;
                    });
                });
            }
        });
    </script>

}

