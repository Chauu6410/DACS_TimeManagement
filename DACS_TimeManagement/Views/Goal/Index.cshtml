@model IEnumerable<DACS_TimeManagement.Models.PersonalGoal>
@{
    ViewData["Title"] = "Personal Goals";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 fw-bold text-dark"><i class="fas fa-bullseye text-primary me-2"></i>My Personal Goals</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm px-4 fw-bold">
        <i class="fas fa-plus me-2"></i>Set New Goal
    </a>
</div>

<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="card p-5 text-center border-0 shadow-sm">
                <i class="fas fa-trophy fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">No goals set yet!</h4>
                <p class="mb-4">Setting goals helps you track long-term achievements and stay motivated.</p>
                <a asp-action="Create" class="btn btn-outline-primary mx-auto" style="width: 200px;">Set First Goal</a>
            </div>
        </div>
    }

    @foreach (var goal in Model)
    {
        var isAchieved = goal.CurrentValue >= goal.TargetValue;
        var statusText = isAchieved ? "Achieved" : "In Progress";
        var statusColor = isAchieved ? "success" : "primary";

        var pct = goal.TargetValue == 0 ? 0 : (int)((double)goal.CurrentValue / goal.TargetValue * 100);
        if (pct > 100) pct = 100;
        
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <span class="badge rounded-pill bg-@statusColor">@statusText</span>
                    <div class="dropdown">
                        <button class="btn btn-light btn-sm rounded-circle border-0" type="button" data-bs-toggle="dropdown">
                            <i class="fas fa-ellipsis-v text-muted"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                            <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@goal.Id"><i class="fas fa-edit text-primary me-2"></i>Edit</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@goal.Id"><i class="fas fa-trash-alt me-2"></i>Delete</a></li>
                        </ul>
                    </div>
                </div>
                
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold text-dark mb-1 text-truncate" title="@goal.GoalName">@goal.GoalName</h5>
                    <p class="text-muted small mb-4">Due: @goal.TargetDate.ToString("MMM dd, yyyy")</p>

                    <div class="position-relative d-inline-block mb-3">
                        <svg width="100" height="100">
                            <circle cx="50" cy="50" r="40" fill="none" stroke="#e9ecef" stroke-width="8"></circle>
                            <circle cx="50" cy="50" r="40" fill="none" stroke="var(--@statusColor)" stroke-width="8" 
                                    stroke-dasharray="251" stroke-dashoffset="@(251 - (251 * pct / 100))" 
                                    style="transition: stroke-dashoffset 1s ease-in-out;" transform="rotate(-90 50 50)"></circle>
                        </svg>
                        <div class="position-absolute top-50 start-50 translate-middle text-center">
                            <span class="fs-4 fw-bold text-dark d-block" style="line-height: 1;">@pct%</span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center align-items-center gap-3 bg-light rounded-3 p-2 mx-auto" style="width: 80%;">
                        <div class="text-end" style="width: 45%;">
                            <span class="d-block fs-5 fw-bold text-primary">@goal.CurrentValue</span>
                            <small class="text-muted text-uppercase" style="font-size: 0.65rem;">Current</small>
                        </div>
                        <div class="text-muted">/</div>
                        <div class="text-start" style="width: 45%;">
                            <span class="d-block fs-5 fw-bold text-dark">@goal.TargetValue</span>
                            <small class="text-muted text-uppercase" style="font-size: 0.65rem;">Target</small>
                        </div>
                    </div>
                </div>
                
                @if (!isAchieved)
                {
                    <div class="card-footer bg-white border-top p-3">
                        <label class="form-label small fw-bold text-muted mb-1">Quick Update log:</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="range" class="form-range flex-grow-1" min="0" max="@goal.TargetValue" value="@goal.CurrentValue" id="slider-@goal.Id" onchange="updateGoalProgress(@goal.Id, this.value)">
                            <span class="badge bg-light text-dark border" id="val-@goal.Id" style="width: 45px;">@goal.CurrentValue</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function updateGoalProgress(id, value) {
            document.getElementById('val-'+id).innerText = value;
            fetch('/Goal/UpdateProgress?id=' + id + '&value=' + value, {
                method: 'POST'
            }).then(response => response.json())
              .then(data => {
                  if(data.success) {
                      window.location.reload(); 
                  }
              });
        }
    </script>
}
