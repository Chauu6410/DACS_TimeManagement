@model IEnumerable<DACS_TimeManagement.Models.PersonalGoal>
@inject DACS_TimeManagement.Services.Interfaces.IGoalService GoalService
@{
    ViewData["Title"] = Localizer["GoalManagement"];
    var totalGoals = Model.Count();
    var projects = (IEnumerable<dynamic>)ViewBag.Projects;
}

@Html.AntiForgeryToken()

<div class="goals-container" data-aos="fade-up">



    <!-- Toolbar: Search, Actions and Filters -->
    <div class="toolbar-premium p-3 mb-4 d-flex flex-wrap justify-content-between align-items-center gap-3 shadow-sm rounded-4">
        <div class="d-flex flex-wrap gap-2 flex-grow-1" style="max-width: 600px;">
            <div class="search-box position-relative flex-grow-1">
                <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-primary"></i>
                <input type="text" id="goalSearch" class="form-control search-input-premium ps-5 border-0" placeholder="@Localizer["SearchGoals"]">
            </div>
            <button class="btn rounded-pill px-3 shadow-sm hover-lift btn-refresh-custom" id="refreshBtn" title="@Localizer["RefreshData"]">
                <i class="fas fa-sync-alt"></i>
            </button>
            <button type="button" class="btn btn-gradient-primary rounded-pill px-4 shadow-sm fw-semibold hover-lift" data-bs-toggle="modal" data-bs-target="#createGoalModal">
                <i class="fas fa-plus-circle me-2"></i>@Localizer["SetUpNewGoal"]
            </button>
        </div>
        <div class="filter-group d-flex gap-2 overflow-auto pb-1 pe-3 me-2">
            <span class="small text-muted align-self-center me-2 d-none d-md-block fw-semibold">@Localizer["Status"]:</span>
            <button class="filter-btn active" data-filter="all">@Localizer["All"]</button>
            <button class="filter-btn filter-active" data-filter="Active">@Localizer["Active"]</button>
            <button class="filter-btn filter-completed" data-filter="Completed">@Localizer["Completed"]</button>
            <button class="filter-btn filter-behind" data-filter="Behind">@Localizer["Behind"]</button>
        </div>
        <div class="filter-group d-flex gap-2 overflow-auto pb-1">
            <span class="small text-muted align-self-center me-2 d-none d-md-block fw-semibold">@Localizer["Type"]:</span>
            <button class="type-filter-btn active" data-type-filter="all">@Localizer["All"]</button>
            <button class="type-filter-btn type-task" data-type-filter="TaskBased">@Localizer["ProjectBased"]</button>
            <button class="type-filter-btn type-time" data-type-filter="TimeBased">@Localizer["PersonalBased"]</button>
        </div>
    </div>

    <!-- Goals Grid -->
    <div class="row g-4" id="goalsGrid">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="empty-state-card card border-0 shadow-lg rounded-4 p-5 text-center">
                    <div class="mb-4">
                        <i class="fas fa-bullseye fa-4x text-pastel-muted opacity-50"></i>
                    </div>
                    <h4 class="fw-bold">@Localizer["NoGoalsDefined"]</h4>
                    <p class="text-muted mb-4">@Localizer["StartCreatingGoal"]</p>
                    <button type="button" class="btn btn-pastel-primary rounded-pill px-4 fw-semibold mx-auto" data-bs-toggle="modal" data-bs-target="#createGoalModal">@Localizer["SetYourFirstGoal"]</button>
                </div>
            </div>
        }
        else
        {
            var pastelColors = new[] { "pastel-blue", "pastel-green", "pastel-yellow", "pastel-pink", "pastel-purple", "pastel-mint" };
            var colorIndex = 0;

            foreach (var goal in Model)
            {
                var colorClass = pastelColors[colorIndex % pastelColors.Length];
                colorIndex++;

                var progressPercent = goal.TargetValue == 0 ? 0 : (int)Math.Min(100, (double)goal.CurrentValue / goal.TargetValue * 100);
                var isCompleted = goal.Status == DACS_TimeManagement.Models.GoalStatus.Completed;
                var daysRemaining = (goal.TargetDate.Date - DateTime.Now.Date).Days;
                var aiShortStatus = GoalService.GetAIShortStatus(goal);
                
                // Determine CSS class for AI Status
                var aiStatusClass = aiShortStatus switch {
                    "Completed" => "text-success fw-bold",
                    "At Risk" => "text-danger fw-bold",
                    "Finishing" => "text-success fw-bold",
                    "Excellent" => "text-primary fw-bold",
                    "Ahead" => "text-info fw-bold",
                    "On Track" => "text-primary fw-semibold",
                    "Starting Up" => "text-muted italic",
                    "Initializing" => "text-info italic",
                    _ => "text-muted"
                };

                <div class="col-lg-6 col-xl-4 goal-item" data-id="@goal.Id" data-status="@goal.Status" data-type="@goal.Type" data-title="@goal.Title">
                    <div class="goal-card card border-0 shadow-md rounded-4 overflow-hidden hover-lift @colorClass h-100">
                        <div class="card-body p-4 d-flex flex-column">
                            <!-- Card Actions -->
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="goal-title fw-bold mb-0 text-truncate" title="@goal.Title">@goal.Title</h5>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm rounded-circle border-0 bg-white bg-opacity-50 text-primary hover-scale edit-goal-btn" title="@Localizer["Edit"]" data-goal-id="@goal.Id">
                                        <i class="fas fa-pencil-alt"></i>
                                    </button>
                                    <button class="btn btn-sm rounded-circle border-0 bg-white bg-opacity-50 text-danger delete-goal-btn hover-scale" data-id="@goal.Id" title="@Localizer["Delete"]">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Progress Info -->
                            <div class="progress-info mb-4">
                                @if (goal.Type == DACS_TimeManagement.Models.GoalType.TaskBased)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="small text-muted fw-medium"><i class="fas fa-tasks me-1"></i> @Localizer["Tasks"]</span>
                                        <span class="small fw-bold text-dark task-counter">@goal.CompletedTasks / @(goal.TargetTasks ?? 0)</span>
                                    </div>
                                }
                                @if (goal.TargetHours.HasValue && goal.Type != DACS_TimeManagement.Models.GoalType.TaskBased)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="small text-muted fw-medium"><i class="fas fa-clock me-1"></i> @Localizer["Effort"]</span>
                                        <span class="small fw-bold text-dark effort-counter">@(goal.CompletedHours < (1.0/60.0) ? (Math.Round(goal.CompletedHours * 3600)) + "s" : (goal.CompletedHours < 1 ? (Math.Round(goal.CompletedHours * 60)) + "m" : goal.CompletedHours.ToString("F1") + "h")) / @goal.TargetHours.Value.ToString("F1")h</span>
                                    </div>
                                }
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small text-muted fw-medium"><i class="far fa-calendar-alt me-1"></i> @Localizer["Deadline"]</span>
                                    @{
                                        var currentCulture = System.Threading.Thread.CurrentThread.CurrentUICulture.Name;
                                        var langCode = currentCulture.StartsWith("vi") ? "vi" : "en";
                                        var culture = new System.Globalization.CultureInfo(langCode == "vi" ? "vi-VN" : "en-US");
                                    }
                                    <span class="small fw-bold text-dark">@goal.TargetDate.ToString("d", culture)</span>
                                </div>

                                <!-- Progress Bar -->
                                <div class="progress rounded-pill mb-2" style="height: 8px; background: rgba(0,0,0,0.05);">
                                    <div class="progress-bar rounded-pill @(isCompleted ? "bg-success" : "")" 
                                         role="progressbar" 
                                         style="width: @progressPercent%; transition: width 1s ease;" 
                                         aria-valuenow="@progressPercent" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100"></div>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="x-small @aiStatusClass"><i class="fas fa-robot me-1"></i> @Localizer[aiShortStatus == "Completed" ? "CompletedStatus" : aiShortStatus.Replace(" ", "")]</span>
                                    <span class="x-small fw-bold @(daysRemaining < 0 ? "text-danger" : "text-primary")">
                                        @if (daysRemaining < 0) {
                                            @Localizer["Overdue"]
                                        } else if (daysRemaining == 0) {
                                            @Localizer["DueToday"]
                                        } else {
                                            @:@daysRemaining @Localizer["DaysLeft"]
                                        }
                                    </span>
                                </div>
                            </div>

                            <!-- AI Strategy Box -->
                            <div class="ai-strategy-box rounded-3 p-3 mb-4 flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="d-flex align-items-center">
                                        <div class="ai-icon bg-white rounded-2 p-1 me-2 shadow-sm">
                                            <i class="fas fa-robot text-primary small"></i>
                                        </div>
                                        <span class="x-small fw-bold text-uppercase letter-spacing-1">@Localizer["AIStrategy"]</span>
                                    </div>
                                    <button class="btn btn-sm btn-link text-primary p-0 regenerate-ai-btn hover-scale" data-goal-id="@goal.Id" title="@Localizer["UpdateStrategy"]">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                </div>
                                <div class="ai-content-scroll" id="aiContent-@goal.Id">
                                    @if (!string.IsNullOrEmpty(goal.AIActionPlan))
                                    {
                                        <div class="ai-response-content initial-markdown" data-raw="@goal.AIActionPlan">
                                            @* Content will be rendered by JS below *@
                                            <div class="text-muted x-small italic">@Localizer["Rendering"]</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted x-small mb-0 italic">@Localizer["AnalyzingData"]</p>
                                    }
                                </div>
                            </div>



                            <!-- Footer Actions -->
                            <div class="d-flex gap-2 mt-auto">
                                <a asp-action="Focus" asp-route-id="@goal.Id" class="btn btn-primary btn-sm flex-grow-1 rounded-pill fw-bold shadow-sm">
                                    <i class="fas fa-brain me-1"></i> @Localizer["Focus"]
                                </a>
                                <a asp-action="Details" asp-route-id="@goal.Id" class="btn btn-outline-secondary btn-sm flex-grow-1 rounded-pill fw-bold">
                                    @Localizer["DetailsHistory"]
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Edit Goal Modal -->
<div class="modal fade" id="editGoalModal" tabindex="-1" aria-labelledby="editGoalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-gradient-primary text-white border-0 py-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle bg-white bg-opacity-25 text-white" style="width: 48px; height: 48px; border-radius: 60px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                        <i class="fas fa-pencil-alt fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">@Localizer["EditGoal"]</h4>
                        <p class="opacity-75 small mb-0">@Localizer["UpdateObjectiveDetails"]</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editGoalForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editGoalId" />
                <div class="modal-body p-4 p-lg-5" style="background-color: var(--card-bg);">
                    <div class="row g-4">
                        <!-- Type (Hidden in Edit) -->
                        <input type="hidden" name="Type" id="editGoalType" />


                        <!-- Title (TimeBased) -->
                        <div class="col-12" id="editTitleGroup">
                            <label for="editTitle" class="form-label fw-semibold mb-2">@Localizer["GoalTitle"] <span class="text-danger">*</span></label>
                            <input type="text" name="Title" id="editTitle" class="form-control rounded-3" placeholder="e.g., Learn English" />
                        </div>

                        <!-- Project (TaskBased) -->
                        <div class="col-12" id="editProjectGroup">
                            <label for="editProjectId" class="form-label fw-semibold mb-2">@Localizer["LinkedProject"] <span class="text-danger">*</span></label>
                            <select name="ProjectId" id="editProjectId" class="form-select rounded-3">
                                <option value="">@Localizer["SelectAProject"]</option>
                                @foreach(var p in projects)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            <label for="editDescription" class="form-label fw-semibold mb-2">@Localizer["Description"]</label>
                            <textarea name="Description" id="editDescription" class="form-control rounded-3" rows="3"></textarea>
                        </div>

                        <!-- Target Date & Hours -->
                        <div class="col-md-6">
                            <label for="editTargetDate" class="form-label fw-semibold mb-2">@Localizer["TargetDate"] <span class="text-danger">*</span></label>
                            <input type="datetime-local" name="TargetDate" id="editTargetDate" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                                <label for="editTargetHours" class="form-label fw-semibold mb-2">@Localizer["TargetHours"]</label>
                                <div class="input-group">
                                    <input type="number" step="0.5" name="TargetHours" id="editTargetHours" class="form-control rounded-start-3" />
                                    <span class="input-group-text rounded-end-3">@Localizer["Hours"]</span>
                                </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top p-4 d-flex justify-content-between" style="background-color: var(--bg-light);">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4 py-2" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                    <button type="submit" id="editGoalSubmitBtn" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">@Localizer["SaveChanges"]</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="createGoalModal" tabindex="-1" aria-labelledby="createGoalModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-gradient-primary text-white border-0 py-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle bg-white bg-opacity-25 text-white" style="width: 48px; height: 48px; border-radius: 60px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                        <i class="fas fa-bullseye fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">@Localizer["SetUpNewGoal"]</h4>
                        <p class="opacity-75 small mb-0">@Localizer["DefineObjectives"]</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post" id="createGoalForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 p-lg-5" style="background-color: var(--card-bg);">
                    <div class="row g-4">
                        <!-- Goal Type -->
                        <div class="col-12 mb-2">
                            <label class="form-label fw-semibold mb-3">@Localizer["GoalType"]</label>
                            <div class="d-flex gap-3 flex-wrap">
                                <div class="form-check custom-radio-card flex-grow-1 p-0 m-0">
                                    <input class="form-check-input" type="radio" name="Type" id="typeTask" value="TaskBased" checked>
                                    <label class="form-check-label w-100 p-3 border rounded-3 text-center cursor-pointer h-100" for="typeTask">
                                        <i class="fas fa-project-diagram fs-4 text-primary d-block mb-2 mt-2"></i>
                                        <span class="fw-bold d-block">@Localizer["ProjectBased"]</span>
                                    </label>
                                </div>
                                <div class="form-check custom-radio-card flex-grow-1 p-0 m-0">
                                    <input class="form-check-input" type="radio" name="Type" id="typeTime" value="TimeBased">
                                    <label class="form-check-label w-100 p-3 border rounded-3 text-center cursor-pointer h-100" for="typeTime">
                                        <i class="fas fa-stopwatch fs-4 text-warning d-block mb-2 mt-2"></i>
                                        <span class="fw-bold d-block">@Localizer["PersonalBased"]</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Title (TimeBased) -->
                        <div class="col-12 d-none" id="titleGroup">
                            <label for="Title" class="form-label fw-semibold mb-2">@Localizer["GoalTitle"] <span class="text-danger">*</span></label>
                            <input type="text" name="Title" id="Title" class="form-control rounded-3" placeholder="@Localizer["LearnEnglishPlaceholder"]" />
                        </div>

                        <!-- Project (TaskBased) -->
                        <div class="col-12" id="projectGroup">
                            <label for="ProjectId" class="form-label fw-semibold mb-2">@Localizer["LinkedProject"] <span class="text-danger">*</span></label>
                            <select name="ProjectId" id="ProjectId" class="form-select rounded-3">
                                <option value="">@Localizer["SelectAProject"]</option>
                                @foreach(var p in projects)
                                {
                                    <option value="@p.Id" data-deadline="@(p.EndDate?.ToString("yyyy-MM-dd"))">@p.Name</option>
                                }
                            </select>
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            <label for="Description" class="form-label fw-semibold mb-2">@Localizer["Description"]</label>
                            <textarea name="Description" id="Description" class="form-control rounded-3" rows="3"></textarea>
                        </div>

                        <!-- Target Date & Hours -->
                        <div class="col-md-6">
                            <label for="TargetDate" class="form-label fw-semibold mb-2">@Localizer["TargetDate"] <span class="text-danger">*</span></label>
                            <input type="datetime-local" name="TargetDate" id="TargetDate" class="form-control rounded-3" value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>
                        <div class="col-md-6">
                            <label for="TargetHours" class="form-label fw-semibold mb-2">@Localizer["TargetHours"]</label>
                            <div class="input-group">
                                <input type="number" step="0.5" name="TargetHours" id="TargetHours" class="form-control rounded-start-3" placeholder="30" />
                                <span class="input-group-text rounded-end-3">@Localizer["Hours"]</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top p-4 d-flex justify-content-between" style="background-color: var(--bg-light);">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4 py-2" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                    <button type="submit" id="createGoalSubmitBtn" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">@Localizer["CreateGoal"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Render initial markdown content
            document.querySelectorAll('.initial-markdown').forEach(el => {
                const raw = el.dataset.raw;
                if (raw) {
                    el.innerHTML = marked.parse(raw);
                }
            });


            // Search Functionality
            const searchInput = document.getElementById('goalSearch');
            const goalItems = document.querySelectorAll('.goal-item');

            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const query = this.value.toLowerCase();
                    goalItems.forEach(item => {
                        const title = item.dataset.title.toLowerCase();
                        item.style.display = title.includes(query) ? '' : 'none';
                    });
                });
            }

            // Filter Functionality
            const filterBtns = document.querySelectorAll('.filter-btn');
            const typeFilterBtns = document.querySelectorAll('.type-filter-btn');
            
            function applyFilters() {
                const query = searchInput.value.toLowerCase();
                const activeStatusFilter = document.querySelector('.filter-btn.active').dataset.filter;
                const activeTypeFilter = document.querySelector('.type-filter-btn.active').dataset.typeFilter;
                
                goalItems.forEach(item => {
                    const matchesSearch = item.dataset.title.toLowerCase().includes(query);
                    const matchesStatus = activeStatusFilter === 'all' || item.dataset.status === activeStatusFilter;
                    const matchesType = activeTypeFilter === 'all' || item.dataset.type === activeTypeFilter;
                    
                    if (matchesSearch && matchesStatus && matchesType) {
                        item.style.display = '';
                    } else {
                        item.style.display = 'none';
                    }
                });
            }

            if (searchInput) {
                searchInput.addEventListener('input', applyFilters);
            }

            filterBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    filterBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    applyFilters();
                });
            });

            typeFilterBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    typeFilterBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    applyFilters();
                });
            });

            // Delete Functionality
            document.querySelectorAll('.delete-goal-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const id = this.dataset.id;
                    const title = this.closest('.goal-item').dataset.title;

                    Swal.fire({
                        title: '@Localizer["DeleteGoalTitle"]',
                        text: `@Localizer["DeleteGoalText"]`.replace("{title}", title),
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#64748b',
                        confirmButtonText: '@Localizer["YesDelete"]',
                        cancelButtonText: '@Localizer["Cancel"]',
                        customClass: { popup: 'rounded-4' }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                            const body = new URLSearchParams();
                            body.append('id', id);
                            if (token) body.append('__RequestVerificationToken', token);

                            fetch('/Goal/Delete', { 
                                method: 'POST', 
                                headers: { 
                                    'Content-Type': 'application/x-www-form-urlencoded',
                                    'X-Requested-With': 'XMLHttpRequest'
                                },
                                body: body
                            })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    location.reload();
                                } else {
                                    Swal.fire('@Localizer["Error"]!', data.message || '@Localizer["CouldNotDeleteGoal"]', 'error');
                                }
                            })
                            .catch(err => {
                                console.error(err);
                                location.reload();
                            });
                        }
                    })
                });
            });

            // Regenerate AI Strategy
            document.querySelectorAll('.regenerate-ai-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const goalId = this.dataset.goalId;
                    const contentBox = document.getElementById(`aiContent-${goalId}`);
                    const icon = this.querySelector('i');
                    
                    if (icon.classList.contains('fa-spin')) return;
                    
                    icon.classList.add('fa-spin');
                    contentBox.innerHTML = `<p class="text-muted x-small mb-0 italic">${'@Localizer["AIDataAnalyzing"]'}</p>`;
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const body = new URLSearchParams();
                    body.append('goalId', goalId);
                    if (token) body.append('__RequestVerificationToken', token);

                    fetch('/Goal/RegenerateAIStrategy', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: body
                    })
                    .then(res => res.json())
                    .then(data => {
                        icon.classList.remove('fa-spin');
                        if (data.success) {
                            contentBox.innerHTML = `<div class="ai-response-content">${marked.parse(data.actionPlan)}</div>`;
                        } else {
                            contentBox.innerHTML = '<p class="text-danger x-small mb-0">Không thể tạo kế hoạch lúc này.</p>';
                        }

                    })
                    .catch(err => {
                        icon.classList.remove('fa-spin');
                        contentBox.innerHTML = '<p class="text-danger x-small mb-0">Đã xảy ra lỗi kết nối.</p>';
                    });
                });
            });

            // Refresh Button
            const refreshBtn = document.getElementById('refreshBtn');
            if (refreshBtn) {
                refreshBtn.addEventListener('click', () => {
                    const icon = refreshBtn.querySelector('i');
                    if (icon) icon.classList.add('fa-spin');
                    location.reload();
                });
            }

            // SignalR Real-time Updates
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/goalHub")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveGoalUpdate", function (data) {
                const goalItem = document.querySelector(`.goal-item[data-id="${data.goalId}"]`);
                if (goalItem) {
                    const pct = Math.round(data.newProgress);
                    const bar = goalItem.querySelector('.progress-bar');
                    const taskVal = goalItem.querySelector('.task-counter');
                    const effortVal = goalItem.querySelector('.effort-counter');
                    
                    if (bar) bar.style.width = pct + '%';
                    if (taskVal) taskVal.innerHTML = `${data.completedTasks} / ${data.targetTasks}`;
                    if (effortVal && data.currentValue !== undefined) {
                        // Assuming targetHours is static or we'd need to send it too
                        const currentEffortText = effortVal.innerText;
                        const targetPart = currentEffortText.split('/')[1] || "0 hrs";
                        effortVal.innerHTML = `${parseFloat(data.currentValue).toFixed(1)} / ${targetPart}`;
                    }
                    goalItem.dataset.status = data.status;
                }
            });

            connection.start().catch(err => console.log("SignalR connection error:", err));

            // Create Goal Modal Logic
            const typeTask = document.getElementById('typeTask');
            const typeTime = document.getElementById('typeTime');
            const titleGroup = document.getElementById('titleGroup');
            const projectGroup = document.getElementById('projectGroup');
            const projectSelect = document.getElementById('ProjectId');
            const titleInput = document.getElementById('Title');
            const targetHoursInput = document.getElementById('TargetHours');

            function toggleType() {
                if (typeTask.checked) {
                    titleGroup.classList.add('d-none');
                    titleInput.required = false;
                    projectGroup.classList.remove('d-none');
                    projectSelect.required = true;
                    targetHoursInput.required = false;
                } else {
                    titleGroup.classList.remove('d-none');
                    titleInput.required = true;
                    projectGroup.classList.add('d-none');
                    projectSelect.required = false;
                    targetHoursInput.required = true;
                }
            }

            typeTask?.addEventListener('change', toggleType);
            typeTime?.addEventListener('change', toggleType);

            // AJAX Submit for Create Goal
            document.getElementById('createGoalForm')?.addEventListener('submit', function(e) {
                e.preventDefault();
                const form = this;
                const submitBtn = document.getElementById('createGoalSubmitBtn');
                const originalText = submitBtn.innerHTML;
                
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>' + '@Localizer["Saving"]';
                
                fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        Swal.fire('@Localizer["Error"]', data.message || '@Localizer["ValidationFailed"]', 'error');
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalText;
                    }
                })
                .catch(err => {
                    console.error(err);
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                });
            });
            // Edit Goal Modal Logic
            const editGoalModal = new bootstrap.Modal(document.getElementById('editGoalModal'));
            const editTitleGroup = document.getElementById('editTitleGroup');
            const editProjectGroup = document.getElementById('editProjectGroup');

            function toggleEditType(type) {
                if (type === 'TaskBased') {
                    editTitleGroup.classList.add('d-none');
                    editProjectGroup.classList.remove('d-none');
                } else {
                    editTitleGroup.classList.remove('d-none');
                    editProjectGroup.classList.add('d-none');
                }
            }


            document.querySelectorAll('.edit-goal-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const id = this.dataset.goalId;
                    fetch(`/Goal/Details/${id}`, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(res => res.json())
                    .then(data => {
                        document.getElementById('editGoalId').value = data.id;
                        document.getElementById('editTitle').value = data.title || '';
                        document.getElementById('editDescription').value = data.description || '';
                        document.getElementById('editTargetDate').value = data.targetDate;
                        document.getElementById('editTargetHours').value = data.targetHours;
                        document.getElementById('editProjectId').value = data.projectId || '';
                        
                        document.getElementById('editGoalType').value = data.type;
                        toggleEditType(data.type);

                        editGoalModal.show();
                    })
                    .catch(err => console.error(err));
                });
            });

            document.getElementById('editGoalForm').addEventListener('submit', function(e) {
                e.preventDefault();
                const form = this;
                const id = document.getElementById('editGoalId').value;
                const submitBtn = document.getElementById('editGoalSubmitBtn');
                const originalText = submitBtn.innerHTML;
                
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>' + '@Localizer["Saving"]';
                
                fetch(`/Goal/Edit/${id}`, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        Swal.fire('@Localizer["Error"]', data.message || '@Localizer["ValidationFailed"]', 'error');
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalText;
                    }
                })
                .catch(err => {
                    console.error(err);
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                });
            });
        });
    </script>
}

