@model IEnumerable<DACS_TimeManagement.Models.PersonalGoal>
@inject DACS_TimeManagement.Services.Interfaces.IGoalService GoalService
@{
    ViewData["Title"] = "Goal Management";
    var totalGoals = Model.Count();
    var completedGoals = Model.Count(g => g.Status == DACS_TimeManagement.Models.GoalStatus.Completed);
    var overallProgress = totalGoals == 0 ? 0 : (completedGoals * 100 / totalGoals);
}

@Html.AntiForgeryToken()

<div class="goals-container" data-aos="fade-up">
    <!-- Action Bar -->
    <div class="d-flex justify-content-end align-items-center mb-4 flex-wrap gap-2">
        <button class="btn btn-light rounded-pill px-3 shadow-sm hover-lift" id="refreshBtn" title="Refresh data">
            <i class="fas fa-sync-alt"></i>
        </button>
        <a asp-action="Create" class="btn btn-pastel-primary rounded-pill px-4 shadow-sm fw-semibold hover-lift">
            <i class="fas fa-plus-circle me-2"></i>Set Up New Goal
        </a>
    </div>

    <!-- Stats Overview Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-3 col-6">
            <div class="stat-card-premium glass-premium">
                <span class="stat-icon-bg"><i class="fas fa-bullseye"></i></span>
                <div class="stat-value">@totalGoals</div>
                <div class="stat-label">Total Goals</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card-premium glass-premium highlight-success">
                <span class="stat-icon-bg"><i class="fas fa-check-double"></i></span>
                <div class="stat-value">@completedGoals</div>
                <div class="stat-label">Completed</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card-premium glass-premium highlight-warning">
                <span class="stat-icon-bg"><i class="fas fa-fire"></i></span>
                <div class="stat-value" id="globalStreak">@(ViewBag.GlobalStreak ?? 0)</div>
                <div class="stat-label">Day Streak</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card-premium glass-premium highlight-info">
                <span class="stat-icon-bg"><i class="fas fa-chart-pie"></i></span>
                <div class="stat-value">@overallProgress%</div>
                <div class="stat-label">Overall Progress</div>
            </div>
        </div>
    </div>

    <!-- Toolbar: Search and Filters -->
    <div class="toolbar glass-premium p-3 mb-4 d-flex flex-wrap justify-content-between align-items-center gap-3 shadow-sm">
        <div class="search-box position-relative flex-grow-1" style="max-width: 400px;">
            <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
            <input type="text" id="goalSearch" class="form-control rounded-pill ps-5 border-0 bg-light" placeholder="Search goals...">
        </div>
        <div class="filter-group d-flex gap-2 overflow-auto pb-1 border-end pe-3 me-2">
            <span class="small text-muted align-self-center me-2 d-none d-md-block">Status:</span>
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="Active">Active</button>
            <button class="filter-btn" data-filter="Completed">Completed</button>
            <button class="filter-btn" data-filter="Behind">Behind</button>
        </div>
        <div class="filter-group d-flex gap-2 overflow-auto pb-1">
            <span class="small text-muted align-self-center me-2 d-none d-md-block">Type:</span>
            <button class="type-filter-btn active" data-type-filter="all">All</button>
            <button class="type-filter-btn" data-type-filter="TaskBased">Project</button>
            <button class="type-filter-btn" data-type-filter="TimeBased">Personal</button>
        </div>
    </div>

    <!-- Goals Grid -->
    <div class="row g-4" id="goalsGrid">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="empty-state-card card border-0 shadow-lg rounded-4 p-5 text-center">
                    <div class="mb-4">
                        <i class="fas fa-bullseye fa-4x text-pastel-muted opacity-50"></i>
                    </div>
                    <h4 class="fw-bold">No goals defined yet</h4>
                    <p class="text-muted mb-4">Start by creating a goal linked to one of your projects.</p>
                    <a asp-action="Create" class="btn btn-pastel-primary rounded-pill px-4 fw-semibold mx-auto">Set Your First Goal</a>
                </div>
            </div>
        }
        else
        {
            var pastelColors = new[] { "pastel-blue", "pastel-green", "pastel-yellow", "pastel-pink", "pastel-purple", "pastel-mint" };
            var colorIndex = 0;

            foreach (var goal in Model)
            {
                var colorClass = pastelColors[colorIndex % pastelColors.Length];
                colorIndex++;

                var progressPercent = goal.TargetValue == 0 ? 0 : (int)Math.Min(100, (double)goal.CurrentValue / goal.TargetValue * 100);
                var isCompleted = goal.Status == DACS_TimeManagement.Models.GoalStatus.Completed;
                var daysRemaining = (goal.TargetDate.Date - DateTime.Now.Date).Days;
                var aiShortStatus = GoalService.GetAIShortStatus(goal);
                
                // Determine CSS class for AI Status
                var aiStatusClass = aiShortStatus switch {
                    "Completed" => "text-success fw-bold",
                    "At Risk" => "text-danger fw-bold",
                    "Finishing" => "text-success fw-bold",
                    "Excellent" => "text-primary fw-bold",
                    "Ahead" => "text-info fw-bold",
                    "On Track" => "text-primary fw-semibold",
                    "Starting Up" => "text-muted italic",
                    "Initializing" => "text-info italic",
                    _ => "text-muted"
                };

                <div class="col-lg-6 col-xl-4 goal-item" data-id="@goal.Id" data-status="@goal.Status" data-type="@goal.Type" data-title="@goal.Title">
                    <div class="goal-card card border-0 shadow-md rounded-4 overflow-hidden hover-lift @colorClass h-100">
                        <div class="card-body p-4 d-flex flex-column">
                            <!-- Card Actions -->
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="goal-title fw-bold mb-0 text-truncate" title="@goal.Title">@goal.Title</h5>
                                <div class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@goal.Id" class="btn btn-sm rounded-circle border-0 bg-white bg-opacity-50 text-secondary hover-scale" title="View History">
                                        <i class="fas fa-clock-rotate-left"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@goal.Id" class="btn btn-sm rounded-circle border-0 bg-white bg-opacity-50 text-primary hover-scale" title="Edit">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <button class="btn btn-sm rounded-circle border-0 bg-white bg-opacity-50 text-danger delete-goal-btn hover-scale" data-id="@goal.Id" title="Delete">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Progress Info -->
                            <div class="progress-info mb-4">
                                @if (goal.Type == DACS_TimeManagement.Models.GoalType.TaskBased)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="small text-muted fw-medium"><i class="fas fa-tasks me-1"></i> Tasks</span>
                                        <span class="small fw-bold text-dark task-counter">@goal.CompletedTasks / @(goal.TargetTasks ?? 0)</span>
                                    </div>
                                }
                                @if (goal.TargetHours.HasValue)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="small text-muted fw-medium"><i class="fas fa-clock me-1"></i> Effort</span>
                                        <span class="small fw-bold text-dark effort-counter">@(goal.CompletedHours < (1.0/60.0) ? (Math.Round(goal.CompletedHours * 3600)) + "s" : (goal.CompletedHours < 1 ? (Math.Round(goal.CompletedHours * 60)) + "m" : goal.CompletedHours.ToString("F1") + "h")) / @goal.TargetHours.Value.ToString("F1")h</span>
                                    </div>
                                }
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small text-muted fw-medium"><i class="far fa-calendar-alt me-1"></i> Deadline</span>
                                    <span class="small fw-bold text-dark">@goal.TargetDate.ToString("dd/MM/yyyy")</span>
                                </div>

                                <!-- Progress Bar -->
                                <div class="progress rounded-pill mb-2" style="height: 8px; background: rgba(0,0,0,0.05);">
                                    <div class="progress-bar rounded-pill @(isCompleted ? "bg-success" : "")" 
                                         role="progressbar" 
                                         style="width: @progressPercent%; transition: width 1s ease;" 
                                         aria-valuenow="@progressPercent" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100"></div>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="x-small @aiStatusClass"><i class="fas fa-robot me-1"></i> @aiShortStatus</span>
                                    <span class="x-small fw-bold @(daysRemaining < 0 ? "text-danger" : "text-primary")">
                                        @if (daysRemaining < 0) {
                                            @:Overdue
                                        } else if (daysRemaining == 0) {
                                            @:Due Today
                                        } else {
                                            @:@daysRemaining days left
                                        }
                                    </span>
                                </div>
                            </div>

                            <!-- AI Strategy Box -->
                            <div class="ai-strategy-box rounded-3 p-3 mb-4 flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="d-flex align-items-center">
                                        <div class="ai-icon bg-white rounded-2 p-1 me-2 shadow-sm">
                                            <i class="fas fa-robot text-primary small"></i>
                                        </div>
                                        <span class="x-small fw-bold text-uppercase letter-spacing-1">AI Strategy</span>
                                    </div>
                                    <button class="btn btn-sm btn-link text-primary p-0 regenerate-ai-btn" data-goal-id="@goal.Id" title="Update Strategy">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                </div>
                                <div class="ai-content-scroll" id="aiContent-@goal.Id">
                                    @if (!string.IsNullOrEmpty(goal.AIActionPlan))
                                    {
                                        <div class="ai-text small">
                                            @Html.Raw(goal.AIActionPlan.Replace("\n", "<br/>"))
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted x-small mb-0 italic">Analyzing project data for optimal strategy...</p>
                                    }
                                </div>
                            </div>

                            <!-- Recent Activity Mini Log -->
                            <div class="recent-activity mb-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-clock-rotate-left text-muted x-small me-2"></i>
                                    <span class="x-small fw-bold text-muted text-uppercase letter-spacing-1">Recent Activity</span>
                                </div>
                                <div class="activity-list">
                                    @{
                                        var now = DateTime.UtcNow;
                                        var recentLogs = goal.GoalTasks
                                            .SelectMany(gt => gt.WorkTask.TimeLogs)
                                            .Select(tl => new { Date = tl.LogDate, Note = tl.Note, Duration = (double?)tl.DurationHours, IsTask = true })
                                            .Concat(goal.GoalProgressHistories
                                                .Where(h => !string.IsNullOrEmpty(h.Note) && !h.Note.Contains("Auto update"))
                                                .Select(h => new { Date = h.RecordedAt, Note = h.Note, Duration = (double?)null, IsTask = false }))
                                            .OrderByDescending(x => x.Date)
                                            .Take(3)
                                            .ToList();
                                    }
                                    @foreach (var log in recentLogs)
                                    {
                                        var isJustNow = (now - log.Date).TotalMinutes < 1;
                                        <div class="activity-item d-flex justify-content-between align-items-center py-1 border-bottom border-light">
                                            <div class="text-truncate me-2" style="max-width: 150px;">
                                                <span class="xx-small d-block @(isJustNow ? "text-success fw-bold" : "text-muted")">
                                                    @(isJustNow ? "Just now" : log.Date.ToString("dd/MM HH:mm"))
                                                </span>
                                                <span class="x-small text-dark">@log.Note</span>
                                            </div>
                                            @if (log.Duration.HasValue)
                                            {
                                                var s = (int)Math.Round(log.Duration.Value * 3600);
                                                <span class="badge bg-light text-primary border xx-small">@(s < 60 ? s + "s" : (s / 60) + "m")</span>
                                            }
                                            else if (log.Note.Contains("giây"))
                                            {
                                                <span class="badge bg-light text-success border xx-small">Focus</span>
                                            }
                                        </div>
                                    }
                                    @if (!recentLogs.Any())
                                    {
                                        <div class="text-muted xx-small italic">No recent focus sessions.</div>
                                    }
                                </div>
                            </div>

                            <!-- Footer Actions -->
                            <div class="d-flex gap-2 mt-auto">
                                <a asp-action="Focus" asp-route-id="@goal.Id" class="btn btn-primary btn-sm flex-grow-1 rounded-pill fw-bold shadow-sm">
                                    <i class="fas fa-brain me-1"></i> Focus
                                </a>
                                <a asp-action="Details" asp-route-id="@goal.Id" class="btn btn-outline-secondary btn-sm flex-grow-1 rounded-pill fw-bold">
                                    Details & History
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Fetch Global Streak
            fetch('/Goal/GetGlobalStreak')
                .then(res => res.json())
                .then(data => {
                    const streakEl = document.getElementById('globalStreak');
                    if (streakEl) streakEl.innerText = data.streak;
                })
                .catch(err => console.error("Error fetching streak:", err));

            // Search Functionality
            const searchInput = document.getElementById('goalSearch');
            const goalItems = document.querySelectorAll('.goal-item');

            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const query = this.value.toLowerCase();
                    goalItems.forEach(item => {
                        const title = item.dataset.title.toLowerCase();
                        item.style.display = title.includes(query) ? '' : 'none';
                    });
                });
            }

            // Filter Functionality
            const filterBtns = document.querySelectorAll('.filter-btn');
            const typeFilterBtns = document.querySelectorAll('.type-filter-btn');
            
            function applyFilters() {
                const query = searchInput.value.toLowerCase();
                const activeStatusFilter = document.querySelector('.filter-btn.active').dataset.filter;
                const activeTypeFilter = document.querySelector('.type-filter-btn.active').dataset.typeFilter;
                
                goalItems.forEach(item => {
                    const matchesSearch = item.dataset.title.toLowerCase().includes(query);
                    const matchesStatus = activeStatusFilter === 'all' || item.dataset.status === activeStatusFilter;
                    const matchesType = activeTypeFilter === 'all' || item.dataset.type === activeTypeFilter;
                    
                    if (matchesSearch && matchesStatus && matchesType) {
                        item.style.display = '';
                    } else {
                        item.style.display = 'none';
                    }
                });
            }

            if (searchInput) {
                searchInput.addEventListener('input', applyFilters);
            }

            filterBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    filterBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    applyFilters();
                });
            });

            typeFilterBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    typeFilterBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    applyFilters();
                });
            });

            // Delete Functionality
            document.querySelectorAll('.delete-goal-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const id = this.dataset.id;
                    const title = this.closest('.goal-item').dataset.title;

                    Swal.fire({
                        title: 'Delete Goal?',
                        text: `Are you sure you want to delete "${title}"? This action cannot be undone.`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ef4444',
                        cancelButtonColor: '#64748b',
                        confirmButtonText: 'Yes, delete it',
                        cancelButtonText: 'Cancel',
                        customClass: { popup: 'rounded-4' }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                            const body = new URLSearchParams();
                            body.append('id', id);
                            if (token) body.append('__RequestVerificationToken', token);

                            fetch('/Goal/Delete', { 
                                method: 'POST', 
                                headers: { 
                                    'Content-Type': 'application/x-www-form-urlencoded',
                                    'X-Requested-With': 'XMLHttpRequest'
                                },
                                body: body
                            })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    location.reload();
                                } else {
                                    Swal.fire('Error!', data.message || 'Could not delete goal', 'error');
                                }
                            })
                            .catch(err => {
                                console.error(err);
                                location.reload();
                            });
                        }
                    })
                });
            });

            // Regenerate AI Strategy
            document.querySelectorAll('.regenerate-ai-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const goalId = this.dataset.goalId;
                    const contentBox = document.getElementById(`aiContent-${goalId}`);
                    const icon = this.querySelector('i');
                    
                    if (icon.classList.contains('fa-spin')) return;
                    
                    icon.classList.add('fa-spin');
                    contentBox.innerHTML = '<p class="text-muted x-small mb-0 italic">AI đang phân tích dữ liệu mới nhất...</p>';
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const body = new URLSearchParams();
                    body.append('goalId', goalId);
                    if (token) body.append('__RequestVerificationToken', token);

                    fetch('/Goal/RegenerateAIStrategy', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: body
                    })
                    .then(res => res.json())
                    .then(data => {
                        icon.classList.remove('fa-spin');
                        if (data.success) {
                            contentBox.innerHTML = `<div class="ai-text small">${data.actionPlan.replace(/\\n/g, '<br/>')}</div>`;
                        } else {
                            contentBox.innerHTML = '<p class="text-danger x-small mb-0">Không thể tạo kế hoạch lúc này.</p>';
                        }
                    })
                    .catch(err => {
                        icon.classList.remove('fa-spin');
                        contentBox.innerHTML = '<p class="text-danger x-small mb-0">Đã xảy ra lỗi kết nối.</p>';
                    });
                });
            });

            // Refresh Button
            const refreshBtn = document.getElementById('refreshBtn');
            if (refreshBtn) {
                refreshBtn.addEventListener('click', () => {
                    const icon = refreshBtn.querySelector('i');
                    if (icon) icon.classList.add('fa-spin');
                    location.reload();
                });
            }

            // SignalR Real-time Updates
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/goalHub")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveGoalUpdate", function (data) {
                const goalItem = document.querySelector(`.goal-item[data-id="${data.goalId}"]`);
                if (goalItem) {
                    const pct = Math.round(data.newProgress);
                    const bar = goalItem.querySelector('.progress-bar');
                    const taskVal = goalItem.querySelector('.task-counter');
                    const effortVal = goalItem.querySelector('.effort-counter');
                    
                    if (bar) bar.style.width = pct + '%';
                    if (taskVal) taskVal.innerHTML = `${data.completedTasks} / ${data.targetTasks}`;
                    if (effortVal && data.currentValue !== undefined) {
                        // Assuming targetHours is static or we'd need to send it too
                        const currentEffortText = effortVal.innerText;
                        const targetPart = currentEffortText.split('/')[1] || "0 hrs";
                        effortVal.innerHTML = `${parseFloat(data.currentValue).toFixed(1)} / ${targetPart}`;
                    }
                    goalItem.dataset.status = data.status;
                }
            });

            connection.start().catch(err => console.log("SignalR connection error:", err));
        });
    </script>
}

<style>
    :root {
        /* Pastel Palette */
        --pastel-blue-bg: #e0f2fe;
        --pastel-blue-border: #7dd3fc;
        --pastel-blue-text: #0284c7;
        --pastel-green-bg: #dcfce7;
        --pastel-green-border: #86efac;
        --pastel-green-text: #16a34a;
        --pastel-yellow-bg: #fef9c3;
        --pastel-yellow-border: #fde047;
        --pastel-yellow-text: #ca8a04;
        --pastel-pink-bg: #fce7f3;
        --pastel-pink-border: #f9a8d4;
        --pastel-pink-text: #db2777;
        --pastel-purple-bg: #f3e8ff;
        --pastel-purple-border: #d8b4fe;
        --pastel-purple-text: #9333ea;
        --pastel-mint-bg: #ccfbf1;
        --pastel-mint-border: #5eead4;
        --pastel-mint-text: #0d9488;
        
        --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
    }

    .goals-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0;
    }

    .glass-premium {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 24px;
    }

    .stat-card-premium { padding: 1.5rem; position: relative; overflow: hidden; transition: transform 0.3s ease; }
    .stat-card-premium:hover { transform: translateY(-5px); }
    .stat-icon-bg { position: absolute; right: -10px; bottom: -10px; font-size: 4rem; opacity: 0.05; transform: rotate(-15deg); }
    .stat-value { font-size: 1.75rem; font-weight: 800; color: #1e293b; }
    .stat-label { font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }

    .highlight-success .stat-value { color: #10b981; }
    .highlight-warning .stat-value { color: #f59e0b; }
    .highlight-info .stat-value { color: #0ea5e9; }

    .filter-btn, .type-filter-btn { border: none; background: transparent; padding: 0.4rem 1.2rem; border-radius: 50px; font-weight: 600; color: #64748b; transition: 0.3s; white-space: nowrap; font-size: 0.85rem; }
    .filter-btn:hover, .type-filter-btn:hover { background: rgba(99, 102, 241, 0.05); color: #6366f1; }
    .filter-btn.active, .type-filter-btn.active { background: var(--primary-gradient); color: white; box-shadow: 0 4px 12px rgba(99,102,241,0.2); }

    /* Goal Card Pastel Variants */
    .goal-card.pastel-blue { background: var(--pastel-blue-bg); border-left: 4px solid var(--pastel-blue-border); }
    .goal-card.pastel-green { background: var(--pastel-green-bg); border-left: 4px solid var(--pastel-green-border); }
    .goal-card.pastel-yellow { background: var(--pastel-yellow-bg); border-left: 4px solid var(--pastel-yellow-border); }
    .goal-card.pastel-pink { background: var(--pastel-pink-bg); border-left: 4px solid var(--pastel-pink-border); }
    .goal-card.pastel-purple { background: var(--pastel-purple-bg); border-left: 4px solid var(--pastel-purple-border); }
    .goal-card.pastel-mint { background: var(--pastel-mint-bg); border-left: 4px solid var(--pastel-mint-border); }

    .goal-card { transition: all 0.3s ease; }
    .goal-card:hover { transform: translateY(-6px); box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.15) !important; }

