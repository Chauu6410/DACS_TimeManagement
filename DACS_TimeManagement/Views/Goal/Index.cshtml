@model IEnumerable<DACS_TimeManagement.Models.PersonalGoal>
@{
    ViewData["Title"] = "Personal Goals";
}

<div class="goals-container" data-aos="fade-up">
    <!-- Header Pastel -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="icon-circle bg-pastel-primary-soft">
                <i class="fas fa-bullseye text-pastel-primary fs-4"></i>
            </div>
            <div>
                <h1 class="display-6 fw-bold text-gradient-pastel mb-0">Personal Goals</h1>
                <p class="text-pastel-muted small mb-0">Track your long-term achievements</p>
            </div>
        </div>
        <a asp-action="Create" class="btn btn-pastel-primary rounded-pill px-4 shadow-sm mt-2 mt-sm-0">
            <i class="fas fa-plus me-2"></i>Set New Goal
        </a>
    </div>

    <!-- Goals Grid -->
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="empty-state-card card border-0 shadow-lg rounded-4 p-5 text-center">
                    <i class="fas fa-trophy fa-4x text-pastel-muted opacity-50 mb-3"></i>
                    <h4 class="fw-semibold text-pastel-dark">No goals set yet!</h4>
                    <p class="text-pastel-muted mb-4">Setting goals helps you track long-term achievements and stay motivated.</p>
                    <a asp-action="Create" class="btn btn-pastel-primary rounded-pill mx-auto px-4">Set First Goal</a>
                </div>
            </div>
        }

        @foreach (var goal in Model)
        {
            var isAchieved = goal.CurrentValue >= goal.TargetValue;
            var statusText = isAchieved ? "Achieved" : "In Progress";
            var statusClass = isAchieved ? "pastel-success" : "pastel-primary";
            var progressPercent = goal.TargetValue == 0 ? 0 : (int)Math.Min(100, (double)goal.CurrentValue / goal.TargetValue * 100);
            var ringColor = isAchieved ? "var(--pastel-success-dark)" : "var(--pastel-primary-dark)";
            
            <div class="col-md-6 col-lg-4">
                <div class="goal-card card border-0 shadow-md rounded-4 overflow-hidden hover-lift">
                    <!-- Card Header -->
                    <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                        <span class="badge @statusClass rounded-pill px-3 py-1 fw-semibold">@statusText</span>
                        <div class="dropdown">
                            <button class="btn btn-sm rounded-circle border-0 bg-pastel-soft" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-ellipsis-v text-pastel-muted"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3">
                                <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@goal.Id"><i class="fas fa-edit me-2 text-pastel-primary"></i>Edit</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@goal.Id"><i class="fas fa-trash-alt me-2"></i>Delete</a></li>
                            </ul>
                        </div>
                    </div>

                    <!-- Card Body -->
                    <div class="card-body p-4 text-center">
                        <h5 class="fw-bold text-pastel-dark mb-1 text-truncate" title="@goal.GoalName">@goal.GoalName</h5>
                        <p class="text-pastel-muted small mb-4">
                            <i class="far fa-calendar-alt me-1"></i>Due: @goal.TargetDate.ToString("MMM dd, yyyy")
                        </p>

                        <!-- Progress Ring Pastel -->
                        <div class="position-relative d-inline-block mb-4">
                            <svg width="120" height="120">
                                <circle cx="60" cy="60" r="50" fill="none" stroke="var(--pastel-border)" stroke-width="8"></circle>
                                <circle cx="60" cy="60" r="50" fill="none" stroke="@ringColor" stroke-width="8" 
                                        stroke-dasharray="314.16" stroke-dashoffset="@(314.16 - (314.16 * progressPercent / 100))" 
                                        style="transition: stroke-dashoffset 0.6s ease; transform: rotate(-90deg); transform-origin: 50% 50%;"></circle>
                            </svg>
                            <div class="position-absolute top-50 start-50 translate-middle text-center">
                                <span class="fs-2 fw-bold text-pastel-primary">@progressPercent%</span>
                            </div>
                        </div>

                        <!-- Current / Target Stats -->
                        <div class="stats-pill d-flex justify-content-center align-items-center gap-3 bg-pastel-soft rounded-3 p-2 mx-auto" style="max-width: 85%;">
                            <div class="text-end" style="min-width: 60px;">
                                <span class="d-block fs-4 fw-bold text-pastel-primary">@goal.CurrentValue</span>
                                <small class="text-pastel-muted text-uppercase fw-semibold" style="font-size: 0.65rem;">Current</small>
                            </div>
                            <div class="text-pastel-muted fw-bold">/</div>
                            <div class="text-start" style="min-width: 60px;">
                                <span class="d-block fs-4 fw-bold text-pastel-dark">@goal.TargetValue</span>
                                <small class="text-pastel-muted text-uppercase fw-semibold" style="font-size: 0.65rem;">Target</small>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Update Footer (if not achieved) -->
                    @if (!isAchieved)
                    {
                        <div class="card-footer bg-transparent border-top border-pastel p-3">
                            <label class="form-label small fw-semibold text-pastel-muted mb-1">
                                <i class="fas fa-sliders-h me-1"></i>Quick Update
                            </label>
                            <div class="d-flex align-items-center gap-3">
                                <input type="range" class="form-range pastel-range flex-grow-1" 
                                       min="0" max="@goal.TargetValue" value="@goal.CurrentValue" 
                                       id="slider-@goal.Id" onchange="updateGoalProgress(@goal.Id, this.value)">
                                <span class="badge bg-pastel-soft text-pastel-dark rounded-pill px-3 py-1" id="val-@goal.Id" style="min-width: 55px;">@goal.CurrentValue</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function updateGoalProgress(id, value) {
            const badge = document.getElementById('val-'+id);
            if (badge) badge.innerText = value;
            
            fetch('/Goal/UpdateProgress?id=' + id + '&value=' + value, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Reload to update progress ring and status
                    location.reload();
                } else {
                    alert('Error updating progress: ' + (data.message || 'Unknown error'));
                }
            })
            .catch(err => console.error('Error:', err));
        }
    </script>
}

<style>
    /* Pastel Goals Styles - đồng bộ với toàn bộ hệ thống */
    .goals-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .text-gradient-pastel {
        background: linear-gradient(135deg, var(--pastel-primary-dark, #818cf8), #c4b5fd);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }
    .bg-pastel-primary-soft {
        background: rgba(99, 102, 241, 0.12);
    }
    .text-pastel-primary {
        color: var(--pastel-primary-dark, #818cf8);
    }
    .text-pastel-dark {
        color: var(--pastel-dark, #1e293b);
    }
    .text-pastel-muted {
        color: var(--pastel-muted, #64748b);
    }
    .bg-pastel-soft {
        background: var(--pastel-soft, #f1f5f9);
    }
    .border-pastel {
        border-color: var(--pastel-border, #e2e8f0) !important;
    }

    /* Buttons & Badges Pastel */
    .btn-pastel-primary {
        background: var(--pastel-primary, #a5b4fc);
        color: #1e293b;
        border: none;
        transition: all 0.2s;
        font-weight: 500;
    }
    .btn-pastel-primary:hover {
        background: var(--pastel-primary-dark, #818cf8);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(129, 140, 248, 0.3);
    }
    .badge.pastel-primary {
        background: #e0e7ff;
        color: #4f46e5;
    }
    .badge.pastel-success {
        background: #dcfce7;
        color: #16a34a;
    }
    .pastel-success-dark {
        color: #22c55e;
    }

    /* Goal Card */
    .goal-card {
        background: var(--pastel-card-bg, #ffffff);
        border: 1px solid var(--pastel-border, #e5e7eb);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .goal-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px -12px rgba(0, 0, 0, 0.1);
    }

    .stats-pill {
        background: var(--pastel-soft, #f8fafc);
    }

    /* Range Slider Pastel */
    .pastel-range {
        height: 6px;
        border-radius: 10px;
        background: var(--pastel-border, #e2e8f0);
    }
    .pastel-range::-webkit-slider-thumb {
        background: var(--pastel-primary-dark, #818cf8);
        width: 16px;
        height: 16px;
        border-radius: 50%;
        cursor: pointer;
        transition: transform 0.1s;
    }
    .pastel-range::-webkit-slider-thumb:hover {
        transform: scale(1.2);
    }

    /* Empty State */
    .empty-state-card {
        background: var(--pastel-card-bg, #ffffff);
        border: 1px solid var(--pastel-border, #e5e7eb);
    }

    /* Dark Mode Variables */
    body.theme-dark {
        --pastel-primary: #818cf8;
        --pastel-primary-dark: #6366f1;
        --pastel-primary-soft: #1e293b;
        --pastel-success-dark: #4ade80;
        --pastel-border: #334155;
        --pastel-card-bg: #1e293b;
        --pastel-dark: #f1f5f9;
        --pastel-muted: #94a3b8;
        --pastel-soft: #0f172a;
    }
    body.theme-dark .badge.pastel-primary {
        background: #1e293b;
        color: #a5b4fc;
    }
    body.theme-dark .badge.pastel-success {
        background: #14532d;
        color: #bbf7d0;
    }
    body.theme-dark .stats-pill {
        background: #0f172a;
    }
    body.theme-dark .pastel-range {
        background: #334155;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .goals-container {
            padding: 0 0.5rem;
        }
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .goal-card .card-body {
            padding: 1.25rem;
        }
        svg {
            width: 100px;
            height: 100px;
        }
        .stats-pill {
            gap: 1rem !important;
        }
        .stats-pill .fs-4 {
            font-size: 1.3rem;
        }
    }
</style>