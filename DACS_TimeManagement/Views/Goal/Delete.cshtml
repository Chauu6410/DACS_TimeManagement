@model DACS_TimeManagement.Models.PersonalGoal
@{
    ViewData["Title"] = "Delete Goal";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-danger text-white p-4 text-center">
                <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
                <h3 class="mb-0 fw-bold">Delete Goal</h3>
            </div>
            <div class="card-body p-4 text-center">
                <h5 class="mb-3">Are you sure you want to abandon this goal?</h5>
                <h3 class="text-dark fw-bold mb-3">"@Model.GoalName"</h3>
                
                <p class="text-muted mb-4">
                    Deleting this goal will permanently erase your progress tracking data. 
                </p>

                <form asp-action="Delete" method="post" class="d-flex justify-content-center gap-3 mt-4">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-light border px-4 py-2 fw-bold text-muted">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-danger px-4 py-2 fw-bold shadow">
                        <i class="fas fa-trash-alt me-2"></i>Yes, Delete Goal
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
