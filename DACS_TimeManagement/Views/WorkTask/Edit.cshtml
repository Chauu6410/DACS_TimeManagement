@model DACS_TimeManagement.Models.WorkTask

@{
    ViewData["Title"] = "Edit Task";
}

<div class="edit-task-container" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden transition-all hover-lift">
                <!-- Header Gradient -->
                <div class="card-header bg-gradient-primary text-white border-0 py-4 px-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-white bg-opacity-25 text-white">
                            <i class="fas fa-edit fs-4"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">Edit Task</h4>
                            <p class="opacity-75 small mb-0">Update your task details</p>
                        </div>
                    </div>
                </div>

                <!-- Form Body -->
                <div class="card-body p-4 p-lg-5">
                    <form asp-action="Edit" id="editTaskForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 border-0" role="alert"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <!-- Title -->
                            <div class="col-12">
                                <label asp-for="Title" class="form-label fw-semibold mb-2">
                                    <i class="fas fa-heading text-primary me-1"></i> Task Title
                                </label>
                                <input asp-for="Title" class="form-control form-control-lg rounded-3" placeholder="e.g., Complete project report" required />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold mb-2">
                                    <i class="fas fa-align-left text-primary me-1"></i> Description
                                </label>
                                <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Describe the task details..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <!-- Start & End Date -->
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label fw-semibold mb-2">
                                    <i class="far fa-calendar-alt text-primary me-1"></i> Start Date
                                </label>
                                <input asp-for="StartDate" type="datetime-local" class="form-control rounded-3" required />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label fw-semibold mb-2">
                                    <i class="far fa-calendar-check text-primary me-1"></i> Due Date
                                </label>
                                <input asp-for="EndDate" type="datetime-local" class="form-control rounded-3" required />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>

                            <!-- Priority, Status, Project -->
                            <div class="col-md-4">
                                <label asp-for="Priority" class="form-label fw-semibold mb-2">
                                    <i class="fas fa-flag text-primary me-1"></i> Priority
                                </label>
                                <select asp-for="Priority" class="form-select rounded-3" asp-items="Html.GetEnumSelectList<DACS_TimeManagement.Models.Priority>()"></select>
                                <span asp-validation-for="Priority" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Status" class="form-label fw-semibold mb-2">
                                    <i class="fas fa-chart-simple text-primary me-1"></i> Status
                                </label>
                                <select asp-for="Status" class="form-select rounded-3" asp-items="Html.GetEnumSelectList<DACS_TimeManagement.Models.TaskStatus>()"></select>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ProjectId" class="form-label fw-semibold mb-2">
                                    <i class="fas fa-diagram-project text-primary me-1"></i> Project
                                </label>
                                <select asp-for="ProjectId" class="form-select rounded-3" asp-items="ViewBag.ProjectId">
                                    <option value="">-- No Project --</option>
                                </select>
                                <span asp-validation-for="ProjectId" class="text-danger small"></span>
                            </div>

                            <!-- Assignee -->
                            <div class="col-12 mt-1">
                                <label asp-for="AssigneeId" class="form-label fw-semibold mb-2">
                                    <i class="fas fa-user-tag text-primary me-1"></i> Assignee
                                </label>
                                <select asp-for="AssigneeId" class="form-select rounded-3" asp-items="ViewBag.AssigneeId">
                                    <option value="">-- Select Member --</option>
                                </select>
                            </div>

                            <!-- Progress -->
                            <div class="col-12">
                                <label asp-for="Progress" class="form-label fw-semibold mb-2">
                                    <i class="fas fa-percent text-primary me-1"></i> Progress (%)
                                </label>
                                <div class="input-group">
                                    <input asp-for="Progress" type="number" min="0" max="100" class="form-control rounded-3" />
                                    <span class="input-group-text bg-light rounded-3">%</span>
                                </div>
                                <span asp-validation-for="Progress" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25" />

                        <!-- Form Actions -->
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                                <i class="fas fa-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Effect on focus
        document.querySelectorAll('.form-control, .form-select').forEach(input => {
            input.addEventListener('focus', function() {
                this.parentElement?.classList.add('focused');
            });
            input.addEventListener('blur', function() {
                this.parentElement?.classList.remove('focused');
            });
        });

        // AJAX update Assignee dropdown based on Project
        document.getElementById('ProjectId').addEventListener('change', function() {
            var projectId = this.value || "0";
            var assigneeSelect = document.getElementById('AssigneeId');
            
            fetch('/WorkTask/GetProjectMembers?projectId=' + projectId)
                .then(response => response.json())
                .then(data => {
                    assigneeSelect.innerHTML = '';
                    if (data.length > 1) {
                         assigneeSelect.innerHTML += '<option value="">-- Select Member --</option>';
                    }
                    data.forEach(item => {
                        var option = document.createElement('option');
                        option.value = item.id;
                        option.text = item.displayName;
                        assigneeSelect.appendChild(option);
                    });
                })
                .catch(error => console.error('Error fetching members:', error));
        });
    </script>
}

<style>
    /* Additional styles for Edit Task page */
    .edit-task-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 0.5rem;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, var(--primary, #6366f1), var(--primary-dark, #4f46e5));
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 60px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(4px);
    }

    .hover-lift {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .hover-lift:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.2) !important;
    }

    /* Form controls styling */
    .form-control, .form-select {
        border: 1px solid var(--border-color, #e2e8f0);
        background-color: var(--card-bg, #ffffff);
        color: var(--text-dark, #0f172a);
        transition: all 0.2s ease;
        font-size: 0.95rem;
        padding: 0.6rem 1rem;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--primary, #6366f1);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
        outline: none;
    }
    .form-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-muted, #64748b);
    }
    /* Progress slider styling */
    .form-range {
        height: 6px;
        border-radius: 10px;
        background: var(--border-color, #e2e8f0);
    }
    .form-range::-webkit-slider-thumb {
        background: var(--primary, #6366f1);
        width: 18px;
        height: 18px;
        border-radius: 50%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        cursor: pointer;
        transition: transform 0.1s;
    }
    .form-range::-webkit-slider-thumb:hover {
        transform: scale(1.2);
    }
    .progress-number {
        text-align: center;
        font-weight: 600;
    }
    /* Alert styling */
    .alert-danger {
        background: rgba(239, 68, 68, 0.1);
        border-left: 4px solid #ef4444;
        color: #b91c1c;
    }
    body.theme-dark .alert-danger {
        background: rgba(239, 68, 68, 0.2);
        color: #fca5a5;
        border-left-color: #ef4444;
    }
    /* Dark mode overrides */
    body.theme-dark .form-control,
    body.theme-dark .form-select {
        background-color: var(--card-bg, #1e293b);
        border-color: var(--border-color, #334155);
        color: #f1f5f9;
    }
    body.theme-dark .form-range {
        background: #334155;
    }
    body.theme-dark .btn-outline-secondary {
        color: #cbd5e1;
        border-color: #475569;
    }
    body.theme-dark .btn-outline-secondary:hover {
        background-color: #334155;
        color: white;
    }
    /* Responsive */
    @@media (max-width: 768px) {
        .card-body {
            padding: 1.5rem !important;
        }
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .btn {
            width: 100%;
            text-align: center;
            justify-content: center;
        }
        .d-flex.flex-wrap {
            flex-direction: column-reverse;
        }
        .progress-input-group {
            flex-wrap: wrap;
        }
        .progress-number {
            width: 100% !important;
            margin-top: 0.5rem;
        }
    }
</style>