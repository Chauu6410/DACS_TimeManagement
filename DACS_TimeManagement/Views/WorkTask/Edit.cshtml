@model DACS_TimeManagement.Models.WorkTask

@{
    ViewData["Title"] = "Edit Task";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white pb-3 pt-4 px-4">
                <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Task</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label fw-bold text-muted">Task Title</label>
                            <input asp-for="Title" class="form-control" placeholder="Enter task title" required />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold text-muted">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter task description (optional)"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-bold text-muted">Start Date</label>
                            <input asp-for="StartDate" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-bold text-muted">Due Date</label>
                            <input asp-for="EndDate" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="Priority" class="form-label fw-bold text-muted">Priority</label>
                            <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<DACS_TimeManagement.Models.Priority>()"></select>
                            <span asp-validation-for="Priority" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label fw-bold text-muted">Status</label>
                            <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<DACS_TimeManagement.Models.TaskStatus>()"></select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ProjectId" class="form-label fw-bold text-muted">Project</label>
                            <select asp-for="ProjectId" class="form-select" asp-items="ViewBag.ProjectId">
                                <option value="">-- No Project --</option>
                            </select>
                            <span asp-validation-for="ProjectId" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <label asp-for="Progress" class="form-label fw-bold text-muted">Progress (%)</label>
                            <div class="d-flex align-items-center gap-3">
                                <input asp-for="Progress" type="range" class="form-range flex-grow-1" min="0" max="100" id="progressSlider" oninput="document.getElementById('progressOutput').value = this.value" />
                                <input type="number" id="progressOutput" value="@Model.Progress" min="0" max="100" class="form-control" style="width: 80px;" oninput="document.getElementById('progressSlider').value = this.value;" />
                            </div>
                            <span asp-validation-for="Progress" class="text-danger"></span>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-light border px-4 fw-bold text-muted">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
