@model DACS_TimeManagement.Models.KanbanViewModel
@{
    ViewData["Title"] = "Kanban Board";
    var lists = Model?.BoardLists ?? new List<DACS_TimeManagement.Models.BoardList>();
}

<div class="kanban-page" data-aos="fade-up">
    <!-- Project Selector & Filters (if any) -->
    <div class="d-flex justify-content-end gap-2 mb-3 align-items-center">
        <form method="get" asp-action="Index" id="projectSelector" class="mb-0">
            <select name="projectId" class="form-select border-pastel shadow-sm rounded-pill fw-medium text-pastel-dark" style="min-width: 250px; background-color: white;" onchange="document.getElementById('projectSelector').submit();">
                @foreach (var p in Model.Projects)
                {
                    if (p.Id == Model.SelectedProjectId)
                    {
                        <option value="@p.Id" selected="selected">@p.Name</option>
                    }
                    else
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                }
            </select>
        </form>
    </div>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-pastel-danger rounded-3 border-0 mb-4">
            <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.ErrorMessage
        </div>
    }

    <!-- Kanban Board Container -->
    <div class="card border-0 shadow-xl rounded-4 overflow-hidden bg-pastel-card">
        <div class="card-body p-3 p-md-4">
            <div id="boardWrapper" class="overflow-auto" style="padding-bottom: 8px;">
                <div id="board" class="d-flex align-items-start" style="gap: 0.75rem;">
                    
                    @if (!lists.Any())
                    {
                        <div class="empty-state w-100 text-center py-5">
                            <i class="fas fa-clipboard-list fa-4x text-pastel-muted opacity-50 mb-3"></i>
                            <h5 class="fw-semibold">No columns in this project</h5>
                            <p class="text-pastel-muted">Please add columns (To Do, Doing, Done) in project settings.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var list in lists)
                        {
                            <div class="column pastel-column rounded-4 p-2 shadow-sm">
                                <div class="column-header d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom border-pastel">
                                    <div class="fw-semibold d-flex align-items-center gap-2">
                                        <span class="column-handle cursor-grab"><i class="fas fa-grip-vertical text-pastel-muted"></i></span>
                                        <span class="fs-5 text-pastel-dark">@list.Name</span>
                                    </div>
                                    <span class="badge bg-pastel-secondary text-pastel-dark rounded-pill px-3 py-1 count">@(list.WorkTasks?.Count ?? 0)</span>
                                </div>

                                <div class="task-list" data-list-id="@list.Id" style="min-height: 200px;">
                                    @if (list.WorkTasks != null)
                                    {
                                        foreach (var t in list.WorkTasks.OrderBy(x => x.Position))
                                        {
                                            <div class="card task-card pastel-task-card mb-3 border-0 shadow-sm rounded-3" data-task-id="@t.Id">
                                                <div class="card-body p-3">
                                                    <!-- Header: Title + Priority Badge -->
                                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                                        <h6 class="fw-bold mb-0 text-pastel-dark">
                                                            <a asp-controller="WorkTask" asp-action="Details" asp-route-id="@t.Id" class="text-decoration-none text-pastel-dark stretched-link">
                                                                @t.Title
                                                            </a>
                                                        </h6>
                                                        @{
                                                            string priorityClass = t.Priority switch
                                                            {
                                                                DACS_TimeManagement.Models.Priority.Urgent => "pastel-danger",
                                                                DACS_TimeManagement.Models.Priority.High => "pastel-danger",
                                                                DACS_TimeManagement.Models.Priority.Medium => "pastel-warning",
                                                                _ => "pastel-info"
                                                            };
                                                            string priorityText = t.Priority.ToString();
                                                        }
                                                        <div class="d-flex align-items-center gap-2 position-relative" style="z-index: 2;">
                                                            @* Edit link: only show if current user is creator or assignee or project owner. If assignee and not creator, opening edit will show request flow *@
                                                            @{
                                                                var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                                                var isCreatorOrAssignee = (t.UserId == currentUserId) || (t.AssigneeId == currentUserId);
                                                            }
                                                            @if (isCreatorOrAssignee)
                                                            {
                                                                <a href="/WorkTask/Edit/@t.Id" class="text-pastel-primary opacity-75 text-decoration-none" style="transition: opacity 0.2s;" onmouseover="this.classList.remove('opacity-75')" onmouseout="this.classList.add('opacity-75')" title="Sửa thẻ">
                                                                    <i class="fas fa-pen" style="font-size: 0.85rem;"></i>
                                                                </a>
                                                            }
                                                            @* If this task has a pending request, and current user is project owner, show approve/reject buttons on hover *@
                                                            @{
                                                                var pending = (ViewBag.PendingRequests as List<DACS_TimeManagement.Models.TaskChangeRequest>) ?? new List<DACS_TimeManagement.Models.TaskChangeRequest>();
                                                                var pr = pending.FirstOrDefault(r => r.TaskId == t.Id);
                                                                var isOwnerView = ViewBag.IsProjectOwner as bool? == true;
                                                            }
                                                            @if (pr != null && isOwnerView)
                                                            {
                                                                <div class="pending-controls ms-2" style="display:inline-block">
                                                                    <button class="btn btn-sm btn-success approve-btn" data-request-id="@pr.Id" title="Approve"><i class="fas fa-check"></i></button>
                                                                    <button class="btn btn-sm btn-danger reject-btn ms-1" data-request-id="@pr.Id" title="Reject"><i class="fas fa-times"></i></button>
                                                                </div>
                                                            }
                                                            <form asp-action="Delete" asp-route-id="@t.Id" method="post" class="d-inline m-0 p-0" onsubmit="return confirmDeleteTask(event, this);">
                                                                <button type="submit" class="btn btn-link text-danger p-0 opacity-75 text-decoration-none border-0" style="transition: opacity 0.2s; background: transparent;" onmouseover="this.classList.remove('opacity-75')" onmouseout="this.classList.add('opacity-75')" title="Xóa thẻ">
                                                                    <i class="fas fa-trash-alt" style="font-size: 0.85rem;"></i>
                                                                </button>
                                                            </form>
                                                            <span class="badge @priorityClass rounded-pill px-2 py-1 fs-6">@priorityText</span>
                                                        </div>
                                                    </div>

                                                    <!-- Description (cắt ngắn) -->
                                                    @if (!string.IsNullOrEmpty(t.Description))
                                                    {
                                                        <p class="small text-pastel-muted mb-3 task-description">
                                                            @(t.Description.Length > 100 ? t.Description.Substring(0, 100) + "..." : t.Description)
                                                        </p>
                                                    }
                                                    else
                                                    {
                                                        <p class="small text-pastel-muted mb-3"><i class="far fa-file-alt me-1"></i>No description</p>
                                                    }

                                                    <!-- Footer: Assignee + Due Date + Progress + Private -->
                                                    <div class="task-footer mt-2 pt-2 border-top border-pastel">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <!-- Assignee với avatar tròn -->
                                                            <div class="d-flex align-items-center gap-2">
                                                                @if (t.Assignee != null)
                                                                {
                                                                    <div class="avatar-xs rounded-circle bg-pastel-primary-soft d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                                                        <span class="fw-bold text-pastel-primary fs-6">@(t.Assignee.UserName?.Substring(0, 1).ToUpper() ?? "U")</span>
                                                                    </div>
                                                                    <span class="small fw-medium text-pastel-dark">@t.Assignee.UserName</span>
                                                                }
                                                                else
                                                                {
                                                                    <div class="avatar-xs rounded-circle bg-pastel-secondary-soft d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                                                        <i class="fas fa-user-slash text-pastel-muted fs-6"></i>
                                                                    </div>
                                                                    <span class="small text-pastel-muted">Unassigned</span>
                                                                }
                                                            </div>
                                                            <!-- Private lock -->
                                                            @if (t.IsPrivate)
                                                            {
                                                                <i class="fas fa-lock text-warning" title="Private (AES encrypted)" style="font-size: 0.8rem;"></i>
                                                            }
                                                        </div>

                                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                                            <small class="text-pastel-muted">
                                                                <i class="far fa-calendar-alt me-1"></i>Due: @t.EndDate.ToString("MMM dd, yyyy")
                                                            </small>
                                                            @if (t.Progress > 0)
                                                            {
                                                                <small class="text-pastel-success"><i class="fas fa-chart-simple me-1"></i>@t.Progress%</small>
                                                            }
                                                            else
                                                            {
                                                                <small class="text-pastel-muted">0%</small>
                                                            }
                                                        </div>

                                                        <!-- Progress bar nhỏ (optional) -->
                                                        @if (t.Progress > 0 && t.Progress < 100)
                                                        {
                                                            <div class="progress mt-2" style="height: 4px;">
                                                                <div class="progress-bar bg-pastel-primary" role="progressbar" style="width: @t.Progress%;" aria-valuenow="@t.Progress" aria-valuemin="0" aria-valuemax="100"></div>
                                                            </div>
                                                        }
                                                        else if (t.Progress == 100)
                                                        {
                                                            <div class="progress mt-2" style="height: 4px;">
                                                                <div class="progress-bar bg-success" role="progressbar" style="width: 100%;"></div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            @* Visual mark when a task has a pending request (client will add class 'pending') *@
                                            @{ var pendingList = (ViewBag.PendingRequests as List<DACS_TimeManagement.Models.TaskChangeRequest>) ?? new List<DACS_TimeManagement.Models.TaskChangeRequest>(); var hasPending = pendingList.Any(r => r.TaskId == t.Id); }
                                            <script>document.addEventListener('DOMContentLoaded', function(){ var el=document.querySelector('[data-task-id="@t.Id"]'); if(el && @((hasPending)?1:0)===1){ el.classList.add('pending-task'); } });</script>
                                            </div>
                                        }
                                    }
                                </div>

                                <div class="add-card-container px-2 pb-2">
                                    <button class="btn btn-sm text-pastel-dark text-start w-100 add-card-btn d-flex align-items-center" style="background: transparent; border: none; padding: 8px 12px; border-radius: 8px; transition: background 0.2s;">
                                        <i class="fas fa-plus me-2 text-pastel-muted"></i> <span class="fw-medium text-pastel-muted">Add task</span>
                                    </button>
                                    <div class="add-card-form d-none mt-2">
                                        <textarea class="form-control rounded-3 border-pastel shadow-sm mb-2 quick-task-title" rows="2" placeholder="Enter task title..."></textarea>
                                        <div class="d-flex align-items-center gap-2">
                                            <button class="btn btn-primary btn-sm rounded-3 px-3 fw-medium submit-quick-task" data-project-id="@Model.SelectedProjectId" data-list-id="@list.Id">Add task</button>
                                            <button class="btn btn-link text-pastel-muted p-0 cancel-add-card text-decoration-none hover-danger" style="font-size: 1.25rem;"><i class="fas fa-times"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js" defer></script>
    <script>
        function confirmDeleteTask(e, form) {
            e.preventDefault();
            Swal.fire({
                title: 'Delete this task?',
                text: "You won't be able to revert this action!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '<i class="fas fa-trash-alt me-1"></i> Yes, delete it',
                cancelButtonText: 'Cancel',
                background: document.body.classList.contains('theme-dark') ? '#1e293b' : '#ffffff',
                color: document.body.classList.contains('theme-dark') ? '#f8fafc' : '#334155',
                customClass: {
                    popup: 'rounded-4 shadow-xl border-0',
                    confirmButton: 'rounded-pill px-4',
                    cancelButton: 'rounded-pill px-4'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
            return false;
        }

        document.addEventListener('DOMContentLoaded', function() {
            const boardEl = document.getElementById('board');
            
            // 1. Sortable for columns
            if (boardEl) {
                new Sortable(boardEl, {
                    animation: 200,
                    handle: '.column-handle',
                    draggable: '.column',
                    ghostClass: 'sortable-ghost-column',
                    chosenClass: 'sortable-chosen-column'
                });
            }

            // 2. Sortable for tasks in each column
            function initTaskLists() {
                const lists = document.querySelectorAll('.task-list');
                lists.forEach(list => {
                    new Sortable(list, {
                        group: 'kanban',
                        animation: 200,
                        draggable: '.task-card',
                        ghostClass: 'sortable-ghost',
                        chosenClass: 'sortable-chosen',
                        onStart: function(evt) {
                            evt.item.classList.add('dragging');
                        },
                        onEnd: function(evt) {
                            evt.item.classList.remove('dragging');
                            
                            const taskId = evt.item.getAttribute('data-task-id');
                            const newListId = evt.to.getAttribute('data-list-id');
                            const newPosition = evt.newIndex;
                            
                            if (!taskId || !newListId) return;

                            const params = new URLSearchParams();
                            params.append('taskId', taskId);
                            params.append('newListId', newListId);
                            params.append('newPosition', newPosition);

                            fetch('/WorkTask/UpdateTaskPosition', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/x-www-form-urlencoded',
                                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                                },
                                body: params
                            })
                            .then(res => res.json())
                            .then(data => {
                                if (!data.success) {
                                    alert("Error: " + data.message);
                                    location.reload();
                                }

                                // If server indicates this change is pending approval, mark the moved card as pending
                                if (data.pending) {
                                    try {
                                        evt.item.classList.add('pending-task');
                                        // Optionally show pending-controls if present
                                        var controls = evt.item.querySelector('.pending-controls');
                                        if (controls) controls.style.display = 'inline-block';
                                    } catch(e) { console.error(e); }
                                }

                                updateCounts();
                            })
                            .catch(() => {
                                alert("Network error. Please refresh.");
                                location.reload();
                            });
                        }
                    });
                });
            }

            function updateCounts() {
                document.querySelectorAll('.column').forEach(col => {
                    const countSpan = col.querySelector('.count');
                    const tasks = col.querySelectorAll('.task-card').length;
                    if (countSpan) countSpan.innerText = tasks;
                });
            }

            initTaskLists();

            // Approve/Reject handlers (delegated) - works for dynamically added buttons too
            document.addEventListener('click', function(e) {
                const approveBtn = e.target.closest('.approve-btn');
                const rejectBtn = e.target.closest('.reject-btn');
                if (approveBtn) {
                    e.stopPropagation();
                    const id = approveBtn.dataset.requestId;
                    if (!id) return;
                    approveBtn.disabled = true;
                    fetch('/TaskChangeRequest/Approve', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                        body: `id=${id}`
                    }).then(r => {
                        approveBtn.disabled = false;
                        if (r.ok) {
                            // optimistic UI: remove pending on this card
                            const card = approveBtn.closest('[data-task-id]');
                            if (card) card.classList.remove('pending-task');
                            location.reload();
                        } else alert('Failed');
                    }).catch(() => { approveBtn.disabled = false; alert('Failed'); });
                }
                if (rejectBtn) {
                    e.stopPropagation();
                    const id = rejectBtn.dataset.requestId;
                    if (!id) return;
                    rejectBtn.disabled = true;
                    fetch('/TaskChangeRequest/Reject', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                        body: `id=${id}`
                    }).then(r => {
                        rejectBtn.disabled = false;
                        if (r.ok) {
                            // optimistic: remove pending class
                            const card = rejectBtn.closest('[data-task-id]');
                            if (card) card.classList.remove('pending-task');
                            location.reload();
                        } else alert('Failed');
                    }).catch(() => { rejectBtn.disabled = false; alert('Failed'); });
                }
            });

            // Inline Task Creation Logic
            document.querySelectorAll('.add-card-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const container = this.closest('.add-card-container');
                    this.classList.add('d-none');
                    const form = container.querySelector('.add-card-form');
                    form.classList.remove('d-none');
                    const textarea = form.querySelector('.quick-task-title');
                    textarea.focus();
                });
            });

            document.querySelectorAll('.cancel-add-card').forEach(btn => {
                btn.addEventListener('click', function() {
                    const container = this.closest('.add-card-container');
                    container.querySelector('.add-card-form').classList.add('d-none');
                    container.querySelector('.add-card-btn').classList.remove('d-none');
                    container.querySelector('.quick-task-title').value = '';
                });
            });

            document.querySelectorAll('.quick-task-title').forEach(textarea => {
                textarea.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        this.closest('.add-card-form').querySelector('.submit-quick-task').click();
                    }
                });
            });

            document.querySelectorAll('.submit-quick-task').forEach(btn => {
                btn.addEventListener('click', function() {
                    const form = this.closest('.add-card-form');
                    const textarea = form.querySelector('.quick-task-title');
                    const title = textarea.value.trim();
                    const projectId = this.dataset.projectId;
                    const listId = this.dataset.listId;
                    const container = this.closest('.column');
                    const taskList = container.querySelector('.task-list');

                    if (!title) {
                        textarea.focus();
                        return;
                    }

                    const originalText = this.innerText;
                    this.innerText = '...';
                    this.disabled = true;

                    const formData = new FormData();
                    formData.append('projectId', projectId);
                    formData.append('boardListId', listId);
                    formData.append('title', title);
                    formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                    fetch('/WorkTask/QuickCreate', {
                        method: 'POST',
                        body: formData
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            // Tạo thẻ task mới bằng JS
                            const t = data.task;
                            const newTaskHtml = `
                                <div class="card task-card pastel-task-card mb-3 border-0 shadow-sm rounded-3" data-task-id="${t.id}">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h6 class="fw-bold mb-0 text-pastel-dark">
                                                <a href="/WorkTask/Details/${t.id}" class="text-decoration-none text-pastel-dark stretched-link">
                                                    ${escapeHtml(t.title)}
                                                </a>
                                            </h6>
                                            <div class="d-flex align-items-center gap-2 position-relative" style="z-index: 2;">
                                                <a href="/WorkTask/Edit/${t.id}" class="text-pastel-primary opacity-75 text-decoration-none" style="transition: opacity 0.2s;" onmouseover="this.classList.remove('opacity-75')" onmouseout="this.classList.add('opacity-75')" title="Sửa thẻ">
                                                    <i class="fas fa-pen" style="font-size: 0.85rem;"></i>
                                                </a>
                                                <form action="/WorkTask/Delete/${t.id}" method="post" class="d-inline m-0 p-0" onsubmit="return confirmDeleteTask(event, this);">
                                                    <input name="__RequestVerificationToken" type="hidden" value="${document.querySelector('[name=__RequestVerificationToken]').value}" />
                                                    <button type="submit" class="btn btn-link text-danger p-0 opacity-75 text-decoration-none border-0" style="transition: opacity 0.2s; background: transparent;" onmouseover="this.classList.remove('opacity-75')" onmouseout="this.classList.add('opacity-75')" title="Xóa thẻ">
                                                        <i class="fas fa-trash-alt" style="font-size: 0.85rem;"></i>
                                                    </button>
                                                </form>
                                                <span class="badge ${t.priorityClass} rounded-pill px-2 py-1 fs-6">${t.priorityText}</span>
                                            </div>
                                        </div>
                                        <p class="small text-pastel-muted mb-3"><i class="far fa-file-alt me-1"></i>No description</p>
                                        <div class="task-footer mt-2 pt-2 border-top border-pastel">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="avatar-xs rounded-circle bg-pastel-primary-soft d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                                                        <span class="fw-bold text-pastel-primary fs-6">${t.assigneeInitial}</span>
                                                    </div>
                                                    <span class="small fw-medium text-pastel-dark">${escapeHtml(t.assigneeName)}</span>
                                                </div>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center mt-2">
                                                <small class="text-pastel-muted">
                                                    <i class="far fa-calendar-alt me-1"></i>Due: ${t.endDate}
                                                </small>
                                                <small class="text-pastel-muted">0%</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            `;
                            taskList.insertAdjacentHTML('beforeend', newTaskHtml);
                            
                            // Giữ form mở để nhập tiếp
                            textarea.value = '';
                            textarea.focus();
                            updateCounts();
                        } else {
                            alert("Lỗi: " + data.message);
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert("Lỗi kết nối");
                    })
                    .finally(() => {
                        this.innerText = originalText;
                        this.disabled = false;
                    });
                });
            });

            function escapeHtml(str) {
                if (!str) return '';
                return str.replace(/[&<>'"]/g, tag => ({
                    '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
                }[tag] || tag));
            }
        });
    </script>
}

<style>
    .task-card.pending-task { opacity: 0.6; filter: grayscale(40%); position: relative; }
    .task-card.pending-task:after { content: '\f110'; font-family: 'Font Awesome 6 Free'; font-weight: 900; position: absolute; right: 12px; top: 12px; color: rgba(0,0,0,0.12); font-size: 20px; }
    .pending-controls { display: none; }
    .task-card:hover .pending-controls { display: inline-block; }
    /* ---------- PASTEL COLOR SYSTEM (giữ nguyên từ bản cũ + bổ sung) ---------- */
    :root {
        --pastel-primary: #a5b4fc;
        --pastel-primary-dark: #818cf8;
        --pastel-primary-soft: #e0e7ff;
        --pastel-secondary: #c4b5fd;
        --pastel-secondary-soft: #ede9fe;
        --pastel-success: #a7f3d0;
        --pastel-danger: #fecaca;
        --pastel-warning: #fde68a;
        --pastel-info: #bfdbfe;
        --pastel-dark: #334155;
        --pastel-muted: #64748b;
        --pastel-border: #e2e8f0;
        --pastel-card-bg: #ffffff;
        --pastel-column-bg: #f8fafc;
    }

    body.theme-dark {
        --pastel-primary: #818cf8;
        --pastel-primary-dark: #6366f1;
        --pastel-primary-soft: #1e293b;
        --pastel-secondary: #5b21b6;
        --pastel-secondary-soft: #2d2a4a;
