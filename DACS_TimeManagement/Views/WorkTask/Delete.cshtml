@model DACS_TimeManagement.Models.WorkTask

@{
    ViewData["Title"] = "Delete Task";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-danger text-white p-4 text-center">
                <i class="fas fa-exclamation-triangle fa-3x mb-2"></i>
                <h3 class="mb-0">Delete Task</h3>
            </div>
            <div class="card-body p-4 text-center">
                <h5 class="mb-3">Are you sure you want to delete this task?</h5>
                <h4 class="text-dark fw-bold mb-4">"@Model.Title"</h4>
                
                <p class="text-muted mb-4">
                    This action cannot be undone. All time logs and sub-data associated with this task will be permanently deleted.
                </p>

                <form asp-action="Delete" method="post" class="d-flex justify-content-center gap-3">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-light border px-4 py-2">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-danger px-4 py-2 fw-bold">
                        <i class="fas fa-trash-alt me-2"></i>Yes, Delete Task
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
