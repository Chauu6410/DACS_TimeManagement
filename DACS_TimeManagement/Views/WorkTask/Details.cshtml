@model DACS_TimeManagement.Models.WorkTask

@using DACS_TimeManagement.Services
@{
    ViewData["Title"] = Localizer["TaskDetails"];
    var totalTimeLogged = Model.TimeLogs?.Sum(t => t.DurationHours) ?? 0;
    var currentCulture = System.Threading.Thread.CurrentThread.CurrentUICulture.Name;
    var langCode = currentCulture.StartsWith("vi") ? "vi" : "en";
}

<div class="task-details-container" data-aos="fade-up">
    <div class="row g-4">
        <!-- Main Task Info Column -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden hover-lift">
                <!-- Card Header with Status Badge -->
                <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-primary-soft text-primary">
                            <i class="fas fa-clipboard-list fs-4"></i>
                        </div>
                        <h3 class="fw-bold mb-0 text-gradient">@Model.Title</h3>
                    </div>
                    @{
                        string statusClass = Model.Status switch
                        {
                            DACS_TimeManagement.Models.TaskStatus.Completed => "success",
                            DACS_TimeManagement.Models.TaskStatus.InProgress => "primary",
                            _ => "secondary"
                        };
                        string statusIcon = Model.Status switch
                        {
                            DACS_TimeManagement.Models.TaskStatus.Completed => "fa-check-circle",
                            DACS_TimeManagement.Models.TaskStatus.InProgress => "fa-spinner fa-pulse",
                            _ => "fa-hourglass-half"
                        };
                    }
                    <span class="badge bg-@statusClass rounded-pill px-3 py-2 fs-6 fw-semibold">
                        <i class="fas @statusIcon me-1"></i> @Localizer[Model.Status.ToString()]
                    </span>
                </div>

                <div class="card-body p-4 pt-2">
                    <!-- Date Row -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="info-card p-3 rounded-3 h-100">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="info-icon bg-primary-soft text-primary">
                                        <i class="far fa-calendar-plus"></i>
                                    </div>
                                    <div>
                                        <span class="text-muted small text-uppercase fw-semibold">@Localizer["StartDate"]</span>
                                        <p class="fw-bold mb-0">@DateTimeHelper.FormatByLanguage(Model.StartDate, langCode)</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-card p-3 rounded-3 h-100 @(Model.EndDate < DateTime.Now && Model.Status != DACS_TimeManagement.Models.TaskStatus.Completed ? "border-start border-danger border-3" : "")">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="info-icon bg-warning-soft text-warning">
                                        <i class="far fa-calendar-check"></i>
                                    </div>
                                    <div>
                                        <span class="text-muted small text-uppercase fw-semibold">@Localizer["DueDate"]</span>
                                        <p class="fw-bold mb-0">@DateTimeHelper.FormatByLanguage(Model.EndDate, langCode)</p>
                                        @if (Model.EndDate < DateTime.Now && Model.Status != DACS_TimeManagement.Models.TaskStatus.Completed)
                                        {
                                            <span class="badge bg-danger mt-1">@Localizer["Overdue"]</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="mb-4">
                        <h6 class="text-muted fw-bold text-uppercase small mb-3">
                            <i class="fas fa-align-left me-2"></i>@Localizer["Description"]
                        </h6>
                        <div class="description-box p-3 rounded-3">
                            <p class="mb-0" style="white-space: pre-wrap;">@(string.IsNullOrEmpty(Model.Description) ? Localizer["NoDescriptionProvided"].Value : Model.Description)</p>
                        </div>
                    </div>

                    <!-- Project, Priority, Progress -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="info-light p-3 rounded-3 text-center">
                                <i class="fas fa-diagram-project text-primary mb-2 d-block"></i>
                                <span class="text-muted small text-uppercase fw-semibold">@Localizer["Project"]</span>
                                <p class="fw-bold mb-0">@(Model.Project?.Name ?? "—")</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-light p-3 rounded-3 text-center">
                                <i class="fas fa-flag text-primary mb-2 d-block"></i>
                                <span class="text-muted small text-uppercase fw-semibold">@Localizer["Priority"]</span>
                                <div>
                                    @{
                                        string priorityClass = Model.Priority switch
                                        {
                                            DACS_TimeManagement.Models.Priority.Urgent or DACS_TimeManagement.Models.Priority.High => "danger",
                                            DACS_TimeManagement.Models.Priority.Medium => "warning text-dark",
                                            _ => "info"
                                        };
                                    }
                                    <span class="badge bg-@priorityClass rounded-pill px-3 py-1">@Localizer[Model.Priority.ToString()]</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-light p-3 rounded-3">
                                <span class="text-muted small text-uppercase fw-semibold">@Localizer["Progress"]</span>
                                <div class="d-flex align-items-center gap-2 mt-1">
                                    <div class="progress flex-grow-1" style="height: 10px; border-radius: 10px;">
                                        <div class="progress-bar @(Model.Progress == 100 ? "bg-success" : "bg-primary") progress-bar-striped @(Model.Progress > 0 && Model.Progress < 100 ? "progress-bar-animated" : "")" 
                                             style="width: @Model.Progress%; border-radius: 10px;"></div>
                                    </div>
                                    <span class="fw-bold">@Model.Progress%</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons (CHỈNH SỬA DELETE) -->
                    <hr class="my-4 opacity-25">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-arrow-left me-2"></i>@Localizer["BackToTasks"]
                        </a>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm edit-task-btn" data-task-id="@Model.Id">
                                <i class="fas fa-edit me-2"></i>@Localizer["Edit"]
                            </button>
                            <!-- Thay vì link đến trang Delete, dùng button + JavaScript confirm -->
                            <button type="button" id="deleteTaskBtn" class="btn btn-outline-danger rounded-pill px-4">
                                <i class="fas fa-trash-alt me-2"></i>@Localizer["Delete"]
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Column: Time Logging & History -->
        <div class="col-lg-4">
            <!-- Log Work Time Card (Gradient) -->
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden mb-4 bg-gradient-primary text-white">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="fas fa-stopwatch fa-2x"></i>
                        <h5 class="fw-bold mb-0">@Localizer["LogWorkTime"]</h5>
                    </div>
                    <form asp-controller="TimeLog" asp-action="LogTime" method="post" id="logTimeForm">
                        <input type="hidden" name="workTaskId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">@Localizer["TimeSpentHours"]</label>
                            <div class="input-group">
                                <input type="number" 
                                   name="durationHours" 
                                   class="form-control bg-white bg-opacity-20 border-0 text-dynamic-input" 
                                   step="0.25" min="0.25" max="24" required="" placeholder="1.5">
                                <span class="input-group-text bg-white bg-opacity-20 border-0 text-pastel-dark">@Localizer["Hrs"]</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">@Localizer["WorkNotes"]</label>
                            <input type="text" 
                               name="note" 
                               class="form-control bg-white bg-opacity-20 border-0 input-dynamic-text" 
                               placeholder="@Localizer["WhatDidYouWorkOn"]">
                        </div>
                        <button type="submit" class="btn btn-light w-100 fw-bold text-primary rounded-pill shadow-sm">
                            <i class="fas fa-save me-2"></i>@Localizer["SaveTimeLog"]
                        </button>
                    </form>
                </div>
            </div>

            <!-- Time History Card -->
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
                <div class="card-header bg-transparent border-0 pt-3 px-4 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-history text-primary"></i>
                        <h5 class="fw-bold mb-0">@Localizer["TimeHistory"]</h5>
                    </div>
                    <span class="badge bg-primary-soft text-primary rounded-pill px-3 py-1">@Localizer["TotalHrs"].Value.Replace("{count}", totalTimeLogged.ToString())</span>
                </div>
                <div class="card-body p-0" style="max-height: 380px; overflow-y: auto;">
                    @if (Model.TimeLogs == null || !Model.TimeLogs.Any())
                    {
                        <div class="text-center py-5">
                            <i class="far fa-clock fa-3x text-muted opacity-50 mb-2"></i>
                            <p class="small text-muted mb-0">@Localizer["NoTimeLoggedYet"]</p>
                        </div>
                    }
                    else
                    {
                        <div class="timeline-list">
                            @foreach (var log in Model.TimeLogs.OrderByDescending(t => t.LogDate))
                            {
                                <div class="timeline-item p-3 border-bottom transition-all">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <i class="fas fa-play-circle text-primary small"></i>
                                                <span class="fw-bold">@log.DurationHours @Localizer["Hrs"]</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(log.Note))
                                            {
                                                <p class="small text-muted mb-0 fst-italic">“@log.Note”</p>
                                            }
                                        </div>
                                        <small class="text-muted">@DateTimeHelper.FormatByLanguage(log.LogDate, langCode)</small>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Task Modal -->
<div class="modal fade" id="editTaskModal" tabindex="-1" aria-labelledby="editTaskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-gradient-primary text-white border-0 py-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle bg-white bg-opacity-25 text-white" style="width: 48px; height: 48px; border-radius: 60px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                        <i class="fas fa-edit fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">@Localizer["EditTaskDetail"]</h4>
                        <p class="opacity-75 small mb-0">@Localizer["UpdateTaskDetails"]</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editTaskForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editTaskId" />
                <input type="hidden" name="ProjectId" id="editProjectId" />
                <div class="modal-body p-4 p-lg-5" style="background-color: var(--card-bg);">
                    <div class="row g-4">
                        <div class="col-12">
                            <label for="editTitle" class="form-label fw-semibold mb-2">@Localizer["Title"] <span class="text-danger">*</span></label>
                            <input type="text" name="Title" id="editTitle" class="form-control rounded-3" required />
                        </div>
                        <div class="col-12">
                            <label for="editDescription" class="form-label fw-semibold mb-2">@Localizer["Description"]</label>
                            <textarea name="Description" id="editDescription" class="form-control rounded-3" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label for="editStartDate" class="form-label fw-semibold mb-2">@Localizer["StartDate"]</label>
                            <input type="datetime-local" name="StartDate" id="editStartDate" class="form-control rounded-3" />
                        </div>
                        <div class="col-md-6">
                            <label for="editEndDate" class="form-label fw-semibold mb-2">@Localizer["EndDate"]</label>
                            <input type="datetime-local" name="EndDate" id="editEndDate" class="form-control rounded-3" />
                        </div>
                        <div class="col-md-4">
                            <label for="editPriority" class="form-label fw-semibold mb-2">@Localizer["Priority"]</label>
                            <select name="Priority" id="editPriority" class="form-select rounded-3">
                                <option value="Low">@Localizer["Low"]</option>
                                <option value="Medium">@Localizer["Medium"]</option>
                                <option value="High">@Localizer["High"]</option>
                                <option value="Urgent">@Localizer["Urgent"]</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="editStatus" class="form-label fw-semibold mb-2">@Localizer["Status"]</label>
                            <select name="Status" id="editStatus" class="form-select rounded-3">
                                <option value="Todo">@Localizer["Todo"]</option>
                                <option value="InProgress">@Localizer["InProgress"]</option>
                                <option value="Completed">@Localizer["Completed"]</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="editProgress" class="form-label fw-semibold mb-2">@Localizer["ProgressPct"]</label>
                            <input type="number" name="Progress" id="editProgress" class="form-control rounded-3" min="0" max="100" />
                        </div>
                        <div class="col-md-6">
                            <label for="editAssigneeId" class="form-label fw-semibold mb-2">@Localizer["Assignee"]</label>
                            <select name="AssigneeId" id="editAssigneeId" class="form-select rounded-3">
                                <!-- Populated via JS -->
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" name="IsPrivate" id="editIsPrivate" value="true">
                                <label class="form-check-label fw-semibold" for="editIsPrivate">@Localizer["PrivateTaskDesc"]</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top p-4 d-flex justify-content-between" style="background-color: var(--bg-light);">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4 py-2" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                    <button type="submit" id="editTaskSubmitBtn" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">@Localizer["SaveChanges"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Thêm hidden antiforgery token cho toàn trang (để dùng trong fetch) -->
@Html.AntiForgeryToken()

<style>
    /* Các style giữ nguyên như cũ, chỉ bổ sung thêm (nếu cần) */
    .task-details-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 0.5rem;
    }
    .text-gradient {
        background: linear-gradient(135deg, var(--primary, #6366f1), #8b5cf6);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }
    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }
    .bg-primary-soft {
        background: rgba(99, 102, 241, 0.12);
    }
    .bg-warning-soft {
        background: rgba(245, 158, 11, 0.12);
    }
    .info-card, .info-light, .description-box {
        background: var(--card-bg, white);
        border: 1px solid var(--border-color, #e5e7eb);
        transition: all 0.2s ease;
    }
    .info-icon {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
        background: rgba(99, 102, 241, 0.1);
    }
    .hover-lift {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .hover-lift:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.15) !important;
    }
    .timeline-item {
        transition: background 0.2s ease;
    }
    .timeline-item:hover {
        background: rgba(99, 102, 241, 0.05);
        transform: translateX(4px);
    }

    :root {
        --input-text: #0f172a;
        --input-placeholder: rgba(15,23,42,0.55);
        --input-bg-translucent: rgba(255,255,255,0.18);
        --input-bg-translucent-focus: rgba(255,255,255,0.28);
    }
    body.theme-dark {
        --input-text: #ffffff;
        --input-placeholder: rgba(255,255,255,0.75);
        --input-bg-translucent: rgba(255,255,255,0.12);
        --input-bg-translucent-focus: rgba(255,255,255,0.22);
    }
    .bg-gradient-primary .form-control,
    .bg-gradient-primary .input-group-text,
    .bg-gradient-primary .input-dynamic-text,
    .bg-gradient-primary .text-dynamic-input {
        background: var(--input-bg-translucent) !important;
        border: none !important;
        color: var(--input-text) !important;
    }
    .bg-gradient-primary .form-control::placeholder,
    .bg-gradient-primary .input-dynamic-text::placeholder,
    .bg-gradient-primary .text-dynamic-input::placeholder {
        color: var(--input-placeholder) !important;
        opacity: 1;
    }
    .bg-gradient-primary .form-control:focus,
    .bg-gradient-primary .input-dynamic-text:focus,
    .bg-gradient-primary .text-dynamic-input:focus {
        background: var(--input-bg-translucent-focus) !important;
        box-shadow: none !important;
        color: var(--input-text) !important;
    }
    body.theme-dark .info-card,
    body.theme-dark .info-light,
    body.theme-dark .description-box {
        background: var(--card-bg, #1e293b);
        border-color: var(--border-color, #334155);
    }
    body.theme-dark .timeline-item:hover {
        background: rgba(99,102,241,0.15);
    }
    body.theme-dark .bg-primary-soft {
        background: rgba(99,102,241,0.2);
    }
    body.theme-dark .bg-warning-soft {
        background: rgba(245,158,11,0.2);
    }
    @@media (max-width: 768px) {
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .info-icon {
            width: 36px;
            height: 36px;
        }
        .card-header h3 {
            font-size: 1.3rem;
        }
    }
    .text-dynamic-input {
        color: #1e293b !important;
    }
    body.theme-dark .text-dynamic-input {
        color: #ffffff !important;
    }
    .text-dynamic-input::placeholder {
        color: var(--pastel-muted);
        opacity: 0.7;
    }
</style>

@section Scripts {
<script>
    (function() {
        const btn = document.getElementById('deleteTaskBtn');
        if (!btn) return;

        btn.addEventListener('click', async function (e) {
            e.preventDefault();

            const result = await Swal.fire({
                title: '@Localizer["DeleteQuestion"]',
                text: '@Localizer["DeleteConfirm"]'.replace(/\\n/g, '\n'),
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: '@Localizer["YesDelete"]',
                cancelButtonText: '@Localizer["Cancel"]'
            });

            if (!result.isConfirmed) return;

            // Dùng form ẩn để submit (An toàn và tự động handle CSRF)
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `/WorkTask/Delete/${@Model.Id}`;
            
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token;
            
            form.appendChild(tokenInput);
            document.body.appendChild(form);
            form.submit();
        });
    })();

    // Edit Task Modal Logic
    document.addEventListener('DOMContentLoaded', function() {
        const editModalElement = document.getElementById('editTaskModal');
        if (!editModalElement) return;
        
        const editModal = new bootstrap.Modal(editModalElement);
        
        document.querySelectorAll('.edit-task-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const taskId = this.dataset.taskId;
                const originalHtml = this.innerHTML;
                
                this.disabled = true;
                this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>' + '@Localizer["Loading"]';

                fetch(`/WorkTask/Details/${taskId}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(res => {
                    if (!res.ok) throw new Error('Failed to load task data');
                    return res.json();
                })
                .then(data => {
                    document.getElementById('editTaskId').value = data.id;
                    document.getElementById('editProjectId').value = data.projectId || '';
                    document.getElementById('editTitle').value = data.title;
                    document.getElementById('editDescription').value = data.description || '';
                    document.getElementById('editStartDate').value = data.startDate;
                    document.getElementById('editEndDate').value = data.endDate;
                    document.getElementById('editPriority').value = data.priority;
                    document.getElementById('editStatus').value = data.status;
                    document.getElementById('editProgress').value = data.progress;
                    document.getElementById('editIsPrivate').checked = data.isPrivate;
                    
                    // Store current assignee to select after loading list
                    const currentAssigneeId = data.assigneeId;

                    // Load assignees
                    fetch(`/WorkTask/GetProjectMembers?projectId=${data.projectId || 0}`)
                        .then(res => res.json())
                        .then(members => {
                            const select = document.getElementById('editAssigneeId');
                            select.innerHTML = '';
                            members.forEach(m => {
                                const opt = document.createElement('option');
                                opt.value = m.id;
                                opt.textContent = m.displayName;
                                if (m.id === currentAssigneeId) opt.selected = true;
                                select.appendChild(opt);
                            });
                            
                            this.disabled = false;
                            this.innerHTML = originalHtml;
                            editModal.show();
                        })
                        .catch(err => {
                            console.error(err);
                            this.disabled = false;
                            this.innerHTML = originalHtml;
                            editModal.show(); // Show anyway, assignee list might just be empty
                        });
                })
                .catch(err => {
                    console.error(err);
                    this.disabled = false;
                    this.innerHTML = originalHtml;
                    Swal.fire('@Localizer["Error"]', '@Localizer["FailedToLoadData"]', 'error');
                });
            });
        });

        document.getElementById('editTaskForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            const form = this;
            const taskId = document.getElementById('editTaskId').value;
            const submitBtn = document.getElementById('editTaskSubmitBtn');
            const originalText = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>' + '@Localizer["Saving"]';
            
            fetch(`/WorkTask/Edit/${taskId}`, {
                method: 'POST',
                body: new FormData(form),
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => {
                if (!response.ok) throw new Error('Server returned error ' + response.status);
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: '@Localizer["Success"]',
                        text: data.message || '@Localizer["UpdateSuccess"]',
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire('@Localizer["Error"]', data.message || '@Localizer["ValidationFailed"]', 'error');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                }
            })
            .catch(err => {
                console.error(err);
                Swal.fire('@Localizer["Error"]', '@Localizer["ServerError"]', 'error');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            });
        });
    });

    // Optional: Auto refresh AOS if present
    if (typeof AOS !== 'undefined') {
        AOS.refresh();
    }

    // Focus effects for log time form
    document.querySelectorAll('#logTimeForm .form-control').forEach(input => {
        input.addEventListener('focus', function() { this.closest('.mb-3')?.classList.add('focused'); });
        input.addEventListener('blur', function() { this.closest('.mb-3')?.classList.remove('focused'); });
    });
</script>
}

