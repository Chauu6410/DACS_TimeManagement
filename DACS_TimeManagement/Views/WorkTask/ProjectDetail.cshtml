@model DACS_TimeManagement.Models.Project

@{
    ViewData["Title"] = Model?.Name ?? "Project Board";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0"><i class="fas fa-columns text-primary me-2"></i> @Model?.Name</h3>
            <small class="text-muted">Project board</small>
        </div>
        <div>
            <a asp-controller="Project" asp-action="Index" class="btn btn-outline-secondary btn-sm me-2">Back to Projects</a>
            <a asp-controller="WorkTask" asp-action="Create" asp-route-projectId="@Model?.Id" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i> New Task
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div id="boardWrapper" class="overflow-auto">
                <div id="boardLists" class="d-flex align-items-start" style="gap:1rem; min-height:300px;">
                    @if (Model?.BoardLists != null && Model.BoardLists.Any())
                    {
                        foreach (var list in Model.BoardLists.OrderBy(b => b.Position))
                        {
                            <div class="board-column bg-light rounded p-2" style="min-width: 280px; max-width:360px;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="fw-semibold">
                                        <i class="fas fa-grip-lines-vertical text-muted me-2 board-handle" style="cursor:grab"></i>
                                        @list.Name
                                    </div>
                                    <small class="text-muted">@list.WorkTasks?.Count()</small>
                                </div>

                                <div class="task-list" data-list-id="@list.Id">
                                    @if (list.WorkTasks != null && list.WorkTasks.Any())
                                    {
                                        foreach (var task in list.WorkTasks.OrderBy(t => t.Position))
                                        {
                                            <div class="card mb-2 task-card" data-task-id="@task.Id">
                                                <div class="card-body p-2">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        <div>
                                                            <div class="fw-bold">@task.Title</div>
                                                            @if (!string.IsNullOrEmpty(task.Description))
                                                            {
                                                                <small class="text-muted">@task.Description</small>
                                                            }
                                                        </div>
                                                        <div class="ms-2 text-end">
                                                            <small class="text-muted">@task.Progress% </small>
                                                        </div>
                                                    </div>
                                                    <div class="mt-2 d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <span class="badge bg-secondary">@task.Status</span>
                                                            <span class="badge bg-info text-dark ms-1">@task.Priority</span>
                                                        </div>
                                                        <div class="btn-group">
                                                            <a asp-controller="WorkTask" asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary" title="Edit"><i class="fas fa-edit"></i></a>
                                                            <a asp-controller="WorkTask" asp-action="Details" asp-route-id="@task.Id" class="btn btn-sm btn-outline-info" title="Details"><i class="fas fa-eye"></i></a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted py-3">No tasks</div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted w-100 py-5">No board lists found for this project.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .board-column { flex: 0 0 auto; }
    .task-list { min-height: 80px; }
    .task-card { cursor: grab; }
    .task-card:active { cursor: grabbing; }
    /* small responsive tweak */
    @@media (max-width: 768px) {
        #boardLists { gap: .75rem; }
        .board-column { min-width: 240px; }
    }
</style>

<!-- SortableJS CDN -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
    (function () {
        // Enable dragging of columns
        var board = document.getElementById('boardLists');
        var columnSortable = new Sortable(board, {
            animation: 150,
            handle: '.board-handle',
            draggable: '.board-column',
            onEnd: function (evt) {
                console.log('Column moved', evt);
                reportBoardState();
            }
        });

        // Enable dragging of tasks between lists
        var taskLists = document.querySelectorAll('.task-list');
        taskLists.forEach(function (el) {
            new Sortable(el, {
                group: 'tasks',
                animation: 150,
                draggable: '.task-card',
                onEnd: function (evt) {
                    console.log('Task moved', evt);
                    reportBoardState();
                }
            });
        });

        function reportBoardState() {
            // Build a simple representation of lists and their tasks and positions
            var state = [];
            document.querySelectorAll('#boardLists .board-column').forEach(function (colEl, colIndex) {
                var listId = colEl.querySelector('.task-list')?.getAttribute('data-list-id');
                var tasks = [];
                colEl.querySelectorAll('.task-card').forEach(function (taskEl, taskIndex) {
                    tasks.push({ id: taskEl.getAttribute('data-task-id'), position: taskIndex });
                });
                state.push({ listId: listId, position: colIndex, tasks: tasks });
            });

            console.log('Board state after change:', state);

            // Example: send to server (commented out) - replace URL with your endpoint
            // fetch('/WorkTask/UpdateBoardState', {
            //     method: 'POST',
            //     headers: { 'Content-Type': 'application/json' },
            //     body: JSON.stringify(state)
            // });
        }
    })();
</script>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
    // Đoạn này giúp các cột có thể nhận diện việc kéo thả
    var el = document.getElementById('items-list'); // ID của khung chứa các task
