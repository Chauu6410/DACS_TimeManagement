@model List<DACS_TimeManagement.Models.UserProfile>
@using DACS_TimeManagement.Models
@{
    ViewData["Title"] = "Gamification Leaderboard";
    var userProfile = ViewBag.UserProfile as UserProfile;
    var projects = ViewBag.Projects as IEnumerable<Project>;
    var selectedProjectId = ViewBag.SelectedProjectId as int?;
    
    // Calculate current user's rank
    int userRank = 0;
    if (userProfile != null && Model != null)
    {
        userRank = Model.ToList().FindIndex(u => u.UserId == userProfile.UserId) + 1;
    }
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #eef2f7 100%);
            min-height: 100vh;
        }

        /* Custom Card Styles */
        .card-modern {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: none;
            border-radius: 28px;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.08), 0 1px 2px rgba(0, 0, 0, 0.02);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .card-modern:hover {
            transform: translateY(-4px);
            box-shadow: 0 28px 40px -16px rgba(0, 0, 0, 0.12);
        }

        /* Stats Card Premium */
        .stats-card {
            background: linear-gradient(145deg, #1e293b, #0f172a);
            border-radius: 32px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        .stats-card::before {
            content: '';
            position: absolute;
            top: -30%;
            right: -20%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(99,102,241,0.25) 0%, rgba(168,85,247,0) 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .stats-card::after {
            content: '';
            position: absolute;
            bottom: -20%;
            left: -10%;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, rgba(168,85,247,0.2) 0%, rgba(99,102,241,0) 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        /* Table Premium */
        .table-leaderboard {
            border-collapse: separate;
            border-spacing: 0 8px;
        }

        .table-leaderboard thead th {
            border: none;
            background: transparent;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            padding: 12px 16px;
        }

        .table-leaderboard tbody tr {
            background: white;
            border-radius: 20px;
            transition: all 0.2s;
            box-shadow: 0 2px 6px rgba(0,0,0,0.02);
        }

        .table-leaderboard tbody tr:hover {
            background: #f8fafc;
            transform: scale(1.01);
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
        }

        .table-leaderboard tbody td {
            border: none;
            padding: 16px 16px;
            vertical-align: middle;
        }

        /* Rank Badges */
        .rank-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 42px;
            height: 42px;
            font-weight: 700;
            font-size: 1rem;
            border-radius: 60px;
            background: #f1f5f9;
            color: #334155;
        }

        .rank-gold {
            background: linear-gradient(135deg, #ffd700, #ffb347);
            color: white;
            box-shadow: 0 4px 12px rgba(255, 179, 71, 0.3);
        }

        .rank-silver {
            background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
            color: #1e293b;
            box-shadow: 0 4px 12px rgba(100, 116, 139, 0.2);
        }

        .rank-bronze {
            background: linear-gradient(135deg, #cd7f56, #b86b3c);
            color: white;
            box-shadow: 0 4px 12px rgba(184, 107, 60, 0.3);
        }

        /* Level Badge */
        .level-badge {
            background: linear-gradient(120deg, #818cf8, #6366f1);
            color: white;
            font-weight: 600;
            padding: 5px 12px;
            border-radius: 40px;
            font-size: 0.75rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            box-shadow: 0 2px 6px rgba(99,102,241,0.25);
        }

        /* Dropdown styling */
        .filter-select {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 60px;
            padding: 8px 20px;
            font-size: 0.9rem;
            font-weight: 500;
            color: #1e293b;
            cursor: pointer;
            transition: all 0.2s;
        }

        .filter-select:hover, .filter-select:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
            outline: none;
        }

        /* Streak fire indicator */
        .streak-fire {
            background: #ffedd5;
            padding: 5px 10px;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 600;
            color: #ea580c;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        /* Current user row highlight */
        .current-user-row {
            background: linear-gradient(90deg, #eef2ff, #ffffff) !important;
            border-left: 4px solid #6366f1;
            box-shadow: 0 6px 14px rgba(99,102,241,0.12);
        }

        /* User avatar */
        .user-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            border-radius: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            margin-right: 12px;
            box-shadow: 0 6px 12px -6px rgba(99,102,241,0.4);
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .stats-card, .card-modern {
                border-radius: 24px;
            }
            .table-leaderboard tbody td {
                padding: 12px 8px;
            }
            .rank-badge {
                width: 34px;
                height: 34px;
                font-size: 0.8rem;
            }
        }

        /* animation subtle */
        @@keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-up {
            animation: fadeSlideUp 0.5s ease-out;
        }
    </style>
</head>
<body>

<div class="container mt-5 mb-5 animate-up">
    <div class="row g-4">
        <!-- My Stats Card - Modern Design -->
        <div class="col-lg-4 col-md-12">
            <div class="stats-card text-white p-4 h-100 shadow-lg">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h5 class="fw-semibold mb-1 opacity-75"><i class="fas fa-chart-line me-2"></i> My Performance</h5>
                        <h2 class="fw-bold mb-0">@(userProfile?.FullName ?? (userProfile?.Email ?? "Guest"))</h2>
                    </div>
                    <div class="bg-white bg-opacity-20 rounded-3 p-2">
                        <i class="fas fa-gamepad fs-4"></i>
                    </div>
                </div>

                @if (userProfile != null)
                {
                    <div class="row g-3 mt-2">
                        <div class="col-6">
                            <div class="bg-white bg-opacity-10 rounded-4 p-3 text-center">
                                <div class="fs-1 fw-bold">@userProfile.Points</div>
                                <div class="small text-white-50">Total XP</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-white bg-opacity-10 rounded-4 p-3 text-center">
                                <div class="fs-1 fw-bold">@userProfile.Level</div>
                                <div class="small text-white-50">Level</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-white bg-opacity-10 rounded-4 p-3 text-center">
                                <div class="fs-4 fw-bold"><i class="fas fa-fire text-warning me-1"></i> @userProfile.CurrentStreak</div>
                                <div class="small text-white-50">Current Streak</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-white bg-opacity-10 rounded-4 p-3 text-center">
                                <div class="fs-4 fw-bold"><i class="fas fa-trophy text-warning me-1"></i> @userProfile.HighestStreak</div>
                                <div class="small text-white-50">Best Streak</div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-2 border-top border-white-20">
                        <div class="d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-ranking-star me-2"></i> Global Rank</span>
                            <span class="fw-bold fs-5 bg-white bg-opacity-20 px-3 py-1 rounded-3">#@(userRank > 0 ? userRank : "—")</span>
                        </div>
                        @if (Model != null)
                        {
                            <div class="small text-white-50 mt-2">
                                <i class="fas fa-users me-1"></i> out of @Model.Count active participants
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-light bg-white bg-opacity-20 border-0 text-white mt-3 text-center">
                        <i class="fas fa-sign-in-alt me-2"></i> Login to see your stats
                    </div>
                }
            </div>
        </div>

        <!-- Leaderboard Section -->
        <div class="col-lg-8 col-md-12">
            <div class="card-modern p-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                    <div>
                        <h3 class="fw-bold mb-0" style="color: #0f172a;">
                            <i class="fas fa-medal text-primary me-2" style="color: #6366f1 !important;"></i> 
                            Leaderboard
                        </h3>
                        <p class="text-muted mt-1 mb-0 small">Real-time ranking based on points & engagement</p>
                    </div>
                    
                    <form method="get" class="d-flex">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-filter"></i></span>
                            <select name="projectId" class="filter-select" onchange="this.form.submit()">
                                <option value="">🌍 Global Ranking</option>
                                @if (projects != null)
                                {
                                    foreach (var proj in projects)
                                    {
                                        if (selectedProjectId != null && selectedProjectId == proj.Id)
                                        {
                                            <option value="@proj.Id" selected>📁 @proj.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@proj.Id">📁 @proj.Name</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </form>
                </div>

                <div class="table-responsive">
                    <table class="table table-leaderboard mb-0">
                        <thead>
                            <tr>
                                <th scope="col"># Rank</th>
                                <th scope="col">User</th>
                                <th scope="col">Level</th>
                                <th scope="col">Points</th>
                                <th scope="col">Streak</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int rank = 1;
                                foreach (var user in Model)
                                {
                                    bool isCurrentUser = (userProfile != null && user.UserId == userProfile.UserId);
                                    <tr class="@(isCurrentUser ? "current-user-row" : "")">
                                        <td>
                                            @if (rank == 1)
                                            {
                                                <div class="rank-badge rank-gold">
                                                    <i class="fas fa-crown"></i>
                                                </div>
                                            }
                                            else if (rank == 2)
                                            {
                                                <div class="rank-badge rank-silver">
                                                    <i class="fas fa-medal"></i>
                                                </div>
                                            }
                                            else if (rank == 3)
                                            {
                                                <div class="rank-badge rank-bronze">
                                                    <i class="fas fa-medal"></i>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="rank-badge">@rank</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="user-avatar">
                                                    @(string.IsNullOrEmpty(user.FullName) ? (user.Email?.Substring(0,1).ToUpper() ?? "U") : user.FullName.Substring(0,1).ToUpper())
                                                </div>
                                                <div class="fw-semibold" style="color:#1e293b;">
                                                    @(string.IsNullOrEmpty(user.FullName) ? (user.Email ?? "User") : user.FullName)
                                                    @if (isCurrentUser)
                                                    {
                                                        <span class="badge bg-primary bg-opacity-10 text-primary ms-2 rounded-pill" style="font-size: 0.7rem;">You</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="level-badge">
                                                <i class="fas fa-rocket"></i> Lv @user.Level
                                            </div>
                                        </td>
                                        <td class="fw-bold text-success fs-6">@user.Points <span class="text-muted fw-normal">xp</span></td>
                                        <td>
                                            <div class="streak-fire">
                                                <i class="fas fa-fire"></i> @user.CurrentStreak
                                            </div>
                                        </td>
                                    </tr>
                                    rank++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <div class="d-flex flex-column align-items-center gap-2">
                                            <i class="fas fa-chart-simple fs-1 text-muted"></i>
                                            <span class="text-muted fw-medium">No leaderboard data available</span>
                                            <small class="text-muted">Start tracking time to appear here</small>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model != null && Model.Any() && userProfile != null && userRank > 10)
                {
                    <div class="mt-3 text-center text-muted small border-top pt-3">
                        <i class="fas fa-arrow-down me-1"></i> Your current rank is #@userRank . Keep working to climb up!
                    </div>
                }
            </div>
        </div>
    </div>
</div>

</body>
</html>