@{
    ViewData["Title"] = "TimeMaster - Smart Time Management";
    Layout = "_Layout";
}

<div class="landing-page">
    <!-- Hero Section với gradient và hiệu ứng -->
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center min-vh-100 py-5">
                <div class="col-lg-6" data-aos="fade-right">
                    <div class="badge-new mb-3">✨ Next-Gen Time Manager</div>
                    <h1 class="display-3 fw-bold mb-4">
                        Master Your Time,<br>
                        <span class="text-gradient">Master Your Life</span>
                    </h1>
                    <p class="lead text-muted mb-4">
                        A smart task management system that helps you optimize productivity,
                        track progress with visual charts, and ensure absolute data security.
                    </p>
                    <div class="d-flex gap-3">
                        <a href="/Identity/Account/Register" class="btn btn-primary-gradient btn-lg px-5 rounded-pill shadow-lg">
                            Get Started <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                        <a href="/Identity/Account/Login" class="btn btn-outline-secondary btn-lg px-5 rounded-pill">
                            Sign In
                        </a>
                    </div>
                    <div class="mt-5 d-flex gap-4">
                        <div><i class="fas fa-check-circle text-primary me-2"></i> No credit card required</div>
                        <div><i class="fas fa-check-circle text-primary me-2"></i> Free 14-day trial</div>
                    </div>
                </div>
                <div class="col-lg-6 text-center" data-aos="fade-left" data-aos-delay="200">
                    <img src="https://cdn-icons-png.flaticon.com/512/2975/2975538.png" alt="Time Management" class="img-fluid floating-img" style="max-width: 80%;">
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section py-5 bg-light">
        <div class="container">
            <div class="row text-center g-4">
                <div class="col-md-3" data-aos="zoom-in">
                    <div class="stat-number display-4 fw-bold text-primary">10k+</div>
                    <div class="stat-label text-muted">Active Users</div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="100">
                    <div class="stat-number display-4 fw-bold text-primary">95%</div>
                    <div class="stat-label text-muted">Satisfaction Rate</div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="200">
                    <div class="stat-number display-4 fw-bold text-primary">2M+</div>
                    <div class="stat-label text-muted">Tasks Completed</div>
                </div>
                <div class="col-md-3" data-aos="zoom-in" data-aos-delay="300">
                    <div class="stat-number display-4 fw-bold text-primary">24/7</div>
                    <div class="stat-label text-muted">Support Available</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section nâng cao -->
    <section class="features-section py-5">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <h2 class="display-5 fw-bold">Powerful Features</h2>
                <p class="lead text-muted">Everything you need to manage your time effectively</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="0">
                    <div class="feature-card h-100 text-center p-4">
                        <div class="icon-box mx-auto mb-4 bg-blue-soft">
                            <i class="fas fa-columns fa-2x text-primary"></i>
                        </div>
                        <h4>Kanban Board</h4>
                        <p class="text-muted">Visualize your workflow with customizable columns: To Do, In Progress, Review, Done.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card h-100 text-center p-4">
                        <div class="icon-box mx-auto mb-4 bg-purple-soft">
                            <i class="fas fa-chart-line fa-2x text-purple"></i>
                        </div>
                        <h4>Advanced Analytics</h4>
                        <p class="text-muted">Track productivity trends, time estimates vs actual, and team performance.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card h-100 text-center p-4">
                        <div class="icon-box mx-auto mb-4 bg-red-soft">
                            <i class="fas fa-shield-alt fa-2x text-danger"></i>
                        </div>
                        <h4>AES-256 Encryption</h4>
                        <p class="text-muted">Your data is encrypted at rest and in transit with bank-grade security.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card h-100 text-center p-4">
                        <div class="icon-box mx-auto mb-4 bg-green-soft">
                            <i class="fas fa-bell fa-2x text-success"></i>
                        </div>
                        <h4>Smart Reminders</h4>
                        <p class="text-muted">Get notified via email, push, or Telegram about upcoming deadlines.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card h-100 text-center p-4">
                        <div class="icon-box mx-auto mb-4 bg-yellow-soft">
                            <i class="fas fa-users fa-2x text-warning"></i>
                        </div>
                        <h4>Team Collaboration</h4>
                        <p class="text-muted">Share projects, assign tasks, and comment in real-time.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="500">
                    <div class="feature-card h-100 text-center p-4">
                        <div class="icon-box mx-auto mb-4 bg-indigo-soft">
                            <i class="fas fa-chart-simple fa-2x text-info"></i>
                        </div>
                        <h4>Time Tracking</h4>
                        <p class="text-muted">Built-in pomodoro timer and manual time logs for accurate billing.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonial / Trust Section -->
    <section class="testimonial-section py-5 bg-light">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <h2 class="display-5 fw-bold">Trusted by Professionals</h2>
                <p class="lead text-muted">Join thousands of users who transformed their productivity</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="0">
                    <div class="testimonial-card p-4 bg-white rounded-4 shadow-sm">
                        <i class="fas fa-quote-left fa-2x text-primary opacity-25 mb-3"></i>
                        <p class="mb-3">"TimeMaster completely changed how our team works. We cut project delays by 40% in just two months."</p>
                        <div class="d-flex align-items-center">
                            <img src="https://randomuser.me/api/portraits/women/68.jpg" class="rounded-circle me-3" width="50" height="50" alt="Avatar">
                            <div><strong>Sarah Johnson</strong><br><small class="text-muted">Product Manager, TechCorp</small></div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="testimonial-card p-4 bg-white rounded-4 shadow-sm">
                        <i class="fas fa-quote-left fa-2x text-primary opacity-25 mb-3"></i>
                        <p class="mb-3">"The AES encryption gives me peace of mind. Finally a time tracker that respects privacy."</p>
                        <div class="d-flex align-items-center">
                            <img src="https://randomuser.me/api/portraits/men/32.jpg" class="rounded-circle me-3" width="50" height="50" alt="Avatar">
                            <div><strong>David Chen</strong><br><small class="text-muted">Freelance Developer</small></div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="testimonial-card p-4 bg-white rounded-4 shadow-sm">
                        <i class="fas fa-quote-left fa-2x text-primary opacity-25 mb-3"></i>
                        <p class="mb-3">"Best investment for my small business. The reporting features alone save me hours each week."</p>
                        <div class="d-flex align-items-center">
                            <img src="https://randomuser.me/api/portraits/women/45.jpg" class="rounded-circle me-3" width="50" height="50" alt="Avatar">
                            <div><strong>Emily Rodriguez</strong><br><small class="text-muted">Startup Founder</small></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Final Section -->
    <section class="cta-section py-5">
        <div class="container">
            <div class="cta-card bg-gradient-primary text-white rounded-4 p-5 text-center" data-aos="zoom-in">
                <h2 class="display-5 fw-bold mb-3">Ready to take control of your time?</h2>
                <p class="lead mb-4 opacity-90">Join thousands of productive users today.</p>
                <a href="/Identity/Account/Register" class="btn btn-light btn-lg px-5 rounded-pill shadow-lg">
                    Start Free Trial <i class="fas fa-rocket ms-2"></i>
                </a>
                <p class="mt-3 small opacity-75">No commitment. Cancel anytime.</p>
            </div>
        </div>
    </section>

    <!-- Footer (đơn giản, vì layout đã có footer riêng, nhưng có thể thêm nếu muốn) -->
</div>

<style>
    /* General */
    .landing-page {
        overflow-x: hidden;
    }
    .text-gradient {
        background: linear-gradient(90deg, #6366f1, #a855f7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    /* Hero */
    .hero-section {
        position: relative;
        background: radial-gradient(circle at 0% 0%, rgba(99,102,241,0.03), transparent);
        padding: 2rem 0;
    }
    .floating-img {
        animation: float 4s ease-in-out infinite;
    }
    @@keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
        100% { transform: translateY(0px); }
    }
    .badge-new {
        display: inline-block;
        padding: 6px 16px;
        background: rgba(99,102,241,0.1);
        color: #4f46e5;
        border-radius: 40px;
        font-size: 0.85rem;
        font-weight: 600;
        backdrop-filter: blur(4px);
    }
    .btn-primary-gradient {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        border: none;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-primary-gradient:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(79,70,229,0.3);
    }
    /* Stats */
    .stats-section {
        background: linear-gradient(135deg, #f8fafc, #f1f5f9);
    }
    .stat-number {
        font-weight: 800;
    }
    /* Feature Cards */
    .feature-card {
        background: white;
        border-radius: 24px;
        transition: all 0.3s ease;
        border: 1px solid #eef2ff;
    }
    .feature-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 30px -12px rgba(0,0,0,0.1);
        border-color: #c7d2fe;
    }
    .icon-box {
        width: 70px;
        height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 20px;
    }
    .bg-blue-soft { background: #eff6ff; }
    .bg-purple-soft { background: #faf5ff; }
    .bg-red-soft { background: #fef2f2; }
    .bg-green-soft { background: #ecfdf5; }
    .bg-yellow-soft { background: #fffbeb; }
    .bg-indigo-soft { background: #eef2ff; }
    .text-purple { color: #a855f7; }
    /* Testimonial */
    .testimonial-card {
        transition: all 0.2s;
        border: 1px solid #e2e8f0;
    }
    .testimonial-card:hover {
        transform: scale(1.02);
        box-shadow: 0 12px 24px -12px rgba(0,0,0,0.15);
    }
    /* CTA */
    .bg-gradient-primary {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
    }
    .cta-card {
        box-shadow: 0 20px 35px -10px rgba(79,70,229,0.3);
    }
    /* Responsive */
    @@media (max-width: 768px) {
        .hero-section .min-vh-100 {
            min-height: auto !important;
            padding: 3rem 0;
        }
        .display-3 {
            font-size: 2.5rem;
        }
        .feature-card {
            margin-bottom: 1rem;
        }
        .stat-number {
            font-size: 2rem;
        }
    }
</style>

<!-- Thêm AOS script nếu chưa có (Layout đã có, nhưng đảm bảo) -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof AOS !== 'undefined') AOS.refresh();
    });
</script>