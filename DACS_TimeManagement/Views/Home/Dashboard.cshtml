@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@using DACS_TimeManagement.Services
@{
    ViewData["Title"] = Localizer["Dashboard"];
    var currentCulture = System.Threading.Thread.CurrentThread.CurrentUICulture.Name;
    var langCode = currentCulture.StartsWith("vi") ? "vi" : "en";
}

<style>
    /* ========== ROOT VARIABLES & DARK MODE ========== */
    :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --primary-light: #a5b4fc;
        --primary-soft: #e0e7ff;
        --secondary: #8b5cf6;
        --success: #10b981;
        --success-soft: #d1fae5;
        --danger: #ef4444;
        --danger-soft: #fee2e2;
        --warning: #f59e0b;
        --warning-soft: #fef3c7;
        --info: #3b82f6;
        --info-soft: #dbeafe;
        --dark: #0f172a;
        --gray: #64748b;
        --border: #e2e8f0;
        --card-bg: #ffffff;
        --body-bg: #f8fafc;
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
        --shadow-md: 0 8px 24px rgba(0,0,0,0.05);
        --shadow-lg: 0 16px 32px -12px rgba(0,0,0,0.1);
        --radius-xl: 28px;
        --radius-lg: 20px;
        --radius-md: 16px;
        --transition: all 0.25s ease;
    }

    body.theme-dark {
        --primary: #818cf8;
        --primary-dark: #6366f1;
        --primary-soft: #1e293b;
        --success: #34d399;
        --success-soft: #064e3b;
        --danger: #f87171;
        --danger-soft: #7f1d1d;
        --warning: #fbbf24;
        --warning-soft: #78350f;
        --info: #60a5fa;
        --info-soft: #1e3a8a;
        --dark: #f1f5f9;
        --gray: #94a3b8;
        --border: #334155;
        --card-bg: #1e293b;
        --body-bg: #0f172a;
    }

    body {
        background: var(--body-bg);
        font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        transition: background 0.2s;
    }

    .dashboard-container {
        max-width: 1440px;
        margin: 0 auto;
        padding: 1.5rem 1.5rem 2rem;
    }

    /* ========== TYPOGRAPHY & UTILITIES ========== */
    .text-gradient {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
    }

    /* ========== CUSTOM CARDS ========== */
    .glass-card {
        background: var(--card-bg);
        border-radius: var(--radius-xl);
        backdrop-filter: blur(0px);
        transition: var(--transition);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
    }

    .glass-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-lg);
        border-color: transparent;
    }


    /* ========== TIMELINE (Today Schedule) ========== */
    .timeline-modern {
        position: relative;
        padding-left: 1.5rem;
        margin-left: 0.5rem;
        border-left: 2px solid var(--border);
    }

    .timeline-item {
        position: relative;
        padding-bottom: 1.5rem;
    }

    .timeline-item:last-child {
        padding-bottom: 0;
    }

    .timeline-item::before {
        content: '';
        position: absolute;
        left: -1.95rem;
        top: 0.25rem;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--primary);
        border: 2px solid var(--card-bg);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
    }

    .timeline-time {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--primary);
        background: var(--primary-soft);
        padding: 0.2rem 0.8rem;
        border-radius: 30px;
        display: inline-block;
        margin-bottom: 0.5rem;
    }


    /* ========== BUTTONS ========== */
    .btn-modern {
        border-radius: 40px;
        padding: 0.5rem 1.25rem;
        font-weight: 500;
        transition: var(--transition);
        border: none;
    }

    .btn-primary-modern {
        background: var(--primary);
        color: white;
    }

    .btn-primary-modern:hover {
        background: var(--primary-dark);
        transform: translateY(-1px);
        box-shadow: 0 6px 12px -6px rgba(99, 102, 241, 0.4);
    }

    .btn-outline-modern {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--dark);
    }

    .btn-outline-modern:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: rgba(99, 102, 241, 0.05);
    }

    /* ========== EMPTY STATE ========== */
    .empty-state-modern {
        text-align: center;
        padding: 2.5rem 1.5rem;
    }

    /* ========== CHART CONTAINER ========== */
    .chart-container {
        background: var(--card-bg);
        border-radius: var(--radius-lg);
        padding: 1rem;
        border: 1px solid var(--border);
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 768px) {
        .dashboard-container { padding: 1rem; }
        .stat-number { font-size: 1.8rem; }
        .stat-icon { width: 40px; height: 40px; font-size: 1.2rem; }
        .timeline-modern { padding-left: 1rem; }
    }
</style>

<div class="dashboard-container">


    <!-- Main Row: Today's Schedule -->
    <div class="row g-4 mb-5">
        <!-- Today Schedule (Timeline) -->
        <div class="col-12">
            <div class="glass-card h-100 d-flex flex-column">
                <div class="p-4 pb-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <div class="stat-icon" style="width: 40px; height: 40px;"><i class="fas fa-calendar-day"></i></div>
                        <h5 class="fw-bold m-0" style="color: var(--dark);">@Localizer["TodaySchedule"]</h5>
                    </div>
                    <a asp-controller="Calendar" asp-action="Create" class="btn btn-outline-modern btn-sm rounded-pill px-3">
                        <i class="fas fa-plus me-1"></i>@Localizer["AddEvent"]
                    </a>
                </div>
                <div class="p-4 pt-3 flex-grow-1">
                    @if (Model.TodayEvents != null && Model.TodayEvents.Count > 0)
                    {
                        <div class="timeline-modern">
                            @foreach (var evt in Model.TodayEvents)
                            {
                                <div class="timeline-item">
                                    <div class="timeline-time">@DateTimeHelper.FormatByLanguage(evt.StartTime, langCode)</div>
                                    <h6 class="fw-bold mb-1" style="color: var(--dark);">@evt.Title</h6>
                                    @if (!string.IsNullOrEmpty(evt.Description))
                                    {
                                        <p class="small text-muted mb-2">@evt.Description</p>
                                    }
                                    <span class="badge rounded-pill @(evt.Status == "Completed" ? "bg-success" : "bg-primary") bg-opacity-10 text-dark">
                                        @Localizer[evt.Status]
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state-modern">
                            <i class="fas fa-calendar-alt fa-3x text-muted opacity-50 mb-3"></i>
                            <h6 class="fw-semibold">@Localizer["NoEventsToday"]</h6>
                            <p class="small text-muted">@Localizer["StartByAddingEvent"]</p>
                            <a asp-controller="Calendar" asp-action="Index" class="btn btn-primary-modern btn-sm rounded-pill mt-2">
                                @Localizer["CreateNewEvent"]
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Productivity Chart (Line) -->
    <div class="row">
        <div class="col-12">
            <div class="glass-card p-4">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <div class="stat-icon" style="width: 40px; height: 40px;"><i class="fas fa-chart-line"></i></div>
                    <h5 class="fw-bold m-0" style="color: var(--dark);">@Localizer["WeeklyProductivity"]</h5>
                </div>
                <div class="chart-container">
                    <canvas id="productivityChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Productivity Chart
        const ctx = document.getElementById('productivityChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['@Localizer["Mon"]', '@Localizer["Tue"]', '@Localizer["Wed"]', '@Localizer["Thu"]', '@Localizer["Fri"]', '@Localizer["Sat"]', '@Localizer["Sun"]'],
                datasets: [
                    {
                        label: '@Localizer["HoursWorkedLabel"]',
                        data: @Html.Raw(Json.Serialize(Model.WeeklyHours)),
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99, 102, 241, 0.05)',
                        borderWidth: 2.5,
                        tension: 0.3,
                        fill: true,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#6366f1',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    },
                    {
                        label: '@Localizer["TasksCompletedLabel"]',
                        data: @Html.Raw(Json.Serialize(Model.WeeklyTasks)),
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16, 185, 129, 0.05)',
                        borderWidth: 2.5,
                        tension: 0.3,
                        fill: true,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#10b981',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'top', labels: { usePointStyle: true, boxWidth: 10, color: getComputedStyle(document.body).getPropertyValue('--dark') } },
                    tooltip: { mode: 'index', intersect: false }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(100,116,139,0.1)' }, ticks: { color: getComputedStyle(document.body).getPropertyValue('--gray') } },
                    x: { grid: { display: false }, ticks: { color: getComputedStyle(document.body).getPropertyValue('--gray') } }
                },
                interaction: { mode: 'nearest', axis: 'x', intersect: false }
            }
        });
    </script>
}