@model IEnumerable<DACS_TimeManagement.Models.CalendarEvent>
@{
    ViewData["Title"] = "Schedule Calendar";
}

<div class="calendar-container" data-aos="fade-up">

    <!-- Calendar Card -->
    <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
        <div class="card-body p-3 p-md-4">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<!-- Add/Edit Event Modal (Pastel) -->
<div class="modal fade" id="addEventModal" tabindex="-1" aria-labelledby="addEventModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-xl rounded-4">
            <div class="modal-header bg-gradient-pastel-primary text-white border-0 rounded-top-4">
                <h5 class="modal-title fw-bold" id="addEventModalLabel">
                    <i class="fas fa-calendar-plus me-2"></i>Add New Event
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="eventForm">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-pastel-dark">Event Title *</label>
                        <input type="text" id="eventTitle" class="form-control rounded-3" required placeholder="e.g., Team Meeting">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-pastel-dark">Description</label>
                        <textarea id="eventDescription" class="form-control rounded-3" rows="3" placeholder="Optional details"></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-pastel-dark">Start Date & Time</label>
                            <input type="datetime-local" id="eventStart" class="form-control rounded-3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-pastel-dark">End Date & Time</label>
                            <input type="datetime-local" id="eventEnd" class="form-control rounded-3" required>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-semibold text-pastel-dark">Color</label>
                        <select id="eventColor" class="form-select rounded-3">
                            <option value="#6366f1">Indigo (Default)</option>
                            <option value="#06b6d4">Cyan</option>
                            <option value="#f59e0b">Amber</option>
                            <option value="#ec4899">Pink</option>
                            <option value="#10b981">Emerald</option>
                            <option value="#ef4444">Red</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 pe-4">
                <button type="button" class="btn btn-outline-pastel rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-pastel-primary rounded-pill px-4 shadow-sm" onclick="saveEvent()">Save Event</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css">
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
    <script>
        let calendar;

        document.addEventListener('DOMContentLoaded', function() {
            const calendarEl = document.getElementById('calendar');
            calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridWeek',
                customButtons: {
                    addEvent: {
                        text: '+ Add Event',
                        click: function() {
                            const now = new Date();
                            const tzOffset = now.getTimezoneOffset() * 60000;
                            const localISOTime = (new Date(Date.now() - tzOffset)).toISOString().slice(0, 16);
                            document.getElementById('eventStart').value = localISOTime;
                            document.getElementById('eventEnd').value = localISOTime;
                            document.getElementById('eventTitle').value = '';
                            document.getElementById('eventDescription').value = '';
                            document.getElementById('eventColor').value = '#6366f1';
                            new bootstrap.Modal(document.getElementById('addEventModal')).show();
                        }
                    }
                },
                headerToolbar: {
                    left: 'prev,next today addEvent',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                events: '/Calendar/GetEvents',
                editable: true,
                selectable: true,
                select: function(info) {
                    // Format datetime-local value
                    const startStr = info.start.toISOString().slice(0, 16);
                    const endStr = info.end.toISOString().slice(0, 16);
                    document.getElementById('eventStart').value = startStr;
                    document.getElementById('eventEnd').value = endStr;
                    document.getElementById('eventTitle').value = '';
                    document.getElementById('eventDescription').value = '';
                    new bootstrap.Modal(document.getElementById('addEventModal')).show();
                },
                eventClick: function(info) {
                    if (confirm('Delete this event?')) {
                        fetch(`/Calendar/DeleteEvent/${info.event.id}`, { method: 'POST' })
                            .then(() => calendar.refetchEvents());
                    }
                },
                // Pastel theme customization
                eventBackgroundColor: '#6366f1',
                eventBorderColor: '#6366f1',
                eventTextColor: '#ffffff',
                nowIndicator: true,
                height: 'auto'
            });
            calendar.render();
        });

        function saveEvent() {
            const eventData = {
                subject: document.getElementById('eventTitle').value,
                description: document.getElementById('eventDescription').value,
                startTime: document.getElementById('eventStart').value,
                endTime: document.getElementById('eventEnd').value,
                themeColor: document.getElementById('eventColor').value
            };
            if (!eventData.subject || !eventData.startTime || !eventData.endTime) {
                alert('Please fill in all required fields (Title, Start, End).');
                return;
            }

            fetch('/Calendar/CreateEvent', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(eventData)
            }).then(response => {
                if (response.ok) {
                    calendar.refetchEvents();
                    bootstrap.Modal.getInstance(document.getElementById('addEventModal')).hide();
                    document.getElementById('eventForm').reset();
                } else {
                    alert('Error saving event. Please try again.');
                }
            }).catch(err => console.error('Error:', err));
        }
    </script>
}

<style>
    /* Calendar Pastel Styles - đồng bộ với toàn bộ hệ thống */
    .calendar-container {
        max-width: 1600px;
        margin: -1rem auto 0; /* Add slight negative margin to pull closer to top-bar */
        padding: 0;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, var(--pastel-primary-dark, #6366f1), #4f46e5);
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }
    .bg-pastel-primary-soft {
        background: rgba(99, 102, 241, 0.12);
    }
    .text-pastel-primary {
        color: var(--pastel-primary-dark, #818cf8);
    }
    .text-pastel-dark {
        color: var(--pastel-dark, #1e293b);
    }
    .text-pastel-muted {
        color: var(--pastel-muted, #64748b);
    }

    /* Buttons Pastel */
    .btn-pastel-primary {
        background: var(--pastel-primary, #a5b4fc);
        color: #1e293b;
        border: none;
        transition: all 0.2s;
        font-weight: 500;
    }
    .btn-pastel-primary:hover {
        background: var(--pastel-primary-dark, #818cf8);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(129, 140, 248, 0.3);
    }
    .btn-outline-pastel {
        border: 1px solid var(--pastel-primary-dark, #818cf8);
        color: var(--pastel-primary-dark, #818cf8);
        background: transparent;
        transition: all 0.2s;
    }
    .btn-outline-pastel:hover {
        background: var(--pastel-primary-dark, #818cf8);
        color: white;
    }

    /* Form controls */
    .form-control, .form-select {
        border: 1px solid var(--pastel-border, #e2e8f0);
        background-color: var(--pastel-card-bg, #ffffff);
        color: var(--pastel-dark, #0f172a);
        transition: all 0.2s ease;
        font-size: 0.95rem;
        padding: 0.6rem 1rem;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--pastel-primary-dark, #818cf8);
        box-shadow: 0 0 0 4px rgba(129, 140, 248, 0.2);
        outline: none;
    }
    .form-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--pastel-muted, #64748b);
    }

    /* FullCalendar Pastel Overrides */
    .fc {
        --fc-border-color: var(--pastel-border, #e2e8f0);
        --fc-button-bg-color: var(--pastel-primary, #a5b4fc);
        --fc-button-border-color: var(--pastel-primary, #a5b4fc);
        --fc-button-hover-bg-color: var(--pastel-primary-dark, #818cf8);
        --fc-button-hover-border-color: var(--pastel-primary-dark, #818cf8);
        --fc-button-active-bg-color: var(--pastel-primary-dark, #818cf8);
        --fc-button-active-border-color: var(--pastel-primary-dark, #818cf8);
        --fc-today-bg-color: rgba(99, 102, 241, 0.08);
        --fc-event-bg-color: #6366f1;
        --fc-event-border-color: #6366f1;
        --fc-page-bg-color: var(--pastel-card-bg, #ffffff);
    }
    .fc .fc-button-primary {
        font-weight: 500;
        text-transform: capitalize;
        border-radius: 40px;
        padding: 0.4rem 1rem;
    }
    .fc .fc-button-primary:not(:disabled):active,
    .fc .fc-button-primary:not(:disabled).fc-button-active {
        background: var(--pastel-primary-dark, #818cf8);
        border-color: var(--pastel-primary-dark, #818cf8);
    }
    .fc-theme-standard .fc-scrollgrid,
    .fc-theme-standard td, 
    .fc-theme-standard th {
        border-color: var(--pastel-border, #e2e8f0);
    }
    .fc .fc-col-header-cell-cushion,
    .fc .fc-daygrid-day-number {
        color: var(--pastel-dark, #0f172a);
    }
    .fc .fc-daygrid-day.fc-day-today {
        background-color: var(--pastel-primary-soft, #e0e7ff);
    }

    /* Dark Mode */
    body.theme-dark {
        --pastel-primary: #818cf8;
        --pastel-primary-dark: #6366f1;
        --pastel-primary-soft: #1e293b;
        --pastel-border: #334155;
        --pastel-card-bg: #1e293b;
        --pastel-dark: #f1f5f9;
        --pastel-muted: #94a3b8;
    }
    body.theme-dark .fc {
        --fc-page-bg-color: #1e293b;
        --fc-border-color: #334155;
        --fc-today-bg-color: rgba(99, 102, 241, 0.15);
    }
    body.theme-dark .fc .fc-col-header-cell-cushion,
    body.theme-dark .fc .fc-daygrid-day-number {
        color: #f1f5f9;
    }
    body.theme-dark .form-control,
    body.theme-dark .form-select {
        background-color: #1e293b;
        border-color: #334155;
        color: #f1f5f9;
    }
    body.theme-dark .btn-outline-pastel {
        border-color: #818cf8;
        color: #a5b4fc;
    }
    body.theme-dark .btn-outline-pastel:hover {
        background: #818cf8;
        color: #1e293b;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .calendar-container {
            padding: 0 0.5rem;
        }
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .fc .fc-toolbar {
            flex-direction: column;
            gap: 0.5rem;
        }
    }
</style>