        async function loadUnplannedTasks(){
            try{
                const dateInput = document.getElementById('aiPlanStartDate');
                if(dateInput && !dateInput.value) {
                    const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate() + 1);
                    dateInput.value = tomorrow.toISOString().split('T')[0];
                }
                const res = await fetch('/Calendar/GetAllTasks'); 
                const tasks = await res.json(); 
                const cont = document.getElementById('tasksListContainer');
                if(!cont) return;
                if(!tasks?.length){ 
                    cont.innerHTML = '<div class="text-center py-5 text-muted"><i class="fas fa-check-circle fa-2x mb-3 text-success"></i><br>@Localizer["NoPendingTasks"]</div>'; 
                    return; 
                }
                
                const groups = tasks.reduce((acc, t) => {
                    const p = t.projectName || "Khác";
                    if(!acc[p]) acc[p] = [];
                    acc[p].push(t);
                    return acc;
                }, {});
                
                let html = '';
                const today = new Date();
                
                for(const proj in groups) {
                    const projectTasks = groups[proj];
                    const hasUrgent = projectTasks.some(t => {
                        if(t.isOverdue) return true;
                        if(t.deadline) {
                            const d = new Date(t.deadline);
                            const diff = (d - today) / (1000 * 60 * 60 * 24);
                            return diff >= 0 && diff <= 3;
                        }
                        return false;
                    });
                    html += `
                        <div class="project-group mb-4">
                            <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                                <h6 class="mb-0 fw-bold" style="color: #4f46e5;"><i class="fas fa-folder-open me-2"></i>${escapeHtml(proj)}</h6>
                                ${hasUrgent ? `<span class="badge bg-warning text-dark ms-2 x-small shadow-sm"><i class="fas fa-exclamation-triangle me-1"></i>@Localizer["ApproachingDeadline"]</span>` : ''}
                            </div>
                            <div class="task-items-list d-flex flex-column gap-2">
                                ${projectTasks.map(t => `
                                    <div class="task-item p-3 border-0 rounded-3 bg-light transition-all" style="border-left: 4px solid ${t.isOverdue ? '#ef4444' : '#e2e8f0'} !important;">
                                        <div class="d-flex align-items-center">
                                            <div class="form-check m-0 p-0">
                                                <input type="checkbox" class="task-checkbox form-check-input ms-0" data-id="${t.id}" ${selectedTasks.includes(t.id) ? 'checked' : ''} onchange="toggleTaskSelection(this)">
                                            </div>
                                            <div class="ms-3 flex-grow-1">
                                                <div class="fw-bold text-dark small">${escapeHtml(t.title)}</div>
                                            </div>
                                            ${t.isOverdue ? `<span class="badge bg-danger rounded-pill x-small px-2 py-1">@Localizer["OverdueLabel"]</span>` : ''}
                                        </div>
                                    </div>
                                `).join('')}
                            </div>
                        </div>
                    `;
                }
                cont.innerHTML = html;
            } catch(e){ 
                document.getElementById('tasksListContainer').innerHTML = '<div class="text-danger text-center py-4">@Localizer["Error"]</div>'; 
            }
        }
        
