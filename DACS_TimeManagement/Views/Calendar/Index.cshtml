                    }).then(r=>r.isConfirmed)) return;
                    // Logic xóa generic event (cần thêm endpoint ở controller)
                    // Ở đây tôi sẽ giả định có thể dùng chung delete endpoint hoặc thêm mới.
                    // Tạm thời gọi DELETE với tham số id.
                    try{
                        const res=await fetch(`/Calendar/DeleteGenericEvent?id=${id}`,{method:'POST'});
                        if((await res.json()).success){ 
                            calendar.refetchEvents(); 
                            Swal.fire('@Localizer["Deleted"]','','success'); 
                        }
                    } catch(e){ Swal.fire('@Localizer["Error"]','','error'); }
                }

                window.showEventDetails = function(event) {
                    const isGeneric = event.extendedProps.isGenericEvent;
                    const isImportant = event.extendedProps.isImportant;
                    const emailNotif = event.extendedProps.isEmailNotification;
                    const desc = event.extendedProps.description || "@Localizer["NoDescription"]";
                    const taskId = event.extendedProps.taskId;

                    let html = `
                        <div class="text-start">
                            <p><strong><i class="far fa-clock me-2"></i>@Localizer["Time"]:</strong> ${event.start.toLocaleString()} - ${event.end ? event.end.toLocaleString() : '...'}</p>
                            <p><strong><i class="fas fa-align-left me-2"></i>@Localizer["Description"]:</strong> ${desc}</p>
                            ${isGeneric ? `
                                <p><strong><i class="fas fa-star me-2"></i>@Localizer["Important"]:</strong> ${isImportant ? '<span class="text-danger">@Localizer["Yes"]</span>' : '@Localizer["No"]'}</p>
                                <p><strong><i class="fas fa-envelope me-2"></i>@Localizer["EmailReminder"]:</strong> ${emailNotif ? '<span class="text-success">@Localizer["On"]</span>' : '@Localizer["Off"]'}</p>
                            ` : `
