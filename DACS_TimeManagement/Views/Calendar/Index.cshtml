                            `}
                        </div>
                    `;

                    Swal.fire({
                        title: event.title,
                        html: html,
                        icon: isImportant ? 'warning' : 'info',
                        showDenyButton: true,
                        showCancelButton: true,
                        confirmButtonText: '<i class="fas fa-edit me-1"></i> @Localizer["Edit"]',
                        denyButtonText: '<i class="fas fa-trash-alt me-1"></i> @Localizer["Delete"]',
                        cancelButtonText: '@Localizer["Close"]',
                        confirmButtonColor: '#6366f1',
                        denyButtonColor: '#ef4444'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            openEditModal(event);
                        } else if (result.isDenied) {
                            if (isGeneric) deleteGenericEvent(event.id);
                            else deleteScheduledEvent(event.id);
                        }
                    });
                };

                window.openEditModal = function(event) {
                    const isGeneric = event.extendedProps.isGenericEvent;
                    document.getElementById('editEventId').value = event.id;
                    document.getElementById('editIsGeneric').value = isGeneric ? "true" : "false";
                    
                    document.getElementById('editStart').value = formatDateTime(event.start);
                    document.getElementById('editEnd').value = event.end ? formatDateTime(event.end) : '';

                    if (isGeneric) {
                        document.getElementById('genericFields').style.display = 'block';
                        document.getElementById('genericCheckboxes').style.display = 'block';
                        document.getElementById('editSubject').value = event.title.replace("⭐ ", "");
                        document.getElementById('editDescription').value = event.extendedProps.description || '';
                        document.getElementById('editIsImportant').checked = event.extendedProps.isImportant;
                        document.getElementById('editIsEmail').checked = event.extendedProps.isEmailNotification;
                    } else {
                        document.getElementById('genericFields').style.display = 'none';
                        document.getElementById('genericCheckboxes').style.display = 'none';
                    }

                    // Render colors
                    const colorContainer = document.getElementById('editColorSwatches');
                    colorContainer.innerHTML = pastelColors.map(c => `
                        <button type="button" class="color-swatch edit-swatch ${c === event.backgroundColor ? 'selected' : ''}" 
                                data-color="${c}" style="background:${c}; width:30px; height:30px; border-radius:6px; border:2px solid white;"></button>
                    `).join('');
                    document.getElementById('editColorValue').value = event.backgroundColor;

                    // Event listener for edit swatches
                    document.querySelectorAll('.edit-swatch').forEach(sw => {
                        sw.onclick = () => {
                            document.querySelectorAll('.edit-swatch').forEach(s => s.classList.remove('selected'));
                            sw.classList.add('selected');
                            document.getElementById('editColorValue').value = sw.dataset.color;
                        };
                    });

                    new bootstrap.Modal(document.getElementById('editEventModal')).show();
                };

                window.updateEvent = async function() {
                    const id = document.getElementById('editEventId').value;
                    const isGeneric = document.getElementById('editIsGeneric').value === "true";
                    
                    const data = {
                        id: parseInt(id),
                        startTime: document.getElementById('editStart').value,
                        endTime: document.getElementById('editEnd').value,
                        themeColor: document.getElementById('editColorValue').value
                    };

                    let url = '';
                    if (isGeneric) {
                        url = '/Calendar/UpdateGenericEvent';
                        data.subject = document.getElementById('editSubject').value;
                        data.description = document.getElementById('editDescription').value;
                        data.isImportant = document.getElementById('editIsImportant').checked;
                        data.isEmailNotification = document.getElementById('editIsEmail').checked;
                    } else {
                        // Assuming we can reuse UpdateScheduledEventColor for color, but for time we might need a new endpoint
                        // For simplicity, I'll just handle Generic for now or implement full update
                        url = '/Calendar/UpdateScheduledEvent'; // I should add this endpoint
                        data.color = data.themeColor;
                    }

                    Swal.fire({title: 'Đang lưu...', allowOutsideClick: false, didOpen: () => Swal.showLoading()});
                    try {
                        const res = await fetch(url, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });
                        const result = await res.json();
                        Swal.close();
                        if (result.success) {
                            bootstrap.Modal.getInstance(document.getElementById('editEventModal')).hide();
                            calendar.refetchEvents();
                            Swal.fire('@Localizer["Success"]', '@Localizer["EventUpdated"]', 'success');
                        } else Swal.fire('@Localizer["Error"]', result.message, 'error');
                    } catch (e) { Swal.close(); Swal.fire('@Localizer["Error"]', '@Localizer["ServerError"]', 'error'); }
                };

                function formatDateTime(date) {
                    const d = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
                    return d.toISOString().slice(0, 16);
                }
            } catch (err) { console.error(err); }
        });
    </script>
}