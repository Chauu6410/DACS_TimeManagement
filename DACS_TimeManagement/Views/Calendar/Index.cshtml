        window.saveScheduledTask = async function() {
            const taskId = document.getElementById('taskSelect').value, 
                  start = document.getElementById('startTimeInput').value, 
                  end = document.getElementById('endTimeInput').value, 
                  color = document.getElementById('eventColorSelect').value;
            if (!taskId || !start || !end) return Swal.fire('@Localizer["Error"]', '@Localizer["MissingFields"]', 'warning');
            if (new Date(start) >= new Date(end)) return Swal.fire('@Localizer["Error"]', '@Localizer["EndAfterStart"]', 'warning');
            try {
                const res = await fetch('/Calendar/CreateScheduledEvent', { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' }, 
                    body: JSON.stringify({ taskId: parseInt(taskId), startTime: start, endTime: end, color }) 
                });
                const result = await res.json();
                if (result.success) {
                    Swal.fire('@Localizer["Success"]', '@Localizer["ScheduledSuccessfully"]', 'success');
                    bootstrap.Modal.getInstance(document.getElementById('setTaskModal')).hide();
                    calendar.refetchEvents(); 
                    loadScheduledTasksByDate();
                    document.getElementById('taskSelect').value = ''; 
                    document.getElementById('startTimeInput').value = ''; 
                    document.getElementById('endTimeInput').value = '';
                } else Swal.fire('@Localizer["Error"]', result.message, 'error');
            } catch(e) { Swal.fire('@Localizer["Error"]', '@Localizer["ServerError"]', 'error'); }
        };
        
        async function loadScheduledTasksByDate() {
            const dateInput = document.getElementById('todoDateFilter');
