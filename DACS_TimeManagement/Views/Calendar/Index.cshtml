@model IEnumerable<DACS_TimeManagement.Models.CalendarEvent>
@{
    ViewData["Title"] = "Schedule Calendar";
}

<div class="calendar-container" data-aos="fade-up">
    <div class="row g-4">
        <!-- Sidebar: Danh sách tất cả Task -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 mb-4 bg-pastel-indigo h-100">
                <h5 class="fw-bold mb-3"><i class="fas fa-tasks me-2"></i>My Tasks</h5>
                <div id="task-list" style="max-height: 70vh; overflow-y: auto;">
                    @if (ViewBag.UserTasks != null && ((IEnumerable<dynamic>)ViewBag.UserTasks).Any())
                    {
                        foreach (var task in ViewBag.UserTasks)
                        {
                            var taskName = task.Title ?? "Unnamed Task";
                            var projectName = task.Project?.Name ?? "No Project";
                            var endDate = task.EndDate as DateTime?;
                            <div class="p-2 mb-2 rounded-3 bg-white shadow-xs border-start border-4 border-primary">
                                <small class="fw-bold d-block">
                                    @taskName
                                    <span class="text-muted" style="font-size: 0.7rem;">(@projectName)</span>
                                </small>
                                <span class="text-muted" style="font-size: 0.7rem;">
                                    <i class="far fa-clock me-1"></i>Due: 
                                    @(endDate.HasValue ? endDate.Value.ToString("dd/MM") : "No deadline")
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-muted text-center py-3">No tasks found</div>
                    }
                </div>
                <hr />
                <a asp-controller="WorkTask" asp-action="Create" class="btn btn-sm btn-primary-soft w-100 rounded-pill mb-2">
                    + Add Task
                </a>
                <button type="button" class="btn btn-sm btn-outline-pastel w-100 rounded-pill fw-bold" data-bs-toggle="modal" data-bs-target="#autoPlanModal">
                    🪄 Tối ưu lịch ngày mai
                </button>
            </div>
        </div>

        <!-- Main Calendar -->
        <div class="col-md-9">
            <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
                <div class="card-body p-3 p-md-4">
                    <div id="calendar"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Event Modal -->
<div class="modal fade" id="addEventModal" tabindex="-1" aria-labelledby="addEventModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-xl rounded-4">
            <div class="modal-header bg-gradient-pastel-primary text-white border-0 rounded-top-4">
                <h5 class="modal-title fw-bold" id="addEventModalLabel">
                    <i class="fas fa-calendar-plus me-2"></i>Add/Edit Event
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="eventForm">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-pastel-dark">Event Title *</label>
                        <input type="text" id="eventTitle" class="form-control rounded-3" required placeholder="e.g., Team Meeting">
                        <div id="eventProject" class="mt-2 small text-pastel-muted" style="display:none;"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-pastel-dark">Description</label>
                        <textarea id="eventDescription" class="form-control rounded-3" rows="3" placeholder="Optional details"></textarea>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-pastel-dark">Start Date & Time</label>
                            <input type="datetime-local" id="eventStart" class="form-control rounded-3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-pastel-dark">End Date & Time</label>
                            <input type="datetime-local" id="eventEnd" class="form-control rounded-3" required>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label fw-semibold text-pastel-dark">Color</label>
                        <div class="d-flex gap-2 align-items-center">
                            <select id="eventColor" class="form-select rounded-3 flex-grow-1">
                                <option value="#6366f1">Indigo (Default)</option>
                                <option value="#06b6d4">Cyan</option>
                                <option value="#f59e0b">Amber</option>
                                <option value="#ec4899">Pink</option>
                                <option value="#10b981">Emerald</option>
                                <option value="#ef4444">Red</option>
                                <option value="#8b5cf6">Violet</option>
                                <option value="#f97316">Orange</option>
                                <option value="#14b8a6">Teal</option>
                                <option value="#d946ef">Fuchsia</option>
                            </select>
                            <button type="button" class="btn btn-outline-pastel rounded-pill px-3" onclick="randomColor()">
                                <i class="fas fa-random"></i> Random
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 pe-4">
                <button type="button" class="btn btn-danger rounded-pill px-4" onclick="deleteCurrentEvent()">Delete</button>
                <button type="button" class="btn btn-outline-pastel rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-pastel-primary rounded-pill px-4 shadow-sm" onclick="saveEvent()">Save Event</button>
            </div>
        </div>
    </div>

<!-- Auto-Plan Modal -->
<div class="modal fade" id="autoPlanModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-xl rounded-4">
            <div class="modal-header bg-gradient-pastel-primary text-white border-0 rounded-top-4">
                <h5 class="modal-title fw-bold">
                    🪄 Auto-schedule for tomorrow
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-pastel-indigo">
                <p class="text-pastel-muted small mb-3">
                    The system will schedule <b>Hard</b> tasks in the morning (8:30-11:30), add a lunch break, and <b>Medium/Easy</b> tasks in the afternoon using the Pomodoro method.
                </p>
                <div id="autoTasksList">
                    <!-- Task Row template -->
                    <div class="row g-2 align-items-center mb-2 auto-task-row">
                        <div class="col-6">
                            <input type="text" class="form-control rounded-3 task-title" placeholder="Task name" required>
                        </div>
                        <div class="col-3">
                            <select class="form-select rounded-3 task-diff">
                                <option value="Hard">Hard (Red)</option>
                                <option value="Medium" selected>Medium (Yellow)</option>
                                <option value="Easy">Easy (Green)</option>
                            </select>
                        </div>
                        <div class="col-2">
                            <input type="number" class="form-control rounded-3 task-duration" placeholder="Phút" value="30" min="5" step="5" required>
                        </div>
                        <div class="col-1 text-end">
                            <button type="button" class="btn btn-danger btn-sm rounded-circle px-2 disabled remove-row-btn" onclick="this.closest('.auto-task-row').remove()"><i class="fas fa-times"></i></button>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-outline-pastel rounded-pill mt-2" onclick="addAutoTaskRow()">+ Add task</button>
            </div>
            <div class="modal-footer border-0 pb-4 pe-4 bg-pastel-indigo rounded-bottom-4">
                <button type="button" class="btn btn-outline-pastel rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-pastel-primary rounded-pill px-4 shadow-sm" onclick="submitAutoPlan()">Start scheduling</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css">
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* Event visual fixes: rounded 8px, pastel, wrap text */
        .fc .fc-event, .fc .fc-daygrid-event, .fc .fc-timegrid-event {
            border: none !important;
            border-radius: 8px !important;
            padding: 6px 8px !important;
            white-space: normal !important;
            overflow: visible !important;
        }
        .fc .fc-event.evt-event { background: #eef2ff !important; color: #0f172a !important; }
        .fc .fc-event.prj-event { background: #fff1f2 !important; color: #7f1d1d !important; }
        .fc .fc-event:hover { transform: translateY(-3px); box-shadow: 0 8px 18px rgba(2,6,23,0.08); }
    </style>
    <script>
        // Khởi tạo biến toàn cục
        let calendar;
        let currentEventId = null; // Lưu id sự kiện đang chọn (dạng "evt_123")
        let isOwner = false; // nếu event thuộc về user đang đăng nhập
        // currentUserId được cung cấp từ server (ViewBag.CurrentUserId)
        const currentUserId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CurrentUserId ?? ""));

        // Mảng màu pastel
        const pastelColors = [
            "#6366f1", "#06b6d4", "#f59e0b", "#ec4899", "#10b981", "#ef4444",
            "#8b5cf6", "#f97316", "#14b8a6", "#d946ef", "#6b7280", "#3b82f6"
        ];

        function getRandomPastelColor() {
            return pastelColors[Math.floor(Math.random() * pastelColors.length)];
        }

        function randomColor() {
            document.getElementById('eventColor').value = getRandomPastelColor();
        }

        // Hàm lưu sự kiện (tạo mới hoặc cập nhật)
        function saveEvent() {
            const title = document.getElementById('eventTitle').value.trim();
            const description = document.getElementById('eventDescription').value;
            const start = document.getElementById('eventStart').value;
            const end = document.getElementById('eventEnd').value;
            let color = document.getElementById('eventColor').value;
            
            // Cắt bỏ hậu tố độ trong suốt (nếu có) để Server chỉ nhận mã màu thuần 7 ký tự
            if (color && color.length > 7) color = color.substring(0, 7);

            if (!title || !start || !end) {
                alert('Please fill in all required fields (Title, Start, End).');
                return;
            }

            // Sử dụng định dạng local ISO (yyyy-MM-ddTHH:mm) để tránh lệch múi giờ khi truyền tải
            const startIso = start;
            const endIso = end;

            // Gửi đi phải khớp 100% với tên thuộc tính trong class CalendarEvent
            const eventData = {
                Id: currentEventId ? parseInt(currentEventId.toString().replace('evt_', '')) : 0,
                Subject: title,
                Description: description,
                StartTime: startIso,
                EndTime: endIso,
                ThemeColor: color,
                IsFullDay: false
            };

            // Nếu user không phải owner và đang chỉnh màu, gọi endpoint cập nhật màu riêng
            if (currentEventId && !isOwner && currentEventId.toString().startsWith('evt_')) {
                const id = currentEventId.toString().replace('evt_', '');
                fetch(`/Calendar/UpdateEventColor/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ themeColor: color })
                })
                .then(r => {
                    if (r.ok) {
                        calendar.refetchEvents();
                        const modal = bootstrap.Modal.getInstance(document.getElementById('addEventModal'));
                        modal.hide();
                        document.getElementById('eventForm').reset();
                        currentEventId = null;
                        isOwner = false;
                    } else {
                        r.json().then(j => alert('Error updating color: ' + (j?.message || r.statusText)));
                    }
                })
                .catch(e => { console.error(e); alert('Error: ' + e); });
                return;
            }

            let url = '/Calendar/SaveEvent';
            let method = 'POST';

            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(eventData)
            })
            .then(async response => {
                const text = await response.text();
                let json = {};
                try { json = text ? JSON.parse(text) : {}; } catch(e) { }
                if (response.ok) {
                    calendar.refetchEvents(); // Tải lại lịch
                    const modal = bootstrap.Modal.getInstance(document.getElementById('addEventModal'));
                    modal.hide();
                    document.getElementById('eventForm').reset();
                    currentEventId = null;
                    isOwner = false;
                } else {
                    alert('Error saving event: ' + (json?.message || response.statusText));
                }
            })
            .catch(err => {
                console.error('Error:', err);
                alert('An error occurred.');
            });
        }

        // Hàm xóa sự kiện
        function deleteCurrentEvent() {
            if (!currentEventId || !currentEventId.toString().startsWith('evt_')) {
                alert('No event selected for deletion.');
                return;
            }
            if (!isOwner) {
                alert('Only the owner can delete this event.');
                return;
            }
            const id = currentEventId.toString().replace('evt_', '');
            if (confirm('Are you sure you want to delete this event?')) {
                fetch(`/Calendar/DeleteEvent/${id}`, { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        calendar.refetchEvents();
                        const modal = bootstrap.Modal.getInstance(document.getElementById('addEventModal'));
                        modal.hide();
                        currentEventId = null;
                        isOwner = false;
                    } else {
                        alert('Delete failed.');
                    }
                })
                .catch(err => alert('Error: ' + err));
            }
        }

        // --- HÀM CHO AUTO PLAN ---
        function addAutoTaskRow() {
            const row = document.createElement('div');
            row.className = 'row g-2 align-items-center mb-2 auto-task-row';
            row.innerHTML = `
                <div class="col-6">
                    <input type="text" class="form-control rounded-3 task-title" placeholder="Task name" required>
                </div>
                <div class="col-3">
                    <select class="form-select rounded-3 task-diff">
                        <option value="Hard">Hard (Red)</option>
                        <option value="Medium" selected>Medium (Yellow)</option>
                        <option value="Easy">Easy (Green)</option>
                    </select>
                </div>
                <div class="col-2">
                    <input type="number" class="form-control rounded-3 task-duration" placeholder="Phút" value="30" min="5" step="5" required>
                </div>
                <div class="col-1 text-end">
                    <button type="button" class="btn btn-danger btn-sm rounded-circle px-2" onclick="this.closest('.auto-task-row').remove()"><i class="fas fa-times"></i></button>
                </div>
            `;
            document.getElementById('autoTasksList').appendChild(row);
        }

        function submitAutoPlan() {
            const rows = document.querySelectorAll('.auto-task-row');
            const tasks = [];
            let isValid = true;

            rows.forEach(row => {
                const title = row.querySelector('.task-title').value.trim();
                const diff = row.querySelector('.task-diff').value;
                const duration = parseInt(row.querySelector('.task-duration').value);

                if (!title || !duration || duration < 5) {
                    isValid = false;
                } else {
                    tasks.push({ Title: title, Difficulty: diff, DurationMinutes: duration });
                }
            });

            if (!isValid || tasks.length === 0) {
                Swal.fire('Missing Information', 'Please enter valid task names and duration for all tasks.', 'warning');
                return;
            }

            fetch('/Calendar/AutoPlanTomorrow', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(tasks)
            })
            .then(async response => {
                if (response.ok) {
                    Swal.fire('Success!', 'Tomorrow\\'s schedule has been created automatically.', 'success');
                    calendar.refetchEvents();
                    bootstrap.Modal.getInstance(document.getElementById('autoPlanModal')).hide();
                    document.getElementById('autoTasksList').innerHTML = '';
                    addAutoTaskRow(); // reset
                } else {
                    Swal.fire('Error', 'An error occurred while creating the schedule.', 'error');
                }
            })
            .catch(err => Swal.fire('Error', 'Cannot connect to server.', 'error'));
        }

        // Cập nhật khi kéo thả/resize sự kiện
        function updateEventDates(eventObj, revertFunc) {
            const eventIdRaw = eventObj.id;
            if (!eventIdRaw || !eventIdRaw.toString().startsWith('evt_')) {
                revertFunc();
                Swal.fire('Oops', 'You cannot change project task schedule from here!', 'warning');
                return;
            }
            
            const realId = parseInt(eventIdRaw.replace('evt_', ''));
            const newStart = eventObj.start ? new Date(eventObj.start.getTime() - eventObj.start.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : null;
            const newEnd = eventObj.end ? new Date(eventObj.end.getTime() - eventObj.end.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : newStart;
            
            let title = eventObj.title || '';
            if (title.startsWith('📅 ')) title = title.replace('📅 ', '');

            const color = eventObj.extendedProps?.rawColor || '#6366f1';
            const hexColor = color.length > 7 ? color.substring(0, 7) : color;

            const eventData = {
                Id: realId,
                Subject: title,
                Description: eventObj.extendedProps?.description || '',
                StartTime: newStart,
                EndTime: newEnd,
                ThemeColor: hexColor,
                IsFullDay: eventObj.allDay || false
            };

            fetch('/Calendar/SaveEvent', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(eventData)
            })
            .then(async response => {
                if (!response.ok) {
                    const text = await response.text();
                    let msg = response.statusText;
                    try { const j = JSON.parse(text); if (j.message) msg = j.message; } catch(e){}
                    revertFunc();
                    Swal.fire('Error', 'Cannot save changes: ' + msg, 'error');
                }
            })
            .catch(err => {
                console.error(err);
                revertFunc();
                Swal.fire('Error', 'A system error occurred.', 'error');
            });
        }

        // Khởi tạo FullCalendar khi DOM sẵn sàng
        document.addEventListener('DOMContentLoaded', function() {
            const calendarEl = document.getElementById('calendar');
            if (!calendarEl) {
                console.error('Calendar element not found');
                return;
            }

            calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridWeek',
                customButtons: {
                    addEvent: {
                        text: '+ Add Event',
                        click: function() {
                            // Reset form cho sự kiện mới
                            document.getElementById('eventTitle').value = '';
                            document.getElementById('eventDescription').value = '';
                            const now = new Date();
                            const localISOTime = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                            document.getElementById('eventStart').value = localISOTime;
                            document.getElementById('eventEnd').value = localISOTime;
                            document.getElementById('eventColor').value = '#6366f1';
                            currentEventId = null;
                            document.getElementById('eventTitle').readOnly = false;
                            document.getElementById('eventDescription').readOnly = false;
                            document.getElementById('eventStart').readOnly = false;
                            document.getElementById('eventEnd').readOnly = false;
                            document.querySelector('#addEventModal .btn-danger').style.display = 'none';
                            new bootstrap.Modal(document.getElementById('addEventModal')).show();
                        }
                    }
                },
                headerToolbar: {
                    left: 'prev,next today addEvent',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                events: '/Calendar/GetEvents',
                editable: true,
                selectable: true,
                eventDrop: function(info) {
                    const ownerId = (info.event.extendedProps && (info.event.extendedProps.ownerId || info.event.extendedProps.ownerid || info.event.extendedProps.userId)) || '';
                    const isEventOwner = (ownerId && currentUserId && ownerId.toString() === currentUserId.toString());
                    if (!isEventOwner) {
                        info.revert();
                        Swal.fire('Unauthorized', "You don't have permission to edit this event's time.", 'warning');
                        return;
                    }
                    updateEventDates(info.event, info.revert);
                },
                eventResize: function(info) {
                    const ownerId = (info.event.extendedProps && (info.event.extendedProps.ownerId || info.event.extendedProps.ownerid || info.event.extendedProps.userId)) || '';
                    const isEventOwner = (ownerId && currentUserId && ownerId.toString() === currentUserId.toString());
                    if (!isEventOwner) {
                        info.revert();
                        Swal.fire('Unauthorized', "You don't have permission to edit this event's time.", 'warning');
                        return;
                    }
                    updateEventDates(info.event, info.revert);
                },
                eventDidMount: function(info) {
                    let tooltipText = info.event.title;
                    if (info.event.extendedProps && info.event.extendedProps.description) {
                        tooltipText += '\n' + info.event.extendedProps.description;
                    }
                    info.el.setAttribute('title', tooltipText);
                },
                select: function(info) {
                    // Khi kéo chọn khoảng thời gian
                    document.getElementById('eventTitle').value = '';
                    document.getElementById('eventDescription').value = '';
                    document.getElementById('eventTitle').readOnly = false;
                    document.getElementById('eventDescription').readOnly = false;
                    document.getElementById('eventStart').readOnly = false;
                    document.getElementById('eventEnd').readOnly = false;
                    
                    const localStart = new Date(info.start.getTime() - info.start.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                    const localEnd = new Date(info.end.getTime() - info.end.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                    
                    document.getElementById('eventStart').value = localStart;
                    document.getElementById('eventEnd').value = localEnd;
                    document.getElementById('eventColor').value = getRandomPastelColor();
                    currentEventId = null;
                    isOwner = true; // since it's anew event, current user is owner
                    document.querySelector('#addEventModal .btn-danger').style.display = 'none';
                    document.querySelector('#addEventModal .btn-pastel-primary').style.display = 'inline-block';
                    new bootstrap.Modal(document.getElementById('addEventModal')).show();
                },
                eventClick: function(info) {
                    info.jsEvent.preventDefault();
                    const rawId = info.event.id;
                    const eventId = rawId !== undefined && rawId !== null ? rawId.toString() : '';
                    let title = info.event.title || '';

                    // TRƯỜNG HỢP 1: NẾU LÀ PROJECT (Vùng màu đỏ có ID bắt đầu bằng prj_)
                    if (eventId && eventId.startsWith('prj_')) {
                        const realProjectId = eventId.replace('prj_', '');

                        // Dùng SweetAlert2 để hỏi cho chuyên nghiệp (giống trang Admin)
                        Swal.fire({
                            title: title,
                            text: "Do you want to manage this task?",
                            icon: 'info',
                            showDenyButton: true, // Xóa
                            showCancelButton: true,
                            confirmButtonText: '<i class="fas fa-edit"></i> Edit',
                            denyButtonText: `<i class="fas fa-trash"></i> Delete`,
                            confirmButtonColor: '#6366f1',
                            denyButtonColor: '#f43f5e'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                // Chuyển hướng sang trang Edit Task
                                window.location.href = '/WorkTask/Edit/' + realProjectId;
                            }
                        });
                        return; // Thoát hàm, không chạy đoạn code mở Modal bên dưới
                    }

                    // TRƯỜNG HỢP 2: NẾU LÀ EVENT BÌNH THƯỜNG
                    // Cắt emoji khỏi title (độ dài emoji "📅 " là 3 characters unicode)
                    if (title.startsWith('📅 ')) title = title.replace('📅 ', '');

                    // Lấy ownerId từ extendedProps
                    const ownerId = (info.event.extendedProps && (info.event.extendedProps.ownerId || info.event.extendedProps.ownerid || info.event.extendedProps.userId)) || '';
                    isOwner = (ownerId && currentUserId && ownerId.toString() === currentUserId.toString());

                    document.getElementById('eventTitle').value = title;
                    document.getElementById('eventDescription').value = info.event.extendedProps?.description || '';
                    // show project name when available
                    const projName = info.event.extendedProps?.projectName || '';
                    const projElem = document.getElementById('eventProject');
                    if (projName) { projElem.style.display = 'block'; projElem.textContent = 'Project: ' + projName; } else { projElem.style.display = 'none'; projElem.textContent = ''; }
                    
                    // Chuyển đổi timestamp sang local string để hiển thị trên input (bỏ phần z và timezone offset)
                    const formStart = info.event.start ? new Date(info.event.start.getTime() - info.event.start.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '';
                    const formEnd = info.event.end ? new Date(info.event.end.getTime() - info.event.end.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '';
                    
                    document.getElementById('eventStart').value = formStart;
                    document.getElementById('eventEnd').value = formEnd;

                    const color = info.event.extendedProps?.rawColor || info.event.backgroundColor || info.event.color || '#6366f1';
                    // Đảm bảo lấy đúng 7 ký tự Hex (#RRGGBB) để khớp chính xác giá trị của thẻ <select>
                    const hexColor = color.length > 7 ? color.substring(0, 7).toLowerCase() : color.toLowerCase();
                    document.getElementById('eventColor').value = hexColor;

                    // Nếu không phải owner -> chỉ cho phép chỉnh màu (readonly)
                    document.getElementById('eventTitle').readOnly = !isOwner;
                    document.getElementById('eventDescription').readOnly = !isOwner;
                    document.getElementById('eventStart').readOnly = !isOwner;
                    document.getElementById('eventEnd').readOnly = !isOwner;
                    // Ẩn/hiện nút Delete
                    document.querySelector('#addEventModal .btn-danger').style.display = isOwner ? 'inline-block' : 'none';

                    currentEventId = eventId;
                    const modal = new bootstrap.Modal(document.getElementById('addEventModal'));
                    modal.show();
                },
                eventDataTransform: function(eventData) {
                    let rawColor = eventData.color || eventData.backgroundColor || '#6366f1';
                    
                    // Lưu lại mã màu nguyên bản để khi click vào Edit sẽ chọn đúng trong Dropdown màu
                    eventData.extendedProps = eventData.extendedProps || {};
                    eventData.extendedProps.rawColor = rawColor;

                    // Nếu là Project Task, bỏ qua vì class prj-event đã xử lý màu CSS cứng
                    if (eventData.className && eventData.className.includes('prj-event')) {
                         return eventData;
                    }

                    // ThemeColor sang Phong cách Pastel (Thêm alpha Hex ~20% vào background)
                    if (rawColor.length === 7 && rawColor.startsWith('#')) {
                        eventData.backgroundColor = rawColor + '33'; // Opacity 20%
                        eventData.borderColor = 'transparent';
                        eventData.textColor = '#1e293b'; // Slate 800 - Text đậm dễ đọc
                        delete eventData.color; // Bỏ mặc định để áp filter mới
                    }
                    
                    return eventData;
                },
                nowIndicator: true,
                height: 'auto'
            });
            
            calendar.render();
        });
    </script>
}

