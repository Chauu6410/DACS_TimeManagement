@using System.Security.Claims
@inject DACS_TimeManagement.Models.ApplicationDbContext _context
@{
    var themeColor = "light";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    // Kiểm tra Landing Page (Home/Index)
    var isLandingPage = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase) &&
                        string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);

    if (User.Identity.IsAuthenticated)
    {
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        var profile = _context.UserProfiles.FirstOrDefault(p => p.UserId == userId);
        if (profile != null) themeColor = profile.Theme;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TimeMaster</title>
    
    <!-- CSS Libraries -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ---------- RESET & GLOBAL ---------- */
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --primary-light: #a5b4fc;
            --secondary: #06b6d4;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg-light: #f9fafb;
            --sidebar-bg: rgba(255,255,255,0.96);
            --topbar-bg: rgba(255,255,255,0.8);
            --card-bg: #ffffff;
            --text-dark: #111827;
            --text-muted: #6b7280;
            --border-color: #e5e7eb;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.02);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.02);
            --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.01);
            --transition: all 0.2s ease;
            --sidebar-width: 260px;
            --topbar-height: 68px;
            --pomodoro-gradient-start: #f97316;
            --pomodoro-gradient-end: #dc2626;
            /* Typography */
            --font-base: 0.938rem;   /* 15px */
            --font-sm: 0.813rem;     /* 13px */
            --font-xs: 0.75rem;      /* 12px */
        }

        /* Dark Theme */
        .theme-dark {
            --primary: #818cf8;
            --primary-dark: #6366f1;
            --bg-light: #0f172a;
            --sidebar-bg: #1e293b;
            --topbar-bg: rgba(30,41,59,0.85);
            --card-bg: #1e293b;
            --text-dark: #f1f5f9;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --shadow-sm: 0 1px 2px 0 rgba(0,0,0,0.3);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.3);
            --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.4);
            --pomodoro-gradient-start: #f97316;
            --pomodoro-gradient-end: #ef4444;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            font-size: var(--font-base);
            background: linear-gradient(135deg, var(--bg-light) 0%, rgba(99,102,241,0.03) 100%);
            color: var(--text-dark);
            overflow-x: hidden;
            height: 100vh;
            display: flex;
        }

        /* Landing Page Mode: body không có flex đặc biệt, cuộn tự nhiên */
        body.landing-page-mode {
            display: block;
            height: auto;
            overflow-y: auto;
        }

        /* Dashboard Mode: giữ layout flex cố định */
        body.dashboard-mode {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--text-muted);
            border-radius: 10px;
            opacity: 0.5;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary);
        }

        /* Layout */
        .app-container {
            display: flex;
            width: 100%;
            height: 100%;
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            backdrop-filter: blur(12px);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1000;
            position: relative;
        }
        .sidebar-header {
            height: var(--topbar-height);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }
        .sidebar-brand {
            font-size: 1.4rem;
            font-weight: 800;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }
        .sidebar-brand i {
            background: none;
            color: var(--primary);
            font-size: 1.6rem;
        }
        .sidebar-content {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem 1rem;
        }
        .nav-category {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            font-weight: 700;
            color: var(--text-muted);
            padding: 0.5rem 1rem;
            margin-top: 0.8rem;
        }
        .nav-item {
            margin-bottom: 0.25rem;
        }
        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0.7rem 1rem;
            border-radius: 12px;
            color: var(--text-dark);
            font-weight: 500;
            transition: var(--transition);
            text-decoration: none;
            font-size: 0.9rem;
        }
        .nav-link i {
            width: 22px;
            font-size: 1.1rem;
            color: var(--text-muted);
            transition: var(--transition);
        }
        .nav-link:hover {
            background: rgba(99,102,241,0.08);
            color: var(--primary);
            transform: translateX(4px);
        }
        .nav-link.active {
            background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(6,182,212,0.06));
            color: var(--primary);
            box-shadow: var(--shadow-sm);
        }
        .nav-link.active i {
            color: var(--primary);
        }
        .sidebar-footer {
            padding: 1rem;
            border-top: 1px solid var(--border-color);
        }

        /* Main Wrapper */
        .main-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Topbar Glassmorphism */
        .topbar {
            height: var(--topbar-height);
            background: var(--topbar-bg);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 99;
        }
        .page-title {
            font-weight: 700;
            font-size: 1.25rem;
            background: linear-gradient(135deg, var(--text-dark), var(--text-muted));
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }
        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .notification-bell {
            position: relative;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 30px;
            background: rgba(99,102,241,0.1);
            transition: var(--transition);
            cursor: pointer;
        }
        .notification-bell:hover {
            background: rgba(99,102,241,0.2);
            transform: scale(1.05);
        }
        .notification-bell i {
            font-size: 1.2rem;
            color: var(--text-muted);
        }
        .notification-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--danger);
            color: white;
            font-size: 0.65rem;
            font-weight: 600;
            padding: 0.2rem 0.45rem;
            border-radius: 30px;
            box-shadow: 0 0 0 2px var(--topbar-bg);
        }

        /* Main Content */
        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 2rem;
            scroll-behavior: smooth;
        }
        /* Dashboard mode: main content có padding bình thường */
        body.dashboard-mode .main-content {
            padding: 2rem;
        }
        /* Landing page mode: main content full width, không padding */
        body.landing-page-mode .main-content {
            padding: 0 !important;
            overflow-y: visible;
        }

        /* Card chuẩn */
        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            box-shadow: var(--shadow-md);
            transition: var(--transition);
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        /* Responsive */
        .mobile-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.3rem;
            color: var(--text-dark);
            cursor: pointer;
            padding: 0.5rem;
        }
        @@media (max-width: 992px) {
            .sidebar {
                position: fixed;
                left: 0;
                transform: translateX(-100%);
                height: 100%;
                box-shadow: var(--shadow-xl);
            }
            .sidebar.show {
                transform: translateX(0);
            }
            .mobile-toggle {
                display: block;
            }
            .main-content {
                padding: 1rem;
            }
            .topbar {
                padding: 0 1rem;
            }
        }

        /* Pomodoro Widget nâng cấp */
        #togglePomodoro {
            background: linear-gradient(145deg, var(--pomodoro-gradient-start), var(--pomodoro-gradient-end));
            border: none;
            width: 64px;
            height: 64px;
            border-radius: 32px;
            box-shadow: 0 12px 24px -8px rgba(249,115,22,0.4), 0 4px 12px rgba(0,0,0,0.1);
            transition: all 0.2s ease;
            cursor: pointer;
            z-index: 1051;
        }
        #togglePomodoro:hover {
            transform: scale(1.05) rotate(4deg);
            box-shadow: 0 20px 30px -10px rgba(249,115,22,0.5);
        }
        .pulse-animation {
            animation: softPulse 2s infinite;
        }
        @@keyframes softPulse {
            0% { box-shadow: 0 0 0 0 rgba(249,115,22,0.4); }
            70% { box-shadow: 0 0 0 12px rgba(249,115,22,0); }
            100% { box-shadow: 0 0 0 0 rgba(249,115,22,0); }
        }
        .glass-card {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(20px);
            border-radius: 32px !important;
            border: 1px solid rgba(255,255,255,0.6);
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.2);
        }
        .theme-dark .glass-card {
            background: rgba(30,41,59,0.9);
            border-color: rgba(255,255,255,0.1);
        }
        .drag-handle {
            cursor: grab;
            background: rgba(0,0,0,0.02);
            transition: background 0.2s;
        }
        .drag-handle:active { cursor: grabbing; }
        #timerDisplay {
            font-size: 2.8rem;
            font-weight: 800;
            letter-spacing: 2px;
            background: linear-gradient(135deg, var(--pomodoro-gradient-start), var(--pomodoro-gradient-end));
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }
        .progress {
            background: rgba(0,0,0,0.08);
            border-radius: 20px;
            height: 8px;
        }
        .progress-bar {
            background: linear-gradient(90deg, var(--pomodoro-gradient-start), var(--pomodoro-gradient-end));
            border-radius: 20px;
        }
        .btn-pomo {
            border-radius: 40px;
            font-weight: 600;
            padding: 8px 0;
            transition: all 0.15s ease;
        }
        .btn-start {
            background: linear-gradient(105deg, #f97316, #dc2626);
            color: white;
            border: none;
            box-shadow: 0 4px 10px rgba(220,38,38,0.3);
        }
        .btn-start:hover {
            transform: scale(0.98);
            box-shadow: 0 2px 5px rgba(220,38,38,0.4);
        }
        .btn-pause {
            background: rgba(245,158,11,0.12);
            border: 1px solid rgba(245,158,11,0.4);
            color: #f59e0b;
        }
        .btn-pause:hover {
            background: rgba(245,158,11,0.25);
        }
        .btn-reset {
            width: 44px;
            height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(107,114,128,0.1);
            border: none;
            color: var(--text-muted);
        }
        .btn-reset:hover {
            background: rgba(107,114,128,0.2);
            transform: rotate(15deg);
        }
        .toast-notify {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(20px);
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            color: white;
            padding: 10px 24px;
            border-radius: 60px;
            font-size: 0.9rem;
            font-weight: 500;
            z-index: 2000;
            opacity: 0;
            transition: 0.2s;
            pointer-events: none;
        }

        /* Small text utilities */
        .text-sm {
            font-size: var(--font-sm);
        }
        .text-xs {
            font-size: var(--font-xs);
        }
    </style>
</head>
<body class="theme-@themeColor @(isLandingPage ? "landing-page-mode" : "dashboard-mode")">
    @if (!isLandingPage)
    {
        <!-- Dashboard Mode: Hiển thị Sidebar, Topbar, Pomodoro -->
        <div class="app-container">
            <!-- Sidebar -->
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-header">
                    <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-brain"></i> TimeMaster
                    </a>
                    <button class="mobile-toggle ms-auto" onclick="toggleSidebar()">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="sidebar-content">
                    <ul class="nav flex-column">
                        <li class="nav-category">Overview</li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-chart-line"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Report" ? "active" : "")" asp-controller="Report" asp-action="Index">
                                <i class="fas fa-chart-pie"></i> Reporting
                            </a>
                        </li>
                        <li class="nav-category mt-2">Workspace</li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "WorkTask" ? "active" : "")" asp-controller="WorkTask" asp-action="Index">
                                <i class="fas fa-columns"></i> Kanban
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Calendar" ? "active" : "")" asp-controller="Calendar" asp-action="Index">
                                <i class="far fa-calendar-alt"></i> Schedule
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Goal" ? "active" : "")" asp-controller="Goal" asp-action="Index">
                                <i class="fas fa-bullseye"></i> Goals
                            </a>
                        </li>
                        <li class="nav-category mt-2">Organization</li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Project" ? "active" : "")" asp-controller="Project" asp-action="Index">
                                <i class="fas fa-project-diagram"></i> Projects
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Share" ? "active" : "")" asp-controller="Share" asp-action="Index">
                                <i class="fas fa-share-alt"></i> Team Shared
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-category mt-2 text-primary">Admin</li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Admin" ? "active" : "")" asp-controller="Admin" asp-action="Index">
                                    <i class="fas fa-shield-alt"></i> System Admin
                                </a>
                            </li>
                        }
                    </ul>
                </div>
                <div class="sidebar-footer">
                    <a class="nav-link @(currentController == "Profile" ? "active" : "")" asp-controller="Profile" asp-action="Index">
                        <i class="fas fa-user-cog"></i> Settings
                    </a>
                </div>
            </aside>

            <!-- Main Wrapper -->
            <div class="main-wrapper">
                <header class="topbar">
                    <div class="d-flex align-items-center gap-2">
                        <button class="mobile-toggle" onclick="toggleSidebar()">
                            <i class="fas fa-bars"></i>
                        </button>
                        <h1 class="page-title mb-0">@ViewData["Title"]</h1>
                    </div>
                    <div class="topbar-actions">
                        <div class="dropdown">
                            <div class="notification-bell" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-bell"></i>
                                <span class="notification-badge" id="notifBadge" style="display: none;">0</span>
                            </div>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0" style="border-radius: 20px; min-width: 300px;">
                                <li><h6 class="dropdown-header fw-bold py-3">Notifications</h6></li>
                                <div id="notifList" style="max-height: 300px; overflow-y: auto;">
                                    <li class="p-4 text-center text-muted small"><i class="fas fa-check-circle fs-4 mb-2"></i><br/>All caught up</li>
                                </div>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-center fw-semibold" href="/Notification/Index">View all →</a></li>
                            </ul>
                        </div>
                        <partial name="_LoginPartial" />
                    </div>
                </header>
                <main class="main-content">
                    <div class="container-fluid px-0">
                        @RenderBody()
                    </div>
                    <footer class="mt-5 pt-3 border-top text-center text-muted small">
                        © 2026 TimeMaster · <a href="#" class="text-decoration-none">Privacy</a> · <a href="#" class="text-decoration-none">Terms</a>
                    </footer>
                </main>
            </div>
        </div>
    }
    else
    {
        <!-- Landing Page Mode: Chỉ hiển thị nội dung, không sidebar, topbar, pomodoro -->
        <main class="main-content" style="width: 100%; padding: 0; margin: 0;">
            @RenderBody()
        </main>
    }

    <!-- Scripts chung (luôn chạy) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ once: true, duration: 500 });
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            if (sidebar) sidebar.classList.toggle('show');
        }
        $(function() {
            function fetchNotif() {
                $.get('/Notification/GetUnreadCount', function(data) {
                    if(data && data > 0) $('#notifBadge').text(data).show();
                    else $('#notifBadge').hide();
                }).fail(() => console.log("Notif err"));
            }
            fetchNotif();
            setInterval(fetchNotif, 60000);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (!isLandingPage)
    {
        <!-- Pomodoro Widget (chỉ hiển thị ở dashboard mode) -->
        <button id="togglePomodoro" class="position-fixed bottom-0 end-0 m-4 rounded-circle shadow-lg pulse-animation">
            <span style="font-size: 1.6rem;">🍅</span>
        </button>
        <div id="pomodoroWidget" class="position-fixed shadow-xl draggable-widget" style="z-index:1050; display:none; bottom: 100px; right: 20px;">
            <div class="card border-0 rounded-4 glass-card" style="width: 280px;">
                <div id="pomodoroHeader" class="drag-handle d-flex justify-content-between align-items-center px-3 py-3">
                    <div><i class="fas fa-grip-vertical text-muted me-1"></i> <span class="fw-semibold small">FOCUS TIMER</span></div>
                    <button id="closePomodoroBtn" class="btn-close-custom" style="background: none; border: none;"><i class="fas fa-times"></i></button>
                </div>
                <div class="card-body p-4 pt-2 text-center">
                    <h1 id="timerDisplay" class="display-5 fw-bold mb-1">25:00</h1>
                    <div class="progress my-3" style="height: 6px;"><div id="progressBar" class="progress-bar" style="width:100%"></div></div>
                    <div class="d-flex gap-2 justify-content-between">
                        <button class="btn btn-pomo btn-start flex-grow-1" id="startBtn"><i class="fas fa-play me-1"></i> Start</button>
                        <button class="btn btn-pomo btn-pause flex-grow-1" id="pauseBtn"><i class="fas fa-pause me-1"></i> Pause</button>
                        <button class="btn btn-pomo btn-reset rounded-circle" id="resetBtn"><i class="fas fa-undo-alt"></i></button>
                    </div>
                </div>
            </div>
        </div>
        <div id="pomodoroToast" class="toast-notify">🍅 Focus session completed! Great job.</div>
        <script>
            (function() {
                let timerInterval = null, isRunning = false, currentSeconds = 25*60, initialSeconds = 25*60;
                const timerDisplay = document.getElementById('timerDisplay'), progressBar = document.getElementById('progressBar');
                const startBtn = document.getElementById('startBtn'), pauseBtn = document.getElementById('pauseBtn'), resetBtn = document.getElementById('resetBtn');
                const widget = document.getElementById('pomodoroWidget'), toggleBtn = document.getElementById('togglePomodoro'), closeBtn = document.getElementById('closePomodoroBtn');
                const toast = document.getElementById('pomodoroToast');
                function formatTime(s){ let m=Math.floor(s/60), sec=s%60; return `${m.toString().padStart(2,'0')}:${sec.toString().padStart(2,'0')}`; }
                function updateUI(){ timerDisplay.innerText=formatTime(currentSeconds); progressBar.style.width=`${(currentSeconds/initialSeconds)*100}%`; }
                function showToast(){ toast.style.opacity='1'; toast.style.transform='translateX(-50%) translateY(0px)'; setTimeout(()=>{ toast.style.opacity='0'; toast.style.transform='translateX(-50%) translateY(20px)'; },2800); if(navigator.vibrate) navigator.vibrate(200); try{ let audio=new Audio(); audio.src='data:audio/wav;base64,U3RlYWx0aCBzb3VuZA=='; audio.play(); }catch(e){} }
                function endTimer(){ if(timerInterval) clearInterval(timerInterval); timerInterval=null; isRunning=false; showToast(); currentSeconds=initialSeconds; updateUI(); startBtn.disabled=false; }
                function startCountdown(){ if(timerInterval) clearInterval(timerInterval); timerInterval=setInterval(()=>{ if(currentSeconds<=1){ clearInterval(timerInterval); timerInterval=null; currentSeconds=0; updateUI(); endTimer(); }else{ currentSeconds--; updateUI(); } },1000); }
                function startTimer(){ if(isRunning) return; if(currentSeconds<=0) currentSeconds=initialSeconds; isRunning=true; startCountdown(); startBtn.disabled=true; }
                function pauseTimer(){ if(!isRunning) return; if(timerInterval) clearInterval(timerInterval); timerInterval=null; isRunning=false; startBtn.disabled=false; }
                function resetTimer(){ if(timerInterval) clearInterval(timerInterval); timerInterval=null; isRunning=false; currentSeconds=initialSeconds; updateUI(); startBtn.disabled=false; }
                startBtn.addEventListener('click',startTimer); pauseBtn.addEventListener('click',pauseTimer); resetBtn.addEventListener('click',resetTimer);
                toggleBtn.addEventListener('click',()=>{ widget.style.display = (widget.style.display==='none'||getComputedStyle(widget).display==='none')?'block':'none'; });
                closeBtn.addEventListener('click',()=>widget.style.display='none');
                const dragHandle=document.getElementById('pomodoroHeader'); let isDragging=false, startX,startY,startLeft,startTop;
                function getWidgetPos(){ let left=parseFloat(widget.style.left),top=parseFloat(widget.style.top); if(isNaN(left)){ let rect=widget.getBoundingClientRect(); left=rect.left; top=rect.top; } return {left,top}; }
                function onMouseDown(e){ if(!dragHandle.contains(e.target)) return; e.preventDefault(); isDragging=true; startX=e.clientX; startY=e.clientY; let {left,top}=getWidgetPos(); startLeft=left; startTop=top; if(widget.style.right!==''||widget.style.bottom!==''){ let rect=widget.getBoundingClientRect(); widget.style.left=rect.left+'px'; widget.style.top=rect.top+'px'; widget.style.right='auto'; widget.style.bottom='auto'; startLeft=rect.left; startTop=rect.top; } document.addEventListener('mousemove',onMouseMove); document.addEventListener('mouseup',onMouseUp); widget.style.transition='none'; }
                function onMouseMove(e){ if(!isDragging) return; let newLeft=startLeft+(e.clientX-startX), newTop=startTop+(e.clientY-startY); newLeft=Math.min(Math.max(newLeft,10),window.innerWidth-widget.offsetWidth-10); newTop=Math.min(Math.max(newTop,10),window.innerHeight-widget.offsetHeight-10); widget.style.left=newLeft+'px'; widget.style.top=newTop+'px'; }
                function onMouseUp(){ isDragging=false; document.removeEventListener('mousemove',onMouseMove); document.removeEventListener('mouseup',onMouseUp); widget.style.transition=''; }
                dragHandle.addEventListener('mousedown',onMouseDown);
                updateUI();
            })();
        </script>

        <!-- SignalR Toast -->
        <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1080">
            <div id="realtimeToast" class="toast bg-white shadow border-0 rounded-4" role="alert">
                <div class="toast-header border-0 bg-primary text-white rounded-top-4">
                    <i class="fas fa-bell me-2"></i><strong class="me-auto">New Assignment</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body p-3">
                    <div class="d-flex gap-3">
                        <div class="bg-primary-subtle text-primary rounded-circle p-2 fs-4"><i class="fas fa-tasks"></i></div>
                        <div><p class="mb-0 fw-bold" id="toastMessage">New task assigned!</p><small class="text-muted" id="toastDetail">Check workspace.</small></div>
                    </div>
                </div>
            </div>
        </div>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                const connection = new signalR.HubConnectionBuilder().withUrl("/notificationHub").configureLogging(signalR.LogLevel.Information).build();
                connection.on("ReceiveNotification", function(message, taskTitle) {
                    document.getElementById("toastMessage").innerText = message;
                    if(taskTitle) document.getElementById("toastDetail").innerText = `Task: ${taskTitle}`;
                    let badge = document.getElementById("notifBadge");
                    if(badge) { let cnt = parseInt(badge.innerText)||0; badge.innerText=cnt+1; badge.style.display="inline"; }
                    new bootstrap.Toast(document.getElementById("realtimeToast"), {delay:5000}).show();
                    if(navigator.vibrate) navigator.vibrate([100,50,100]);
                });
                connection.start().catch(err=>console.error(err));
            });
        </script>
    }
</body>
</html>