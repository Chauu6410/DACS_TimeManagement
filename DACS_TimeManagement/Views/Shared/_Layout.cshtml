@using System.Security.Claims
@inject DACS_TimeManagement.Models.ApplicationDbContext _context
@{
    var themeColor = "light";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();

    if (User.Identity.IsAuthenticated)
    {
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        var profile = _context.UserProfiles.FirstOrDefault(p => p.UserId == userId);
        if (profile != null) themeColor = profile.Theme;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TimeMaster</title>
    
    <!-- CSS Libraries -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        :root {
            --primary: #6366f1; /* Indigo 500 */
            --primary-dark: #4338ca; /* Indigo 700 */
            --secondary: #06b6d4; /* Cyan 500 */
            --bg-light: #f8fafc; /* Cool very light gray background */
            --sidebar-bg: #ffffff;
            --sidebar-width: 260px;
            --topbar-height: 70px;
            --text-dark: #0f172a;
            --text-muted: #64748b;
            --border-color: rgba(0,0,0,0.05);
            --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            --shadow-sm: 0 2px 5px rgba(0,0,0,0.02);
            --shadow-md: 0 4px 10px rgba(0,0,0,0.04);
            --shadow-lg: 0 10px 20px -3px rgba(99, 102, 241, 0.1);
            --shadow-2xl: 0 25px 50px -12px rgba(0,0,0,0.15);
            --pomodoro-gradient-start: #ff6b6b;
            --pomodoro-gradient-end: #ffa25b;
        }

        /* Dark Theme overrides */
        .theme-dark {
            --primary: #818cf8;
            --primary-dark: #4f46e5;
            --bg-light: #0f172a;
            --sidebar-bg: #1e293b;
            --text-dark: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: rgba(255,255,255,0.08);
            --shadow-lg: 0 10px 20px -3px rgba(0,0,0,0.4);
            --pomodoro-gradient-start: #ff8a5c;
            --pomodoro-gradient-end: #ff4d4d;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            display: flex;
            height: 100vh;
        }

        /* App Layout Container */
        .app-container {
            display: flex;
            width: 100%;
            height: 100%;
        }

        /* Sidebar Styling */
        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            transition: var(--transition);
            z-index: 1000;
        }

        .sidebar-header {
            height: var(--topbar-height);
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }

        .sidebar-brand {
            font-size: 1.4rem;
            font-weight: 800;
            text-decoration: none;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-brand i {
            color: var(--primary);
            font-size: 1.6rem;
        }

        .sidebar-content {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem 1rem;
        }
        
        .sidebar-content::-webkit-scrollbar { width: 5px; }
        .sidebar-content::-webkit-scrollbar-track { background: transparent; }
        .sidebar-content::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 10px; }

        .nav-category {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            font-weight: 700;
            color: var(--text-muted);
            padding: 0.5rem 1rem;
            margin-top: 0.5rem;
        }

        .nav-item { margin-bottom: 0.2rem; }

        .nav-link {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            color: var(--text-dark);
            font-weight: 500;
            border-radius: 10px;
            transition: var(--transition);
            text-decoration: none;
            gap: 12px;
        }

        .nav-link i {
            font-size: 1.1rem;
            color: var(--text-muted);
            width: 20px;
            text-align: center;
            transition: var(--transition);
        }

        .nav-link:hover, .nav-link.active {
            background-color: rgba(67, 97, 238, 0.08);
            color: var(--primary);
        }

        .nav-link:hover i, .nav-link.active i {
            color: var(--primary);
        }

        .sidebar-footer {
            padding: 1rem;
            border-top: 1px solid var(--border-color);
        }

        /* Main Content Styling */
        .main-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Topbar */
        .topbar {
            height: var(--topbar-height);
            background-color: var(--sidebar-bg);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            box-shadow: var(--shadow-sm);
            z-index: 100;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.25rem;
            color: var(--text-dark);
            margin: 0;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .notification-bell {
            color: var(--text-muted);
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 50%;
            transition: var(--transition);
        }

        .notification-bell:hover {
            background-color: rgba(0,0,0,0.05);
            color: var(--primary);
        }

        .notification-badge {
            font-size: 0.6rem;
            padding: 0.25em 0.5em;
        }

        /* Main Content Area */
        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 2rem;
            scroll-behavior: smooth;
        }

        /* Standardized Card Style */
        .card {
            background-color: var(--sidebar-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            box-shadow: var(--shadow-lg);
        }
        .card-header {
            background-color: transparent;
            border-bottom: 1px solid var(--border-color);
        }

        /* Responsive */
        @@media (max-width: 992px) {
            .sidebar {
                position: fixed;
                left: -260px;
                height: 100%;
                box-shadow: var(--shadow-2xl);
            }
            .sidebar.show { left: 0; }
            .topbar { padding: 0 1rem; }
            .main-content { padding: 1rem; }
            .mobile-toggle { display: block !important; }
        }
        
        .mobile-toggle { display: none; background: none; border: none; font-size: 1.5rem; color: var(--text-dark); cursor: pointer; padding: 0.5rem; }

        /* ========== POMODORO WIDGET - NÂNG CẤP ========== */
        #togglePomodoro {
            background: linear-gradient(145deg, var(--pomodoro-gradient-start), var(--pomodoro-gradient-end));
            border: none;
            width: 70px;
            height: 70px;
            transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            box-shadow: 0 12px 24px -8px rgba(238, 90, 90, 0.4), 0 4px 12px rgba(0,0,0,0.1);
            cursor: pointer;
            backdrop-filter: blur(2px);
            z-index: 1051;
        }
        #togglePomodoro:hover {
            transform: scale(1.08) translateY(-4px);
            box-shadow: 0 20px 30px -10px rgba(238, 90, 90, 0.5);
        }
        #togglePomodoro:active { transform: scale(0.96); }
        .pulse-animation {
            animation: pulseGlow 2s infinite;
        }
        @@keyframes pulseGlow {
            0% { box-shadow: 0 0 0 0 rgba(255, 107, 107, 0.5); }
            70% { box-shadow: 0 0 0 14px rgba(255, 107, 107, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 107, 107, 0); }
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(16px);
            border-radius: 36px !important;
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.25), 0 4px 12px rgba(0, 0, 0, 0.05);
            transition: transform 0.2s ease;
        }
        .theme-dark .glass-card {
            background: rgba(30, 41, 59, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.15);
        }
        .drag-handle {
            background: rgba(255, 255, 255, 0.5);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            cursor: grab;
            transition: background 0.2s;
            user-select: none;
        }
        .drag-handle:active { cursor: grabbing; }
        .theme-dark .drag-handle { background: rgba(0, 0, 0, 0.2); }

        #timerDisplay {
            font-family: 'Inter', monospace;
            font-weight: 800;
            background: linear-gradient(135deg, var(--pomodoro-gradient-start), var(--pomodoro-gradient-end));
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: 2px;
            font-size: 3.2rem;
        }
        .progress {
            background: rgba(0, 0, 0, 0.08);
            border-radius: 20px;
            height: 8px;
            overflow: hidden;
        }
        .progress-bar {
            background: linear-gradient(90deg, var(--pomodoro-gradient-start), var(--pomodoro-gradient-end));
            border-radius: 20px;
            transition: width 0.25s linear;
        }
        .btn-pomo {
            border-radius: 50px;
            padding: 8px 0;
            font-weight: 600;
            transition: all 0.2s ease;
            border: none;
        }
        .btn-start {
            background: linear-gradient(105deg, #ff5e5e, #ff3b3b);
            color: white;
            box-shadow: 0 6px 14px rgba(255, 59, 59, 0.25);
        }
        .btn-start:hover {
            background: linear-gradient(105deg, #ff4747, #ff2323);
            transform: translateY(-2px);
        }
        .btn-pause {
            background: rgba(255, 193, 7, 0.15);
            border: 1px solid rgba(255, 193, 7, 0.5);
            color: #e67e22;
        }
        .btn-pause:hover {
            background: rgba(255, 193, 7, 0.25);
            transform: scale(0.97);
        }
        .btn-reset {
            background: rgba(108, 117, 125, 0.15);
            border: 1px solid rgba(108, 117, 125, 0.3);
            color: #4a5b6e;
            width: 44px;
            height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .btn-reset:hover {
            background: rgba(108, 117, 125, 0.3);
            transform: rotate(12deg) scale(1.05);
        }
        .toast-notify {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(20px);
            background: #1e272ecc;
            backdrop-filter: blur(12px);
            color: white;
            padding: 10px 24px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 500;
            z-index: 2000;
            opacity: 0;
            transition: opacity 0.25s, transform 0.25s;
            pointer-events: none;
            white-space: nowrap;
        }
        @@media (max-width: 480px) {
            #pomodoroWidget .card { width: 260px !important; }
            #timerDisplay { font-size: 2.6rem !important; }
        }
    </style>
</head>
<body class="theme-@themeColor">

    <div class="app-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-clock"></i> TimeMaster
                </a>
                <button class="mobile-toggle ms-auto" onclick="toggleSidebar()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="sidebar-content">
                <ul class="nav flex-column mb-auto">
                    <li class="nav-category">Overview</li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-chart-line"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Report" ? "active" : "")" asp-controller="Report" asp-action="Index">
                            <i class="fas fa-chart-pie"></i> Reporting & Stats
                        </a>
                    </li>
                    
                    <li class="nav-category mt-3">My Workspace</li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "WorkTask" ? "active" : "")" asp-controller="WorkTask" asp-action="Index">
                            <i class="fas fa-tasks"></i> My Tasks
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Calendar" ? "active" : "")" asp-controller="Calendar" asp-action="Index">
                            <i class="far fa-calendar-alt"></i> Schedule
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Goal" ? "active" : "")" asp-controller="Goal" asp-action="Index">
                            <i class="fas fa-bullseye"></i> Personal Goals
                        </a>
                    </li>
                    
                    <li class="nav-category mt-3">Organization</li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Project" ? "active" : "")" asp-controller="Project" asp-action="Index">
                            <i class="fas fa-project-diagram"></i> Projects
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Share" ? "active" : "")" asp-controller="Share" asp-action="Index">
                            <i class="fas fa-share-alt"></i> Team Shared
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-category mt-3 text-primary"><i class="fas fa-shield-alt"></i> Admin Panel</li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Admin" ? "active" : "")" asp-controller="Admin" asp-action="Index">
                                <i class="fas fa-users-cog"></i> Quản lý hệ thống
                            </a>
                        </li>
                    }
                </ul>
            </div>
            
            <div class="sidebar-footer">
                <a class="nav-link @(currentController == "Profile" ? "active" : "")" asp-controller="Profile" asp-action="Index">
                    <i class="fas fa-cog"></i> Settings & Profile
                </a>
            </div>
        </aside>

        <!-- Main Wrapper -->
        <div class="main-wrapper">
            <header class="topbar">
                <div class="d-flex align-items-center">
                    <button class="mobile-toggle me-3" onclick="toggleSidebar()">
                        <i class="fas fa-bars"></i>
                    </button>
                    <h1 class="page-title d-none d-sm-block">@ViewData["Title"]</h1>
                </div>
                
                <div class="topbar-actions">
                    <div class="dropdown">
                        <a class="notification-bell text-decoration-none" href="#" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge" id="notifBadge" style="display: none;">0</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0" aria-labelledby="dropdownMenuLink" style="width: 320px; border-radius: 12px;">
                            <li><h6 class="dropdown-header fw-bold text-dark fs-6 py-3 border-bottom">Notifications</h6></li>
                            <div id="notifList" style="max-height: 300px; overflow-y: auto;">
                                <li class="p-4 text-center text-muted small"><i class="fas fa-check-circle fs-4 mb-2 text-success"></i><br/>You're all caught up!</li>
                            </div>
                            <li><hr class="dropdown-divider m-0"></li>
                            <li><a class="dropdown-item text-center py-2 fw-bold text-primary small" href="/Notification/Index">View All Activity</a></li>
                        </ul>
                    </div>
                    <div class="ms-2">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </header>

            <main class="main-content">
                <div class="container-fluid p-0">
                    @RenderBody()
                </div>
                <footer class="mt-5 pt-3 border-top text-center text-muted small">
                    &copy; 2026 TimeMaster &middot; <a href="#">Privacy</a> &middot; <a href="#">Terms</a>
                </footer>
            </main>
        </div>
        
        <div class="modal-backdrop fade show d-none" id="sidebarBackdrop" onclick="toggleSidebar()" style="z-index: 999;"></div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    
    <script>
        AOS.init({ once: true, offset: 50, duration: 600 });

        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('show');
            const backdrop = document.getElementById('sidebarBackdrop');
            if(backdrop.classList.contains('d-none')) backdrop.classList.remove('d-none');
            else backdrop.classList.add('d-none');
        }
        
        $(document).ready(function() {
            function fetchNotifications() {
                $.get('/Notification/GetUnreadCount', function(data) {
                    const badge = $('#notifBadge');
                    if (data && data > 0) badge.text(data).show();
                    else badge.hide();
                }).fail(() => console.log("Notif fetch failed"));
            }
            fetchNotifications();
            setInterval(fetchNotifications, 60000);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- 🍅 Pomodoro Widget - Thiết kế lại đẹp mắt, kéo thả, hỗ trợ theme -->
    <button id="togglePomodoro" class="position-fixed bottom-0 end-0 m-4 rounded-circle shadow-lg pulse-animation">
        <span style="font-size: 1.8rem;">🍅</span>
    </button>

    <div id="pomodoroWidget" class="position-fixed shadow-lg draggable-widget" style="z-index:1050; display:none; bottom: 100px; right: 25px;">
        <div class="card border-0 rounded-4 glass-card" style="width: 290px; overflow: hidden;">
            <div id="pomodoroHeader" class="drag-handle d-flex justify-content-between align-items-center px-3 py-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-grip-vertical text-muted" style="font-size: 0.9rem;"></i>
                    <span class="fw-semibold" style="font-size: 0.7rem; letter-spacing: 1px;">FOCUS FLOW</span>
                </div>
                <button id="closePomodoroBtn" class="btn-close-custom" style="background: none; border: none; font-size: 1rem;">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="card-body p-4 pt-2 text-center">
                <div class="timer-container mb-2">
                    <h1 id="timerDisplay" class="display-4 fw-bold mb-0">25:00</h1>
                    <p class="small mt-2 mb-0"><i class="fas fa-hourglass-half me-1"></i> Focus Session</p>
                </div>
                <div class="progress mb-4 mt-2" style="height: 8px;">
                    <div id="progressBar" class="progress-bar" style="width: 100%;"></div>
                </div>
                <div class="d-flex justify-content-between gap-2 align-items-center">
                    <button class="btn btn-pomo btn-start flex-grow-1" id="startBtn"><i class="fas fa-play me-1"></i> Start</button>
                    <button class="btn btn-pomo btn-pause flex-grow-1" id="pauseBtn"><i class="fas fa-pause me-1"></i> Pause</button>
                    <button class="btn btn-pomo btn-reset rounded-circle" id="resetBtn"><i class="fas fa-arrow-rotate-right"></i></button>
                </div>
            </div>
        </div>
    </div>

    <div id="pomodoroToast" class="toast-notify">🍅 Time's up! Great focus ✨</div>

    <script>
        // Pomodoro Timer Logic + Drag & Drop + Theme aware
        (function() {
            let timerInterval = null;
            let isRunning = false;
            let currentSeconds = 25 * 60;
            const initialSeconds = 25 * 60;

            const timerDisplay = document.getElementById('timerDisplay');
            const progressBar = document.getElementById('progressBar');
            const startBtn = document.getElementById('startBtn');
            const pauseBtn = document.getElementById('pauseBtn');
            const resetBtn = document.getElementById('resetBtn');
            const widget = document.getElementById('pomodoroWidget');
            const toggleBtn = document.getElementById('togglePomodoro');
            const closeBtn = document.getElementById('closePomodoroBtn');
            const toast = document.getElementById('pomodoroToast');

            function formatTime(seconds) {
                const mins = Math.floor(seconds / 60);
                const secs = seconds % 60;
                return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
            }

            function updateUI() {
                timerDisplay.innerText = formatTime(currentSeconds);
                const percent = (currentSeconds / initialSeconds) * 100;
                progressBar.style.width = `${percent}%`;
            }

            function showToast() {
                toast.style.opacity = '1';
                toast.style.transform = 'translateX(-50%) translateY(0px)';
                setTimeout(() => {
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateX(-50%) translateY(20px)';
                }, 2800);
                if (navigator.vibrate) navigator.vibrate(200);
                try {
                    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                    const osc = audioCtx.createOscillator();
                    const gain = audioCtx.createGain();
                    osc.connect(gain);
                    gain.connect(audioCtx.destination);
                    osc.frequency.value = 880;
                    gain.gain.value = 0.2;
                    osc.type = 'sine';
                    osc.start();
                    gain.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + 1.2);
                    osc.stop(audioCtx.currentTime + 1);
                    audioCtx.resume();
                } catch(e) { console.log("Audio not allowed"); }
            }

            function endTimer() {
                if (timerInterval) clearInterval(timerInterval);
                timerInterval = null;
                isRunning = false;
                showToast();
                currentSeconds = initialSeconds;
                updateUI();
                startBtn.disabled = false;
            }

            function startCountdown() {
                if (timerInterval) clearInterval(timerInterval);
                timerInterval = setInterval(() => {
                    if (currentSeconds <= 1) {
                        clearInterval(timerInterval);
                        timerInterval = null;
                        currentSeconds = 0;
                        updateUI();
                        endTimer();
                        isRunning = false;
                    } else {
                        currentSeconds--;
                        updateUI();
                    }
                }, 1000);
            }

            function startTimer() {
                if (isRunning) return;
                if (currentSeconds <= 0) currentSeconds = initialSeconds;
                isRunning = true;
                startCountdown();
                startBtn.disabled = true;
            }

            function pauseTimer() {
                if (!isRunning) return;
                if (timerInterval) clearInterval(timerInterval);
                timerInterval = null;
                isRunning = false;
                startBtn.disabled = false;
            }

            function resetTimer() {
                if (timerInterval) clearInterval(timerInterval);
                timerInterval = null;
                isRunning = false;
                currentSeconds = initialSeconds;
                updateUI();
                startBtn.disabled = false;
            }

            startBtn.addEventListener('click', startTimer);
            pauseBtn.addEventListener('click', pauseTimer);
            resetBtn.addEventListener('click', resetTimer);

            // Toggle widget
            function toggleWidget() {
                if (widget.style.display === 'none' || getComputedStyle(widget).display === 'none') {
                    widget.style.display = 'block';
                } else {
                    widget.style.display = 'none';
                }
            }
            toggleBtn.addEventListener('click', toggleWidget);
            closeBtn.addEventListener('click', () => widget.style.display = 'none');

            // Draggable
            const dragHandle = document.getElementById('pomodoroHeader');
            let isDragging = false, startX, startY, startLeft, startTop;
            function getWidgetPos() {
                let left = parseFloat(widget.style.left);
                let top = parseFloat(widget.style.top);
                if (isNaN(left)) {
                    const rect = widget.getBoundingClientRect();
                    left = rect.left;
                    top = rect.top;
                }
                return { left, top };
            }
            function onMouseDown(e) {
                if (!dragHandle.contains(e.target)) return;
                e.preventDefault();
                isDragging = true;
                startX = e.clientX;
                startY = e.clientY;
                const { left, top } = getWidgetPos();
                startLeft = left;
                startTop = top;
                if (widget.style.right !== '' || widget.style.bottom !== '') {
                    const rect = widget.getBoundingClientRect();
                    widget.style.left = rect.left + 'px';
                    widget.style.top = rect.top + 'px';
                    widget.style.right = 'auto';
                    widget.style.bottom = 'auto';
                    startLeft = rect.left;
                    startTop = rect.top;
                }
                document.addEventListener('mousemove', onMouseMove);
                document.addEventListener('mouseup', onMouseUp);
                widget.style.transition = 'none';
            }
            function onMouseMove(e) {
                if (!isDragging) return;
                let newLeft = startLeft + (e.clientX - startX);
                let newTop = startTop + (e.clientY - startY);
                const maxLeft = window.innerWidth - widget.offsetWidth - 10;
                const maxTop = window.innerHeight - widget.offsetHeight - 10;
                newLeft = Math.min(Math.max(newLeft, 10), maxLeft);
                newTop = Math.min(Math.max(newTop, 10), maxTop);
                widget.style.left = newLeft + 'px';
                widget.style.top = newTop + 'px';
            }
            function onMouseUp() {
                isDragging = false;
                document.removeEventListener('mousemove', onMouseMove);
                document.removeEventListener('mouseup', onMouseUp);
                widget.style.transition = '';
            }
            dragHandle.addEventListener('mousedown', onMouseDown);
            updateUI();
        })();
    <!-- Thêm Notification Toast UI cho SignalR -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1080;">
        <div id="realtimeToast" class="toast bg-white shadow border-0 rounded-4" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header border-0 bg-primary text-white rounded-top-4">
                <i class="fas fa-bell me-2"></i>
                <strong class="me-auto">New Assignment</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary-subtle text-primary rounded-circle p-2 me-3 fs-4">
                        <i class="fas fa-tasks"></i>
                    </div>
                    <div>
                        <p class="mb-0 text-dark fw-bold" id="toastMessage">You have been assigned a new task!</p>
                        <small class="text-muted" id="toastDetail">Check your workspace.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tích hợp SignalR Client JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Khởi tạo kết nối tới Hub
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/notificationHub")
                .configureLogging(signalR.LogLevel.Information)
                .build();

            // Nhận tin nhắn thông báo dạng "ReceiveNotification" từ Server
            connection.on("ReceiveNotification", function (message, taskTitle) {
                console.log("Realtime notification received!", message, taskTitle);
                
                // Cập nhật nội dung toast
                document.getElementById("toastMessage").innerText = message;
                if(taskTitle) document.getElementById("toastDetail").innerText = `Task: ${taskTitle}`;
                
                // Tăng số thông báo chưa đọc trên quả chuông
                const badge = document.getElementById("notifBadge");
                if (badge) {
                     let count = parseInt(badge.innerText) || 0;
                     badge.innerText = count + 1;
                     badge.style.display = "inline";
                }

                // Hiển thị Toast (dùng Bootstrap)
                const toastEl = document.getElementById("realtimeToast");
                const toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                toast.show();
                
                // Kích âm thanh/rung nếu có
                if (navigator.vibrate) navigator.vibrate([100, 50, 100]);
            });

            // Bắt đầu kết nối
            connection.start()
                .then(function () {
                    console.log("Connected to Realtime Notification Hub.");
                })
                .catch(function (err) {
                    return console.error("SignalR Connection Error: ", err.toString());
                });
        });
    </script>
</body>
