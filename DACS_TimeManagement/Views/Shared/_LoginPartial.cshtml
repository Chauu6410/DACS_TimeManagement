@using Microsoft.AspNetCore.Identity

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" 
           data-bs-toggle="dropdown" aria-expanded="false">
            <div class="user-avatar">
                @{
                    var userName = UserManager.GetUserName(User);
                    var userInitial = !string.IsNullOrEmpty(userName) ? userName.Substring(0, 1).ToUpper() : "U";
                }
                <span class="avatar-initials">@userInitial</span>
                <div class="avatar-status"></div>
            </div>
            <div class="user-info-wrapper">
                <span class="user-name">@UserManager.GetUserName(User)!.Split('@')[0]</span>
                <span class="user-role">Member</span>
            </div>
            <i class="fas fa-chevron-down dropdown-icon"></i>
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
            <li>
                <div class="dropdown-user-header">
                    <div class="user-avatar-large">
                        <span class="avatar-initials-large">@userInitial</span>
                    </div>
                    <div class="user-details">
                        <h6 class="mb-0">@UserManager.GetUserName(User)!.Split('@')[0]</h6>
                        <small class="text-muted">@UserManager.GetUserName(User)</small>
                    </div>
                </div>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                    <i class="fas fa-user-circle"></i>
                    <span>My Profile</span>
                </a>
            </li>
            <li>
                <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Settings">
                    <i class="fas fa-sliders-h"></i>
                    <span>Settings</span>
                </a>
            </li>
            <li>
                <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Notifications">
                    <i class="fas fa-bell"></i>
                    <span>Notifications</span>
                    <span class="notification-badge" id="notifCountBadge" style="display: none;">0</span>
                </a>
            </li>
            <li>
                <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Activity">
                    <i class="fas fa-history"></i>
                    <span>Activity Log</span>
                </a>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <form id="logoutForm" class="dropdown-item p-0" asp-area="Identity" asp-page="/Account/Logout" 
                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button id="logout" type="submit" class="dropdown-item logout-btn">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link auth-btn login-btn" id="login" asp-area="Identity" asp-page="/Account/Login">
            <i class="fas fa-sign-in-alt"></i>
            <span>Login</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link auth-btn register-btn" id="register" asp-area="Identity" asp-page="/Account/Register">
            <i class="fas fa-user-plus"></i>
            <span>Register</span>
        </a>
    </li>
}

<style>
    /* ---------- VARIABLES (light mode mặc định) ---------- */
    .user-avatar, .user-avatar-large, .dropdown-item i,
    .login-btn, .register-btn, .notification-badge {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --primary-light: #a5b4fc;
        --success: #10b981;
        --danger: #ef4444;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
        --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1);
        --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1);
        --shadow-xl: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
        --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Dark mode override (dựa trên class body.theme-dark) */
    body.theme-dark .dropdown-menu,
    body.theme-dark .dropdown-menu::before {
        background: #1e293b;
    }
    body.theme-dark .dropdown-user-header {
        background: linear-gradient(135deg, rgba(99,102,241,0.2), rgba(139,92,246,0.2));
    }
    body.theme-dark .user-name,
    body.theme-dark .user-details h6,
    body.theme-dark .dropdown-item {
        color: #f1f5f9;
    }
    body.theme-dark .user-role,
    body.theme-dark .user-details small {
        color: #94a3b8;
    }
    body.theme-dark .dropdown-item:hover {
        background: rgba(99,102,241,0.2);
    }
    body.theme-dark .dropdown-divider {
        border-color: #334155;
    }
    body.theme-dark .avatar-status {
        border-color: #1e293b;
    }

    /* ---------- USER AVATAR ---------- */
    .user-avatar {
        position: relative;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        box-shadow: var(--shadow-sm);
    }
    .avatar-initials {
        color: white;
        font-size: 16px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .avatar-status {
        position: absolute;
        bottom: 2px;
        right: 2px;
        width: 10px;
        height: 10px;
        background: var(--success);
        border: 2px solid white;
        border-radius: 50%;
        transition: var(--transition);
    }
    .user-info-wrapper {
        display: flex;
        flex-direction: column;
        line-height: 1.3;
    }
    .user-name {
        font-weight: 600;
        color: var(--gray-800);
        font-size: 0.9rem;
        max-width: 130px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .user-role {
        font-size: 0.7rem;
        color: #6b7280;
        font-weight: 500;
    }
    .dropdown-icon {
        font-size: 0.7rem;
        color: #9ca3af;
        transition: transform 0.2s ease;
    }
    .nav-link.dropdown-toggle.show .dropdown-icon {
        transform: rotate(180deg);
    }

    /* ---------- DROPDOWN MENU (Glassmorphism) ---------- */
    .dropdown-menu {
        border: none;
        border-radius: 20px;
        background: rgba(255,255,255,0.98);
        backdrop-filter: blur(12px);
        box-shadow: var(--shadow-xl);
        padding: 0.5rem 0;
        min-width: 300px;
        margin-top: 12px;
        animation: dropdownFadeIn 0.2s ease;
    }
    @@keyframes dropdownFadeIn {
        from {
            opacity: 0;
            transform: translateY(-12px) scale(0.96);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
    .dropdown-menu::before {
        content: '';
        position: absolute;
        top: -7px;
        right: 20px;
        width: 14px;
        height: 14px;
        background: inherit;
        transform: rotate(45deg);
        border-radius: 3px;
        box-shadow: -2px -2px 5px rgba(0,0,0,0.02);
    }
    .dropdown-user-header {
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 14px;
        background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(139,92,246,0.08));
        border-radius: 20px 20px 0 0;
    }
    .user-avatar-large {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-md);
    }
    .avatar-initials-large {
        color: white;
        font-size: 20px;
        font-weight: 600;
    }
    .user-details h6 {
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 2px;
        color: var(--gray-800);
    }
    .user-details small {
        font-size: 0.7rem;
        color: #6b7280;
    }
    .dropdown-item {
        padding: 0.65rem 1.25rem;
        transition: var(--transition);
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--gray-700);
        position: relative;
    }
    .dropdown-item i {
        width: 20px;
        font-size: 1rem;
        color: var(--primary);
        transition: var(--transition);
    }
    .dropdown-item span:not(.notification-badge) {
        flex: 1;
    }
    .dropdown-item:hover {
        background: rgba(99,102,241,0.08);
        padding-left: 1.6rem;
        color: var(--primary-dark);
    }
    .dropdown-item:hover i {
        transform: scale(1.1);
        color: var(--primary-dark);
    }
    .logout-btn {
        color: var(--danger) !important;
    }
    .logout-btn i {
        color: var(--danger) !important;
    }
    .logout-btn:hover {
        background: rgba(239,68,68,0.08) !important;
        color: #dc2626 !important;
    }
    .dropdown-divider {
        margin: 0.5rem 0;
        border-top: 1px solid var(--gray-200);
        opacity: 0.6;
    }
    /* Notification Badge trong dropdown */
    .notification-badge {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.2rem 0.5rem;
        border-radius: 30px;
        min-width: 22px;
        text-align: center;
        box-shadow: 0 2px 5px rgba(239,68,68,0.3);
        animation: subtlePulse 1.5s infinite;
    }
    @@keyframes subtlePulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.05); opacity: 0.9; }
    }

    /* ---------- AUTH BUTTONS (Login/Register) ---------- */
    .auth-btn {
        position: relative;
        padding: 0.5rem 1.2rem !important;
        border-radius: 40px !important;
        transition: var(--transition) !important;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 0 4px;
        overflow: hidden;
    }
    .auth-btn::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        transform: translate(-50%, -50%);
        transition: width 0.4s, height 0.4s;
    }
    .auth-btn:active::before {
        width: 200px;
        height: 200px;
    }
    .login-btn {
        background: transparent;
        color: var(--primary) !important;
        border: 1.5px solid var(--primary) !important;
    }
    .login-btn:hover {
        background: var(--primary);
        color: white !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 14px rgba(99,102,241,0.3);
    }
    .register-btn {
        background: linear-gradient(135deg, var(--primary), #8b5cf6);
        color: white !important;
        border: none !important;
        box-shadow: var(--shadow-sm);
    }
    .register-btn:hover {
        background: linear-gradient(135deg, var(--primary-dark), #7c3aed);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(99,102,241,0.4);
    }

    /* Hover effect avatar */
    .nav-link.dropdown-toggle:hover .user-avatar {
        transform: scale(1.05);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
    }
    /* Responsive */
    @@media (max-width: 768px) {
        .user-info-wrapper {
            display: none;
        }
        .user-avatar {
            width: 36px;
            height: 36px;
        }
        .avatar-initials {
            font-size: 14px;
        }
        .dropdown-menu {
            min-width: 260px;
            margin-top: 8px;
        }
        .auth-btn {
            padding: 0.4rem 1rem !important;
            font-size: 0.85rem;
        }
        .dropdown-user-header {
            padding: 0.75rem 1rem;
        }
        .user-avatar-large {
            width: 40px;
            height: 40px;
        }
        .avatar-initials-large {
            font-size: 16px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Cập nhật số lượng thông báo chưa đọc (giả lập API, bạn có thể thay bằng endpoint thật)
        function updateNotificationBadge() {
            const badge = document.getElementById('notifCountBadge');
            if (!badge) return;
            // Thử gọi API lấy số lượng thông báo chưa đọc
            fetch('/Notification/GetUnreadCount')
                .then(res => res.json())
                .then(data => {
                    let count = data.count || data || 0;
                    if (count > 0) {
                        badge.textContent = count;
                        badge.style.display = 'inline-block';
                    } else {
                        badge.style.display = 'none';
                    }
                })
                .catch(() => {
                    // Fallback: ẩn badge nếu không có API
                    badge.style.display = 'none';
                });
        }
        updateNotificationBadge();
        // Tự động cập nhật mỗi 60 giây (có thể tuỳ chỉnh)
        setInterval(updateNotificationBadge, 60000);

        // Active class cho current page trong dropdown
        const currentUrl = window.location.pathname;
        document.querySelectorAll('.dropdown-item').forEach(item => {
            const href = item.getAttribute('href');
            if (href && href !== '#' && currentUrl.includes(href)) {
                item.classList.add('active');
                // Thêm indicator nhẹ
                item.style.background = 'rgba(99,102,241,0.1)';
            }
        });
    });
</script>