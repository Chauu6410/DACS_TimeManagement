@model DACS_TimeManagement.Models.AdminViewModel
@{
    ViewData["Title"] = "System Admin Dashboard";
}

<div class="admin-container" data-aos="fade-up">
    <!-- Header Pastel -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="icon-circle bg-pastel-primary-soft">
                <i class="fas fa-shield-alt text-pastel-primary fs-4"></i>
            </div>
            <div>
                <h1 class="display-6 fw-bold text-gradient-pastel mb-0">Admin Dashboard</h1>
                <p class="text-pastel-muted small mb-0">System overview and user management</p>
            </div>
        </div>
    </div>

    <!-- Stats Cards (Pastel) -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stats-card-pastel pastel-indigo h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stats-icon mb-2">
                            <i class="fas fa-users fa-2x"></i>
                        </div>
                        <div class="stats-number display-4 fw-bold">@Model.TotalUsers</div>
                        <div class="stats-label text-pastel-muted small fw-semibold">Total Users</div>
                    </div>
                    <i class="fas fa-users fa-4x opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card-pastel pastel-green h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stats-icon mb-2">
                            <i class="fas fa-project-diagram fa-2x"></i>
                        </div>
                        <div class="stats-number display-4 fw-bold">@Model.TotalProjects</div>
                        <div class="stats-label text-pastel-muted small fw-semibold">Total Projects</div>
                    </div>
                    <i class="fas fa-project-diagram fa-4x opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card-pastel pastel-cyan h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stats-icon mb-2">
                            <i class="fas fa-tasks fa-2x"></i>
                        </div>
                        <div class="stats-number display-4 fw-bold">@Model.TotalTasks</div>
                        <div class="stats-label text-pastel-muted small fw-semibold">Total Work Tasks</div>
                    </div>
                    <i class="fas fa-tasks fa-4x opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Users List Table (Pastel) -->
    <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
        <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
            <div class="d-flex align-items-center gap-2">
                <div class="icon-circle bg-pastel-primary-soft" style="width: 36px; height: 36px;">
                    <i class="fas fa-users-cog text-pastel-primary fs-6"></i>
                </div>
                <h5 class="fw-bold mb-0 text-pastel-dark">Registered Users</h5>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-pastel align-middle m-0">
                    <thead>
                        <tr>
                            <th class="ps-4">User ID</th>
                            <th>Email / Username</th>
                            <th>Email Confirmed</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="ps-4 text-pastel-muted small font-monospace">@user.Id</td>
                                <td class="fw-semibold text-pastel-dark">
                                    @if (user.Email == "admin@gmail.com")
                                    {
                                        <span class="badge bg-pastel-danger me-2">Admin</span>
                                    }
                                    @user.Email
                                </td>
                                <td>
                                    @if (user.EmailConfirmed)
                                    {
                                        <span class="badge bg-pastel-success rounded-pill px-3 py-1">
                                            <i class="fas fa-check-circle me-1"></i>Confirmed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-pastel-warning rounded-pill px-3 py-1 text-dark">
                                            <i class="fas fa-clock me-1"></i>Pending
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Users.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center text-pastel-muted py-5">No users found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Admin Dashboard Pastel Styles - đồng bộ với toàn bộ hệ thống */
    .admin-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .text-gradient-pastel {
        background: linear-gradient(135deg, var(--pastel-primary-dark, #818cf8), #c4b5fd);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }
    .bg-pastel-primary-soft {
        background: rgba(99, 102, 241, 0.12);
    }
    .text-pastel-primary {
        color: var(--pastel-primary-dark, #818cf8);
    }
    .text-pastel-dark {
        color: var(--pastel-dark, #1e293b);
    }
    .text-pastel-muted {
        color: var(--pastel-muted, #64748b);
    }

    /* Stats Cards Pastel */
    .stats-card-pastel {
        border-radius: 20px;
        padding: 1.25rem;
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: default;
    }
    .stats-card-pastel:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 20px rgba(0,0,0,0.08);
    }
    .pastel-indigo {
        background: #e0e7ff;
        border-left: 4px solid #6366f1;
    }
    .pastel-green {
        background: #dcfce7;
        border-left: 4px solid #22c55e;
    }
    .pastel-cyan {
        background: #cffafe;
        border-left: 4px solid #06b6d4;
    }
    .stats-icon i {
        color: #334155;
    }
    .stats-number {
        color: #0f172a;
    }

    /* Table Pastel */
    .table-pastel {
        background-color: var(--pastel-card-bg, #ffffff);
        color: var(--pastel-dark, #0f172a);
        border-collapse: separate;
        border-spacing: 0;
    }
    .table-pastel thead th {
        background-color: var(--pastel-soft, #f8fafc);
        border-bottom: 1px solid var(--pastel-border, #e2e8f0);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        color: var(--pastel-muted, #64748b);
        padding: 1rem 0.75rem;
    }
    .table-pastel tbody td {
        padding: 1rem 0.75rem;
        border-bottom: 1px solid var(--pastel-border, #e2e8f0);
        vertical-align: middle;
    }
    .table-pastel tbody tr:hover {
        background-color: rgba(99, 102, 241, 0.04);
    }

    /* Badge Pastel */
    .bg-pastel-danger {
        background: #fee2e2;
        color: #b91c1c;
    }
    .bg-pastel-success {
        background: #dcfce7;
        color: #16a34a;
    }
    .bg-pastel-warning {
        background: #fef9c3;
        color: #854d0e;
    }

    /* Dark Mode Variables */
    body.theme-dark {
        --pastel-primary-dark: #6366f1;
        --pastel-border: #334155;
        --pastel-card-bg: #1e293b;
        --pastel-dark: #f1f5f9;
        --pastel-muted: #94a3b8;
        --pastel-soft: #0f172a;
    }
    body.theme-dark .pastel-indigo {
        background: #1e293b;
        border-left-color: #6366f1;
    }
    body.theme-dark .pastel-green {
        background: #1e293b;
        border-left-color: #4ade80;
    }
    body.theme-dark .pastel-cyan {
        background: #1e293b;
        border-left-color: #06b6d4;
    }
    body.theme-dark .stats-icon i,
    body.theme-dark .stats-number {
        color: #f1f5f9;
    }
    body.theme-dark .table-pastel {
        background-color: #1e293b;
    }
    body.theme-dark .table-pastel thead th {
        background-color: #0f172a;
        border-bottom-color: #334155;
        color: #94a3b8;
    }
    body.theme-dark .table-pastel tbody td {
        border-bottom-color: #334155;
    }
    body.theme-dark .table-pastel tbody tr:hover {
        background-color: rgba(99, 102, 241, 0.1);
    }
    body.theme-dark .bg-pastel-danger {
        background: #7f1d1d;
        color: #fecaca;
    }
    body.theme-dark .bg-pastel-success {
        background: #14532d;
        color: #bbf7d0;
    }
    body.theme-dark .bg-pastel-warning {
        background: #854d0e;
        color: #fef9c3;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .admin-container {
            padding: 0 0.5rem;
        }
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .stats-number {
            font-size: 1.8rem;
        }
        .table-pastel thead th,
        .table-pastel tbody td {
            padding: 0.75rem 0.5rem;
        }
    }
</style>

@* Kích hoạt AOS nếu có *@
<script>
    if (typeof AOS !== 'undefined') {
        AOS.refresh();
    }
</script>