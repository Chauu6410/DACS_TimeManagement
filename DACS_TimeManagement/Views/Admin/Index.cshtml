@model DACS_TimeManagement.Models.AdminViewModel
@{
    ViewData["Title"] = "System Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 fw-bold text-dark"><i class="fas fa-shield-alt text-primary me-2"></i>Admin Dashboard</h2>
</div>

<!-- Overview Cards -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-gradient-primary text-white h-100" style="background: linear-gradient(135deg, #6366f1 0%, #4338ca 100%);">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-uppercase fw-bold opacity-75 mb-1">Total Users</h6>
                    <h2 class="display-4 fw-bold mb-0">@Model.TotalUsers</h2>
                </div>
                <div class="text-white opacity-50">
                    <i class="fas fa-users fa-4x"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-gradient-success text-white h-100" style="background: linear-gradient(135deg, #10b981 0%, #047857 100%);">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-uppercase fw-bold opacity-75 mb-1">Total Projects</h6>
                    <h2 class="display-4 fw-bold mb-0">@Model.TotalProjects</h2>
                </div>
                <div class="text-white opacity-50">
                    <i class="fas fa-project-diagram fa-4x"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-gradient-info text-white h-100" style="background: linear-gradient(135deg, #0ea5e9 0%, #0369a1 100%);">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-uppercase fw-bold opacity-75 mb-1">Total Work Tasks</h6>
                    <h2 class="display-4 fw-bold mb-0">@Model.TotalTasks</h2>
                </div>
                <div class="text-white opacity-50">
                    <i class="fas fa-tasks fa-4x"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Users List Table -->
<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom p-4">
        <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-users-cog text-primary me-2"></i>Registered Users</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle m-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">User ID</th>
                        <th>Email / Username</th>
                        <th>Email Confirmed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="ps-4 text-muted small font-monospace">@user.Id</td>
                            <td class="fw-bold text-dark">
                                @if (user.Email == "admin@gmail.com")
                                {
                                    <span class="badge bg-danger me-2">Admin</span>
                                }
                                @user.Email
                            </td>
                            <td>
                                @if (user.EmailConfirmed)
                                {
                                    <span class="badge bg-success"><i class="fas fa-check me-1"></i>Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">No</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted p-4">No users found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
