@using Microsoft.AspNetCore.Identity
@model DACS_TimeManagement.Models.AdminViewModel
@inject UserManager<IdentityUser> _userManager
@{
    ViewData["Title"] = Localizer["SystemAdminDashboard"];
}

<div class="admin-container" data-aos="fade-up">

    <!-- Anti-forgery token for fetch calls -->
    <form id="antiForgeryForm" method="post">@Html.AntiForgeryToken()</form>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-pastel-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }



    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stats-card-pastel pastel-indigo h-100 position-relative overflow-hidden">
                <div class="d-flex justify-content-between align-items-center h-100 position-relative z-1">
                    <div class="d-flex flex-column">
                        <div class="stats-icon mb-2"><i class="fas fa-users fs-4"></i></div>
                        <div class="stats-number fw-bolder">@Model.TotalUsers</div>
                        <div class="stats-label small fw-medium">@Localizer["TotalUsers"]</div>
                    </div>
                </div>
                <i class="fas fa-users watermark-icon watermark-indigo"></i>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card-pastel pastel-green h-100 position-relative overflow-hidden">
                <div class="d-flex justify-content-between align-items-center h-100 position-relative z-1">
                    <div class="d-flex flex-column">
                        <div class="stats-icon mb-2"><i class="fas fa-project-diagram fs-4"></i></div>
                        <div class="stats-number fw-bolder">@Model.TotalProjects</div>
                        <div class="stats-label small fw-medium">@Localizer["TotalProjects"]</div>
                    </div>
                </div>
                <i class="fas fa-project-diagram watermark-icon watermark-green"></i>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card-pastel pastel-cyan h-100 position-relative overflow-hidden">
                <div class="d-flex justify-content-between align-items-center h-100 position-relative z-1">
                    <div class="d-flex flex-column">
                        <div class="stats-icon mb-2"><i class="fas fa-list-ul fs-4"></i></div>
                        <div class="stats-number fw-bolder">@Model.TotalTasks</div>
                        <div class="stats-label small fw-medium">@Localizer["TotalWorkTasks"]</div>
                    </div>
                </div>
                <i class="fas fa-list-ul watermark-icon watermark-cyan"></i>
            </div>
        </div>
    </div>

    <!-- Users List with Search & Bulk Actions -->
    <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
        <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-2">
                    <div class="icon-circle bg-pastel-primary-soft" style="width: 36px; height: 36px;">
                        <i class="fas fa-users-cog text-pastel-primary fs-6"></i>
                    </div>
                    <h5 class="fw-bold mb-0 text-pastel-dark">@Localizer["RegisteredUsers"]</h5>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <!-- Selection Mode Toggle Button -->
                    <button type="button" id="toggleSelectionModeBtn" class="btn btn-sm btn-outline-secondary rounded-pill">
                        <i class="fas fa-check-double me-1"></i> <span id="selectionModeText">@Localizer["EnableSelection"]</span>
                    </button>
                    <!-- Search input -->
                    <div class="search-box" style="min-width: 250px;">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" id="searchUserInput" class="form-control border-start-0" placeholder="@Localizer["SearchEmailPlaceholder"]" aria-label="Search">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bulk Actions Toolbar (initially hidden) -->
            <div class="bulk-actions-bar mt-3 d-flex flex-wrap gap-2 align-items-center" id="bulkActionsBar" style="display: none;">
                <span class="me-2 small fw-semibold text-pastel-muted"><i class="fas fa-check-circle me-1"></i><span id="selectedCount">0</span> @Localizer["Selected"]</span>
                <div class="vr"></div>
                <button type="button" class="btn btn-sm btn-outline-primary rounded-pill bulk-action" data-action="set-admin">
                    <i class="fas fa-user-shield me-1"></i> @Localizer["SetAsAdmin"]
                </button>
                <button type="button" class="btn btn-sm btn-outline-warning rounded-pill bulk-action" data-action="remove-admin">
                    <i class="fas fa-user-minus me-1"></i> @Localizer["RemoveAdmin"]
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill bulk-action" data-action="lock">
                    <i class="fas fa-lock me-1"></i> @Localizer["Lock"]
                </button>
                <button type="button" class="btn btn-sm btn-outline-success rounded-pill bulk-action" data-action="unlock">
                    <i class="fas fa-unlock me-1"></i> @Localizer["Unlock"]
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill bulk-action" data-action="delete">
                    <i class="fas fa-trash-alt me-1"></i> @Localizer["Delete"]
                </button>
                <button type="button" class="btn btn-sm btn-outline-info rounded-pill bulk-action" data-action="confirm-email">
                    <i class="fas fa-envelope-open-text me-1"></i> @Localizer["ConfirmEmail"]
                </button>
                <button type="button" class="btn btn-sm btn-link text-muted ms-auto" id="clearSelectionBtn">@Localizer["Clear"]</button>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-pastel align-middle m-0" id="usersTable">
                    <thead>
                        <tr id="tableHeaderRow">
                            <!-- Selection checkbox column (hidden by default) -->
                            <th id="selectHeaderTh" style="width: 40px; display: none;" class="ps-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="selectAllCheckbox">
                                </div>
                            </th>
                            <th>@Localizer["UserID"]</th>
                            <th>@Localizer["EmailUsername"]</th>
                            <th>@Localizer["LastAccess"]</th>
                            <th class="text-end pe-4">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        @foreach (var detail in Model.UserDetails)
                        {
                            var user = detail.User;
                            var isAdmin = detail.IsAdmin;
                            var isLocked = detail.IsLocked;
                            var isSuperAdmin = (user.Email == "admin@gmail.com");
                            <tr data-user-id="@user.Id" data-email="@user.Email" data-is-admin="@isAdmin.ToString().ToLower()" data-is-locked="@isLocked.ToString().ToLower()">
                                <td class="select-td ps-4" style="display: none;">
                                    @if (!isSuperAdmin)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input user-select-checkbox" type="checkbox" value="@user.Id">
                                        </div>
                                    }
                                </td>
                                <td class="text-pastel-muted small font-monospace">@user.Id</td>
                                <td class="fw-semibold text-pastel-dark">
                                    @if (isAdmin)
                                    {
                                        <span class="badge bg-pastel-danger me-2 admin-badge">@Localizer["Admin"]</span>
                                    }
                                    <span class="user-email">@user.Email</span>
                                    @if (user.EmailConfirmed)
                                    {
                                        <i class="fas fa-check-circle text-success ms-1" title="@Localizer["Confirmed"]"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-exclamation-circle text-warning ms-1" title="@Localizer["PendingFix"]"></i>
                                    }
                                </td>
                                <td>
                                    @if (detail.LastAccess.HasValue)
                                    {
                                        <span class="text-muted small time-ago" data-timestamp="@detail.LastAccess.Value.ToString("o")">@detail.LastAccess.Value.ToString("g")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small italic">@Localizer["Never"]</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (!isSuperAdmin)
                                    {
                                        <div class="btn-group shadow-sm rounded-pill overflow-hidden" style="white-space: nowrap; display: inline-flex;">
                                            @if (!user.EmailConfirmed)
                                            {
                                                <button type="button" class="btn btn-sm bg-white text-warning border-end confirm-email-individual" data-user-id="@user.Id" title="@Localizer["ConfirmEmail"]">
                                                    <i class="fas fa-envelope-open-text"></i>
                                                </button>
                                            }
                                            <button type="button" class="btn btn-sm bg-white text-primary border-end toggle-admin-btn" data-user-id="@user.Id" data-is-admin="@(isAdmin ? "true" : "false")" title="@Localizer["ToggleAdminUser"]">
                                                <i class="fas fa-user-tag"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm bg-white toggle-lock-btn border-end @(isLocked ? "text-danger" : "text-success")" data-user-id="@user.Id" data-is-locked="@(isLocked ? "true" : "false")" title="@(isLocked ? Localizer["Unlock"].Value : Localizer["Lock"].Value)">
                                                <i class="fas @(isLocked ? "fa-lock" : "fa-unlock")"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm bg-white text-danger delete-user-btn" data-user-id="@user.Id" title="@Localizer["Delete"]">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.UserDetails.Any())
                        {
                            <tr id="noUsersRow">
                                <td colspan="5" class="text-center text-pastel-muted py-5">@Localizer["NoUsersFound"]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Helper: get anti-forgery token
        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // Show temporary toast
        window.showToast = function(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `alert alert-pastel-${type} alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow-lg`;
            toast.style.zIndex = '9999';
            toast.style.minWidth = '250px';
            toast.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'} me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        };

        // ==================== SELECTION MODE TOGGLE ====================
        let selectionMode = false;
        const toggleBtn = document.getElementById('toggleSelectionModeBtn');
        const selectionModeTextSpan = document.getElementById('selectionModeText');
        const selectHeaderTh = document.getElementById('selectHeaderTh');
        const allSelectTds = document.querySelectorAll('#usersTableBody .select-td');
        const bulkActionsBar = document.getElementById('bulkActionsBar');

        function updateSelectionModeUI() {
            // Show/hide checkbox column
            if (selectHeaderTh) selectHeaderTh.style.display = selectionMode ? '' : 'none';
            allSelectTds.forEach(td => td.style.display = selectionMode ? '' : 'none');
            // Hide bulk actions bar when selection mode off
            if (!selectionMode) {
                bulkActionsBar.style.display = 'none';
                // Uncheck all checkboxes
                document.querySelectorAll('.user-select-checkbox').forEach(cb => cb.checked = false);
                updateSelectAllCheckbox(); // will also clear selected count
            } else {
                // When selection mode enabled, we keep bulk bar hidden until at least one checkbox checked
                updateSelectedCount(); // will show bar if count>0
            }
            // Update button text
            selectionModeTextSpan.innerText = selectionMode ? '@Localizer["DisableSelection"]' : '@Localizer["EnableSelection"]';
        }

        toggleBtn.addEventListener('click', () => {
            selectionMode = !selectionMode;
            updateSelectionModeUI();
            // Re-run search filter to maintain row visibility (no change needed)
            filterUsers();
        });

        // ==================== SEARCH FUNCTIONALITY ====================
        const searchInput = document.getElementById('searchUserInput');
        const tableRows = document.querySelectorAll('#usersTableBody tr[data-user-id]');

        function filterUsers() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            let hasVisible = false;
            tableRows.forEach(row => {
                const email = row.querySelector('.user-email')?.innerText.toLowerCase() || '';
                const userId = row.querySelector('td:first-child + td')?.innerText.toLowerCase() || '';
                const matches = email.includes(searchTerm) || userId.includes(searchTerm);
                row.style.display = matches ? '' : 'none';
                if (matches) hasVisible = true;
            });
            const noUsersRow = document.getElementById('noUsersRow');
            if (noUsersRow) {
                noUsersRow.style.display = hasVisible ? 'none' : '';
            }
            updateSelectAllCheckbox();
        }
        searchInput.addEventListener('input', filterUsers);

        // ==================== SHARED UTILITIES ====================
        async function apiCall(url, body, isJson = true) {
            const token = getAntiForgeryToken();
            const headers = { 'RequestVerificationToken': token };
            if (isJson) headers['Content-Type'] = 'application/json';
            else headers['Content-Type'] = 'application/x-www-form-urlencoded';

            const response = await fetch(url, {
                method: 'POST',
                headers: headers,
                body: isJson ? JSON.stringify(body) : body
            });
            
            const result = await response.json();
            if (!response.ok || !result.success) {
                throw new Error(result.message || '@Localizer["Error"]');
            }
            return result;
        }

        function fadeOutAndRemove(element) {
            element.style.transition = 'all 0.5s ease';
            element.style.opacity = '0';
            element.style.transform = 'translateX(20px)';
            setTimeout(() => element.remove(), 500);
        }

        // ==================== SELECTION / CHECKBOX LOGIC ====================
        const selectAllCheckbox = document.getElementById('selectAllCheckbox');
        const selectedCountSpan = document.getElementById('selectedCount');
        const clearSelectionBtn = document.getElementById('clearSelectionBtn');

        function getSelectedUserIds() {
            const checkboxes = document.querySelectorAll('#usersTableBody .user-select-checkbox:checked');
            return Array.from(checkboxes).map(cb => cb.value);
        }

        function updateSelectedCount() {
            const count = getSelectedUserIds().length;
            selectedCountSpan.innerText = count;
            if (selectionMode) {
                bulkActionsBar.style.display = count > 0 ? 'flex' : 'none';
            } else {
                bulkActionsBar.style.display = 'none';
            }
        }

        function updateSelectAllCheckbox() {
            if (!selectAllCheckbox) return;
            const visibleRows = Array.from(document.querySelectorAll('#usersTableBody tr[data-user-id]')).filter(row => row.style.display !== 'none');
            const visibleCheckboxes = visibleRows.map(row => row.querySelector('.user-select-checkbox')).filter(cb => cb !== null);
            const checkedCount = visibleCheckboxes.filter(cb => cb.checked).length;
            
            selectAllCheckbox.checked = visibleCheckboxes.length > 0 && checkedCount === visibleCheckboxes.length;
            selectAllCheckbox.indeterminate = checkedCount > 0 && checkedCount < visibleCheckboxes.length;
            
            updateSelectedCount();
        }

        function attachCheckboxEvents() {
            // Checkboxes are handled by event delegation on the table body now
        }

        if (selectAllCheckbox) {
            selectAllCheckbox.addEventListener('change', function() {
                const isChecked = selectAllCheckbox.checked;
                const visibleRows = Array.from(document.querySelectorAll('#usersTableBody tr[data-user-id]')).filter(row => row.style.display !== 'none');
                visibleRows.forEach(row => {
                    const cb = row.querySelector('.user-select-checkbox');
                    if (cb) cb.checked = isChecked;
                });
                updateSelectedCount();
            });
        }

        clearSelectionBtn.addEventListener('click', () => {
            document.querySelectorAll('.user-select-checkbox').forEach(cb => cb.checked = false);
            if (selectAllCheckbox) selectAllCheckbox.checked = false;
            updateSelectedCount();
        });

        // ==================== BULK ACTIONS ====================
        async function bulkAction(action, userIds) {
            if (!userIds.length) {
                showToast('@Localizer["NoUsersSelected"]', 'warning');
                return false;
            }

            let confirmMessage = '';
            let endpoint = '';
            let successMessage = '';

            switch (action) {
                case 'set-admin': confirmMessage = '@Localizer["ConfirmSetAdmin"]'; endpoint = '/Admin/BulkToggleAdmin'; successMessage = '@Localizer["UsersUpdatedToAdmin"]'; break;
                case 'remove-admin': confirmMessage = '@Localizer["ConfirmRemoveAdmin"]'; endpoint = '/Admin/BulkToggleAdmin'; successMessage = '@Localizer["AdminRoleRemoved"]'; break;
                case 'lock': confirmMessage = '@Localizer["ConfirmLockUsers"]'; endpoint = '/Admin/BulkToggleLockout'; successMessage = '@Localizer["UsersLocked"]'; break;
                case 'unlock': confirmMessage = '@Localizer["ConfirmUnlockUsers"]'; endpoint = '/Admin/BulkToggleLockout'; successMessage = '@Localizer["UsersUnlocked"]'; break;
                case 'confirm-email': confirmMessage = '@Localizer["ConfirmEmails"]'; endpoint = '/Admin/BulkConfirmEmail'; successMessage = '@Localizer["EmailsConfirmed"]'; break;
                case 'delete': confirmMessage = '@Localizer["ConfirmBulkDelete"]'; endpoint = '/Admin/BulkDelete'; successMessage = '@Localizer["BulkDeleted"]'; break;
                default: return false;
            }

            const confirmed = await Swal.fire({
                title: '@Localizer["ConfirmAction"]',
                text: confirmMessage,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: '@Localizer["YesProceed"]'
            });
            if (!confirmed.isConfirmed) return false;

            const bulkBtns = document.querySelectorAll('.bulk-action');
            const originalHtmls = Array.from(bulkBtns).map(b => b.innerHTML);
            bulkBtns.forEach(btn => { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>'; });

            try {
                const result = await apiCall(endpoint, userIds, true);
                showToast(result.message, 'success');
                
                if (action === 'delete') {
                    userIds.forEach(id => {
                        const row = document.querySelector(`tr[data-user-id="${id}"]`);
                        if (row) fadeOutAndRemove(row);
                    });
                } else {
                    userIds.forEach(id => updateUserRowAfterAction(id, action, result));
                }
            } catch (err) {
                showToast(err.message, 'error');
            } finally {
                bulkBtns.forEach((btn, i) => { btn.disabled = false; btn.innerHTML = originalHtmls[i]; });
                clearSelectionBtn.click();
            }
        }

        function updateUserRowAfterAction(userId, action, result) {
            const row = document.querySelector(`tr[data-user-id="${userId}"]`);
            if (!row) return;

            const emailCell = row.querySelector('td:nth-child(3)'); // 1:Selection, 2:ID, 3:Email
            const adminBadge = emailCell.querySelector('.admin-badge');
            const toggleAdminBtn = row.querySelector('.toggle-admin-btn');
            const toggleLockBtn = row.querySelector('.toggle-lock-btn');
            // Confirmation status icon in Email column
            const confirmIcon = emailCell.querySelector('.fa-exclamation-circle, .fa-check-circle');

            if (action === 'set-admin' || action === 'remove-admin' || action === 'toggle-admin') {
                const isAdminNow = result.isAdmin !== undefined ? result.isAdmin : (action === 'set-admin');
                if (isAdminNow) {
                    if (!adminBadge) {
                        const badge = document.createElement('span');
                        badge.className = 'badge bg-pastel-danger me-2 admin-badge';
                        badge.innerText = '@Localizer["Admin"]';
                        emailCell.insertBefore(badge, emailCell.firstChild);
                    }
                } else {
                    if (adminBadge) adminBadge.remove();
                }
                if (toggleAdminBtn) toggleAdminBtn.dataset.isAdmin = isAdminNow.toString();
                row.dataset.isAdmin = isAdminNow.toString();
            }
            else if (action === 'lock' || action === 'unlock' || action === 'toggle-lock') {
                const isLockedNow = result.isLocked !== undefined ? result.isLocked : (action === 'lock');
                if (toggleLockBtn) {
                    const icon = toggleLockBtn.querySelector('i');
                    icon.className = isLockedNow ? 'fas fa-lock' : 'fas fa-unlock';
                    toggleLockBtn.className = `btn btn-sm bg-white toggle-lock-btn ${isLockedNow ? 'text-danger' : 'text-success'}`;
                    toggleLockBtn.title = isLockedNow ? '@Localizer["Unlock"]' : '@Localizer["Lock"]';
                    toggleLockBtn.dataset.isLocked = isLockedNow.toString();
                    row.dataset.isLocked = isLockedNow.toString();
                }
            }
            else if (action === 'confirm-email') {
                if (confirmIcon) {
                    confirmIcon.className = 'fas fa-check-circle text-success ms-1';
                    confirmIcon.title = '@Localizer["Confirmed"]';
                }
                const confirmBtn = row.querySelector('.confirm-email-individual');
                if (confirmBtn) confirmBtn.remove();
            }
        }

        // ==================== EVENT DELEGATION ====================
        const tableBody = document.getElementById('usersTableBody');
        tableBody.addEventListener('click', async function(e) {
            const btn = e.target.closest('button');
            const checkbox = e.target.closest('.user-select-checkbox');
            
            if (checkbox) {
                updateSelectAllCheckbox();
                return;
            }
            
            if (!btn) return;

            const row = btn.closest('tr');
            const userId = btn.dataset.userId || row.dataset.userId;
            const email = row.dataset.email;
            
            // Individual Actions
            if (btn.classList.contains('toggle-admin-btn')) {
                await performIndividualAction(btn, '/Admin/ToggleAdminRole', `userId=${userId}`, 'toggle-admin');
            }
            else if (btn.classList.contains('toggle-lock-btn')) {
                await performIndividualAction(btn, '/Admin/ToggleLockout', `userId=${userId}`, 'toggle-lock');
            }
            else if (btn.classList.contains('confirm-email-individual')) {
                await performIndividualAction(btn, '/Admin/ConfirmEmail', `userId=${userId}`, 'confirm-email');
            }
            else if (btn.classList.contains('delete-user-btn')) {
                const confirmed = await Swal.fire({
                    title: '@Localizer["AreYouSure"]',
                    text: `@Localizer["DeleteUserWarning"] (${email})`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    confirmButtonText: '@Localizer["YesDeleteIt"]'
                });
                if (confirmed.isConfirmed) {
                    await performIndividualAction(btn, '/Admin/DeleteUser', `userId=${userId}`, 'delete');
                }
            }
        });

        async function performIndividualAction(btn, url, body, actionType) {
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            btn.disabled = true;

            try {
                const result = await apiCall(url, body, false);
                showToast(result.message, 'success');
                if (actionType === 'delete') {
                    fadeOutAndRemove(btn.closest('tr'));
                } else {
                    updateUserRowAfterAction(btn.dataset.userId, actionType, result);
                }
            } catch (err) {
                showToast(err.message, 'error');
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            } finally {
                if (actionType !== 'delete') {
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                }
            }
        }

        // Attach bulk action listeners
        document.querySelectorAll('.bulk-action').forEach(btn => {
            btn.addEventListener('click', () => bulkAction(btn.dataset.action, getSelectedUserIds()));
        });

        // ==================== TIME AGO LOGIC ====================
        function updateTimeAgo() {
            const lang = document.documentElement.lang || 'en';
            document.querySelectorAll('.time-ago').forEach(el => {
                const date = new Date(el.dataset.timestamp);
                if (isNaN(date)) return;
                el.innerText = timeAgo(date, lang);
            });
        }

        function timeAgo(date, lang) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return lang === 'vi' ? 'vừa xong' : 'just now';
            const intervals = {
                year: 31536000, month: 2592000, day: 86400, hour: 3600, minute: 60
            };
            const labels = {
                vi: { year: 'năm', month: 'tháng', day: 'ngày', hour: 'giờ', minute: 'phút', suffix: 'trước' },
                en: { year: 'y', month: 'mo', day: 'd', hour: 'h', minute: 'm', suffix: 'ago' }
            };
            
            for (let [key, value] of Object.entries(intervals)) {
                const count = Math.floor(seconds / value);
                if (count >= 1) {
                    return lang === 'vi' 
                        ? `${count} ${labels.vi[key]} ${labels.vi.suffix}` 
                        : `${count}${labels.en[key]} ${labels.en.suffix}`;
                }
            }
            return lang === 'vi' ? 'vừa xong' : 'just now';
        }

        // Initialize
        updateTimeAgo();
        setInterval(updateTimeAgo, 60000);
        updateSelectionModeUI();
        filterUsers();
    </script>
}

