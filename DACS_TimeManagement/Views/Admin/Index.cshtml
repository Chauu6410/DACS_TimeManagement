@using Microsoft.AspNetCore.Identity
@model DACS_TimeManagement.Models.AdminViewModel
@inject UserManager<IdentityUser> _userManager
@{
    ViewData["Title"] = "System Admin Dashboard";
}

<div class="admin-container" data-aos="fade-up">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-pastel-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <!-- Header -->
    <div class="welcome-card card border-0 shadow-xl rounded-4 overflow-hidden mb-4">
        <div class="bg-gradient-primary text-white p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle bg-white bg-opacity-25 text-white">
                        <i class="fas fa-shield-alt fs-3"></i>
                    </div>
                    <div>
                        <h1 class="display-6 fw-bold mb-0">Admin Dashboard</h1>
                        <p class="opacity-90 mb-0">System overview and user management</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Cards (Pastel) -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stats-card-pastel pastel-indigo h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stats-icon mb-2">
                            <i class="fas fa-users fa-2x"></i>
                        </div>
                        <div class="stats-number display-4 fw-bold">@Model.TotalUsers</div>
                        <div class="stats-label text-pastel-muted small fw-semibold">Total Users</div>
                    </div>
                    <i class="fas fa-users fa-4x opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card-pastel pastel-green h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stats-icon mb-2">
                            <i class="fas fa-project-diagram fa-2x"></i>
                        </div>
                        <div class="stats-number display-4 fw-bold">@Model.TotalProjects</div>
                        <div class="stats-label text-pastel-muted small fw-semibold">Total Projects</div>
                    </div>
                    <i class="fas fa-project-diagram fa-4x opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card-pastel pastel-cyan h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="stats-icon mb-2">
                            <i class="fas fa-tasks fa-2x"></i>
                        </div>
                        <div class="stats-number display-4 fw-bold">@Model.TotalTasks</div>
                        <div class="stats-label text-pastel-muted small fw-semibold">Total Work Tasks</div>
                    </div>
                    <i class="fas fa-tasks fa-4x opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Users List Table (Pastel) -->
    <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
        <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
            <div class="d-flex align-items-center gap-2">
                <div class="icon-circle bg-pastel-primary-soft" style="width: 36px; height: 36px;">
                    <i class="fas fa-users-cog text-pastel-primary fs-6"></i>
                </div>
                <h5 class="fw-bold mb-0 text-pastel-dark">Registered Users</h5>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-pastel align-middle m-0">
                    <thead>
                        <tr>
                            <th class="ps-4">User ID</th>
                            <th>Email / Username</th>
                            <th>Email Confirmed</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            var isAdmin = await _userManager.IsInRoleAsync(user, "Admin");
                            var isLocked = await _userManager.IsLockedOutAsync(user);
                            <tr>
                                <td class="ps-4 text-pastel-muted small font-monospace">@user.Id</td>
                                <td class="fw-semibold text-pastel-dark">
                                    @if (isAdmin)
                                    {
                                        <span class="badge bg-pastel-danger me-2">Admin</span>
                                    }
                                    @user.Email
                                </td>
                                <td>
                                    @if (user.EmailConfirmed)
                                    {
                                        <span class="badge bg-pastel-success rounded-pill px-3 py-1">
                                            <i class="fas fa-check-circle me-1"></i>Confirmed
                                        </span>
                                    }
                                    else
                                    {
                                        <form asp-action="ConfirmEmail" asp-route-userId="@user.Id" method="post" class="d-inline">
                                            <button type="submit" class="badge bg-pastel-warning border-0 rounded-pill px-3 py-1 text-dark cursor-pointer" style="cursor: pointer;">
                                                <i class="fas fa-clock me-1"></i>Pending (Fix)
                                            </button>
                                        </form>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (user.Email != "admin@gmail.com")
                                    {
                                        <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                            <button type="button" class="btn btn-sm bg-white text-primary border-end toggle-admin-btn" data-user-id="@user.Id" data-is-admin="@(isAdmin ? "true" : "false")" title="Toggle Admin/User">
                                                <i class="fas fa-user-tag"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm bg-white @(isLocked ? "text-success" : "text-danger") toggle-lock-btn" data-user-id="@user.Id" data-is-locked="@(isLocked ? "true" : "false")" title="@(isLocked ? "Unlock" : "Lock")">
                                                <i class="fas @(isLocked ? "fa-unlock" : "fa-lock")"></i>
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Users.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-pastel-muted py-5">No users found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    @section Scripts {
    <script>
        // Handle Toggle Admin Role
        document.querySelectorAll('.toggle-admin-btn').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                const userId = this.dataset.userId;
                const isAdmin = this.dataset.isAdmin === 'true';
                const originalHtml = this.innerHTML;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                this.disabled = true;

                try {
                    const response = await fetch('/Admin/ToggleAdminRole', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: `userId=${encodeURIComponent(userId)}`
                    });
                    const result = await response.json();
                    if (result.success) {
                        showToast(result.message, 'success');
                        // Cập nhật giao diện: thay đổi badge Admin và trạng thái nút
                        const row = this.closest('tr');
                        const emailCell = row.cells[1];
                        const badgeSpan = emailCell.querySelector('.badge.bg-pastel-danger');
                        if (result.isAdmin) {
                            if (!badgeSpan) {
                                const newBadge = document.createElement('span');
                                newBadge.className = 'badge bg-pastel-danger me-2';
                                newBadge.innerText = 'Admin';
                                emailCell.insertBefore(newBadge, emailCell.firstChild);
                            }
                            this.dataset.isAdmin = 'true';
                        } else {
                            if (badgeSpan) badgeSpan.remove();
                            this.dataset.isAdmin = 'false';
                        }
                    } else {
                        showToast(result.message || 'Error', 'error');
                    }
                } catch (err) {
                    showToast('Network error', 'error');
                } finally {
                    this.innerHTML = originalHtml;
                    this.disabled = false;
                }
            });
        });

        // Handle Toggle Lockout
        document.querySelectorAll('.toggle-lock-btn').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                const userId = this.dataset.userId;
                const isLocked = this.dataset.isLocked === 'true';
                const originalHtml = this.innerHTML;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                this.disabled = true;

                try {
                    const response = await fetch('/Admin/ToggleLockout', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: `userId=${encodeURIComponent(userId)}`
                    });
                    const result = await response.json();
                    if (result.success) {
                        showToast(result.message, 'success');
                        // Cập nhật icon và trạng thái
                        const icon = this.querySelector('i');
                        if (result.isLocked) {
                            icon.className = 'fas fa-unlock';
                            this.classList.add('text-success');
                            this.classList.remove('text-danger');
                            this.title = 'Unlock';
                            this.dataset.isLocked = 'true';
                        } else {
                            icon.className = 'fas fa-lock';
                            this.classList.add('text-danger');
                            this.classList.remove('text-success');
                            this.title = 'Lock';
                            this.dataset.isLocked = 'false';
                        }
                    } else {
                        showToast(result.message || 'Error', 'error');
                    }
                } catch (err) {
                    showToast('Network error', 'error');
                } finally {
                    this.innerHTML = originalHtml;
                    this.disabled = false;
                }
            });
        });

        function showToast(message, type) {
            // Tạo toast tạm thời
            const toast = document.createElement('div');
            toast.className = `alert alert-pastel-${type} alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow-lg`;
            toast.style.zIndex = '9999';
            toast.style.minWidth = '250px';
            toast.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'} me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
}
</div>

<style>
    /* Admin Dashboard Pastel Styles - đồng bộ với toàn bộ hệ thống */
    .admin-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }
    .bg-pastel-primary-soft {
        background: rgba(99, 102, 241, 0.12);
    }
    .text-pastel-primary {
        color: #4f46e5;
    }
    .text-pastel-dark {
        color: #1e293b;
    }
    .text-pastel-muted {
        color: #64748b;
    }

    /* Stats Cards Pastel */
    .stats-card-pastel {
        border-radius: 20px;
        padding: 1.25rem;
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: default;
    }
    .stats-card-pastel:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 20px rgba(0,0,0,0.08);
    }
    .pastel-indigo {
        background: #e0e7ff;
        border-left: 4px solid #6366f1;
    }
    .pastel-green {
        background: #dcfce7;
        border-left: 4px solid #22c55e;
    }
    .pastel-cyan {
        background: #cffafe;
        border-left: 4px solid #06b6d4;
    }
    .stats-icon i {
        color: #334155;
    }
    .stats-number {
        color: #0f172a;
    }

    /* Table Pastel */
    .table-pastel {
        background-color: #ffffff;
        color: #1e293b;
        border-collapse: separate;
        border-spacing: 0;
    }
    .table-pastel thead th {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        color: #64748b;
        padding: 1rem 0.75rem;
    }
    .table-pastel tbody td {
        padding: 1rem 0.75rem;
        border-bottom: 1px solid #e2e8f0;
        vertical-align: middle;
    }
    .table-pastel tbody tr:hover {
        background-color: rgba(99, 102, 241, 0.04);
    }

    /* Badge Pastel */
    .bg-pastel-danger {
        background: #fee2e2;
        color: #b91c1c;
    }
    .bg-pastel-success {
        background: #dcfce7;
        color: #16a34a;
    }
    .bg-pastel-warning {
        background: #fef9c3;
        color: #854d0e;
    }

    /* Button group custom */
    .btn-group .btn {
        border-radius: 0;
        transition: all 0.2s;
    }
    .btn-group .btn:first-child {
        border-top-left-radius: 40px;
        border-bottom-left-radius: 40px;
    }
    .btn-group .btn:last-child {
        border-top-right-radius: 40px;
        border-bottom-right-radius: 40px;
    }
    .btn-group .btn:hover {
        background-color: #f1f5f9 !important;
        transform: scale(1.02);
    }

    /* Dark Mode Variables */
    body.theme-dark {
        --pastel-primary-dark: #6366f1;
        --pastel-border: #334155;
        --pastel-card-bg: #1e293b;
        --pastel-dark: #f1f5f9;
        --pastel-muted: #94a3b8;
        --pastel-soft: #0f172a;
    }
    body.theme-dark .pastel-indigo {
        background: #1e293b;
        border-left-color: #6366f1;
    }
    body.theme-dark .pastel-green {
        background: #1e293b;
        border-left-color: #4ade80;
    }
    body.theme-dark .pastel-cyan {
        background: #1e293b;
        border-left-color: #06b6d4;
    }
    body.theme-dark .stats-icon i,
    body.theme-dark .stats-number {
        color: #f1f5f9;
    }
    body.theme-dark .table-pastel {
        background-color: #1e293b;
    }
    body.theme-dark .table-pastel thead th {
        background-color: #0f172a;
        border-bottom-color: #334155;
        color: #94a3b8;
    }
    body.theme-dark .table-pastel tbody td {
        border-bottom-color: #334155;
    }
    body.theme-dark .table-pastel tbody tr:hover {
        background-color: rgba(99, 102, 241, 0.1);
    }
    body.theme-dark .bg-pastel-danger {
        background: #7f1d1d;
        color: #fecaca;
    }
    body.theme-dark .bg-pastel-success {
        background: #14532d;
        color: #bbf7d0;
    }
    body.theme-dark .bg-pastel-warning {
        background: #854d0e;
        color: #fef9c3;
    }
    body.theme-dark .btn-group .btn {
        background-color: #1e293b !important;
        color: #cbd5e1;
        border-color: #334155;
    }
    body.theme-dark .btn-group .btn:hover {
        background-color: #334155 !important;
    }
    .alert-pastel-success {
        background: #dcfce7;
        border-left: 4px solid #22c55e;
        color: #166534;
    }
    body.theme-dark .alert-pastel-success {
        background: #14532d;
        color: #bbf7d0;
        border-left-color: #4ade80;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .admin-container {
            padding: 0 0.5rem;
        }
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .stats-number {
            font-size: 1.8rem;
        }
        .table-pastel thead th,
        .table-pastel tbody td {
            padding: 0.75rem 0.5rem;
        }
    }
</style>

<script>
    if (typeof AOS !== 'undefined') {
        AOS.refresh();
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $('.role-form').on('submit', function(e) {
        e.preventDefault();
        var form = this;
        Swal.fire({
            title: 'Xác nhận thay đổi quyền?',
            text: "Vai trò của người dùng này sẽ bị thay đổi ngay lập tức!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#6366f1',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Đồng ý',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
    });
</script>