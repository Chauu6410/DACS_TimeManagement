@model DACS_TimeManagement.Models.Project
@{
    ViewData["Title"] = "Delete Project";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-danger text-white p-4 text-center">
                <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
                <h3 class="mb-0 fw-bold">Delete Project</h3>
            </div>
            <div class="card-body p-4 text-center">
                <h5 class="mb-3">Are you sure you want to delete this project?</h5>
                <h3 class="text-dark fw-bold mb-3">"@Model.Name"</h3>
                
                <div class="alert alert-warning text-start mb-4">
                    <strong><i class="fas fa-skull-crossbones me-2"></i>Warning:</strong> 
                    This action is permanent and cannot be undone. All tasks, time logs, and files associated strictly with this project will be removed.
                </div>

                <form asp-action="Delete" method="post" class="d-flex justify-content-center gap-3 mt-4">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-light border px-4 py-2 fw-bold text-muted">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-danger px-4 py-2 fw-bold shadow">
                        <i class="fas fa-trash-alt me-2"></i>Yes, Delete Everything
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
