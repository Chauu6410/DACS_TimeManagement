@model IEnumerable<DACS_TimeManagement.Models.Project>
@{
    ViewData["Title"] = Localizer["ProjectsDashboard"];
}

<div class="projects-container" data-aos="fade-up" style="opacity: 1 !important;">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <!-- Search Bar -->
        <div class="search-wrapper position-relative" style="min-width: 300px;">
            <i class="fas fa-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
            <input type="text" id="projectSearch" class="form-control rounded-pill ps-5 border-0 shadow-sm" placeholder="@Localizer["SearchProjects"]..." style="background: rgba(255,255,255,0.8); backdrop-filter: blur(4px);">
        </div>

        <button type="button" class="btn btn-pastel-primary rounded-pill px-4 shadow-sm fw-semibold hover-lift" data-bs-toggle="modal" data-bs-target="#createProjectModal">
            <i class="fas fa-plus me-2"></i>@Localizer["NewProject"]
        </button>
    </div>


    <!-- Projects Grid -->
    <div class="row g-4" id="projectsGrid">

        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="empty-state-card card border-0 shadow-lg rounded-4 p-5 text-center">
                    <i class="fas fa-folder-open fa-4x text-pastel-muted mb-3"></i>
                    <h4 class="fw-semibold">@Localizer["NoProjectsYet"]</h4>
                    <p class="text-muted mb-4">@Localizer["OrganizeTasksDescription"]</p>
                    <button type="button" class="btn btn-pastel-primary rounded-pill mx-auto px-4" data-bs-toggle="modal" data-bs-target="#createProjectModal">@Localizer["CreateFirstProject"]</button>
                </div>
            </div>
        }

        @{
            var pastelColors = new[] { "pastel-blue", "pastel-green", "pastel-yellow", "pastel-pink", "pastel-purple", "pastel-mint" };
            var colorIndex = 0;
        }
        @foreach (var project in Model)
        {
            var colorClass = pastelColors[colorIndex % pastelColors.Length];
            colorIndex++;

            var totalTasks = project.Tasks?.Count() ?? 0;
            var completedTasks = project.Tasks?.Count(t => t.Status == DACS_TimeManagement.Models.TaskStatus.Completed) ?? 0;
            var completionPercent = totalTasks == 0 ? 0 : (int)((double)completedTasks / totalTasks * 100);

            <div class="col-md-6 col-lg-4 project-item" data-name="@project.Name.ToLower()">

                <div class="project-card card border-0 shadow-md rounded-4 overflow-hidden hover-lift @colorClass">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title fw-bold mb-0 text-truncate" title="@project.Name">@project.Name</h5>
                            <div class="dropdown">
                                <button class="btn btn-sm rounded-circle border-0 bg-white bg-opacity-50 text-danger hover-scale" 
                                        type="button" 
                                        onclick="confirmDelete('@project.Id', '@project.Name')"
                                        title="@Localizer["DeleteProject"]">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                                <form id="delete-form-@project.Id" asp-action="Delete" asp-route-id="@project.Id" method="post" style="display:none;">
                                    @Html.AntiForgeryToken()
                                </form>
                            </div>
                        </div>

                        <p class="card-text text-muted small mb-4" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 40px;">
                            @(string.IsNullOrEmpty(project.Description) ? Localizer["NoDescriptionProvided"] : project.Description)
                        </p>

                        <!-- Progress Ring mini -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="progress-ring-mini">
                                <svg width="50" height="50">
                                    <circle cx="25" cy="25" r="20" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="4"></circle>
                                    <circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" 
                                            stroke-dasharray="125.66" stroke-dashoffset="@(125.66 - (125.66 * completionPercent / 100))" 
                                            style="transition: stroke-dashoffset 0.5s ease; transform: rotate(-90deg); transform-origin: 50% 50%;"></circle>
                                </svg>
                                <span class="progress-text">@completionPercent%</span>
                            </div>
                            <div class="text-end">
                                <div class="d-flex gap-3">
                                    <div>
                                        <span class="d-block text-muted small fw-semibold">@Localizer["Tasks"]</span>
                                        <span class="fs-5 fw-bold">@totalTasks</span>
                                    </div>
                                    <div>
                                        <span class="d-block text-muted small fw-semibold">@Localizer["Done"]</span>
                                        <span class="fs-5 fw-bold text-success">@completedTasks</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-pastel-outline w-100 rounded-pill fw-semibold mt-2">
                            @Localizer["ViewDetails"] <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Empty Search Result -->
    <div id="emptySearchResult" class="col-12 text-center py-5" style="display: none;">
        <div class="card glass-card border-0 shadow-sm rounded-4 p-5">
            <i class="fas fa-search fa-3x text-muted mb-3 opacity-50"></i>
            <h5 class="fw-semibold text-muted">@Localizer["NoProjectsFound"]</h5>
            <p class="text-muted mb-0">@Localizer["TryDifferentSearch"]</p>
        </div>
    </div>

</div>


<!-- Create Project Modal -->
<div class="modal fade" id="createProjectModal" tabindex="-1" aria-labelledby="createProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-gradient-primary text-white border-0 py-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle bg-white bg-opacity-25 text-white" style="width: 48px; height: 48px; border-radius: 60px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
                        <i class="fas fa-folder-plus fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">@Localizer["CreateNewProject"]</h4>
                        <p class="opacity-75 small mb-0">@Localizer["ProjectWorkspaceDescription"]</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post" id="createProjectForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 p-lg-5" style="background-color: var(--card-bg);">
                    <div class="row g-4">
                        <div class="col-12">
                            <label for="Name" class="form-label fw-semibold mb-2" style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);">
                                <i class="fas fa-tag text-primary me-1"></i> @Localizer["ProjectName"] <span class="text-danger">*</span>
                            </label>
                            <input type="text" id="Name" name="Name" class="form-control form-control-lg rounded-3" style="border: 1px solid var(--border-color); background-color: var(--card-bg); color: var(--text-dark);" placeholder="@Localizer["ProjectNamePlaceholder"]" required />
                        </div>
                        <div class="col-12">
                            <label for="Description" class="form-label fw-semibold mb-2" style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);">
                                <i class="fas fa-align-left text-primary me-1"></i> @Localizer["Description"]
                            </label>
                            <textarea id="Description" name="Description" class="form-control rounded-3" style="border: 1px solid var(--border-color); background-color: var(--card-bg); color: var(--text-dark);" rows="5" placeholder="@Localizer["DescriptionPlaceholder"]"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top p-4 d-flex justify-content-between" style="border-color: var(--border-color) !important; background-color: var(--bg-light);">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4 py-2" data-bs-dismiss="modal">
                        <i class="fas fa-arrow-left me-2"></i> @Localizer["Cancel"]
                    </button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm fw-bold">
                        <i class="fas fa-check-circle me-2"></i> @Localizer["CreateProject"]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Pastel Theme Variables */
    :root {
        --pastel-blue-bg: #e0f2fe;
        --pastel-blue-border: #7dd3fc;
        --pastel-blue-text: #0284c7;
        --pastel-green-bg: #dcfce7;
        --pastel-green-border: #86efac;
        --pastel-green-text: #16a34a;
        --pastel-yellow-bg: #fef9c3;
        --pastel-yellow-border: #fde047;
        --pastel-yellow-text: #ca8a04;
        --pastel-pink-bg: #fce7f3;
        --pastel-pink-border: #f9a8d4;
        --pastel-pink-text: #db2777;
        --pastel-purple-bg: #f3e8ff;
        --pastel-purple-border: #d8b4fe;
        --pastel-purple-text: #9333ea;
        --pastel-mint-bg: #ccfbf1;
        --pastel-mint-border: #5eead4;
        --pastel-mint-text: #0d9488;
    }

    .projects-container {
        max-width: 1400px;
        margin: -1rem auto 0;
        padding: 0;
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 30px;
    }

    .text-primary-pastel {
        color: #4f46e5;
    }
    .text-gradient-pastel {
        background: linear-gradient(135deg, #4f46e5, #a855f7);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
    }
    .btn-pastel-primary {
        background: #e0e7ff;
        color: #4f46e5;
        border: none;
        transition: all 0.2s;
    }
    .btn-pastel-primary:hover {
        background: #c7d2fe;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
    }
    .btn-pastel-outline {
        background: transparent;
        border: 1px solid rgba(0,0,0,0.1);
        color: inherit;
        transition: all 0.2s;
    }
    .btn-pastel-outline:hover {
        background: rgba(0,0,0,0.03);
        transform: translateX(4px);
    }

    /* Project Card Pastel Variants */
    .project-card.pastel-blue {
        background: var(--pastel-blue-bg);
        border-left: 4px solid var(--pastel-blue-border);
    }
    .project-card.pastel-blue .progress-ring-mini svg circle:last-child {
        stroke: var(--pastel-blue-text);
    }
    .project-card.pastel-green {
        background: var(--pastel-green-bg);
        border-left: 4px solid var(--pastel-green-border);
    }
    .project-card.pastel-green .progress-ring-mini svg circle:last-child {
        stroke: var(--pastel-green-text);
    }
    .project-card.pastel-yellow {
        background: var(--pastel-yellow-bg);
        border-left: 4px solid var(--pastel-yellow-border);
    }
    .project-card.pastel-yellow .progress-ring-mini svg circle:last-child {
        stroke: var(--pastel-yellow-text);
    }
    .project-card.pastel-pink {
        background: var(--pastel-pink-bg);
        border-left: 4px solid var(--pastel-pink-border);
    }
    .project-card.pastel-pink .progress-ring-mini svg circle:last-child {
        stroke: var(--pastel-pink-text);
    }
    .project-card.pastel-purple {
        background: var(--pastel-purple-bg);
        border-left: 4px solid var(--pastel-purple-border);
    }
    .project-card.pastel-purple .progress-ring-mini svg circle:last-child {
        stroke: var(--pastel-purple-text);
    }
    .project-card.pastel-mint {
        background: var(--pastel-mint-bg);
        border-left: 4px solid var(--pastel-mint-border);
    }
    .project-card.pastel-mint .progress-ring-mini svg circle:last-child {
        stroke: var(--pastel-mint-text);
    }

    .project-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .project-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.15) !important;
    }

    .progress-ring-mini {
        position: relative;
        width: 50px;
        height: 50px;
    }
    .progress-ring-mini svg {
        width: 100%;
        height: 100%;
    }
    .progress-ring-mini .progress-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 0.7rem;
        font-weight: bold;
    }

    .empty-state-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

    /* Dark mode overrides */
    body.theme-dark .project-card {
        background: #161b30;
        border-left-color: var(--primary);
    }
    body.theme-dark .project-card.pastel-blue,
    body.theme-dark .project-card.pastel-green,
    body.theme-dark .project-card.pastel-yellow,
    body.theme-dark .project-card.pastel-pink,
    body.theme-dark .project-card.pastel-purple,
    body.theme-dark .project-card.pastel-mint {
        background: #161b30;
        border-left-color: var(--primary);
    }
    body.theme-dark .btn-pastel-primary {
        background: rgba(255, 255, 255, 0.06);
        color: #a5b4fc;
    }
    body.theme-dark .btn-pastel-primary:hover {
        background: #475569;
    }
    body.theme-dark .empty-state-card {
        background: #161b30;
        border-color: #334155;
    }
    body.theme-dark .text-pastel-muted {
        color: #94a3b8;
    }
    body.theme-dark .dropdown-menu {
        background: #161b30;
        border-color: #334155;
    }
    body.theme-dark .dropdown-item {
        color: #e2e8f0;
    }
    body.theme-dark .dropdown-item:hover {
        background: rgba(255, 255, 255, 0.06);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .projects-container {
            padding: 0 0.5rem;
        }
        .icon-circle {
            width: 40px;
            height: 40px;
        }
        .project-card .card-body {
            padding: 1.25rem;
        }
    }
    .hover-scale {
        transition: transform 0.2s ease, background-color 0.2s ease;
    }
    .hover-scale:hover {
        transform: scale(1.2);
        background-color: #fee2e2 !important; /* Nền đỏ nhạt khi hover */
        color: #dc2626 !important;
    }

    /* Search Bar Styles */
    .search-wrapper input {
        transition: all 0.3s ease;
        border: 1px solid transparent !important;
    }
    .search-wrapper input:focus {
        background: #fff !important;
        box-shadow: 0 8px 20px rgba(0,0,0,0.06) !important;
        border-color: var(--pastel-blue-border) !important;
        width: 350px;
    }
    body.theme-dark .search-wrapper input {
        background: rgba(30, 41, 59, 0.7) !important;
        color: #f1f5f9;
    }
    body.theme-dark .search-wrapper input:focus {
        background: rgba(30, 41, 59, 0.9) !important;
        border-color: #475569 !important;
    }
</style>


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Đảm bảo AOS được làm mới sau khi nội dung load
            if (typeof AOS !== 'undefined') {
                AOS.refresh();
            }

            // Chức năng tìm kiếm dự án
            const projectSearch = document.getElementById('projectSearch');
            if (projectSearch) {
                projectSearch.addEventListener('input', function(e) {
                    const searchTerm = e.target.value.toLowerCase().trim();
                    const projectItems = document.querySelectorAll('.project-item');
                    let hasResults = false;

                    projectItems.forEach(item => {
                        const projectName = item.getAttribute('data-name');
                        if (projectName.includes(searchTerm)) {
                            item.style.display = 'block';
                            hasResults = true;
                        } else {
                            item.style.display = 'none';
                        }
                    });

                    // Hiển thị thông báo nếu không tìm thấy
                    const emptySearch = document.getElementById('emptySearchResult');
                    if (emptySearch) {
                        emptySearch.style.display = hasResults ? 'none' : 'block';
                    }

                    if (typeof AOS !== 'undefined') AOS.refresh();
                });
            }
        });



        /**
         * Xác nhận xóa dự án với thông báo đa ngôn ngữ an toàn
         */
        function confirmDelete(projectId, projectName) {
            const rawMessage = "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Localizer["DeleteProjectConfirm"].Value))";
            const message = rawMessage.replace("{projectName}", projectName).replace(/\\n/g, '\n');
        
            Swal.fire({
                title: '@Localizer["AreYouSure"]',
                text: message,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '@Localizer["YesDeleteIt"]',
                cancelButtonText: '@Localizer["Cancel"]',
                borderRadius: '1rem'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(`delete-form-${projectId}`).submit();
                }
            });
        }

        /**
         * Xử lý submit form Create Project bằng AJAX
         */
        document.getElementById('createProjectForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            const form = this;
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>@Localizer["Saving"]';
            
            fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Tắt modal và reload trang để hiện project mới
                    const modalEl = document.getElementById('createProjectModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) {
                        modal.hide();
                    }
                    window.location.reload();
                } else {
                    alert(data.message || '@Localizer["ErrorOccurred"]');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('@Localizer["NetworkError"]');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            });
        });
    </script>
}