@model DACS_TimeManagement.Models.Project
@{
    ViewData["Title"] = "Project Details";
    var completedTasks = Model.Tasks?.Count(t => t.Status == DACS_TimeManagement.Models.TaskStatus.Completed) ?? 0;
    var totalTasks = Model.Tasks?.Count() ?? 0;
    var progressPct = totalTasks == 0 ? 0 : (int)((double)completedTasks / totalTasks * 100);
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3 border-0 shadow-sm" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3 border-0 shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row mt-4">
    <!-- Project Header Info -->
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm border-0 h-100 position-relative overflow-hidden">
            <div class="bg-primary pt-5 pb-3 px-4 text-white">
                <h3 class="fw-bold mb-1">@Model.Name</h3>
                <small class="opacity-75"><i class="fas fa-calendar-alt me-1"></i> Created @Model.CreatedDate.ToString("MMM dd, yyyy")</small>
            </div>
            <div class="card-body p-4 text-center mt-3">
                
                <!-- Circular Progress Ring Concept -->
                <div class="position-relative d-inline-block mb-4">
                    <svg width="120" height="120">
                        <circle cx="60" cy="60" r="50" fill="none" stroke="#e9ecef" stroke-width="8"></circle>
                        <circle cx="60" cy="60" r="50" fill="none" stroke="var(--primary)" stroke-width="8" 
                                stroke-dasharray="314" stroke-dashoffset="@(314 - (314 * progressPct / 100))" 
                                style="transition: stroke-dashoffset 1s ease-in-out;" transform="rotate(-90 60 60)"></circle>
                    </svg>
                    <div class="position-absolute top-50 start-50 translate-middle text-center">
                        <span class="fs-3 fw-bold text-dark d-block" style="line-height: 1;">@progressPct%</span>
                    </div>
                </div>

                <div class="row text-center mb-4">
                    <div class="col-6 border-end">
                        <h3 class="mb-0 text-dark fw-bold">@totalTasks</h3>
                        <small class="text-muted text-uppercase fw-bold">Total Tasks</small>
                    </div>
                    <div class="col-6">
                        <h3 class="mb-0 text-success fw-bold">@completedTasks</h3>
                        <small class="text-muted text-uppercase fw-bold">Completed</small>
                    </div>
                </div>

                <div class="d-grid gap-2 mb-3">
                    <button type="button" class="btn btn-outline-primary fw-bold" data-bs-toggle="modal" data-bs-target="#inviteMemberModal">
                        <i class="fas fa-user-plus me-2"></i>Invite Member
                    </button>
                </div>

                <div class="d-flex align-items-center justify-content-center gap-1 mb-4 flex-wrap">
                    @if (ViewBag.Members != null)
                    {
                        var members = ViewBag.Members as List<DACS_TimeManagement.Models.ProjectMember>;
                        if (members != null && members.Any())
                        {
                            foreach (var member in members)
                            {
                                <span class="badge bg-secondary-subtle text-dark border p-2" title="@member.Role"><i class="fas fa-user-circle me-1"></i>Member</span>
                            }
                        }
                    }
                </div>

                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-light border fw-bold"><i class="fas fa-edit text-primary me-2"></i>Edit Project</a>
                    <a asp-controller="WorkTask" asp-action="Create" asp-route-projectId="@Model.Id" class="btn btn-primary fw-bold"><i class="fas fa-plus me-2"></i>Add Task to Project</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Kanban Board cho Project -->
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-columns text-primary me-2"></i>Kanban Board</h5>
            <a asp-controller="WorkTask" asp-action="Create" class="btn btn-sm btn-primary fw-bold"><i class="fas fa-plus me-1"></i>New Task</a>
        </div>

        <div class="kanban-container d-flex overflow-auto pb-3" style="min-height: 500px; gap: 15px;">
            @if (Model.BoardLists != null)
            {
                foreach (var board in Model.BoardLists.OrderBy(b => b.Position))
                {
                    <div class="kanban-column bg-light rounded-3 p-3 d-flex flex-column" style="min-width: 300px; width: 300px; max-height: 100%;">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold mb-0">@board.Name</h6>
                            <span class="badge bg-secondary rounded-pill">@(Model.Tasks?.Count(t => t.BoardListId == board.Id) ?? 0)</span>
                        </div>

                        <div class="kanban-tasks flex-grow-1 overflow-auto" id="kanban-list-@board.Id" data-list-id="@board.Id">
                            @if (Model.Tasks != null)
                            {
                                foreach (var task in Model.Tasks.Where(t => t.BoardListId == board.Id).OrderBy(t => t.Position))
                                {
                                    <div class="kanban-task card shadow-sm mb-2 border-0" data-task-id="@task.Id" style="cursor: grab;">
                                        <div class="card-body p-3">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h6 class="card-title fw-bold text-dark mb-0 fs-6">
                                                    <a asp-controller="WorkTask" asp-action="Details" asp-route-id="@task.Id" class="text-decoration-none text-dark">@task.Title</a>
                                                </h6>
                                                <!-- Dropdown options -->
                                                <div class="dropdown">
                                                    <button class="btn btn-link text-muted p-0 text-decoration-none dropdown-toggle-no-caret" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                        <i class="fas fa-ellipsis-v"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 text-sm">
                                                        <li><a class="dropdown-item" asp-controller="WorkTask" asp-action="Edit" asp-route-id="@task.Id"><i class="fas fa-edit text-muted me-2"></i>Edit</a></li>
                                                        <li><a class="dropdown-item text-danger" asp-controller="WorkTask" asp-action="Delete" asp-route-id="@task.Id"><i class="fas fa-trash me-2"></i>Delete</a></li>
                                                    </ul>
                                                </div>
                                            </div>
                                            
                                            @if (!string.IsNullOrEmpty(task.Description))
                                            {
                                                <p class="text-muted small mb-2 text-truncate">@task.Description</p>
                                            }

                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="badge @(task.Priority == DACS_TimeManagement.Models.Priority.High || task.Priority == DACS_TimeManagement.Models.Priority.Urgent ? "bg-danger-subtle text-danger" : "bg-light-subtle text-muted text-dark") border">
                                                    @task.Priority
                                                </span>
                                                <small class="text-muted fw-medium" title="Due Date">
                                                    <i class="far fa-clock me-1"></i>@task.EndDate.ToString("MMM dd")
                                                </small>
                                            </div>
                                            
                                            <!-- Hiển thị Assignee (nếu có user được gán trong tương lai) -->
                                            @if (!string.IsNullOrEmpty(task.AssigneeId))
                                            {
                                                <div class="mt-2 text-end">
                                                    <div class="avatar-circle bg-primary text-white d-inline-flex justify-content-center align-items-center rounded-circle" style="width: 24px; height: 24px; font-size: 10px;" title="Assigned to @task.AssigneeId">
                                                        <i class="fas fa-user"></i>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <!-- SortableJS cho Kanban Drag & Drop -->
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const currentProjectId = @Model.Id;
            const kanbanLists = document.querySelectorAll('.kanban-tasks');

            kanbanLists.forEach(list => {
                new Sortable(list, {
                    group: 'kanban', // set both lists to same group
                    animation: 150,
                    ghostClass: 'bg-light',
                    dragClass: 'shadow-lg',
                    chosenClass: 'border-primary',
                    onEnd: function (evt) {
                        const itemEl = evt.item;  // dragged element
                        const taskId = itemEl.getAttribute('data-task-id');
                        const newListEl = evt.to;    // target list
                        const newListId = newListEl.getAttribute('data-list-id');
                        const newPosition = evt.newIndex; // new index within the list

                        // Gọi API để cập nhật vào Database
                        updateTaskPosition(taskId, newListId, newPosition);
                    }
                });
            });

            function updateTaskPosition(taskId, newListId, newPosition) {
                // Chúng ta cung cấp AntiForgeryToken nếu có
                fetch('/WorkTask/UpdateTaskPosition', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: new URLSearchParams({
                        taskId: taskId,
                        newListId: newListId,
                        newPosition: newPosition
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        console.error('Lỗi khi lưu vị trí Task: ', data.message);
                        alert('Không thể lưu vị trí kéo thả. Vui lòng thử lại!');
                        // Trị trường hợp lỗi có thể refresh lại trang
                    } else {
                        // Tính toán lại badge số lượng thẻ cho từng cột
                        recalculateCounts();
                    }
                })
                .catch(error => {
                    console.error('Network Error: ', error);
                });
            }

            function recalculateCounts() {
                var columns = document.querySelectorAll('.kanban-column');
                columns.forEach(col => {
                    var count = col.querySelectorAll('.kanban-task').length;
                    var badge = col.querySelector('.badge');
                    if(badge) badge.innerText = count;
                });
            }
        });
    </script>
}

<!-- Modal Invite Member -->
<div class="modal fade" id="inviteMemberModal" tabindex="-1" aria-labelledby="inviteMemberModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold" id="inviteMemberModalLabel"><i class="fas fa-user-plus me-2"></i>Invite Teammate</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddMember" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <div class="mb-3">
                        <label for="email" class="form-label fw-bold text-muted">User Email Address</label>
                        <input type="email" class="form-control form-control-lg bg-light" id="email" name="email" placeholder="example@email.com" required>
                    </div>
                    <p class="text-muted small mb-0"><i class="fas fa-info-circle me-1"></i>Users must quickly register an account before you can invite them.</p>
                </div>
                <div class="modal-footer border-0 pb-4 pe-4">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Send Invite</button>
                </div>
            </form>
        </div>
    </div>
</div>
