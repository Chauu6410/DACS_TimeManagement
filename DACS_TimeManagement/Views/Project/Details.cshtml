@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let isLoadingComments = false;
        let currentUserId = null; // sẽ được gán từ server

        // Lấy userId hiện tại (có thể gán từ ViewBag hoặc từ API)
        @{
            var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }
        currentUserId = "@currentUserId";

        // Handle Edit Project form submission
        document.getElementById('editProjectForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            const form = this;
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>' + '@Localizer["Saving"]';
            
            fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const modalEl = document.getElementById('editProjectModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) {
                        modal.hide();
                    }
                    window.location.reload();
                } else {
                    alert(data.message || '@Localizer["ErrorUpdatingProject"]');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('@Localizer["NetworkError"]');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            });
        });

        function loadComments() {
            if (isLoadingComments) return;
            isLoadingComments = true;
            const projectId = @Model.Id;
            fetch(`/ProjectDiscussions/GetComments?projectId=${projectId}`)
                .then(response => response.ok ? response.json() : Promise.reject('HTTP error'))
                .then(data => {
                    const container = document.getElementById('chatMessages');
                    const countSpan = document.getElementById('commentCount');
                    if (data.success && data.comments && data.comments.length) {
                        countSpan.innerText = data.comments.length;
                        container.innerHTML = data.comments.map(c => {
                            const isMine = (c.userId === currentUserId);
                            return `
                                <div class="chat-message d-flex gap-3 ${isMine ? 'justify-content-end' : ''}" data-comment-id="${c.id}">
                                    ${!isMine ? `
                                    <div class="avatar-chat rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 shadow-sm border border-white mt-auto" style="width: 34px; height: 34px; background: rgba(99, 102, 241, 0.12); margin-bottom: 22px;">
                                        <span class="fw-bold" style="color: var(--primary); font-size: 0.8rem;">${c.userName ? c.userName.charAt(0).toUpperCase() : 'U'}</span>
                                    </div>
                                    ` : ''}
                                    <div class="d-flex flex-column ${isMine ? 'align-items-end' : 'align-items-start'}" style="max-width: 75%;">
                                        ${!isMine ? `<div class="fw-bold text-pastel-muted mb-1 ms-2" style="font-size: 0.75rem;">${escapeHtml(c.userName || 'Unknown')}</div>` : ''}
                                        <div class="message-wrapper">
                                            <div class="message-bubble ${isMine ? 'mine' : 'theirs'}">
                                                <div class="${isMine ? 'text-white' : 'text-pastel-dark'}">${escapeHtml(c.content)}</div>
                                                ${c.attachmentFileName ? `
                                                    <div class="mt-2 p-2 rounded-3" style="background: rgba(0,0,0,0.1);">
                                                        ${c.attachmentContentType && c.attachmentContentType.startsWith('audio/') ? `
                                                            <audio controls class="w-100 mt-1" style="max-height: 40px; outline: none; border-radius: 20px;">
                                                                <source src="/uploads/project_discussions/${c.attachmentFileName}" type="${c.attachmentContentType}">
                                                                @Localizer["AudioNotSupported"]
                                                            </audio>
                                                        ` : `
                                                            <a href="/uploads/project_discussions/${c.attachmentFileName}" target="_blank" class="text-decoration-none ${isMine ? 'text-white' : 'text-primary'} d-flex align-items-center gap-2">
                                                                <i class="fas fa-paperclip"></i>
                                                                <span class="small fw-medium">${escapeHtml(c.attachmentOriginalName)}</span>
                                                            </a>
                                                        `}
                                                    </div>
                                                ` : ''}
                                            </div>
                                            ${isMine ? `<button type="button" class="delete-message-btn" data-id="${c.id}" title="@Localizer["DeleteMessage"]"><i class="fas fa-trash-alt"></i></button>` : ''}
                                        </div>
                                        <div class="small fw-medium text-muted mt-1 ${isMine ? 'me-2' : 'ms-2'}" style="font-size: 0.75rem; opacity: 0.7;">
                                            ${formatDateTime(c.createdAt)}
                                        </div>
                                    </div>
                                </div>
                            `;
                        }).join('');
                        // Gắn sự kiện xóa cho các nút mới
                        document.querySelectorAll('.delete-message-btn').forEach(btn => {
                            btn.addEventListener('click', function(e) {
                                e.stopPropagation();
                                const commentId = this.dataset.id;
                                deleteComment(commentId, this);
                            });
                        });
                    } else {
                        container.innerHTML = `
                        <div class="d-flex h-100 justify-content-center align-items-center">
                            <div class="text-center text-pastel-muted w-100">
                                <div class="mb-3 opacity-25"><i class="fas fa-comment-slash" style="font-size: 4rem;"></i></div>
                                <h6 class="fw-semibold">@Localizer["NoMessagesYet"]</h6>
                                <p class="small mb-0">@Localizer["BeFirstStartConversation"]</p>
                            </div>
                        </div>`;
                        countSpan.innerText = '0';
                    }
                    // Auto scroll to bottom
                    container.scrollTop = container.scrollHeight;
                })
                .catch(err => {
                    console.error('Failed to load comments:', err);
                    document.getElementById('chatMessages').innerHTML = '<div class="alert alert-pastel-danger m-3 border-0 rounded-3 shadow-sm"><i class="fas fa-exclamation-triangle me-2"></i>' + '@Localizer["FailedToLoadMessages"]' + '</div>';
                })
                .finally(() => isLoadingComments = false);
        }

        function deleteComment(commentId, btnElement) {
            if (!confirm('@Localizer["DeleteMessageConfirm"]')) return;
            const messageDiv = btnElement.closest('.chat-message');
            // Hiệu ứng fade out
            messageDiv.style.transition = 'opacity 0.2s ease-out';
            messageDiv.style.opacity = '0';
            const formData = new FormData();
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if(token) formData.append('__RequestVerificationToken', token.value);
            
            fetch(`/ProjectDiscussions/DeleteComment/${commentId}`, {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    // Xóa khỏi DOM
                    messageDiv.remove();
                    // Cập nhật số lượng tin nhắn
                    const countSpan = document.getElementById('commentCount');
                    let currentCount = parseInt(countSpan.innerText);
                    if (!isNaN(currentCount) && currentCount > 0) {
                        countSpan.innerText = currentCount - 1;
                    }
                    // Nếu không còn tin nhắn nào, hiển thị empty state
                    const container = document.getElementById('chatMessages');
                    if (container.children.length === 0) {
                        container.innerHTML = `
                        <div class="d-flex h-100 justify-content-center align-items-center">
                            <div class="text-center text-pastel-muted w-100">
                                <div class="mb-3 opacity-25"><i class="fas fa-comment-slash" style="font-size: 4rem;"></i></div>
                                <h6 class="fw-semibold">@Localizer["NoMessagesYet"]</h6>
                                <p class="small mb-0">@Localizer["BeFirstStartConversation"]</p>
                            </div>
                        </div>`;
                    }
                } else {
                    alert(data.message || '@Localizer["FailedToDeleteMessage"]');
                    messageDiv.style.opacity = '1'; // khôi phục nếu lỗi
                }
            })
            .catch(err => {
                console.error(err);
                alert('@Localizer["ErrorDeletingMessage"]');
                messageDiv.style.opacity = '1';
            });
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // loadGoalContributions(); // Removed

        // Submit comment & Voice logic
        let voiceBlob = null;
        let mediaRecorder;
        let audioChunks = [];
        let recordTimerInterval;
        let recordSeconds = 0;

        const btnRecordVoice = document.getElementById('btnRecordVoice');
        const micIcon = document.getElementById('micIcon');
        const recordingUI = document.getElementById('recordingUI');
        const recordingTimer = document.getElementById('recordingTimer');
        const cancelRecordBtn = document.getElementById('cancelRecordBtn');

        if (btnRecordVoice) {
            btnRecordVoice.addEventListener('click', async function() {
                if (mediaRecorder && mediaRecorder.state === 'recording') {
                    mediaRecorder.stop();
                    return;
                }
                
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    mediaRecorder = new MediaRecorder(stream);
                    audioChunks = [];
                    
                    mediaRecorder.ondataavailable = event => {
                        if (event.data.size > 0) audioChunks.push(event.data);
                    };

                    mediaRecorder.onstart = () => {
                        recordingUI.classList.remove('d-none');
                        recordingUI.classList.add('d-flex');
                        micIcon.classList.replace('fa-microphone', 'fa-stop');
                        btnRecordVoice.classList.add('text-danger');
                        recordSeconds = 0;
                        updateTimerUI();
                        recordTimerInterval = setInterval(() => {
                            recordSeconds++;
                            updateTimerUI();
                        }, 1000);
                    };

                    mediaRecorder.onstop = () => {
                        clearInterval(recordTimerInterval);
                        recordingUI.classList.add('d-none');
                        recordingUI.classList.remove('d-flex');
                        micIcon.classList.replace('fa-stop', 'fa-microphone');
                        btnRecordVoice.classList.remove('text-danger');
                        
                        voiceBlob = new Blob(audioChunks, { type: 'audio/webm' });
                        stream.getTracks().forEach(track => track.stop());
                        
                        const filePreview = new File([voiceBlob], "voice_message.webm", { type: 'audio/webm' });
                        currentAttachment = filePreview;
                        document.getElementById('attachmentName').innerHTML = '<i class="fas fa-microphone-lines me-1"></i> ' + '@Localizer["VoiceMessage"]' + ' (' + getTimerFormat(recordSeconds) + ')';
                        document.getElementById('attachmentPreview').classList.remove('d-none');
                    };

                    mediaRecorder.start();
                } catch (err) {
                    console.error("Error accessing mic: ", err);
                    alert("Could not access microphone. Please check permissions.");
                }
            });
        }

        if (cancelRecordBtn) {
            cancelRecordBtn.addEventListener('click', () => {
                if (mediaRecorder && mediaRecorder.state === 'recording') {
                    mediaRecorder.onstop = () => {
                        clearInterval(recordTimerInterval);
                        recordingUI.classList.add('d-none');
                        recordingUI.classList.remove('d-flex');
                        micIcon.classList.replace('fa-stop', 'fa-microphone');
                        btnRecordVoice.classList.remove('text-danger');
                        mediaRecorder.stream.getTracks().forEach(track => track.stop());
                        voiceBlob = null;
                        audioChunks = [];
                    };
                    mediaRecorder.stop();
                }
            });
        }

        function updateTimerUI() {
            recordingTimer.innerText = getTimerFormat(recordSeconds);
        }
        function getTimerFormat(sec) {
            const m = Math.floor(sec / 60).toString().padStart(2, '0');
            const s = (sec % 60).toString().padStart(2, '0');
            return `${m}:${s}`;
        }

        const form = document.getElementById('commentForm');
        if (form) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const contentInput = document.getElementById('commentContent');
                let content = contentInput.value.trim();
                
                if (!content && !currentAttachment) return;
                
                if (!content && currentAttachment && currentAttachment.type && currentAttachment.type.startsWith('audio/')) {
                    content = "🎤 Voice Message";
                }

                const submitBtn = form.querySelector('button[type="submit"]');
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>';

                const formData = new FormData();
                formData.append('projectId', @Model.Id);
                formData.append('content', content);
                if (currentAttachment) {
                    formData.append('attachment', currentAttachment);
                }
                const token = document.querySelector('input[name="__RequestVerificationToken"]');
                if(token) formData.append('__RequestVerificationToken', token.value);

                fetch('/ProjectDiscussions/AddComment', {
                    method: 'POST',
                    body: formData
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        contentInput.value = '';
                        removeAttachment();
                        loadComments();
                    } else {
                        alert(data.message || 'Failed to post comment.');
                    }
                })
                .catch(err => alert('Error: ' + err.message))
                .finally(() => {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="fas fa-paper-plane fs-5"></i>';
                });
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Load comments
            loadComments();
            setInterval(loadComments, 10000);
            
            // Handle AI Content Initialization
            initAIStrategy();
        });

        // Initialize Emojis
        const emojis = ["😀","😁","😂","🤣","😊","😇","😉","😍","😘","😋","😎","😢","😭","😡","👍","👎","👏","🙏","🔥","❤️","🎉","✅","❌","🚀","👀","💯"];
        const emojiPicker = document.getElementById('emojiPickerContent');
        if(emojiPicker) {
            emojiPicker.innerHTML = emojis.map(e => `<button type="button" class="btn btn-light btn-sm rounded-circle p-1 hover-lift" style="width: 36px; height: 36px; font-size: 1.25rem; line-height: 1;" onclick="insertEmoji('${e}')">${e}</button>`).join('');
        }
        function insertEmoji(emoji) {
            const input = document.getElementById('commentContent');
            input.value += emoji;
            input.focus();
        }

        // Initialize Attachment Logic
        let currentAttachment = null;
        document.getElementById('attachmentInput')?.addEventListener('change', function(e) {
            if(this.files && this.files[0]) {
                currentAttachment = this.files[0];
                document.getElementById('attachmentName').textContent = currentAttachment.name;
                document.getElementById('attachmentPreview').classList.remove('d-none');
            }
        });
        function removeAttachment() {
            currentAttachment = null;
            const input = document.getElementById('attachmentInput');
            if (input) input.value = '';
            document.getElementById('attachmentPreview')?.classList.add('d-none');
        }
        // Gemini AI Project Integration (Streaming)
        document.getElementById('generateProjectAI')?.addEventListener('click', async function() {
            const btn = this;
            const contentDiv = document.getElementById('projectAIContent');
            const projectId = '@Model.Id';
            
            // Show loading state
            btn.disabled = true;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> ' + '@Localizer["Analyzing"]';
            
            contentDiv.innerHTML = `
                <div class="text-center py-5" id="aiLoading">
                    <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                    <h5 class="text-primary fw-bold">@Localizer["GeminiAnalyzingStructure"]</h5>
                    <p class="text-muted">@Localizer["BreakingDownTasks"]</p>
                </div>
                <div id="aiContainer" class="ai-response-container d-none">
                    <div id="aiStreamOutput" class="ai-response-content"></div>
                </div>`;

            let fullText = "";
            const container = document.getElementById('aiContainer');
            const streamOutput = document.getElementById('aiStreamOutput');
            const loadingDiv = document.getElementById('aiLoading');

            const eventSource = new EventSource(`/api/ai/stream-project-strategy?projectId=${projectId}`);

            eventSource.onmessage = function(e) {
                if (loadingDiv) {
                    loadingDiv.remove();
                    container.classList.remove('d-none');
                }

                try {
                    const chunk = JSON.parse(e.data);
                    if (chunk.error) {
                        throw new Error(chunk.error);
                    }
                    fullText += chunk;
                    streamOutput.innerHTML = marked.parse(fullText);
                } catch (err) {
                    console.error(err);
                    contentDiv.innerHTML = `<div class="alert alert-danger rounded-4"><i class="fas fa-exclamation-triangle me-2"></i><strong>@Localizer["Error"]:</strong> ${err.message}</div>`;
                    eventSource.close();
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            };

            eventSource.onerror = function(e) {
                eventSource.close();
                btn.disabled = false;
                btn.innerHTML = originalText;

                // Parse tasks and add Import button
                processAITasks(fullText);
                
                // Add copy button after completion
                if (fullText.length > 0) {
                    const copyBtn = document.createElement('button');
                    copyBtn.className = 'btn btn-sm btn-outline-primary rounded-pill mt-3 me-2';
                    copyBtn.innerHTML = '<i class="far fa-copy me-1"></i> ' + '@Localizer["CopyStrategy"]';
                    copyBtn.onclick = () => {
                        navigator.clipboard.writeText(fullText);
                        copyBtn.innerHTML = '<i class="fas fa-check me-1"></i> ' + '@Localizer["Copied"]';
                        setTimeout(() => copyBtn.innerHTML = '<i class="far fa-copy me-1"></i> ' + '@Localizer["CopyStrategy"]', 2000);
                    };
                    streamOutput.appendChild(copyBtn);
                }
            };
        });

        function processAITasks(text) {
            const streamOutput = document.getElementById('aiStreamOutput');
            const match = text.match(/```json-tasks\s+([\s\S]*?)```/);
            if (match && match[1]) {
                try {
                    const tasks = JSON.parse(match[1]);
                    if (tasks && tasks.length > 0) {
                        // Remove old suggested tasks UI if exists
                        const oldUI = document.getElementById('aiSuggestedTasksContainer');
                        if (oldUI) oldUI.remove();

                        // Create new container
                        const tasksContainer = document.createElement('div');
                        tasksContainer.id = 'aiSuggestedTasksContainer';
                        tasksContainer.className = 'mt-4 border-top border-pastel pt-4';
                        tasksContainer.innerHTML = `
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <div class="icon-circle-sm bg-pastel-primary-soft text-pastel-primary">
                                    <i class="fas fa-lightbulb"></i>
                                </div>
                                <h6 class="fw-bold mb-0 text-pastel-dark">@Localizer["SuggestedTasksToCreate"]</h6>
                            </div>
                            <div class="suggested-tasks-list d-flex flex-column gap-2"></div>
                        `;
                        
                        const list = tasksContainer.querySelector('.suggested-tasks-list');
                        const existingTitles = @Html.Raw(Json.Serialize(Model.Tasks?.Select(t => t.Title.ToLower().Trim()) ?? new List<string>()));
                        const existingKeys = @Html.Raw(Json.Serialize(Model.Tasks?.Where(t => !string.IsNullOrEmpty(t.AITaskKey)).Select(t => t.AITaskKey) ?? new List<string>()));
                        
                        tasks.forEach((task, index) => {
                            const normalizedTitle = task.title.toLowerCase().trim();
                            const isAdded = (task.key && existingKeys.includes(task.key)) || existingTitles.includes(normalizedTitle);
                            
                            const taskCard = document.createElement('div');
                            taskCard.className = 'd-flex align-items-center justify-content-between p-3 rounded-4 border border-pastel bg-white hover-lift-sm transition-all';
                            if (isAdded) {
                                taskCard.style.opacity = '0.6';
                                taskCard.style.backgroundColor = '#f8fafc';
                            }
                            taskCard.id = `suggested-task-${index}`;
                            
                            taskCard.innerHTML = `
                                <div class="flex-grow-1 pe-3">
                                    <h6 class="fw-bold text-pastel-dark mb-1">${escapeHtml(task.title)}</h6>
                                    <p class="small text-muted mb-0 line-clamp-1">${escapeHtml(task.description || '')}</p>
                                </div>
                                <button class="btn btn-sm ${isAdded ? 'btn-success' : 'btn-pastel-primary'} rounded-pill px-3 shadow-sm flex-shrink-0" 
                                        ${isAdded ? 'disabled' : ''}
                                        onclick="importSingleTask(${index}, '${encodeURIComponent(JSON.stringify(task))}')">
                                    <i class="fas ${isAdded ? 'fa-check' : 'fa-plus'} me-1"></i> 
                                    ${isAdded ? '@Localizer["AddedToKanban"]' : '@Localizer["Add"]'}
                                </button>
                            `;
                            list.appendChild(taskCard);
                        });

                        streamOutput.appendChild(tasksContainer);
                    }
                } catch (e) { console.error("Error parsing AI tasks", e); }
            }
        }

        async function importSingleTask(index, taskJsonEncoded) {
            const task = JSON.parse(decodeURIComponent(taskJsonEncoded));
            const card = document.getElementById(`suggested-task-${index}`);
            const btn = card.querySelector('button');
            
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            }

            try {
                const response = await fetch('/api/ai/import-tasks', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ projectId: @Model.Id, tasks: [task] })
                });
                const data = await response.json();
                if (data.success) {
                    btn.className = 'btn btn-sm btn-success rounded-pill px-3';
                    btn.innerHTML = '<i class="fas fa-check"></i>';
                    card.style.opacity = '0.6';
                    card.style.backgroundColor = '#f8fafc';
                    
                    // Optional: reload kanban if on same page
                    if (typeof loadTasks === 'function') loadTasks();
                }
            } catch (err) {
                console.error("Import error:", err);
                if (btn) {
                    btn.disabled = false;
                    btn.className = 'btn btn-sm btn-danger rounded-pill px-3';
                    btn.innerHTML = '<i class="fas fa-times"></i>';
                }
            }
        }

        function initAIStrategy() {
            const output = document.getElementById('aiStreamOutput');
            
            if (output) {
                const content = output.innerHTML.trim();
                if (content && !content.startsWith('<')) {
                    // Nếu là Markdown thô, tiến hành parse
                    output.innerHTML = marked.parse(content);
                    processAITasks(content);
                } else if (!content) {
                    // Nếu trống, kiểm tra xem có bản dịch ở ngôn ngữ khác không
                    const viExists = @(string.IsNullOrEmpty(Model.AIStrategyVi) ? "false" : "true");
                    const enExists = @(string.IsNullOrEmpty(Model.AIStrategyEn) ? "false" : "true");
                    
                    if (viExists || enExists) {
                        autoTranslateStrategy();
                    }
                }
            }
        }

        async function autoTranslateStrategy() {
            const loading = document.getElementById('aiTranslationLoading');
            const container = document.getElementById('aiContainer');
            const output = document.getElementById('aiStreamOutput');
            const langCode = '@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name.StartsWith("vi") ? "vi" : "en")';

            if (container) container.classList.add('translating');
            if (loading) loading.classList.remove('d-none');

            try {
                const response = await fetch('/api/ai/translate-strategy', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ projectId: @Model.Id, targetLang: langCode })
                });
                
                if (!response.ok) throw new Error("Translation request failed");
                
                const data = await response.json();
                if (data.result) {
                    output.innerHTML = marked.parse(data.result);
                    if (loading) loading.classList.add('d-none');
                    if (container) {
                        container.classList.remove('d-none', 'translating');
                    }
                    processAITasks(data.result);
                }
            } catch (err) {
                console.error("Translation error:", err);
                if (container) container.classList.remove('translating');
                if (loading) loading.innerHTML = '<div class="alert alert-warning py-2 small"><i class="fas fa-language me-2"></i>Không thể tự động dịch bản kế hoạch.</div>';
            }
        }
    </script>
}
