@model DACS_TimeManagement.Models.Project
@{
    ViewData["Title"] = "Project Details";
    var completedTasks = Model.Tasks?.Count(t => t.Status == DACS_TimeManagement.Models.TaskStatus.Completed) ?? 0;
    var totalTasks = Model.Tasks?.Count() ?? 0;
    var progressPct = totalTasks == 0 ? 0 : (int)((double)completedTasks / totalTasks * 100);
}

<div class="row mt-4">
    <!-- Project Header Info -->
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm border-0 h-100 position-relative overflow-hidden">
            <div class="bg-primary pt-5 pb-3 px-4 text-white">
                <h3 class="fw-bold mb-1">@Model.Name</h3>
                <small class="opacity-75"><i class="fas fa-calendar-alt me-1"></i> Created @Model.CreatedDate.ToString("MMM dd, yyyy")</small>
            </div>
            <div class="card-body p-4 text-center mt-3">
                
                <!-- Circular Progress Ring Concept -->
                <div class="position-relative d-inline-block mb-4">
                    <svg width="120" height="120">
                        <circle cx="60" cy="60" r="50" fill="none" stroke="#e9ecef" stroke-width="8"></circle>
                        <circle cx="60" cy="60" r="50" fill="none" stroke="var(--primary)" stroke-width="8" 
                                stroke-dasharray="314" stroke-dashoffset="@(314 - (314 * progressPct / 100))" 
                                style="transition: stroke-dashoffset 1s ease-in-out;" transform="rotate(-90 60 60)"></circle>
                    </svg>
                    <div class="position-absolute top-50 start-50 translate-middle text-center">
                        <span class="fs-3 fw-bold text-dark d-block" style="line-height: 1;">@progressPct%</span>
                    </div>
                </div>

                <div class="row text-center mb-4">
                    <div class="col-6 border-end">
                        <h3 class="mb-0 text-dark fw-bold">@totalTasks</h3>
                        <small class="text-muted text-uppercase fw-bold">Total Tasks</small>
                    </div>
                    <div class="col-6">
                        <h3 class="mb-0 text-success fw-bold">@completedTasks</h3>
                        <small class="text-muted text-uppercase fw-bold">Completed</small>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-light border fw-bold"><i class="fas fa-edit text-primary me-2"></i>Edit Project</a>
                    <a asp-controller="WorkTask" asp-action="Create" class="btn btn-primary fw-bold"><i class="fas fa-plus me-2"></i>Add Task to Project</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Task List for this Project -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-list-ul text-primary me-2"></i>Project Tasks</h5>
                <a asp-controller="WorkTask" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All Tasks Dashboard</a>
            </div>
            <div class="card-body p-0">
                @if (Model.Tasks == null || !Model.Tasks.Any())
                {
                    <div class="p-5 text-center text-muted">
                        <i class="fas fa-clipboard-check fa-3x mb-3 text-light"></i>
                        <h5>No tasks here yet.</h5>
                        <p>Fill up your project by adding some tasks.</p>
                        <a asp-controller="WorkTask" asp-action="Create" class="btn btn-sm btn-primary mt-2">Create Task</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle m-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Task Name</th>
                                    <th>Status</th>
                                    <th>Priority</th>
                                    <th>Due Date</th>
                                    <th class="pe-4 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach(var task in Model.Tasks.OrderByDescending(t => t.Id))
                                {
                                    <tr>
                                        <td class="ps-4 fw-medium text-dark">
                                            <a asp-controller="WorkTask" asp-action="Details" asp-route-id="@task.Id" class="text-decoration-none text-dark">@task.Title</a>
                                        </td>
                                        <td>
                                            <span class="badge rounded-pill bg-@(task.Status == DACS_TimeManagement.Models.TaskStatus.Completed ? "success" : task.Status == DACS_TimeManagement.Models.TaskStatus.InProgress ? "primary" : "secondary")">
                                                @task.Status
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge @(task.Priority == DACS_TimeManagement.Models.Priority.High || task.Priority == DACS_TimeManagement.Models.Priority.Urgent ? "text-danger bg-danger-subtle" : "text-muted bg-light")">
                                                @task.Priority
                                            </span>
                                        </td>
                                        <td class="text-muted small">
                                            @task.EndDate.ToString("MMM dd")
                                        </td>
                                        <td class="pe-4 text-end">
                                            <a asp-controller="WorkTask" asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-light border rounded-circle"><i class="fas fa-edit text-muted"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
